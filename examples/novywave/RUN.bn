-- NovyWave - Boon-first physical waveform viewer playground example.

store: [
    visible_editor_reference: NovyReference/visual_basis_label()
    visible_editor_pipe_probe:
        LATEST {
            TEXT { Visible editor syntax probe }
            elements.load_default_file.event.press |> THEN { TEXT { Default file path exercised } }
        }

    elements: [
        open_workspace_dialog: SOURCE
        close_workspace_dialog: SOURCE
        select_workspace_repo: SOURCE
        select_workspace_a: SOURCE
        select_workspace_b: SOURCE
        open_selected_workspace: SOURCE
        open_load_files_dialog: SOURCE
        close_load_files_dialog: SOURCE
        load_file_path_focus_probe: SOURCE
        load_file_path_input: SOURCE
        load_external_file: SOURCE
        external_file_loaded_name: SOURCE
        external_file_loaded_path: SOURCE
        external_file_loaded_format: SOURCE
        external_file_loaded_digest: SOURCE
        external_file_loaded_waveform_ref: SOURCE
        external_file_loaded_stats: SOURCE
        external_file_loaded_contract: SOURCE
        external_file_load_error: SOURCE
        begin_default_file_load: SOURCE
        load_default_file: SOURCE
        show_empty: SOURCE
        select_counter_file: SOURCE
        select_uart_compare_file: SOURCE
        select_ghw_file: SOURCE
        diagnostic_probe: SOURCE
        signal_search_focus_probe: SOURCE
        mode_to_light: SOURCE
        mode_to_dark: SOURCE
        zoom_in: SOURCE
        zoom_out: SOURCE
        zoom_reset: SOURCE
        pan_left: SOURCE
        pan_right: SOURCE
        cursor_left: SOURCE
        cursor_right: SOURCE
        marker_toggle: SOURCE
        marker_rename: SOURCE
        marker_remove: SOURCE
        marker_jump: SOURCE
        group_create: SOURCE
        group_toggle: SOURCE
        group_expand: SOURCE
        stale_response_probe: SOURCE
        row_taller: SOURCE
        row_shorter: SOURCE
        selected_remove_data: SOURCE
        selected_remove_clk: SOURCE
        selected_remove_reset: SOURCE
        selected_remove_data_valid: SOURCE
        selected_remove_data_ready: SOURCE
        selected_remove_state: SOURCE
        selected_remove_error_count: SOURCE
        selected_remove_temperature: SOURCE
        selected_remove_tx_data: SOURCE
        selected_remove_rx_data: SOURCE
        selected_remove_baud_tick: SOURCE
        selected_remove_uart_busy: SOURCE
        selected_remove_ghw_counter: SOURCE
        selected_remove_ghw_enable: SOURCE
        selected_remove_ghw_state: SOURCE
        selected_restore_data: SOURCE
        selected_data_up: SOURCE
        selected_data_down: SOURCE
        analog_limits_auto: SOURCE
        analog_limits_manual: SOURCE
        analog_limits_invalid: SOURCE
        format_dropdown_toggle: SOURCE
        format_cycle: SOURCE
        format_binary: SOURCE
        format_hex: SOURCE
        format_grouped: SOURCE
        format_octal: SOURCE
        format_signed: SOURCE
        format_unsigned: SOURCE
        format_ascii: SOURCE
        keyboard_capture: SOURCE
        waveform_click: SOURCE
        signal_search_input: SOURCE
        scope_cpu: SOURCE
        scope_cpu_expand: SOURCE
        scope_cpu_collapse: SOURCE
        scope_uart: SOURCE
        scope_analog: SOURCE
        select_clk: SOURCE
        select_reset: SOURCE
        select_data: SOURCE
        select_temperature: SOURCE
        panels_files_wider: SOURCE
        panels_variables_wider: SOURCE
        panels_reset: SOURCE
        panels_toggle_arrangement: SOURCE
        files_main_resize_drag: SOURCE
        files_secondary_resize_drag: SOURCE
        variables_name_resize_drag: SOURCE
        variables_value_resize_drag: SOURCE
        signal_row_resize_drag: SOURCE
    ]

    workspace_dialog:
        LATEST {
            TEXT { Closed }
            elements.open_workspace_dialog.event.press |> THEN { TEXT { Open } }
            elements.close_workspace_dialog.event.press |> THEN { TEXT { Closed } }
            elements.open_selected_workspace.event.press |> THEN { TEXT { Closed } }
            elements.open_load_files_dialog.event.press |> THEN { TEXT { Closed } }
        }

    workspace_path_key:
        TEXT { WorkspaceA } |> HOLD workspace_path_key {
            LATEST {
                elements.open_selected_workspace.event.press |> THEN { workspace_selected_key }
            }
        }

    workspace_selected_key:
        TEXT { WorkspaceA } |> HOLD workspace_selected_key {
            LATEST {
                elements.open_workspace_dialog.event.press |> THEN { workspace_path_key }
                elements.select_workspace_repo.event.press |> THEN { TEXT { Repo } }
                elements.select_workspace_a.event.press |> THEN { TEXT { WorkspaceA } }
                elements.select_workspace_b.event.press |> THEN { TEXT { WorkspaceB } }
            }
        }

    workspace_path:
        workspace_path_key |> WHEN {
            TEXT { WorkspaceB } => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b }
            TEXT { Repo } => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a }
        }

    workspace_header_path:
        workspace_path_key |> WHEN {
            TEXT { WorkspaceB } => TEXT { .../test_files/my_workspaces/workspace_b }
            TEXT { Repo } => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { .../test_files/my_workspaces/workspace_a }
        }

    workspace_selected_path:
        workspace_selected_key |> WHEN {
            TEXT { WorkspaceB } => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b }
            TEXT { Repo } => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a }
        }

    workspace_dialog_title:
        workspace_dialog == TEXT { Open } |> WHEN {
            True => TEXT { Open Workspace }
            False => TEXT { Workspace dialog closed }
        }

    workspace_dialog_hint:
        workspace_dialog == TEXT { Open } |> WHEN {
            True => TEXT { Pick a directory to use as your workspace. NovyWave will create the .novywave file automatically if it is missing. }
            False => TEXT { No workspace picker }
        }

    workspace_dialog_selection:
        workspace_dialog == TEXT { Open } |> WHEN {
            True => TEXT { Selected: } |> Text/concat(with: workspace_selected_path, separator: " ")
            False => TEXT { none }
        }

    workspace_status_label:
        workspace_path_key |> WHEN {
            TEXT { WorkspaceB } => TEXT { workspace_b ready }
            TEXT { Repo } => TEXT { NovyWave repo ready }
            __ => TEXT { workspace_a ready }
        }

    load_files_dialog:
        LATEST {
            TEXT { Closed }
            elements.open_load_files_dialog.event.press |> THEN { TEXT { Open } }
            elements.close_load_files_dialog.event.press |> THEN { TEXT { Closed } }
            elements.external_file_loaded_name.text |> THEN { TEXT { Closed } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { Closed } }
            elements.load_default_file.event.press |> THEN { TEXT { Closed } }
            elements.show_empty.event.press |> THEN { TEXT { Closed } }
            elements.select_counter_file.event.press |> THEN { TEXT { Closed } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { Closed } }
            elements.select_ghw_file.event.press |> THEN { TEXT { Closed } }
            elements.open_workspace_dialog.event.press |> THEN { TEXT { Closed } }
        }

    panel_layout:
        TEXT { Balanced } |> HOLD panel_layout {
            LATEST {
                elements.panels_files_wider.event.press |> THEN { TEXT { FilesWide } }
                elements.panels_variables_wider.event.press |> THEN { TEXT { VariablesWide } }
                elements.panels_reset.event.press |> THEN { TEXT { Balanced } }
                elements.files_main_resize_drag.text |> THEN {
                    elements.files_main_resize_drag.text |> WHEN {
                        TEXT { Grow } => panel_layout |> WHEN {
                            TEXT { VariablesWidest } => TEXT { VariablesWide }
                            TEXT { VariablesWide } => TEXT { Balanced }
                            TEXT { Balanced } => TEXT { FilesWide }
                            TEXT { FilesWide } => TEXT { FilesWidest }
                            __ => TEXT { FilesWidest }
                        }
                        TEXT { Shrink } => panel_layout |> WHEN {
                            TEXT { FilesWidest } => TEXT { FilesWide }
                            TEXT { FilesWide } => TEXT { Balanced }
                            TEXT { Balanced } => TEXT { VariablesWide }
                            TEXT { VariablesWide } => TEXT { VariablesWidest }
                            __ => TEXT { VariablesWidest }
                        }
                        __ => panel_layout
                    }
                }
                elements.show_empty.event.press |> THEN { TEXT { Balanced } }
                elements.load_default_file.event.press |> THEN { TEXT { Balanced } }
            }
        }

    panel_layout_label:
        panel_layout |> WHEN {
            TEXT { FilesWidest } => TEXT { Files panel widest }
            TEXT { FilesWide } => TEXT { Files panel wide }
            TEXT { VariablesWidest } => TEXT { Variables panel widest }
            TEXT { VariablesWide } => TEXT { Variables panel wide }
            __ => TEXT { Panels balanced }
        }

    panel_arrangement:
        TEXT { Stacked } |> HOLD panel_arrangement {
            LATEST {
                elements.panels_toggle_arrangement.event.press |> THEN {
                    panel_arrangement |> WHEN {
                        TEXT { Docked } => TEXT { Stacked }
                        __ => TEXT { Docked }
                    }
                }
                elements.show_empty.event.press |> THEN { TEXT { Stacked } }
                elements.load_default_file.event.press |> THEN { TEXT { Stacked } }
            }
        }

    panel_arrangement_label:
        panel_arrangement |> WHEN {
            TEXT { Docked } => TEXT { Docked panels }
            __ => TEXT { Stacked panels }
        }

    panel_arrangement_button_label:
        panel_arrangement |> WHEN {
            TEXT { Docked } => TEXT { Stack }
            __ => TEXT { Dock }
        }

    files_panel_width:
        panel_layout |> WHEN {
            TEXT { FilesWidest } => 650
            TEXT { FilesWide } => 520
            TEXT { VariablesWidest } => 260
            TEXT { VariablesWide } => 340
            __ => 430
        }

    variables_panel_width:
        panel_layout |> WHEN {
            TEXT { FilesWidest } => 300
            TEXT { FilesWide } => 390
            TEXT { VariablesWidest } => 650
            TEXT { VariablesWide } => 570
            __ => 480
        }

    browser_panel_width:
        panel_layout |> WHEN {
            TEXT { FilesWidest } => 650
            TEXT { FilesWide } => 520
            TEXT { VariablesWidest } => 260
            TEXT { VariablesWide } => 340
            __ => 430
        }

    files_panel_height_key:
        TEXT { Balanced } |> HOLD files_panel_height_key {
            LATEST {
                elements.panels_reset.event.press |> THEN { TEXT { Balanced } }
                elements.files_secondary_resize_drag.text |> THEN {
                    elements.files_secondary_resize_drag.text |> WHEN {
                        TEXT { Grow } => files_panel_height_key |> WHEN {
                            TEXT { Short } => TEXT { Balanced }
                            TEXT { Balanced } => TEXT { Tall }
                            TEXT { Tall } => TEXT { Tallest }
                            __ => TEXT { Tallest }
                        }
                        TEXT { Shrink } => files_panel_height_key |> WHEN {
                            TEXT { Tallest } => TEXT { Tall }
                            TEXT { Tall } => TEXT { Balanced }
                            TEXT { Balanced } => TEXT { Short }
                            __ => TEXT { Short }
                        }
                        __ => files_panel_height_key
                    }
                }
                elements.show_empty.event.press |> THEN { TEXT { Balanced } }
                elements.load_default_file.event.press |> THEN { TEXT { Balanced } }
            }
        }

    files_panel_height:
        files_panel_height_key |> WHEN {
            TEXT { Short } => 284
            TEXT { Tall } => 520
            TEXT { Tallest } => 650
            __ => 390
        }

    selected_name_column_width_key:
        TEXT { Normal } |> HOLD selected_name_column_width_key {
            LATEST {
                elements.variables_name_resize_drag.text |> THEN {
                    elements.variables_name_resize_drag.text |> WHEN {
                        TEXT { Grow } => selected_name_column_width_key |> WHEN {
                            TEXT { Compact } => TEXT { Normal }
                            TEXT { Normal } => TEXT { Wide }
                            TEXT { Wide } => TEXT { Widest }
                            __ => TEXT { Widest }
                        }
                        TEXT { Shrink } => selected_name_column_width_key |> WHEN {
                            TEXT { Widest } => TEXT { Wide }
                            TEXT { Wide } => TEXT { Normal }
                            TEXT { Normal } => TEXT { Compact }
                            __ => TEXT { Compact }
                        }
                        __ => selected_name_column_width_key
                    }
                }
                elements.panels_reset.event.press |> THEN { TEXT { Normal } }
            }
        }

    selected_name_column_width:
        selected_name_column_width_key |> WHEN {
            TEXT { Compact } => 130
            TEXT { Wide } => 250
            TEXT { Widest } => 340
            __ => 190
        }

    selected_value_column_width_key:
        TEXT { Normal } |> HOLD selected_value_column_width_key {
            LATEST {
                elements.variables_value_resize_drag.text |> THEN {
                    elements.variables_value_resize_drag.text |> WHEN {
                        TEXT { Grow } => selected_value_column_width_key |> WHEN {
                            TEXT { Compact } => TEXT { Normal }
                            TEXT { Normal } => TEXT { Wide }
                            TEXT { Wide } => TEXT { Widest }
                            __ => TEXT { Widest }
                        }
                        TEXT { Shrink } => selected_value_column_width_key |> WHEN {
                            TEXT { Widest } => TEXT { Wide }
                            TEXT { Wide } => TEXT { Normal }
                            TEXT { Normal } => TEXT { Compact }
                            __ => TEXT { Compact }
                        }
                        __ => selected_value_column_width_key
                    }
                }
                elements.panels_reset.event.press |> THEN { TEXT { Normal } }
            }
        }

    selected_value_column_width:
        selected_value_column_width_key |> WHEN {
            TEXT { Compact } => 120
            TEXT { Wide } => 300
            TEXT { Widest } => 400
            __ => 220
        }

    load_files_path:
        TEXT { ~/repos/NovyWave/test_files/simple.vcd } |> HOLD load_files_path {
            LATEST {
                elements.load_file_path_input.text |> THEN { elements.load_file_path_input.text }
                elements.select_counter_file.event.press |> THEN { TEXT { ~/repos/NovyWave/test_files/simple.vcd } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { ~/repos/NovyWave/test_files/wave_27.fst } }
                elements.select_ghw_file.event.press |> THEN { TEXT { ~/repos/NovyWave/test_files/simple_test.ghw } }
            }
        }

    external_file_error:
        Text/empty() |> HOLD external_file_error {
            LATEST {
                elements.external_file_load_error.text
                elements.open_load_files_dialog.event.press |> THEN { Text/empty() }
                elements.load_file_path_input.text |> THEN { Text/empty() }
                elements.external_file_loaded_name.text |> THEN { Text/empty() }
                elements.close_load_files_dialog.event.press |> THEN { Text/empty() }
            }
        }

    external_file_active:
        TEXT { No } |> HOLD external_file_active {
            LATEST {
                elements.external_file_loaded_name.text |> THEN { TEXT { Yes } }
                elements.select_counter_file.event.press |> THEN { TEXT { No } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { No } }
                elements.select_ghw_file.event.press |> THEN { TEXT { No } }
                elements.load_default_file.event.press |> THEN { TEXT { No } }
                elements.show_empty.event.press |> THEN { TEXT { No } }
            }
        }

    external_file_tree_label:
        TEXT { - local file } |> HOLD external_file_tree_label {
            LATEST {
                elements.external_file_loaded_name.text |> THEN {
                    TEXT { - } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
                }
                elements.show_empty.event.press |> THEN { TEXT { - local file } }
            }
        }

    load_files_dialog_title:
        load_files_dialog == TEXT { Open } |> WHEN {
            True => TEXT { Load files }
            False => TEXT { No file dialog }
        }

    load_files_dialog_hint:
        load_files_dialog == TEXT { Open } |> WHEN {
            True => TEXT { Enter a local VCD, FST, or GHW path. The native host validates the file and sends pure metadata to Boon. }
            False => TEXT { File dialog closed }
        }

    load_files_dialog_selection:
        load_files_dialog == TEXT { Open } |> WHEN {
            True => external_file_error |> Text/is_empty() |> WHEN {
                True => TEXT { Path: } |> Text/concat(with: load_files_path, separator: " ")
                False => external_file_error
            }
            False => TEXT { none }
        }

    waveform_status:
        LATEST {
            TEXT { Loaded }
            elements.show_empty.event.press |> THEN { TEXT { Empty } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { Loading } }
            elements.load_default_file.event.press |> THEN { TEXT { Loaded } }
            elements.external_file_loaded_name.text |> THEN { TEXT { Loaded } }
        }

    empty_state_title: TEXT { No waveform loaded }
    empty_state_hint: TEXT { Drop or load a VCD, FST, or GHW waveform to inspect signals. }
    empty_state_bridge_label: TEXT { Bridge state: no request scheduled; pure descriptor is wave:none }
    empty_state_formats_label: TEXT { Supported waveform formats: VCD, FST, GHW }
    loading_state_title: TEXT { Loading waveform }
    loading_state_hint: TEXT { Opening simple.vcd through wellen.v1 descriptor handshake. }
    reference_visual_basis: NovyReference/visual_basis_label()
    reference_loaded_basis: NovyReference/loaded_reference_label()
    reference_empty_basis: NovyReference/empty_reference_label()
    reference_workflow_basis: NovyReference/workflow_basis_label()
    reference_waveform_basis: NovyReference/waveform_basis_label()
    reference_comparison_status: NovyReference/comparison_compact_label()
    reference_descriptor: NovyReference/reference_descriptor()

    active_file:
        LATEST {
            TEXT { simple.vcd }
            elements.select_counter_file.event.press |> THEN { TEXT { simple.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { wave_27.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { simple_test.ghw } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { simple.vcd } }
            elements.load_default_file.event.press |> THEN { TEXT { simple.vcd } }
            elements.external_file_loaded_name.text
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    compare_file:
        LATEST {
            TEXT { none }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { simple.vcd } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.external_file_loaded_name.text |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    file_compare_status:
        LATEST {
            TEXT { single file: simple.vcd }
            elements.select_counter_file.event.press |> THEN { TEXT { single file: simple.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { comparing simple.vcd to wave_27.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { single file: simple_test.ghw } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { opening simple.vcd } }
            elements.load_default_file.event.press |> THEN { TEXT { single file: simple.vcd } }
            elements.external_file_loaded_name.text |> THEN {
                TEXT { local file: } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
            }
            elements.show_empty.event.press |> THEN { TEXT { no waveform loaded } }
        }

    file_compare_descriptor:
        [
            primary: active_file
            compare: compare_file
            status: file_compare_status
            page: compare_request_page
            source: TEXT { wellen-page-data }
            bridge_contract: TEXT { wellen.v1 }
            waveform_ref: bridge_waveform_ref
        ]

    bridge_file_format:
        LATEST {
            TEXT { VCD }
            elements.select_counter_file.event.press |> THEN { TEXT { VCD } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { FST } }
            elements.select_ghw_file.event.press |> THEN { TEXT { GHW } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { VCD } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { VCD } }
            elements.load_default_file.event.press |> THEN { TEXT { VCD } }
            elements.external_file_loaded_format.text
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    bridge_file_digest:
        LATEST {
            TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de }
            elements.select_counter_file.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { sha256:aa4a6993101ff31601e12d613b746d8753f20448d78e8b720f708403047dc172 } }
            elements.select_ghw_file.event.press |> THEN { TEXT { sha256:3485b4b9a423ce61e54a9bd4a2c525cf7576f0e36d39ad73b208c2e38e980491 } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { sha256:78e6f482fe39dd5ae04a7162d27f513d6a57be6e9d1a948b916167459bead01e } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
            elements.load_default_file.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
            elements.external_file_loaded_digest.text
            elements.show_empty.event.press |> THEN { TEXT { sha256:none } }
        }

    bridge_waveform_ref:
        LATEST {
            TEXT { wave:vcd:simple:0-240ns }
            elements.select_counter_file.event.press |> THEN { TEXT { wave:vcd:simple:0-240ns } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { wave:fst:wave-27:0-240ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { wave:ghw:simple-test:0-100ns } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { diagnostic:unsupported-corrupted-vcd } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { wave:opening:simple } }
            elements.load_default_file.event.press |> THEN { TEXT { wave:vcd:simple:0-240ns } }
            elements.external_file_loaded_waveform_ref.text
            elements.show_empty.event.press |> THEN { TEXT { wave:none } }
        }

    bridge_descriptor_file:
        LATEST {
            TEXT { simple.vcd }
            elements.select_counter_file.event.press |> THEN { TEXT { simple.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { wave_27.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { simple_test.ghw } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { corrupted.vcd } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { simple.vcd } }
            elements.load_default_file.event.press |> THEN { TEXT { simple.vcd } }
            elements.external_file_loaded_name.text
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    bridge_open_status:
        LATEST {
            TEXT { FILE_READY }
            elements.select_counter_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.select_ghw_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { DIAGNOSTIC } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { OPENING } }
            elements.load_default_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.external_file_loaded_name.text |> THEN { TEXT { FILE_READY } }
            elements.show_empty.event.press |> THEN { TEXT { NOT_REQUESTED } }
        }

    bridge_open_summary:
        LATEST {
            TEXT { opened VCD wave:vcd:simple:0-240ns }
            elements.select_counter_file.event.press |> THEN { TEXT { opened VCD wave:vcd:simple:0-240ns } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { opened FST wave:fst:wave-27:0-240ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { opened GHW wave:ghw:simple-test:0-100ns } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { unsupported waveform file: corrupted.vcd } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { opening VCD simple.vcd } }
            elements.load_default_file.event.press |> THEN { TEXT { opened VCD wave:vcd:simple:0-240ns } }
            elements.external_file_loaded_name.text |> THEN {
                TEXT { local file } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
            }
            elements.show_empty.event.press |> THEN { TEXT { no file loaded } }
        }

    bridge_hierarchy_page_label:
        LATEST {
            TEXT { HIER:top.cpu/top.uart/top.analog }
            elements.select_counter_file.event.press |> THEN { TEXT { HIER:top.cpu/top.uart/top.analog } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { HIER:top.uart compare page } }
            elements.select_ghw_file.event.press |> THEN { TEXT { HIER:ghw.simple/counter } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { HIER:none } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { HIER:opening } }
            elements.load_default_file.event.press |> THEN { TEXT { HIER:top.cpu/top.uart/top.analog } }
            elements.external_file_loaded_name.text |> THEN { TEXT { HIER:local file metadata } }
            elements.show_empty.event.press |> THEN { TEXT { HIER:none } }
        }

    bridge_file_stats_label:
        LATEST {
            TEXT { VCD 15 signals, 0-240ns, bounded pages }
            elements.select_counter_file.event.press |> THEN { TEXT { VCD 15 signals, 0-240ns, bounded pages } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { FST 5 signals, 0-240ns, bounded pages } }
            elements.select_ghw_file.event.press |> THEN { TEXT { GHW 4 signals, 0-100ns, bounded pages } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { no waveform stats } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { loading waveform stats } }
            elements.load_default_file.event.press |> THEN { TEXT { VCD 15 signals, 0-240ns, bounded pages } }
            elements.external_file_loaded_stats.text
            elements.show_empty.event.press |> THEN { TEXT { no waveform stats } }
        }

    bridge_large_file_contract:
        LATEST {
            TEXT { simple.vcd 311B -> bounded page requests only }
            elements.select_counter_file.event.press |> THEN { TEXT { simple.vcd 311B -> bounded page requests only } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { wave_27.fst 28860652B -> bounded compare page only } }
            elements.select_ghw_file.event.press |> THEN { TEXT { simple_test.ghw 833B -> bounded page requests only } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { corrupted.vcd 25B -> diagnostic only } }
            elements.show_empty.event.press |> THEN { TEXT { no large file materialized } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { simple.vcd pending -> no page materialized } }
            elements.load_default_file.event.press |> THEN { TEXT { simple.vcd 311B -> bounded page requests only } }
            elements.external_file_loaded_contract.text
        }

    bridge_payload_limit_bytes: 65536
    bridge_transition_limit: 256
    bridge_visible_row_limit: 32
    bridge_segment_limit: 256

    bridge_page_window_label:
        NovyModel/page_window_label(window: bridge_request_window_label)

    bridge_hierarchy_page_cursor_label:
        LATEST {
            TEXT { hierarchy cursor root:0..64 next=top.cpu }
            elements.select_counter_file.event.press |> THEN { TEXT { hierarchy cursor root:0..64 next=top.cpu } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { hierarchy cursor top.uart:0..64 next=none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { hierarchy cursor ghw.simple:0..64 next=none } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { hierarchy cursor none } }
            elements.show_empty.event.press |> THEN { TEXT { hierarchy cursor none } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { hierarchy cursor opening } }
            elements.load_default_file.event.press |> THEN { TEXT { hierarchy cursor root:0..64 next=top.cpu } }
            elements.external_file_loaded_name.text |> THEN { TEXT { hierarchy cursor root:0..64 next=local } }
        }

    bridge_materialization_bound_label:
        LATEST {
            TEXT { visible rows 8/15, waveform segments 64/256 max }
            elements.select_counter_file.event.press |> THEN { TEXT { visible rows 8/15, waveform segments 64/256 max } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { visible rows 4/5, waveform segments 28/256 max } }
            elements.select_ghw_file.event.press |> THEN { TEXT { visible rows 3/4, waveform segments 20/256 max } }
            elements.selected_remove_data.event.press |> THEN { TEXT { visible rows 7/15, waveform segments 56/256 max } }
            elements.show_empty.event.press |> THEN { TEXT { visible rows 0/0, waveform segments 0/256 max } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { visible rows 0/15, waveform segments 0/256 max } }
            elements.load_default_file.event.press |> THEN { TEXT { visible rows 8/15, waveform segments 64/256 max } }
            elements.external_file_loaded_name.text |> THEN { TEXT { visible rows 8/15, waveform segments 64/256 max } }
        }

    bridge_payload_bound_label:
        TEXT { payload <= 64KiB; full waveform never enters Boon }

    compare_request_page:
        LATEST {
            TEXT { compare:simple.vcd:primary }
            elements.select_counter_file.event.press |> THEN { TEXT { compare:simple.vcd:primary } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { compare:simple.vcd+wave_27.fst:0-240ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { compare:simple_test.ghw:primary } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { compare:simple.vcd:opening } }
            elements.load_default_file.event.press |> THEN { TEXT { compare:simple.vcd:primary } }
            elements.external_file_loaded_name.text |> THEN {
                TEXT { compare: } |> Text/concat(with: elements.external_file_loaded_name.text, separator: "") |> Text/concat(with: TEXT { primary }, separator: ":")
            }
            elements.show_empty.event.press |> THEN { TEXT { compare:none } }
        }

    compare_result_label:
        LATEST {
            TEXT { primary page: simple.vcd }
            elements.select_counter_file.event.press |> THEN { TEXT { primary page: simple.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { shared window: 0 ns - 240 ns, 2 files } }
            elements.select_ghw_file.event.press |> THEN { TEXT { primary page: simple_test.ghw, GHW file } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { opening page: simple.vcd } }
            elements.load_default_file.event.press |> THEN { TEXT { primary page: simple.vcd } }
            elements.external_file_loaded_name.text |> THEN {
                TEXT { primary page: } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
            }
            elements.show_empty.event.press |> THEN { TEXT { no compare page } }
        }

    file_status_detail:
        diagnostic_state == TEXT { Unsupported } |> WHEN {
            True => diagnostic_label
            False => compare_result_label
        }

    diagnostic_state:
        LATEST {
            TEXT { OK }
            elements.diagnostic_probe.event.press |> THEN { TEXT { Unsupported } }
            elements.select_counter_file.event.press |> THEN { TEXT { OK } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { OK } }
            elements.select_ghw_file.event.press |> THEN { TEXT { OK } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { Loading } }
            elements.load_default_file.event.press |> THEN { TEXT { OK } }
            elements.external_file_loaded_name.text |> THEN { TEXT { OK } }
            elements.external_file_load_error.text |> THEN { TEXT { Unsupported } }
            elements.show_empty.event.press |> THEN { TEXT { Idle } }
        }

    diagnostic_label:
        LATEST {
            TEXT { bridge diagnostics OK }
            elements.diagnostic_probe.event.press |> THEN { TEXT { unsupported waveform file: corrupted.vcd } }
            elements.select_counter_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_ghw_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { loading waveform } }
            elements.load_default_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.external_file_loaded_name.text |> THEN { TEXT { local file metadata OK } }
            elements.external_file_load_error.text
            elements.show_empty.event.press |> THEN { TEXT { no file loaded } }
        }

    diagnostic_file:
        LATEST {
            TEXT { none }
            elements.diagnostic_probe.event.press |> THEN { TEXT { corrupted.vcd } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.external_file_loaded_path.text
            elements.external_file_load_error.text |> THEN { load_files_path }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    bridge_diagnostic:
        [
            kind: diagnostic_state
            file: diagnostic_file
            library: TEXT { wellen.v1 }
            message: diagnostic_label
        ]

    mode:
        LATEST {
            Dark
            elements.mode_to_light.event.press |> THEN { Light }
            elements.mode_to_dark.event.press |> THEN { Dark }
        }

    active_scope:
        LATEST {
            TEXT { top_cpu }
            elements.scope_cpu.event.press |> THEN { TEXT { top_cpu } }
            elements.scope_cpu_expand.event.press |> THEN { TEXT { top_cpu } }
            elements.scope_cpu_collapse.event.press |> THEN { TEXT { top_cpu } }
            elements.scope_uart.event.press |> THEN { TEXT { top_uart } }
            elements.scope_analog.event.press |> THEN { TEXT { top_analog } }
            elements.select_counter_file.event.press |> THEN { TEXT { top_cpu } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { top_uart } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw_simple } }
            elements.load_default_file.event.press |> THEN { TEXT { top_cpu } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    active_signal:
        TEXT { clk } |> HOLD active_signal {
            LATEST {
            signal_catalog
                |> List/map(signal_catalog_item, new: LATEST {
                    signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN { signal_catalog_item.key }
                })
                |> List/latest()
            elements.select_clk.event.press |> THEN { TEXT { clk } }
            elements.select_reset.event.press |> THEN { TEXT { reset_n } }
            elements.select_data.event.press |> THEN {
                active_signal |> WHEN {
                    data_bus => TEXT { none }
                    __ => TEXT { data_bus }
                }
            }
            elements.select_temperature.event.press |> THEN { TEXT { temperature } }
            elements.select_counter_file.event.press |> THEN { TEXT { clk } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { tx_data } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw_counter } }
            elements.load_default_file.event.press |> THEN { TEXT { clk } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    signal_catalog:
        LIST {
            [key: TEXT { clk }, scope: TEXT { top.cpu }, name: TEXT { clk }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }, family: TEXT { clock }]
            [key: TEXT { reset_n }, scope: TEXT { top.cpu }, name: TEXT { reset_n }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }, family: TEXT { reset }]
            [key: TEXT { data_bus }, scope: TEXT { top.cpu }, name: TEXT { data_bus[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }, family: TEXT { data }]
            [key: TEXT { data_valid }, scope: TEXT { top.cpu }, name: TEXT { data_valid }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }, family: TEXT { data }]
            [key: TEXT { data_ready }, scope: TEXT { top.cpu }, name: TEXT { data_ready }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }, family: TEXT { data }]
            [key: TEXT { data_parity }, scope: TEXT { top.cpu }, name: TEXT { data_parity }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }, family: TEXT { data }]
            [key: TEXT { state }, scope: TEXT { top.cpu }, name: TEXT { state[2:0] }, kind: TEXT { Reg }, bit_width: TEXT { 3-bit }, direction: TEXT { State }, family: TEXT { state }]
            [key: TEXT { error_count }, scope: TEXT { top.cpu }, name: TEXT { error_count[15:0] }, kind: TEXT { Reg }, bit_width: TEXT { 16-bit }, direction: TEXT { Counter }, family: TEXT { state }]
            [key: TEXT { tx_data }, scope: TEXT { top.uart }, name: TEXT { tx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }, family: TEXT { uart }]
            [key: TEXT { rx_data }, scope: TEXT { top.uart }, name: TEXT { rx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Input }, family: TEXT { uart }]
            [key: TEXT { baud_tick }, scope: TEXT { top.uart }, name: TEXT { baud_tick }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { Clock }, family: TEXT { uart }]
            [key: TEXT { uart_busy }, scope: TEXT { top.uart }, name: TEXT { uart_busy }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { State }, family: TEXT { uart }]
            [key: TEXT { framing_error }, scope: TEXT { top.uart }, name: TEXT { framing_error }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Error }, family: TEXT { uart }]
            [key: TEXT { temperature }, scope: TEXT { top.analog }, name: TEXT { temperature }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Input }, family: TEXT { analog }]
            [key: TEXT { voltage }, scope: TEXT { top.analog }, name: TEXT { vcore }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Sense }, family: TEXT { analog }]
            [key: TEXT { ghw_counter }, scope: TEXT { ghw.simple }, name: TEXT { ghw.counter[3:0] }, kind: TEXT { Reg }, bit_width: TEXT { 4-bit }, direction: TEXT { Counter }, family: TEXT { ghw }]
            [key: TEXT { ghw_enable }, scope: TEXT { ghw.simple }, name: TEXT { ghw.enable }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }, family: TEXT { ghw }]
            [key: TEXT { ghw_state }, scope: TEXT { ghw.simple }, name: TEXT { ghw.state }, kind: TEXT { Reg }, bit_width: TEXT { 2-bit }, direction: TEXT { State }, family: TEXT { ghw }]
            [key: TEXT { ghw_clk }, scope: TEXT { ghw.simple }, name: TEXT { ghw.clk }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Clock }, family: TEXT { ghw }]
        }
        |> List/map(signal, new: new_signal(signal: signal))

    selected_signal_count:
        selected_rows_count

    row_selected_signal_key:
        signal_catalog
        |> List/map(signal_catalog_item, new: LATEST {
            signal_catalog_item.signal_elements.select_signal.event.press
                |> THEN { signal_catalog_item.key }
        })
        |> List/latest()

    selected_signal_family:
        LATEST {
            TEXT { counter }
            elements.select_counter_file.event.press |> THEN { TEXT { counter } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { uart } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw } }
            elements.load_default_file.event.press |> THEN { TEXT { counter } }
            elements.show_empty.event.press |> THEN { TEXT { counter } }
        }

    selected_signal_defaults:
        LIST {
            [family: TEXT { counter }, id: TEXT { clk }, name: TEXT { clk }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { counter }, id: TEXT { reset_n }, name: TEXT { reset_n }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { counter }, id: TEXT { data_bus }, name: TEXT { data_bus[7:0] }, current_value: TEXT { 0x2a }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { counter }, id: TEXT { data_valid }, name: TEXT { data_valid }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { counter }, id: TEXT { data_ready }, name: TEXT { data_ready }, current_value: TEXT { 0 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { counter }, id: TEXT { state }, name: TEXT { state[2:0] }, current_value: TEXT { Run }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { counter }, id: TEXT { error_count }, name: TEXT { error_count[15:0] }, current_value: TEXT { 0 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { counter }, id: TEXT { temperature }, name: TEXT { temperature }, current_value: TEXT { 42.8 C }, kind: Analog, enabled: TEXT { loaded }]
            [family: TEXT { uart }, id: TEXT { tx_data }, name: TEXT { tx_data[7:0] }, current_value: TEXT { 0x55 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { uart }, id: TEXT { rx_data }, name: TEXT { rx_data[7:0] }, current_value: TEXT { 0xaa }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { uart }, id: TEXT { baud_tick }, name: TEXT { baud_tick }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { uart }, id: TEXT { uart_busy }, name: TEXT { uart_busy }, current_value: TEXT { 0 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { ghw }, id: TEXT { ghw_counter }, name: TEXT { ghw.counter[3:0] }, current_value: TEXT { 3 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { ghw }, id: TEXT { ghw_enable }, name: TEXT { ghw.enable }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [family: TEXT { ghw }, id: TEXT { ghw_state }, name: TEXT { ghw.state }, current_value: TEXT { Count }, kind: Digital, enabled: TEXT { loaded }]
        }

    selected_waveform_segments:
        LIST {
            [signal_id: TEXT { clk }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { clk }, width: 28, state: High, label: TEXT { 1 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { clk }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { clk }, width: 28, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { clk }, width: 28, state: High, label: TEXT { 1 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { clk }, width: 28, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { clk }, width: 28, state: High, label: TEXT { 1 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { clk }, width: 28, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { clk }, width: 28, state: High, label: TEXT { 1 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { clk }, width: 28, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { clk }, width: 28, state: High, label: TEXT { 1 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { clk }, width: 28, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
