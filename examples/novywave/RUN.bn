            [signal_id: TEXT { data_bus }, width: 56, state: High, label: TEXT { 0x12 }]
            [signal_id: TEXT { data_bus }, width: 56, state: Low, label: TEXT { 0x00 }]
            [signal_id: TEXT { data_bus }, width: 84, state: High, label: TEXT { 0x2a }]
            [signal_id: TEXT { data_bus }, width: 84, state: Low, label: TEXT { 0x08 }]
