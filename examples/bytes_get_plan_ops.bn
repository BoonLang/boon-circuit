payload:
    BYTES[4] { 16u01, 16u02, 16uFE, 16u04 } |> HOLD payload { LATEST {} }

store: [
    measure: SOURCE
    selected_byte:
        16u00 |> HOLD selected_byte {
            LATEST {
                store.measure |> THEN { payload |> Bytes/get(index: 2) }
            }
        }
]

document: Document/new(root: Element/label(element: [], label: TEXT { Bytes }))
