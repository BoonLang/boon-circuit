{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fjordpulse.kavik.cz/contracts/realtime/server-message.schema.json",
  "title": "FjordPulse server realtime message",
  "description": "Exactly one protocol v1 server acknowledgement, authoritative snapshot, database-originated notification, health notification, pong, or structured error.",
  "oneOf": [
    { "$ref": "#/$defs/WatchStationAckMessage" },
    { "$ref": "#/$defs/UnwatchStationAckMessage" },
    { "$ref": "#/$defs/WatchVehicleAckMessage" },
    { "$ref": "#/$defs/UnwatchVehicleAckMessage" },
    { "$ref": "#/$defs/FocusStartedMessage" },
    { "$ref": "#/$defs/FocusStoppedMessage" },
    { "$ref": "#/$defs/FocusPausedMessage" },
    { "$ref": "#/$defs/FocusResumedMessage" },
    { "$ref": "#/$defs/StationSnapshotMessage" },
    { "$ref": "#/$defs/StationSnapshotChangedMessage" },
    { "$ref": "#/$defs/StationDeparturesChangedMessage" },
    { "$ref": "#/$defs/NearbyVehiclesChangedMessage" },
    { "$ref": "#/$defs/VehicleSnapshotMessage" },
    { "$ref": "#/$defs/VehicleMovedMessage" },
    { "$ref": "#/$defs/VehicleStaleMessage" },
    { "$ref": "#/$defs/VehicleLostMessage" },
    { "$ref": "#/$defs/SourceBackoffMessage" },
    { "$ref": "#/$defs/RateLimitedMessage" },
    { "$ref": "#/$defs/TelemetryTickMessage" },
    { "$ref": "#/$defs/RealtimeDegradedMessage" },
    { "$ref": "#/$defs/ResyncRequiredMessage" },
    { "$ref": "#/$defs/PongMessage" },
    { "$ref": "#/$defs/ErrorMessage" }
  ],
  "$defs": {
    "StationId": {
      "type": "string",
      "pattern": "^NSR:StopPlace:[A-Za-z0-9_-]+$",
      "maxLength": 200
    },
    "VehicleId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:._-]{0,199}$"
    },
    "SourceState": {
      "type": "string",
      "enum": ["loading", "fresh", "refreshing", "empty", "stale", "unavailable", "error", "backoff", "rate_limited"]
    },
    "VehicleTransportMode": {
      "type": "string",
      "enum": ["air", "bus", "coach", "ferry", "metro", "taxi", "tram", "rail", "unknown"]
    },
    "VehiclePassengerServiceState": {
      "type": "string",
      "enum": ["passenger", "non_passenger", "unknown"]
    },
    "Departure": {
      "type": "object",
      "required": ["id", "lineCode", "destination", "aimedDepartureAt", "expectedDepartureAt", "status", "realtime"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 300 },
        "serviceJourneyId": { "type": ["string", "null"], "maxLength": 300 },
        "lineId": { "type": ["string", "null"], "maxLength": 300 },
        "lineCode": { "type": ["string", "null"], "maxLength": 100 },
        "destination": { "type": ["string", "null"], "maxLength": 300 },
        "aimedDepartureAt": { "type": "string", "format": "date-time" },
        "expectedDepartureAt": { "type": ["string", "null"], "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["scheduled", "realtime", "delayed", "cancelled", "departed", "unknown"]
        },
        "delaySeconds": { "type": ["integer", "null"] },
        "platform": { "type": ["string", "null"], "maxLength": 100 },
        "realtime": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "VehicleSummary": {
      "type": "object",
      "required": ["id", "transportMode", "passengerServiceState", "lineCode", "state", "latitude", "longitude", "lastSeenAt", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/VehicleId" },
        "transportMode": { "$ref": "#/$defs/VehicleTransportMode" },
        "passengerServiceState": { "$ref": "#/$defs/VehiclePassengerServiceState" },
        "lineCode": { "type": ["string", "null"], "maxLength": 100 },
        "destination": { "type": ["string", "null"], "maxLength": 300 },
        "state": { "type": "string", "enum": ["live", "stale", "lost"] },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "bearing": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "delaySeconds": { "type": ["integer", "null"] },
        "distanceMeters": { "type": ["number", "null"], "minimum": 0 },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "version": { "$ref": "./envelope.schema.json#/$defs/EntityVersion" }
      },
      "additionalProperties": false
    },
    "StationVehicle": {
      "type": "object",
      "required": ["id", "transportMode", "passengerServiceState", "lineCode", "state", "latitude", "longitude", "lastSeenAt", "version", "callRole", "progress", "stationCallAt"],
      "properties": {
        "id": { "$ref": "#/$defs/VehicleId" },
        "transportMode": { "$ref": "#/$defs/VehicleTransportMode" },
        "passengerServiceState": {
          "allOf": [
            { "$ref": "#/$defs/VehiclePassengerServiceState" },
            { "type": "string", "enum": ["passenger", "unknown"] }
          ]
        },
        "lineCode": { "type": ["string", "null"], "maxLength": 100 },
        "destination": { "type": ["string", "null"], "maxLength": 300 },
        "state": { "type": "string", "enum": ["live", "stale", "lost"] },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "bearing": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "delaySeconds": { "type": ["integer", "null"] },
        "distanceMeters": { "type": ["number", "null"], "minimum": 0 },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "version": { "$ref": "./envelope.schema.json#/$defs/EntityVersion" },
        "callRole": { "type": "string", "enum": ["starts_here", "calls_here"] },
        "progress": { "type": "string", "enum": ["at_station", "before_station", "after_station", "unknown"] },
        "stationCallAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },
    "ServingVehicleCoverage": {
      "type": "object",
      "required": ["windowStart", "windowEnd", "candidateJourneyCount", "queriedJourneyCount", "truncated"],
      "properties": {
        "windowStart": { "type": ["string", "null"], "format": "date-time" },
        "windowEnd": { "type": ["string", "null"], "format": "date-time" },
        "candidateJourneyCount": { "type": "integer", "minimum": 0 },
        "queriedJourneyCount": { "type": "integer", "minimum": 0, "maximum": 200 },
        "truncated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "DepartureBoardPreview": {
      "type": "object",
      "required": ["windowStart", "windowEnd", "limit", "hasMore"],
      "properties": {
        "windowStart": { "type": "string", "format": "date-time" },
        "windowEnd": { "type": "string", "format": "date-time" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 20 },
        "hasMore": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "VehicleState": {
      "type": "object",
      "required": ["id", "transportMode", "passengerServiceState", "lineCode", "routeName", "state", "latitude", "longitude", "lastSeenAt", "refreshedAt", "version", "nextStop", "journeyReference", "monitoredCall", "progressBetweenStops", "journeyVersion", "routeProgress"],
      "properties": {
        "id": { "$ref": "#/$defs/VehicleId" },
        "transportMode": { "$ref": "#/$defs/VehicleTransportMode" },
        "passengerServiceState": { "$ref": "#/$defs/VehiclePassengerServiceState" },
        "lineCode": { "type": ["string", "null"], "maxLength": 100 },
        "routeName": { "type": ["string", "null"], "maxLength": 300 },
        "destination": { "type": ["string", "null"], "maxLength": 300 },
        "state": { "type": "string", "enum": ["live", "stale", "lost"] },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "bearing": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "delaySeconds": { "type": ["integer", "null"] },
        "distanceMeters": { "type": ["number", "null"], "minimum": 0 },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "refreshedAt": { "type": "string", "format": "date-time" },
        "version": { "$ref": "./envelope.schema.json#/$defs/EntityVersion" },
        "nextStop": {
          "oneOf": [
            { "$ref": "#/$defs/StopCall" },
            { "type": "null" }
          ]
        },
        "journeyReference": { "oneOf": [{ "$ref": "#/$defs/VehicleJourneyReference" }, { "type": "null" }] },
        "monitoredCall": { "oneOf": [{ "$ref": "#/$defs/MonitoredCallReference" }, { "type": "null" }] },
        "progressBetweenStops": { "oneOf": [{ "$ref": "#/$defs/ProgressBetweenStops" }, { "type": "null" }] },
        "journeyVersion": { "oneOf": [{ "$ref": "./envelope.schema.json#/$defs/EntityVersion" }, { "type": "null" }] },
        "routeProgress": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "VehicleJourneyReference": {
      "type": "object",
      "required": ["serviceJourneyId", "operatingDate", "datedServiceJourneyId", "originRef", "originName", "destinationRef", "destinationName"],
      "properties": {
        "serviceJourneyId": { "type": "string", "minLength": 1, "maxLength": 300 },
        "operatingDate": { "type": "string", "format": "date" },
        "datedServiceJourneyId": { "type": ["string", "null"], "maxLength": 300 },
        "originRef": { "type": ["string", "null"], "maxLength": 300 },
        "originName": { "type": ["string", "null"], "maxLength": 300 },
        "destinationRef": { "type": ["string", "null"], "maxLength": 300 },
        "destinationName": { "type": ["string", "null"], "maxLength": 300 }
      },
      "additionalProperties": false
    },
    "MonitoredCallReference": {
      "type": "object",
      "required": ["stopPointRef", "order", "vehicleAtStop"],
      "properties": {
        "stopPointRef": { "type": ["string", "null"], "maxLength": 300 },
        "order": { "type": "integer", "minimum": 0, "maximum": 999 },
        "vehicleAtStop": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ProgressBetweenStops": {
      "type": "object",
      "required": ["linkDistance", "percentage"],
      "properties": {
        "linkDistance": { "type": ["number", "null"], "minimum": 0 },
        "percentage": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "StationSnapshotPayload": {
      "type": "object",
      "required": ["stationId", "state", "version", "updatedAt", "departures", "departureBoard", "nearbyVehicles", "servingVehicles", "servingVehicleCoverage"],
      "properties": {
        "stationId": { "$ref": "#/$defs/StationId" },
        "state": { "$ref": "#/$defs/SourceState" },
        "version": { "$ref": "./envelope.schema.json#/$defs/EntityVersion" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastSuccessfulAt": { "type": ["string", "null"], "format": "date-time" },
        "warning": { "type": ["string", "null"], "maxLength": 500 },
        "departures": {
          "type": "array",
          "maxItems": 20,
          "items": { "$ref": "#/$defs/Departure" }
        },
        "departureBoard": { "$ref": "#/$defs/DepartureBoardPreview" },
        "nearbyVehicles": {
          "type": "array",
          "items": { "$ref": "#/$defs/VehicleSummary" }
        },
        "servingVehicles": {
          "type": "array",
          "items": { "$ref": "#/$defs/StationVehicle" }
        },
        "servingVehicleCoverage": { "$ref": "#/$defs/ServingVehicleCoverage" }
      },
      "additionalProperties": false
    },
    "StationDeparturesPayload": {
      "type": "object",
      "required": ["stationId", "state", "version", "updatedAt", "departures"],
      "properties": {
        "stationId": { "$ref": "#/$defs/StationId" },
        "state": { "$ref": "#/$defs/SourceState" },
        "version": { "$ref": "./envelope.schema.json#/$defs/EntityVersion" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "departures": {
          "type": "array",
          "maxItems": 20,
          "items": { "$ref": "#/$defs/Departure" }
        }
      },
      "additionalProperties": false
    },
    "NearbyVehiclesPayload": {
      "type": "object",
      "required": ["stationId", "state", "version", "updatedAt", "vehicles"],
      "properties": {
        "stationId": { "$ref": "#/$defs/StationId" },
        "state": { "$ref": "#/$defs/SourceState" },
        "version": { "$ref": "./envelope.schema.json#/$defs/EntityVersion" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "vehicles": {
          "type": "array",
          "items": { "$ref": "#/$defs/VehicleSummary" }
        }
      },
      "additionalProperties": false
    },
    "VehicleObservation": {
      "type": "object",
      "required": ["latitude", "longitude", "bearing", "observedAt"],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "bearing": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "observedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "StopCall": {
      "type": "object",
      "required": ["stopPlaceId", "quayId", "name", "order", "latitude", "longitude", "aimedArrivalAt", "expectedArrivalAt", "aimedDepartureAt", "expectedDepartureAt", "realtime", "cancellation"],
      "properties": {
        "stopPlaceId": { "type": ["string", "null"], "maxLength": 200 },
        "quayId": { "type": ["string", "null"], "maxLength": 200 },
        "name": { "type": "string", "minLength": 1, "maxLength": 300 },
        "order": { "type": "integer", "minimum": 0, "maximum": 999 },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "aimedArrivalAt": { "type": ["string", "null"], "format": "date-time" },
        "expectedArrivalAt": { "type": ["string", "null"], "format": "date-time" },
        "aimedDepartureAt": { "type": ["string", "null"], "format": "date-time" },
        "expectedDepartureAt": { "type": ["string", "null"], "format": "date-time" },
        "realtime": { "type": "boolean" },
        "cancellation": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "JourneyRoute": {
      "type": "object",
      "required": ["type", "coordinates", "distanceMeters"],
      "properties": {
        "type": { "const": "LineString" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20000,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "prefixItems": [
              { "type": "number", "minimum": -180, "maximum": 180 },
              { "type": "number", "minimum": -90, "maximum": 90 }
            ]
          }
        },
        "distanceMeters": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "JourneySnapshot": {
      "type": "object",
      "required": ["serviceJourneyId", "operatingDate", "datedServiceJourneyId", "version", "state", "route", "calls", "refreshedAt", "lastSuccessfulAt", "warning"],
      "properties": {
        "serviceJourneyId": { "type": "string", "minLength": 1, "maxLength": 300 },
        "operatingDate": { "type": "string", "format": "date" },
        "datedServiceJourneyId": { "type": ["string", "null"], "maxLength": 300 },
        "version": { "$ref": "./envelope.schema.json#/$defs/EntityVersion" },
        "state": { "$ref": "#/$defs/SourceState" },
        "route": { "oneOf": [{ "$ref": "#/$defs/JourneyRoute" }, { "type": "null" }] },
        "calls": { "type": "array", "maxItems": 1000, "items": { "$ref": "#/$defs/StopCall" } },
        "refreshedAt": { "type": "string", "format": "date-time" },
        "lastSuccessfulAt": { "type": ["string", "null"], "format": "date-time" },
        "warning": { "type": ["string", "null"], "maxLength": 500 }
      },
      "additionalProperties": false
    },
    "VehicleSnapshotPayload": {
      "type": "object",
      "required": ["vehicle", "trail", "journey", "upcomingStops"],
      "properties": {
        "vehicle": { "$ref": "#/$defs/VehicleState" },
        "trail": {
          "type": "array",
          "maxItems": 500,
          "items": { "$ref": "#/$defs/VehicleObservation" }
        },
        "journey": { "oneOf": [{ "$ref": "#/$defs/JourneySnapshot" }, { "type": "null" }] },
        "upcomingStops": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/StopCall" }
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "vehicle": {
                "type": "object",
                "required": ["passengerServiceState"],
                "properties": {
                  "passengerServiceState": { "const": "non_passenger" }
                }
              }
            },
            "required": ["vehicle"]
          },
          "then": {
            "type": "object",
            "properties": {
              "journey": { "type": "null" },
              "upcomingStops": { "type": "array", "maxItems": 0 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "VehicleEventPayload": {
      "type": "object",
      "required": ["vehicle", "observation"],
      "properties": {
        "vehicle": { "$ref": "#/$defs/VehicleState" },
        "observation": {
          "oneOf": [
            { "$ref": "#/$defs/VehicleObservation" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "WatchAckPayload": {
      "type": "object",
      "required": ["entityId", "scope", "clientCount", "watchExpiresAt"],
      "properties": {
        "entityId": { "type": "string", "minLength": 1, "maxLength": 200 },
        "scope": { "$ref": "./envelope.schema.json#/$defs/Scope" },
        "clientCount": { "type": "integer", "minimum": 0 },
        "watchExpiresAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "UnwatchAckPayload": {
      "type": "object",
      "required": ["entityId", "scope", "remainingClientCount"],
      "properties": {
        "entityId": { "type": "string", "minLength": 1, "maxLength": 200 },
        "scope": { "$ref": "./envelope.schema.json#/$defs/Scope" },
        "remainingClientCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "FocusAckPayload": {
      "type": "object",
      "required": ["vehicleId", "scope", "state", "watchExpiresAt"],
      "properties": {
        "vehicleId": { "$ref": "#/$defs/VehicleId" },
        "scope": { "$ref": "./envelope.schema.json#/$defs/Scope" },
        "state": { "type": "string", "enum": ["following", "paused", "stopped"] },
        "watchExpiresAt": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },
    "AckWithEntityEnvelope": {
      "allOf": [
        { "$ref": "./envelope.schema.json#/$defs/AckEnvelope" },
        { "type": "object", "required": ["scope", "entityId"] }
      ]
    },
    "SnapshotEnvelope": {
      "allOf": [
        { "$ref": "./envelope.schema.json#/$defs/ServerEnvelope" },
        {
          "type": "object",
          "required": ["scope", "entityId", "version", "payload"],
          "properties": {
            "id": false,
            "eventId": false,
            "error": false
          }
        }
      ]
    },
    "PayloadEnvelope": {
      "allOf": [
        { "$ref": "./envelope.schema.json#/$defs/ServerEnvelope" },
        {
          "type": "object",
          "required": ["payload"],
          "properties": {
            "id": false,
            "entityId": false,
            "eventId": false,
            "version": false,
            "error": false
          }
        }
      ]
    },
    "WatchStationAckMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "watch_station_ack" },
            "payload": { "$ref": "#/$defs/WatchAckPayload" }
          }
        }
      ]
    },
    "UnwatchStationAckMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "unwatch_station_ack" },
            "payload": { "$ref": "#/$defs/UnwatchAckPayload" }
          }
        }
      ]
    },
    "WatchVehicleAckMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "watch_vehicle_ack" },
            "payload": { "$ref": "#/$defs/WatchAckPayload" }
          }
        }
      ]
    },
    "UnwatchVehicleAckMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "unwatch_vehicle_ack" },
            "payload": { "$ref": "#/$defs/UnwatchAckPayload" }
          }
        }
      ]
    },
    "FocusStartedMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "focus_started" },
            "payload": { "$ref": "#/$defs/FocusAckPayload" }
          }
        }
      ]
    },
    "FocusStoppedMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "focus_stopped" },
            "payload": { "$ref": "#/$defs/FocusAckPayload" }
          }
        }
      ]
    },
    "FocusPausedMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "focus_paused" },
            "payload": { "$ref": "#/$defs/FocusAckPayload" }
          }
        }
      ]
    },
    "FocusResumedMessage": {
      "allOf": [
        { "$ref": "#/$defs/AckWithEntityEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "focus_resumed" },
            "payload": { "$ref": "#/$defs/FocusAckPayload" }
          }
        }
      ]
    },
    "StationSnapshotMessage": {
      "allOf": [
        { "$ref": "#/$defs/SnapshotEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "station_snapshot" },
            "payload": { "$ref": "#/$defs/StationSnapshotPayload" }
          }
        }
      ]
    },
    "StationSnapshotChangedMessage": {
      "allOf": [
        { "$ref": "./envelope.schema.json#/$defs/PersistentEventEnvelope" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "station_snapshot_changed" },
            "payload": { "$ref": "#/$defs/StationSnapshotPayload" }
          }
        }
      ]
    },
