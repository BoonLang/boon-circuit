FUNCTION variables_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: Fill
            height: Fill
            padding: 10
            depth: 10
            rounded_corners: 0
            background: [color: TEXT { #172033 }]
            border: [color: TEXT { #2F80ED }]
            material: NovyTheme/material(of: PanelSurface)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 10
                style: [width: Fill, height: 38, paint: False]
                items: LIST {
                    panel_title(title_text: TEXT { Variables })
                    search_box()
                }
            )
            variables_list()
            search_result_line()
            inspector_strip()
        }
    )
}

FUNCTION variables_list() {
    PASSED.store.signal_search_text |> WHEN {
        data => variables_list_data()
        reset => variables_list_reset()
        temp => variables_list_temperature()
        clk => variables_list_clk()
        zzz => variables_list_empty()
        __ => variables_list_all()
    }
}

FUNCTION variables_list_all() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: 116, paint: False]
        items: LIST {
            variable_clk_button()
            variable_reset_button()
            variable_data_button()
            variable_temperature_button()
        }
    )
}

FUNCTION variables_list_clk() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: 116, paint: False]
        items: LIST {
            variable_clk_button()
        }
    )
}

FUNCTION variables_list_reset() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: 116, paint: False]
        items: LIST {
            variable_reset_button()
        }
    )
}

FUNCTION variables_list_data() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: 116, paint: False]
        items: LIST {
            variable_data_button()
        }
    )
}

FUNCTION variables_list_temperature() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: 116, paint: False]
        items: LIST {
            variable_temperature_button()
        }
    )
}

FUNCTION variables_list_empty() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 116
            padding: 8
            rounded_corners: 8
            background: [color: TEXT { #101A2B }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Muted)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #90A4BF }
            ]
            text: TEXT { No matching signals }
        )
    )
}

FUNCTION variable_clk_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_clk], hovered: PASSED.store.elements.select_clk]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_clk()
    )
}

FUNCTION variable_reset_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_reset], hovered: PASSED.store.elements.select_reset]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_reset()
    )
}

FUNCTION variable_data_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_data], hovered: PASSED.store.elements.select_data]
        style: [
            width: Fill
            height: 24
            rounded_corners: 8
            material: PASSED.store.active_signal == TEXT { data_bus } |> WHEN {
                True => NovyTheme/material(of: SelectedRow)
                False => NovyTheme/material(of: HoverControl)
            }
        ]
        label: variable_row_data()
    )
}

FUNCTION variable_temperature_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_temperature], hovered: PASSED.store.elements.select_temperature]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_temperature()
    )
}

