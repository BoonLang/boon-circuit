FUNCTION row_analog_limits_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.analog_limits_manual], hovered: PASSED.store.elements.analog_limits_manual]
        style: row_value_action_style(button_width: 56, hovered: element.hovered)
        label: row_value_action_label(button_text: PASSED.store.analog_limit_validity == Rejected |> WHEN {
            True => TEXT { Fix }
            False => PASSED.store.analog_range_label |> Text/contains(needle: TEXT { Manual }) |> WHEN {
                True => TEXT { Manual }
                False => TEXT { Auto }
            }
        })
    )
}

FUNCTION row_value_action_label(button_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: Fill
            height: Fill
            center: True
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #24364b }
            }
        ]
        text: button_text
    )
}

FUNCTION wave_area(signal) {
    Scene/Element/block(
        element: [
            event: [
                key_down: PASSED.store.elements.keyboard_capture
            ]
            hovered: PASSED.store.elements.waveform_hover
        ]
        style: [
            width: Fill
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #020817 }]
            border: [color: TEXT { #1f2a3c }]
            glow: [color: TEXT { #3b82f62a }, intensity: 0.03]
        ]
        child: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 2
            style: [
                width: Fill
                height: Fill
                padding: [top: 6, bottom: 6, left: 8, right: 8]
                paint: False
            ]
            items: LIST {
                waveform_segment_lane(signal: signal)
            }
        )
    )
}

FUNCTION waveform_segment_lane(signal) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 2
        style: [width: Fill, height: Fill, paint: False]
        items:
            PASSED.store.selected_waveform_segments
            |> List/filter_field_equal(field: "signal_id", value: signal.id)
            |> List/map(segment, new: waveform_segment(segment: waveform_segment_for_signal(segment: segment, signal: signal)))
    )
}

FUNCTION waveform_segment_for_signal(segment, signal) {
    [
        file: segment.file
        signal_id: segment.signal_id
        start_time_value: segment.start_time_value
        end_time_value: segment.end_time_value
        visible_start_time_value: segment.visible_start_time_value
        visible_end_time_value: segment.visible_end_time_value
        projection_source: segment.projection_source
        width: segment.width
        state: segment.state
        raw_label: segment.raw_label
        label: NovyModel/format_signal_value(value: segment.raw_label, bit_width: signal.bit_width, format: signal.formatter)
        click_time: segment.click_time
    ]
}

FUNCTION waveform_segment(segment) {
    segment.state |> WHEN {
        CursorLine => NoElement
        MarkerLine => NoElement
        High => waveform_segment_blue(segment: segment)
        Low => waveform_segment_dark(segment: segment)
        Unknown => waveform_segment_sky(segment: segment)
        AnalogLow => waveform_segment_indigo(segment: segment)
        AnalogMid => waveform_segment_cyan(segment: segment)
        AnalogHigh => waveform_segment_pale(segment: segment)
        __ => waveform_segment_sky(segment: segment)
    }
}

FUNCTION waveform_segment_blue(segment) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [
            width: segment.width
            height: Fill
            paint: False
        ]
        items: LIST {
            waveform_transition_edge_blue()
            waveform_trace_cell_blue(segment: segment)
        }
    )
}

FUNCTION waveform_segment_dark(segment) {
