FUNCTION variables_panel() {
    variables_panel_base(panel_width: Fill, panel_height: Fill)
}

FUNCTION variables_panel_docked() {
    variables_panel_base(panel_width: Fill, panel_height: Fill)
}

FUNCTION variables_panel_base(panel_width, panel_height) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 4
        style: [
            width: panel_width
            height: panel_height
            padding: 10
            depth: 10
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #304057 }
                Light => TEXT { #c9d7ea }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 10
                style: [width: Fill, height: 38, paint: False]
                items: LIST {
                    panel_title(title_text: TEXT { Variables })
                    search_box()
                }
            )
            variables_list()
            search_result_line()
        }
    )
}

FUNCTION variables_list() {
    PASSED.store.active_scope == TEXT { simple_tb_s } |> WHEN {
        True => PASSED.store.scope_cpu_expansion_state == Expanded |> WHEN {
            True => variables_virtual_list()
            False => variables_scope_collapsed()
        }
        False => variables_virtual_list()
    }
}

FUNCTION variables_virtual_list() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 4
        style: [width: Fill, height: 112, paint: False, scroll_y: True, scrollbars: True]
        items:
            PASSED.store.variable_rows |> List/map(row, new: variables_virtual_row(row: row))
    )
}

FUNCTION variables_virtual_row(row) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [width: Fill, height: 24, paint: False]
        items:
            row.signals |> List/map(signal, new: variable_result_row(signal: signal))
    )
}

FUNCTION variable_result_row(signal) {
    variable_signal_button(signal: signal)
}

FUNCTION variable_result_static_row(signal) {
    signal.key == TEXT { data_valid } |> WHEN {
        True => variable_data_valid_row()
        False => signal.key == TEXT { data_ready } |> WHEN {
            True => variable_data_ready_row()
            False => signal.key == TEXT { data_parity } |> WHEN {
                True => variable_data_parity_row()
                False => signal.key == TEXT { state } |> WHEN {
                    True => variable_state_row()
                    False => signal.key == TEXT { error_count } |> WHEN {
                        True => variable_error_count_row()
                        False => signal.key == TEXT { tx_data } |> WHEN {
                            True => variable_uart_tx_row()
                            False => signal.key == TEXT { rx_data } |> WHEN {
                                True => variable_uart_rx_row()
                                False => signal.key == TEXT { baud_tick } |> WHEN {
                                    True => variable_baud_tick_row()
                                    False => signal.key == TEXT { uart_busy } |> WHEN {
                                        True => variable_uart_busy_row()
                                        False => signal.key == TEXT { framing_error } |> WHEN {
                                            True => variable_framing_error_row()
                                            False => signal.key == TEXT { voltage } |> WHEN {
                                                True => variable_vcore_row()
                                                False => variable_static_row(
                                                    name_text: signal.name
                                                    chip_a: signal.kind
                                                    chip_b: signal.bit_width
                                                    chip_c: signal.direction
                                                )
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

FUNCTION variables_list_empty() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 116
            padding: 8
            rounded_corners: 8
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #90a4bf }
                    Light => TEXT { #60748b }
                }
            ]
            text: TEXT { No matching signals }
        )
    )
}

FUNCTION variables_scope_collapsed() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 108
            padding: 8
            rounded_corners: 8
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #90a4bf }
                    Light => TEXT { #60748b }
                }
            ]
            text: TEXT { Scope collapsed }
        )
    )
}

FUNCTION variable_clk_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_clk], hovered: PASSED.store.elements.select_clk]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_clk()
    )
}

FUNCTION variable_reset_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_reset], hovered: PASSED.store.elements.select_reset]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_reset()
    )
}

FUNCTION variable_data_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_data], hovered: PASSED.store.elements.select_data]
        style: [
            width: Fill
            height: 24
            rounded_corners: 8
            material: PASSED.store.active_signal == TEXT { data_bus } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
        ]
        label: variable_row_data()
    )
}

FUNCTION variable_temperature_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_temperature], hovered: PASSED.store.elements.select_temperature]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_temperature()
    )
}

FUNCTION variable_signal_button(signal) {
    Scene/Element/button(
        element: [
            event: [press: signal.signal_elements.select_signal]
            hovered: signal.signal_elements.select_signal
        ]
        style: [
            width: Fill
            height: 20
            rounded_corners: 8
            material: signal.selected_once |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => PASSED.store.active_signal == signal.key |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
                }
            }
        ]
        label: variable_signal_row(signal: signal)
        target: signal.name
        address: signal.key
    )
}

FUNCTION variable_signal_row(signal) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 20, paint: False]
        items: LIST {
            variable_name_text(label_text: variable_signal_display_name(signal: signal))
            variable_chip_literal(label_text: signal.kind)
            variable_chip_literal(label_text: signal.bit_width)
            variable_chip_literal(label_text: signal.direction)
        }
    )
}

FUNCTION variable_signal_display_name(signal) {
    signal.alias |> Text/is_empty() |> WHEN {
        True => signal.name
        False => signal.alias
    }
}

