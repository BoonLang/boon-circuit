-- Deterministic FjordPulse public HTTP contract slice. The generic host emits
-- one normalized request source; all route, method, validation, and payload
-- decisions below are Boon-owned.

store: [
    http_request: SOURCE

    mode: Deterministic

    request_count:
        0 |> HOLD request_count {
            http_request.method |> THEN { request_count + 1 }
        }

    request_path:
        TEXT { / } |> HOLD request_path {
            http_request.method |> THEN { http_request.path }
        }

    request_method:
        TEXT { GET } |> HOLD request_method {
            http_request.method |> THEN { http_request.method }
        }

    search_query:
        http_request.method |> THEN {
            http_request.query
                |> List/filter(item, if: item.name == TEXT { q })
                |> List/map(item, new: item.value)
                |> Text/join(separator: Text/empty())
        }

    stations: LIST {
        [id: TEXT { NSR:StopPlace:548 }, name: TEXT { Førde rutebilstasjon }, latitude: 61.452, longitude: 5.857, kind: TEXT { bus_station }, modes: TEXT { bus,coach }]
        [id: TEXT { NSR:StopPlace:337 }, name: TEXT { Oslo S }, latitude: 59.9109, longitude: 10.7523, kind: TEXT { rail_station }, modes: TEXT { rail,metro,tram,bus }]
        [id: TEXT { NSR:StopPlace:58366 }, name: TEXT { Bergen stasjon }, latitude: 60.3905, longitude: 5.3331, kind: TEXT { rail_station }, modes: TEXT { rail,bus }]
        [id: TEXT { NSR:StopPlace:417 }, name: TEXT { Trondheim S }, latitude: 63.4365, longitude: 10.3981, kind: TEXT { rail_station }, modes: TEXT { rail,bus }]
        [id: TEXT { NSR:StopPlace:390 }, name: TEXT { Bodø stasjon }, latitude: 67.2868, longitude: 14.3908, kind: TEXT { rail_station }, modes: TEXT { rail,bus,ferry }]
    }

    station_matches:
        List/query_prefix(
            list: stations
            field: name
            prefix: search_query
            limit: 20
            normalization: TrimLowercase
        )

    departures: LIST {
        [
            id: TEXT { dep_100_1 }
            serviceJourneyId: TEXT { SKY:ServiceJourney:100-1 }
            lineId: TEXT { SKY:Line:100 }
            lineCode: TEXT { 100 }
            destination: TEXT { Nordfjordeid }
            aimedDepartureAt: TEXT { 2026-07-10T10:15:00Z }
            expectedDepartureAt: TEXT { 2026-07-10T10:17:00Z }
            status: TEXT { delayed }
            delaySeconds: 120
            platform: TEXT { 1 }
            realtime: True
        ]
    }

    nearby_vehicles: LIST {
        [
            id: TEXT { SKY:Vehicle:12345 }
            transportMode: TEXT { bus }
            passengerServiceState: TEXT { passenger }
            lineCode: TEXT { 100 }
            destination: TEXT { Nordfjordeid }
            state: TEXT { live }
            latitude: 61.453
            longitude: 5.858
            bearing: 42
            delaySeconds: 120
            lastSeenAt: TEXT { 2026-07-10T09:59:58Z }
            version: TEXT { 2026-07-10T09:59:58Z }
        ]
    }
]

outputs: [
    health: [
        ok: True
        data: [
            status: TEXT { healthy }
            mode: TEXT { normal }
            dataMode: TEXT { deterministic }
            checkedAt: TEXT { 2026-07-10T10:00:00Z }
            version: TEXT { boon-deterministic-v1 }
            fallbackAvailable: False
            dependencies: [
                boonServer: [status: TEXT { healthy }, checkedAt: TEXT { 2026-07-10T10:00:00Z }]
                redb: [status: TEXT { healthy }, checkedAt: TEXT { 2026-07-10T10:00:00Z }]
                entur: [status: TEXT { configured }, checkedAt: TEXT { 2026-07-10T10:00:00Z }]
                mapTiles: [status: TEXT { configured }, checkedAt: TEXT { 2026-07-10T10:00:00Z }]
            ]
        ]
        meta: [requestId: TEXT { req_health }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    readiness: [
        ok: True
        data: [
            status: TEXT { healthy }
            restored: True
            migrations: TEXT { compatible }
            indexes: TEXT { valid }
            listener: TEXT { admitted }
        ]
        meta: [requestId: TEXT { req_readiness }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    map_config: [
        ok: True
        data: [
            version: TEXT { raster-v1 }
            defaultBasemap: TEXT { streets }
            sourceCount: 2
            capabilityPolicy: TEXT { allowlisted-opaque-raster }
        ]
        meta: [requestId: TEXT { req_map_config }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    station_catalog: [
        ok: True
        data: [
            bounds: [minLongitude: 4.5, minLatitude: 58, maxLongitude: 8.5, maxLatitude: 63]
            zoom: 7.5
            dataSource: TEXT { deterministic }
            items: store.stations
            completeMatchedCount: 5
        ]
        meta: [requestId: TEXT { req_station_map }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    search_contract: [
        ok: True
        query: store.search_query |> Text/concat(with: Text/empty(), separator: Text/empty())
        indexedResultCount: store.station_matches |> List/length()
        limit: 20
        meta: [requestId: TEXT { req_search }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    station_snapshot: [
        ok: True
        data: [
            stationId: TEXT { NSR:StopPlace:548 }
            stationName: TEXT { Førde rutebilstasjon }
            state: TEXT { fresh }
            version: TEXT { 2026-07-10T10:00:00Z }
            departures: store.departures
            nearbyVehicles: store.nearby_vehicles
        ]
        meta: [requestId: TEXT { req_station }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    departure_board: [
        ok: True
        data: [
            stationId: TEXT { NSR:StopPlace:548 }
            mode: TEXT { day }
            date: TEXT { 2026-07-10 }
            timeZone: TEXT { Europe/Oslo }
            departures: store.departures
            limit: 50
            complete: True
            totalCount: 1
        ]
        meta: [requestId: TEXT { req_station_departures_01 }, updatedAt: TEXT { 2026-07-10T10:00:00.000Z }]
    ]

    nearby_vehicle_snapshot: [
        ok: True
        data: [
            stationId: TEXT { NSR:StopPlace:548 }
            searchRadiusMeters: 5000
            state: TEXT { fresh }
            vehicles: store.nearby_vehicles
        ]
        meta: [requestId: TEXT { req_nearby_vehicles }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    vehicle_snapshot: [
        ok: True
        data: [
            id: TEXT { SKY:Vehicle:12345 }
            transportMode: TEXT { bus }
            passengerServiceState: TEXT { passenger }
            lineCode: TEXT { 100 }
            destination: TEXT { Nordfjordeid }
            state: TEXT { live }
            latitude: 61.453
            longitude: 5.858
            bearing: 42
            routeProgress: 0.42
            version: TEXT { 2026-07-10T09:59:58Z }
        ]
        meta: [requestId: TEXT { req_vehicle }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    realtime_token: [
        ok: True
        data: [
            token: TEXT { deterministic-fixture-token-00000001 }
            expiresAt: TEXT { 2026-07-10T10:05:00Z }
            webSocketUrl: TEXT { ws://127.0.0.1/live }
            protocolVersion: 1
        ]
        meta: [requestId: TEXT { req_realtime_token }, updatedAt: TEXT { 2026-07-10T10:00:00Z }]
    ]

    -- Existing deterministic Admin roots stay available while public routing is
    -- expanded independently.
    admin_session: [authenticated: True, username: TEXT { Fixture operator }, access: TEXT { read-only }]
    admin_status: FjordPulseContract/admin_status(request_count: store.request_count)
    admin_infrastructure: FjordPulseContract/admin_infrastructure()
    admin_database: FjordPulseContract/admin_database()

    http_response: [
        status: public_http_status(
            path: store.request_path
            method: store.request_method
            query: store.search_query
        ) + 0
        headers: LIST {
            [name: TEXT { content-type }, value: TEXT { application/json }]
        }
        body: public_http_body(
            path: store.request_path
            method: store.request_method
            query: store.search_query
        )
            |> Text/trim()
            |> Text/to_bytes(encoding: Utf8)
    ]
]

host_ports: [
    http: [
        request: store.http_request
        response: http_response
    ]
]

FUNCTION public_http_status(path, method, query) {
    path |> WHEN {
        TEXT { /api/realtime-token } => method |> WHEN { TEXT { POST } => 201, __ => 405 }
        TEXT { /api/search } => method |> WHEN {
            TEXT { GET } => query |> WHEN {
                TEXT { førde } => 200
                TEXT { ber } => 200
                __ => 400
            }
            __ => 405
        }
        TEXT { /api/health } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/readiness } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/map/config } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/stations } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/stations/NSR:StopPlace:548 } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/stations/NSR:StopPlace:548/departures } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/stations/NSR:StopPlace:548/nearby-vehicles } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/vehicles/SKY:Vehicle:12345 } => method |> WHEN { TEXT { GET } => 200, __ => 405 }
        TEXT { /api/stations/not-an-id } => method |> WHEN { TEXT { GET } => 400, __ => 405 }
        TEXT { /api/stations/NSR:StopPlace:999 } => method |> WHEN { TEXT { GET } => 404, __ => 405 }
        TEXT { /api/vehicles/not-an-id } => method |> WHEN { TEXT { GET } => 400, __ => 405 }
        TEXT { /api/vehicles/SKY:Vehicle:999 } => method |> WHEN { TEXT { GET } => 404, __ => 405 }
        __ => 404
    }
}

FUNCTION public_http_body(path, method, query) {
    path |> WHEN {
        TEXT { /api/health } => method |> WHEN { TEXT { GET } => health_json(), __ => method_not_allowed_json() }
        TEXT { /api/readiness } => method |> WHEN { TEXT { GET } => readiness_json(), __ => method_not_allowed_json() }
        TEXT { /api/map/config } => method |> WHEN { TEXT { GET } => map_config_json(), __ => method_not_allowed_json() }
        TEXT { /api/stations } => method |> WHEN { TEXT { GET } => station_map_json(), __ => method_not_allowed_json() }
        TEXT { /api/search } => method |> WHEN {
            TEXT { GET } => query |> WHEN {
                TEXT { førde } => search_forde_json()
                TEXT { ber } => search_bergen_json()
                __ => invalid_query_json()
            }
            __ => method_not_allowed_json()
        }
        TEXT { /api/stations/NSR:StopPlace:548 } => method |> WHEN { TEXT { GET } => station_json(), __ => method_not_allowed_json() }
        TEXT { /api/stations/NSR:StopPlace:548/departures } => method |> WHEN { TEXT { GET } => station_departures_json(), __ => method_not_allowed_json() }
        TEXT { /api/stations/NSR:StopPlace:548/nearby-vehicles } => method |> WHEN { TEXT { GET } => nearby_vehicles_json(), __ => method_not_allowed_json() }
        TEXT { /api/vehicles/SKY:Vehicle:12345 } => method |> WHEN { TEXT { GET } => vehicle_json(), __ => method_not_allowed_json() }
        TEXT { /api/realtime-token } => method |> WHEN { TEXT { POST } => realtime_token_json(), __ => method_not_allowed_json() }
        TEXT { /api/stations/not-an-id } => invalid_station_json()
        TEXT { /api/stations/NSR:StopPlace:999 } => unknown_station_json()
        TEXT { /api/vehicles/not-an-id } => invalid_vehicle_json()
        TEXT { /api/vehicles/SKY:Vehicle:999 } => unknown_vehicle_json()
        __ => not_found_json()
    }
}

FUNCTION health_json() {
    "{\"ok\":true,\"data\":{\"status\":\"healthy\",\"mode\":\"normal\",\"dataMode\":\"deterministic\",\"checkedAt\":\"2026-07-10T10:00:00Z\",\"version\":\"boon-deterministic-v1\",\"fallbackAvailable\":false,\"dependencies\":{\"boonServer\":{\"status\":\"healthy\",\"checkedAt\":\"2026-07-10T10:00:00Z\"},\"redb\":{\"status\":\"healthy\",\"checkedAt\":\"2026-07-10T10:00:00Z\"},\"entur\":{\"status\":\"configured\",\"checkedAt\":\"2026-07-10T10:00:00Z\"},\"mapTiles\":{\"status\":\"configured\",\"checkedAt\":\"2026-07-10T10:00:00Z\"}}},\"meta\":{\"requestId\":\"req_health\",\"updatedAt\":\"2026-07-10T10:00:00Z\"}}"
}

