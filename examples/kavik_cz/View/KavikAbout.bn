                element: []
                direction: Row
                gap: 14
                style: [width: Fill, wrap: True, wrap_min_width: 300, paint: False]
                items: LIST {
                    KavikComponents/media(
                        title: TEXT { Bungee jumping }
                        video_id: TEXT { muVBtlwP4BQ }
                        poster_url: TEXT { asset://kavik_cz/images/videos/bungee.jpg }
                        to: TEXT { https://www.youtube.com/watch?v=muVBtlwP4BQ }
                        PASS: [store: PASSED.store]
                    )
                    KavikComponents/media(
                        title: TEXT { Skydiving }
                        video_id: TEXT { 0-UQKFUs02M }
                        poster_url: TEXT { asset://kavik_cz/images/videos/skydiving.jpg }
                        to: TEXT { https://www.youtube.com/watch?v=0-UQKFUs02M }
                        PASS: [store: PASSED.store]
                    )
                }
            )
            KavikComponents/paragraph(text: TEXT { If you do not experience real fear from time to time, the mind starts creating fears out of nothing. }, PASS: [store: PASSED.store])
        }
    )
}

FUNCTION life() {
    section(
        title: TEXT { Life }
        subtitle: TEXT { Who I am now. }
        items: LIST {
            KavikComponents/paragraph(text: TEXT { I live in Prague with two hobbits and one queen. I am nocturnal, enjoy the brief Czech spring before the sun becomes a Death Star, and now lift mostly toys and small creatures instead of dumbbells. }, PASS: [store: PASSED.store])
            KavikComponents/paragraph(text: TEXT { I like one-to-one conversations, spicy food and sushi, cozy cafes, and hikes. Skip the formalities. A slow reply probably means I am on the kindergarten walk, thinking about your problem. Our Tour de Norge 2024 confirmed the plan to learn Norwegian and move there. }, PASS: [store: PASSED.store])
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 14
                style: [width: Fill, wrap: True, wrap_min_width: 300, paint: False]
                items: LIST {
                    KavikComponents/image(url: TEXT { asset://kavik_cz/images/about/cat_alesund.jpg }, alt: TEXT { Cat in Alesund }, aspect: 1.3, PASS: [store: PASSED.store])
                    KavikComponents/image(url: TEXT { asset://kavik_cz/images/about/norway_trip.jpg }, alt: TEXT { Norway road trip map }, aspect: 1.3, PASS: [store: PASSED.store])
                }
            )
        }
    )
}

FUNCTION partner() {
    section(
        title: TEXT { As Your Partner }
        subtitle: TEXT { I'm not hired to write code. I'm hired to help with the product. }
        items: LIST {
            KavikComponents/paragraph(text: TEXT { How I naturally work has a name: Shape Up. Six years of four-to-six-week cycles ending with progress reports and demos taught me to ask business questions early and fill whatever gap blocks the product. }, PASS: [store: PASSED.store])
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 8
                style: [width: Fill, wrap: True, wrap_min_width: 130, paint: False]
                items: LIST {
                    KavikComponents/pill(label: TEXT { Systematic }, accent: KavikTheme/accent(of: Blue), PASS: [store: PASSED.store])
                    KavikComponents/pill(label: TEXT { Empathetic }, accent: KavikTheme/accent(of: Pink), PASS: [store: PASSED.store])
                    KavikComponents/pill(label: TEXT { Proactive }, accent: KavikTheme/accent(of: Teal), PASS: [store: PASSED.store])
                    KavikComponents/pill(label: TEXT { INTJ-A }, accent: KavikTheme/accent(of: Purple), PASS: [store: PASSED.store])
                }
            )
            KavikComponents/paragraph(text: TEXT { I have also been paid to teach Rust, get apps through Facebook review, design in Figma and Penpot, audit smart contracts, write email templates and articles, accelerate integration tests, and edit visual assets. I work mostly part-time so open source, research, and two small creators in training receive attention too. }, PASS: [store: PASSED.store])
        }
    )
}
