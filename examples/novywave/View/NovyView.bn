        element: [event: [press: PASSED.store.elements.marker_remove], hovered: PASSED.store.elements.marker_remove]
        style: compact_button_style(button_width: 70, hovered: element.hovered)
        label: button_label(button_text: TEXT { Delete })
    )
}

FUNCTION format_button() {
    PASSED.store.pressed_control_label == TEXT { Fmt } |> WHEN {
        True => format_button_pressed()
        False => format_button_resting()
    }
}

FUNCTION format_button_resting() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.format_cycle], hovered: PASSED.store.elements.format_cycle]
        style: compact_button_style(button_width: 112, hovered: element.hovered)
        label: button_label(button_text: TEXT { Next format })
    )
}

FUNCTION format_button_pressed() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.format_cycle], hovered: PASSED.store.elements.format_cycle]
        style: format_button_pressed_style()
        label: button_label(button_text: TEXT { Next format })
    )
}

