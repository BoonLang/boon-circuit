            [signal_id: TEXT { reset_n }, width: 0, state: MarkerLine, label: TEXT { marker }]
            [signal_id: TEXT { reset_n }, width: 252, state: High, label: TEXT { released }]
            [signal_id: TEXT { data_bus }, width: 0, state: CursorLine, label: TEXT { cursor }]
