                    )
                    FjordPulseComponents/heading(value: FjordPulseModel/admin_page_title(route: PASSED.store.route, language: PASSED.store.language), size: 26)
                    FjordPulseComponents/muted(value: FjordPulseModel/admin_page_subtitle(route: PASSED.store.route, language: PASSED.store.language))
