FUNCTION text_line(label_text, font, width, height) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: font)
            width: width
            height: height
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
        ]
        text: label_text
    )
}
