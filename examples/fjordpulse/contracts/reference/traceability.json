  "crossCuttingRequirements": [
    {
      "id": "FP-CONTRACT-001",
      "requirement": "The browser never calls Entur or SurrealDB directly.",
      "sources": ["AGENTS.md rules 1-2", "FP-041", "FP-078"]
    },
    {
      "id": "FP-CONTRACT-002",
      "requirement": "Database-originated notifications use the sole DEFINE EVENT to LIVE SELECT publication path and are not broadcast directly after writes.",
      "sources": ["AGENTS.md rules 10-11", "GOAL.md phase 8", "FP-046", "FP-063"]
    },
    {
      "id": "FP-CONTRACT-003",
      "requirement": "Snapshots are authoritative; notifications carry versions and clients ignore duplicate or older versions.",
      "sources": ["AGENTS.md rules 13-14", "GOAL.md phase 8", "FP-047", "FP-061"]
    },
    {
      "id": "FP-CONTRACT-004",
      "requirement": "A failed live-query bridge exposes degraded health and uses HTTP snapshot polling without a second publication path.",
      "sources": ["AGENTS.md rule 12", "FP-048", "FP-069", "FP-097"]
    },
    {
      "id": "FP-CONTRACT-005",
      "requirement": "All boundary timestamps are UTC RFC3339 and transport display conversion occurs only in the UI using Europe/Oslo.",
      "sources": ["AGENTS.md rule 15", "docs/03_api_contract.md"]
    },
    {
      "id": "FP-CONTRACT-006",
      "requirement": "Development scenarios are unavailable in production and production never fakes or interpolates vehicle movement.",
      "sources": ["AGENTS.md rules 3-4", "FP-056", "FP-078"]
    }
  ],
