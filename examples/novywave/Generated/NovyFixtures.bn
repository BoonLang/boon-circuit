FUNCTION selected_signals() {
    LIST {
        [id: TEXT { clk }, name: TEXT { clk }, current_value: TEXT { 1 }, kind: Digital]
        [id: TEXT { reset_n }, name: TEXT { reset_n }, current_value: TEXT { 1 }, kind: Digital]
        [id: TEXT { data_bus }, name: TEXT { data_bus[7:0] }, current_value: TEXT { 0x2a }, kind: Digital]
        [id: TEXT { data_valid }, name: TEXT { data_valid }, current_value: TEXT { 1 }, kind: Digital]
        [id: TEXT { data_ready }, name: TEXT { data_ready }, current_value: TEXT { 0 }, kind: Digital]
        [id: TEXT { state }, name: TEXT { state[2:0] }, current_value: TEXT { Run }, kind: Digital]
        [id: TEXT { error_count }, name: TEXT { error_count[15:0] }, current_value: TEXT { 0 }, kind: Digital]
        [id: TEXT { temperature }, name: TEXT { temperature }, current_value: TEXT { 42.8 C }, kind: Analog]
    }
}

