FUNCTION admin_header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 12
        style: [
            width: Fill
            padding: [left: 22, right: 22, top: 16, bottom: 14]
            ...FjordPulseTheme/surface_frame(of: Surface)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Column
                gap: 2
                style: [width: Fill, paint: False]
                items: LIST {
                    Scene/Element/text(
                        element: []
                        style: [...FjordPulseTheme/muted(), width: Fill, height: 18, size: 10, weight: 700]
