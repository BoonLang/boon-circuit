                                    size: 21
                                )
                                FjordPulseComponents/muted(value: FjordPulseModel/vehicle_id(vehicle: PASSED.store.selected_vehicle))
                            }
                        )
                        FjordPulseComponents/icon_button(label: TEXT { × }, selected: False)
                            |> SOURCE { PASSED.store.elements.vehicle.close }
                    }
                )
                vehicle_body()
            }
        )
    )
}

FUNCTION mobile_sheet_controls() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 5
        style: [width: Fill, height: 38, paint: False]
        items: LIST {
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Kompakt }, english: TEXT { Peek })
                selected: PASSED.store.mobile_sheet == Peek
                width: Fill
            ) |> SOURCE { PASSED.store.elements.sheet.peek }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Halv }, english: TEXT { Half })
                selected: PASSED.store.mobile_sheet == Half
                width: Fill
            ) |> SOURCE { PASSED.store.elements.sheet.half }
            FjordPulseComponents/button(label: TEXT { Full }, selected: PASSED.store.mobile_sheet == Full, width: Fill)
                |> SOURCE { PASSED.store.elements.sheet.full }
        }
    )
}

FUNCTION mobile_navigation() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [
            width: Fill
            height: 64
            padding: [left: 10, right: 10, top: 8, bottom: 8]
            ...FjordPulseTheme/physical_surface(of: Chrome)
        ]
        items: LIST {
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Kart }, english: TEXT { Map })
                selected: True
                width: Fill
            ) |> SOURCE { PASSED.store.elements.navigation.map }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Søk }, english: TEXT { Search })
                selected: PASSED.store.search_state != Closed
                width: Fill
            ) |> SOURCE { PASSED.store.elements.navigation.search }
            FjordPulseComponents/button(label: TEXT { Admin }, selected: False, width: Fill)
                |> SOURCE { PASSED.store.elements.navigation.admin }
        }
    )
}

FUNCTION admin_root() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [...FjordPulseTheme/page(), ...FjordPulseTheme/physical_surface(of: AdminPage), overflow: Hidden, language: FjordPulseModel/language_code(language: PASSED.store.language)]
        items: LIST {
            admin_sidebar()
            admin_main()
        }
    )
}

FUNCTION admin_sidebar() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: 250
            height: Fill
            visible_min_width: 801
            padding: [left: 14, right: 14, top: 16, bottom: 16]
            ...FjordPulseTheme/physical_surface(of: Chrome)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 9
                style: [width: Fill, height: 44, paint: False]
                items: LIST {
                    Scene/Element/block(
                        element: []
                        style: [width: 38, height: 34, background: [url: TEXT { asset://fjordpulse/fjordpulse-mark.svg }]]
                        child: Scene/Element/text(element: [], style: [height: 1], text: Text/empty())
                    )
                    Scene/Element/text(element: [], style: [width: Fill, height: Fill, vertical_align: Center, color: FjordPulseTheme/text_on_dark(), size: 19, weight: 700], text: TEXT { FjordPulse })
                }
            )
            Scene/Element/text(
                element: []
                style: [width: Fill, height: 24, color: FjordPulseTheme/text_on_chrome_subtle(), size: 10, weight: 700]
                text: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { ADMINPANEL }, english: TEXT { ADMIN CONSOLE })
            )
            admin_navigation_buttons()
            Scene/Element/text(element: [], style: [width: Fill, height: Fill, paint: False], text: Text/empty())
            FjordPulseComponents/status_pill(
                status: PASSED.store.admin_resource_state
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Deterministisk Admin }, english: TEXT { Deterministic Admin })
            )
            Scene/Element/text(element: [], style: [width: Fill, height: 24, color: FjordPulseTheme/text_on_chrome_muted(), size: 11], text: TEXT { Fixture operator · read-only })
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Logg ut }, english: TEXT { Log out })
                selected: False
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.logout }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Til transportkartet }, english: TEXT { Public map })
                selected: False
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.public_map }
        }
    )
}

FUNCTION admin_navigation_buttons() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, paint: False]
        items: LIST {
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Systemstatus }, english: TEXT { System status })
                selected: PASSED.store.route == AdminStatus
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.status }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Infrastruktur }, english: TEXT { Infrastructure })
                selected: PASSED.store.route == AdminInfrastructure
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.infrastructure }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Overvåkinger }, english: TEXT { Watches })
                selected: PASSED.store.route == AdminWatches
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.watches }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Entur-logg }, english: TEXT { Entur log })
                selected: PASSED.store.route == AdminEnturLog
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.entur_log }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Sanntid }, english: TEXT { Realtime })
                selected: PASSED.store.route == AdminRealtime
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.realtime }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Hendelser }, english: TEXT { Events })
                selected: PASSED.store.route == AdminEvents
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.events }
            FjordPulseComponents/button(
                label: TEXT { Database }
                selected: PASSED.store.route == AdminDatabaseSchema
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.database_schema }
        }
    )
}

