FUNCTION column_divider_style() {
    [
        width: 4
        height: Fill
        rounded_corners: 0
        cursor: TEXT { col-resize }
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #3b82f6 }
            Light => TEXT { #60a5fa }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #93c5fd }
            Light => TEXT { #2563eb }
        }
        glow: [color: TEXT { #60a5fa66 }, intensity: 0.08]
        material: NovyTheme/material(mode: PASSED.store.mode, of: FocusedControl)
        __hover_gloss: 0.12
    ]
}

FUNCTION row_divider_style() {
    [
        width: Fill
        height: 4
        rounded_corners: 0
        cursor: TEXT { row-resize }
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #3b82f6 }
            Light => TEXT { #60a5fa }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #93c5fd }
            Light => TEXT { #2563eb }
        }
        glow: [color: TEXT { #60a5fa66 }, intensity: 0.08]
        material: NovyTheme/material(mode: PASSED.store.mode, of: FocusedControl)
        __hover_gloss: 0.12
    ]
}

FUNCTION signal_row_divider_style() {
    [
        width: Fill
        height: 3
        rounded_corners: 0
        cursor: TEXT { row-resize }
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #1d4ed8 }
            Light => TEXT { #60a5fa }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #93c5fd }
            Light => TEXT { #2563eb }
        }
        material: NovyTheme/material(mode: PASSED.store.mode, of: TraceEdge)
        __hover_gloss: 0.10
    ]
}

FUNCTION empty_state() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 16
        style: [
            width: Fill
            height: 650
            align: [row: Center]
            scroll_y: True
            scrollbars: True
            padding: 72
            depth: 10
            move: [closer: 2]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #f8fbff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #93b4e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TimelineGlass)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Title)
                    width: Fill
                    height: 44
                    center: True
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dceaff }
                        Light => TEXT { #172033 }
                    }
                ]
                text: PASSED.store.empty_state_title
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                    width: Fill
                    height: 28
                    center: True
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dbeafe }
                        Light => TEXT { #24364b }
                    }
                ]
                text: PASSED.store.empty_state_hint
            )
            empty_state_fact(label_text: PASSED.store.empty_state_bridge_label)
            empty_state_fact(label_text: PASSED.store.empty_state_formats_label)
            empty_open_button()
            empty_load_button()
        }
    )
}

