    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: 118
            height: Fill
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #24364b }
            }
        ]
        text: PASSED.store.analog_limit_validity == Rejected |> WHEN {
            True => PASSED.store.analog_limit_error
            False => PASSED.store.analog_range_label
        }
    )
}

