FUNCTION value_pill_text(value_text) {
    Scene/Element/label(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: PASSED.store.selected_value_column_width
            height: Fill
            center: True
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #E9F0FA }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #B8C8DF }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        text: value_text
    )
}

FUNCTION wave_area(signal) {
    Scene/Element/block(
        element: [
            event: [
                key_down: PASSED.store.elements.keyboard_capture
            ]
            hovered: PASSED.store.elements.waveform_click
        ]
        style: [
            width: Fill
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #020817 }]
            border: [color: TEXT { #1f2a3c }]
            glow: [color: TEXT { #3b82f62a }, intensity: 0.03]
        ]
        child: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 2
            style: [
                width: Fill
                height: Fill
                padding: [top: 6, bottom: 6, left: 8, right: 8]
                paint: False
            ]
            items: LIST {
                waveform_segment_lane(signal: signal)
                waveform_marker_lane()
            }
        )
    )
}

FUNCTION waveform_segment_lane(signal) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 2
        style: [width: Fill, height: Fill, paint: False]
        items:
            PASSED.store.selected_waveform_segments
            |> List/filter_field_equal(field: "signal_id", value: signal.id)
            |> List/map(segment, new: waveform_segment(segment: segment))
    )
}

FUNCTION waveform_marker_lane() {
    PASSED.store.marker_visibility == TEXT { Visible } |> WHEN {
        True => Scene/Element/stripe(
            element: []
            direction: Row
            gap: 18
            style: [width: Fill, height: 8, paint: False]
            items:
                PASSED.store.markers |> List/map(marker, new: waveform_marker_list_line(marker: marker))
        )
        False => Scene/Element/label(
            element: []
            style: [width: Fill, height: 0, paint: False]
            label: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
        )
    }
}

FUNCTION waveform_marker_list_line(marker) {
    Scene/Element/block(
        element: [target: marker.label]
        style: [
            width: 18
            height: Fill
            rounded_corners: 1
            background: [color: TEXT { #A78BFA }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: MarkerChip)
        ]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION waveform_segment(segment) {
    segment.state |> WHEN {
        CursorLine => waveform_cursor_line(segment: segment)
        MarkerLine => waveform_marker_line()
        High => waveform_segment_blue(segment: segment)
        Low => waveform_segment_dark(segment: segment)
        Unknown => waveform_segment_sky(segment: segment)
        AnalogLow => waveform_segment_indigo(segment: segment)
        AnalogMid => waveform_segment_cyan(segment: segment)
        AnalogHigh => waveform_segment_pale(segment: segment)
        __ => waveform_segment_sky(segment: segment)
    }
}

FUNCTION waveform_segment_blue(segment) {
    Scene/Element/stripe(
        element: [event: [press: PASSED.store.elements.waveform_click, key_down: PASSED.store.elements.keyboard_capture], hovered: PASSED.store.elements.waveform_click, target: segment.click_time]
        direction: Row
        gap: 0
        style: [
            width: segment.width
            height: Fill
            paint: False
        ]
        items: LIST {
            waveform_transition_edge_blue()
            waveform_trace_cell_blue(segment: segment)
        }
    )
}

FUNCTION waveform_segment_dark(segment) {
    Scene/Element/stripe(
