FUNCTION search_result_line() {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: Fill
            height: 18
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #90a4bf }
                Light => TEXT { #60748b }
            }
        ]
        text: PASSED.store.search_result_label
    )
}

FUNCTION variable_name_text(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: 180
            height: Fill
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
        ]
        text: label_text
    )
}

FUNCTION variable_chip_wire() {
    variable_chip_literal(label_text: TEXT { Wire })
}

FUNCTION variable_chip_analog() {
    variable_chip_literal(label_text: TEXT { Analog })
}

FUNCTION variable_chip_1bit() {
    variable_chip_literal(label_text: TEXT { 1-bit })
}

FUNCTION variable_chip_8bit() {
    variable_chip_literal(label_text: TEXT { 8-bit })
}

FUNCTION variable_chip_16bit() {
    variable_chip_literal(label_text: TEXT { 16-bit })
}

FUNCTION variable_chip_input() {
    variable_chip_literal(label_text: TEXT { Input })
}

FUNCTION variable_chip_output() {
    variable_chip_literal(label_text: TEXT { Output })
}

FUNCTION variable_chip_literal(label_text) {
    Scene/Element/label(
        element: []
        style: [
            width: 54
            height: 20
            rounded_corners: 10
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1d4ed8 }
                Light => TEXT { #d7e9ff }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: MarkerChip)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #dbeafe }
                    Light => TEXT { #17406f }
                }
            ]
            text: label_text
        )
    )
}

FUNCTION inspector_strip() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 4
        style: [width: Fill, height: 90, paint: False]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 6
                style: [width: Fill, height: 42, paint: False]
                items: LIST {
                    compact_inspector_row(row_label: TEXT { Active }, row_value: PASSED.store.active_signal_label, row_width: 118)
                    compact_inspector_row(row_label: TEXT { Format }, row_value: PASSED.store.format_label, row_width: 76)
                    compact_inspector_row(row_label: TEXT { View }, row_value: PASSED.store.keyboard_viewport_label, row_width: 118)
                    row_resize_controls_compact()
                }
            )
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 6
                style: [width: Fill, height: 42, paint: False]
                items: LIST {
                    compact_inspector_row(row_label: TEXT { Cursor }, row_value: PASSED.store.keyboard_cursor_label, row_width: 76)
                    compact_inspector_row(row_label: TEXT { Request }, row_value: PASSED.store.bridge_request_compact_label, row_width: 118)
                    compact_inspector_row(row_label: TEXT { Fixture }, row_value: PASSED.store.bridge_response_compact_label, row_width: 104)
                    compact_inspector_row(row_label: TEXT { Match }, row_value: PASSED.store.bridge_response_status_compact_label, row_width: 82)
                }
            )
        }
    )
}

FUNCTION inspector_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: 275
            height: Fill
            padding: 10
            depth: 10
            rounded_corners: 14
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            panel_title(title_text: TEXT { Inspector })
            inspector_row(row_label: TEXT { Active signal }, row_value: PASSED.store.active_signal_label)
            inspector_row(row_label: TEXT { Format }, row_value: PASSED.store.format_label)
            inspector_row(row_label: TEXT { Cursor }, row_value: PASSED.store.keyboard_cursor_label)
            inspector_row(row_label: TEXT { Viewport }, row_value: PASSED.store.keyboard_viewport_label)
            inspector_row(row_label: TEXT { Open result }, row_value: PASSED.store.bridge_waveform_ref)
            inspector_row(row_label: TEXT { Hierarchy }, row_value: PASSED.store.bridge_hierarchy_page_label)
            inspector_row(row_label: TEXT { Fixture request }, row_value: PASSED.store.bridge_request_label)
            inspector_row(row_label: TEXT { Fixture page }, row_value: PASSED.store.bridge_response_fingerprint)
            inspector_row(row_label: TEXT { Fixture match }, row_value: PASSED.store.bridge_response_status)
            inspector_row(row_label: TEXT { Cursor values }, row_value: PASSED.store.bridge_cursor_values_label)
            inspector_row(row_label: TEXT { Bridge policy }, row_value: PASSED.store.bridge_data_policy)
            row_resize_controls()
        }
    )
}

FUNCTION inspector_row(row_label, row_value) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 52
            padding: 8
            rounded_corners: 9
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: row_label, font: Muted, width: Fill, height: 16)
            text_line(label_text: row_value, font: Mono, width: Fill, height: 22)
        }
    )
}

FUNCTION compact_inspector_row(row_label, row_value, row_width) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: row_width
            height: 40
            padding: [left: 8, right: 8, top: 4, bottom: 4]
            rounded_corners: 9
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: row_label, font: Muted, width: Fill, height: 12)
            text_line(label_text: row_value, font: Mono, width: Fill, height: 18)
        }
    )
}

FUNCTION row_resize_controls() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 36, paint: False]
        items: LIST {
            row_shorter_button()
            row_taller_button()
        }
    )
}

FUNCTION row_resize_controls_compact() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: 104, height: 36, paint: False]
        items: LIST {
            row_shorter_button_compact()
            row_taller_button_compact()
        }
    )
}

FUNCTION format_palette() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 32, paint: False]
        items: LIST {
            format_hex_button()
            format_binary_button()
            format_grouped_button()
            format_octal_button()
            format_signed_button()
            format_unsigned_button()
            format_ascii_button()
        }
    )
}

