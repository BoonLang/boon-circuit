                Light => TEXT { #f8fbff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1f2a3c }
                Light => TEXT { #b7c9e6 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TimelineGlass)
            scroll_x: True
            scrollbars: True
        ]
        items: LIST {
            waveform_cursor_line()
            wave_cell_analog_low(width_value: 64, label_text: TEXT { 39 })
            wave_cell_analog_mid(width_value: 64, label_text: TEXT { 41 })
            waveform_marker_line()
            wave_cell_analog_high(width_value: 64, label_text: TEXT { 43 })
            wave_cell_analog_mid(width_value: 64, label_text: TEXT { 42 })
            wave_cell_analog_low(width_value: 64, label_text: TEXT { 40 })
            wave_cell_analog_mid(width_value: 64, label_text: TEXT { 42 })
            wave_cell_analog_high(width_value: 64, label_text: TEXT { 44 })
            wave_cell_analog_mid(width_value: 64, label_text: TEXT { 43 })
        }
    )
}

FUNCTION waveform_cursor_line() {
    Scene/Element/block(
        element: []
        style: [
            width: 2
            height: Fill
            rounded_corners: 1
            background: [color: TEXT { #FDE68A }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: CursorGlow)
        ]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION waveform_marker_line() {
    PASSED.store.marker_count_label == TEXT { 1 marker } |> WHEN {
        True => Scene/Element/block(
            element: []
            style: [
                width: 2
                height: Fill
                rounded_corners: 1
                background: [color: TEXT { #A78BFA }]
                material: NovyTheme/material(mode: PASSED.store.mode, of: MarkerChip)
            ]
            child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
        )
        __ => NoElement
    }
}

FUNCTION data_bus_label_cursor_spacer() {
    Scene/Element/block(
