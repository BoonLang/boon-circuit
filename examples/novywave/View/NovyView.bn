FUNCTION collapsed_group() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.group_expand]
            hovered: PASSED.store.elements.group_expand
        ]
        style: [
            width: Fill
            height: 48
            rounded_corners: 10
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 12
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                        width: Fill
                        height: Fill
                        center: True
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: TEXT { Core bus group collapsed }
                )
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                        width: 112
                        height: Fill
                        center: True
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: TEXT { Expand group }
                )
            }
        )
    )
}

FUNCTION waveform_rows() {
    PASSED.store.selected_group == TEXT { Collapsed } |> WHEN {
        True => collapsed_group()
        False => waveform_rows_expanded()
    }
}

FUNCTION waveform_rows_expanded() {
    PASSED.store.selected_rows_profile == TEXT { WithoutData } |> WHEN {
        True => waveform_rows_from(list: NovyFixtures/selected_signals_without_data())
        False => PASSED.store.selected_rows_profile == TEXT { DataFirst } |> WHEN {
            True => waveform_rows_from(list: NovyFixtures/selected_signals_data_first())
            False => PASSED.store.selected_rows_profile == TEXT { DataLast } |> WHEN {
                True => waveform_rows_from(list: NovyFixtures/selected_signals_data_last())
                False => waveform_rows_from(list: NovyFixtures/selected_signals())
            }
        }
    }
}

FUNCTION waveform_rows_from(list) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [width: Fill, height: Fill, paint: False]
        items:
            list |> List/map(row, new: selected_waveform_row(row: row))
    )
}

FUNCTION selected_waveform_row(row) {
    row.id == TEXT { clk } |> WHEN {
        True => waveform_row_clk()
        False => row.id == TEXT { reset_n } |> WHEN {
            True => waveform_row_reset()
            False => row.id == TEXT { data_bus } |> WHEN {
                True => waveform_row_data()
                False => row.id == TEXT { temperature } |> WHEN {
                    True => waveform_row_temperature()
                    False => waveform_row(signal: row)
                }
            }
        }
    }
}

FUNCTION waveform_row_clk() {
    BLOCK {
        active: PASSED.store.active_signal == TEXT { clk }

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 2
                background: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #071120 }
                    Light => TEXT { #f7fbff }
                }]
                border: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #1c2b43 }
                    Light => TEXT { #cbd9ec }
                }]
                material: active |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
                }
            ]
            items: LIST {
                fixed_signal_label(label_text: NovyFixtures/selected_clk_name())
                fixed_value_clk()
                fixed_wave_area_clk()
            }
        )
    }
}

