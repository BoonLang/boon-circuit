FUNCTION timeline_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 6
        style: [
            width: Fill
            height: Fill
            padding: 8
            depth: 4
            move: [closer: 1]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #2563eb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            timeline_header()
            timeline_toolbar()
            timeline_axis()
            waveform_rows()
        }
    )
}

FUNCTION timeline_header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 30, paint: False]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Heading)
                    width: 240
                    height: Fill
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dceaff }
                        Light => TEXT { #182a3d }
                    }
                ]
                text: TEXT { Selected Variables }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                    width: Fill
                    height: Fill
                    center: True
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #90a4bf }
                        Light => TEXT { #60748b }
                    }
                ]
                text: PASSED.store.selected_rows_order_label
            )
            remove_all_button()
        }
    )
}

FUNCTION timeline_toolbar() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: 104, paint: False]
        items: LIST {
            timeline_navigation_controls()
            selected_row_controls()
            analog_limit_controls()
            keyboard_capture()
        }
    )
}

FUNCTION timeline_navigation_controls() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 28, paint: False]
        items: LIST {
            zoom_in_button()
            zoom_out_button()
            pan_left_button()
            pan_right_button()
            cursor_left_button()
            cursor_right_button()
            marker_button()
            control_separator()
            create_group_button()
            control_separator()
            group_button()
            control_separator()
            format_button()
        }
    )
}

FUNCTION selected_row_controls() {
    Scene/Element/stripe(
