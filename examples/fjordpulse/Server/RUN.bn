    "{\"ok\":true,\"data\":{\"status\":\"healthy\",\"mode\":\"normal\",\"dataMode\":\"deterministic\",\"checkedAt\":\"2026-07-10T10:00:00Z\",\"version\":\"boon-deterministic-v1\",\"fallbackAvailable\":false,\"dependencies\":{\"artifact\":{\"status\":\"healthy\",\"checkedAt\":\"2026-07-10T10:00:00Z\"},\"redb\":{\"status\":\"healthy\",\"checkedAt\":\"2026-07-10T10:00:00Z\"},\"indexes\":{\"status\":\"healthy\",\"checkedAt\":\"2026-07-10T10:00:00Z\"},\"listener\":{\"status\":\"healthy\",\"checkedAt\":\"2026-07-10T10:00:00Z\"}}},\"meta\":{\"requestId\":\"req_readiness\",\"updatedAt\":\"2026-07-10T10:00:00Z\"}}"
