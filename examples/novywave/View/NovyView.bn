    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 24, paint: False]
        items: LIST {
            variable_name_text(label_text: TEXT { data_bus[7:0] })
            variable_chip_wire()
            variable_chip_8bit()
            variable_chip_output()
        }
    )
}

