FUNCTION marker_rows_panel() {
    PASSED.store.marker_visibility == Visible |> WHEN {
        True => Scene/Element/stripe(
            element: []
            direction: Row
            gap: 4
            style: [width: 180, height: 28, paint: False, scroll_x: True, scrollbars: True]
            items:
                PASSED.store.markers |> List/map(marker, new: marker_row(marker: marker))
        )
        False => Scene/Element/label(
            element: []
            style: [width: 180, height: 28, paint: False]
            label: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
        )
    }
}

FUNCTION marker_row(marker) {
    Scene/Element/label(
        element: [target: marker.label]
        style: [
            width: 96
            height: 24
            rounded_corners: 6
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f2f5fb }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #334761 }
                Light => TEXT { #c9d7ea }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
            ]
            text: TEXT { M {marker.label} }
        )
    )
}

