    selected_rows_enabled_value:
        TEXT { loaded } |> HOLD selected_rows_enabled_value {
            LATEST {
                elements.show_empty.event.press |> THEN { TEXT { none } }
                elements.begin_default_file_load.event.press |> THEN { TEXT { none } }
                elements.load_default_file.event.press |> THEN { TEXT { loaded } }
                elements.external_file_loaded_name.text |> THEN { TEXT { loaded } }
                elements.select_counter_file.event.press |> THEN { TEXT { loaded } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { loaded } }
                elements.select_ghw_file.event.press |> THEN { TEXT { loaded } }
            }
        }

    group_header_collapsed:
        selected_group == Collapsed

    group_header_chevron:
        group_header_collapsed |> WHEN {
            True => TEXT { > }
            False => TEXT { v }
        }

    selected_rows_profile:
        LATEST {
            DefaultOrder
            elements.selected_remove_data.event.press |> THEN { WithoutData }
            elements.selected_remove_clk.event.press |> THEN { WithoutSelection }
            elements.selected_remove_reset.event.press |> THEN { WithoutSelection }
            elements.selected_remove_data_valid.event.press |> THEN { WithoutSelection }
            elements.selected_remove_data_ready.event.press |> THEN { WithoutSelection }
            elements.selected_remove_state.event.press |> THEN { WithoutSelection }
            elements.selected_remove_error_count.event.press |> THEN { WithoutSelection }
            elements.selected_remove_temperature.event.press |> THEN { WithoutSelection }
            elements.selected_remove_tx_data.event.press |> THEN { WithoutSelection }
            elements.selected_remove_rx_data.event.press |> THEN { WithoutSelection }
            elements.selected_remove_baud_tick.event.press |> THEN { WithoutSelection }
            elements.selected_remove_uart_busy.event.press |> THEN { WithoutSelection }
            elements.selected_remove_ghw_counter.event.press |> THEN { WithoutSelection }
            elements.selected_remove_ghw_enable.event.press |> THEN { WithoutSelection }
            elements.selected_remove_ghw_state.event.press |> THEN { WithoutSelection }
            elements.selected_clear_all.event.press |> THEN { Empty }
            elements.selected_restore_data.event.press |> THEN { DefaultOrder }
            elements.selected_data_up.event.press |> THEN { DataFirst }
            elements.selected_data_down.event.press |> THEN { DataLast }
            elements.select_counter_file.event.press |> THEN { DefaultOrder }
            elements.select_uart_compare_file.event.press |> THEN { DefaultOrder }
            elements.select_ghw_file.event.press |> THEN { DefaultOrder }
            elements.load_default_file.event.press |> THEN { DefaultOrder }
            elements.show_empty.event.press |> THEN { Empty }
        }

    selected_rows_removed_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_remove_data.event.press |> THEN { TEXT { data_bus } }
            elements.selected_remove_clk.event.press |> THEN { TEXT { clk } }
            elements.selected_remove_reset.event.press |> THEN { TEXT { reset_n } }
            elements.selected_remove_data_valid.event.press |> THEN { TEXT { data_valid } }
            elements.selected_remove_data_ready.event.press |> THEN { TEXT { data_ready } }
            elements.selected_remove_state.event.press |> THEN { TEXT { state } }
            elements.selected_remove_error_count.event.press |> THEN { TEXT { error_count } }
            elements.selected_remove_temperature.event.press |> THEN { TEXT { temperature } }
            elements.selected_remove_tx_data.event.press |> THEN { TEXT { tx_data } }
            elements.selected_remove_rx_data.event.press |> THEN { TEXT { rx_data } }
            elements.selected_remove_baud_tick.event.press |> THEN { TEXT { baud_tick } }
            elements.selected_remove_uart_busy.event.press |> THEN { TEXT { uart_busy } }
            elements.selected_remove_ghw_counter.event.press |> THEN { TEXT { ghw_counter } }
            elements.selected_remove_ghw_enable.event.press |> THEN { TEXT { ghw_enable } }
            elements.selected_remove_ghw_state.event.press |> THEN { TEXT { ghw_state } }
            elements.selected_clear_all.event.press |> THEN { TEXT { none } }
            elements.selected_restore_data.event.press |> THEN { TEXT { none } }
            elements.selected_data_up.event.press |> THEN { TEXT { none } }
            elements.selected_data_down.event.press |> THEN { TEXT { none } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    selected_rows_first_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_data_up.event.press |> THEN { TEXT { data_bus } }
            elements.selected_remove_data.event.press |> THEN { TEXT { none } }
            elements.selected_restore_data.event.press |> THEN { TEXT { none } }
            elements.selected_data_down.event.press |> THEN { TEXT { none } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    selected_rows_last_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_data_down.event.press |> THEN { TEXT { data_bus } }
            elements.selected_remove_data.event.press |> THEN { TEXT { none } }
            elements.selected_restore_data.event.press |> THEN { TEXT { none } }
            elements.selected_data_up.event.press |> THEN { TEXT { none } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    selected_visible_items:
        selected_signal_defaults
        |> List/filter_field_equal(field: "family", value: selected_signal_family)
        |> List/filter_field_equal(field: "enabled", value: selected_rows_enabled_value)
        |> List/filter_field_not_equal(field: "hidden_when_group", value: selected_group)
        |> List/filter_field_not_equal(field: "id", value: selected_rows_removed_signal_id)
        |> List/retain(row, if: selected_row_is_visible(row: row))
        |> List/move_field_first(field: "id", value: selected_rows_first_signal_id)
        |> List/move_field_last(field: "id", value: selected_rows_last_signal_id)

    selected_signal_rows:
        selected_visible_items
        |> List/filter_field_equal(field: "item_kind", value: VariableRow)

    selected_signals:
        selected_signal_rows

    selected_signal_format_rows:
        selected_signal_rows
        |> List/map(signal, new: [id: signal.id, formatter: signal.formatter, bit_width: signal.bit_width])

    selected_cursor_pair_rows:
        selected_signal_rows
        |> List/map(signal, new: selected_cursor_pair_row(signal: signal))

    selected_variable_file:
        active_signal == TEXT { none } |> WHEN {
            True => active_file
            False => List/find_value(selected_signal_defaults, field: "id", value: active_signal, target: "file", fallback: active_file)
        }

    selected_timeline_metadata_file:
        external_file_active == Yes |> WHEN {
            True => active_file
            False => selected_variable_file
        }

    selected_timeline_full_range:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "full_range", fallback: active_metadata_full_range)

    selected_timeline_initial_window:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "initial_window", fallback: active_metadata_initial_window)

    selected_timeline_range_start:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "range_start", fallback: active_metadata_range_start)
        |> Text/to_number()

    selected_timeline_range_end:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "range_end", fallback: active_metadata_range_end)
        |> Text/to_number()

    selected_timeline_window_start:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "initial_start", fallback: active_metadata_initial_start)
        |> Text/to_number()

    selected_timeline_window_end:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "initial_end", fallback: active_metadata_initial_end)
        |> Text/to_number()

    selected_waveform_metadata_canvas_width:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "canvas_width", fallback: active_metadata_canvas_width)
        |> Text/to_number()

    selected_waveform_canvas_width:
        selected_waveform_metadata_canvas_width |> HOLD selected_waveform_canvas_width {
            LATEST {
                elements.waveform_click.pointer_width |> THEN { elements.waveform_click.pointer_width |> Text/to_number() }
                elements.waveform_hover.pointer_width |> THEN { elements.waveform_hover.pointer_width |> Text/to_number() }
                elements.load_default_file.event.press |> THEN { selected_waveform_metadata_canvas_width }
                elements.show_empty.event.press |> THEN { selected_waveform_metadata_canvas_width }
            }
        }

    selected_timeline_time_unit:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "time_unit", fallback: active_metadata_time_unit)

    selected_timeline_timescale:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "timescale", fallback: active_metadata_timescale)

    selected_timeline_range_source:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "range_source", fallback: active_metadata_range_source)

    selected_timeline_metadata_source:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "metadata_source", fallback: active_metadata_source)

    selected_timeline_cursor_left:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "cursor_left", fallback: 0)
        |> Text/to_number()

    selected_timeline_cursor_default:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "cursor_default", fallback: 0)
        |> Text/to_number()

    selected_timeline_cursor_right:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "cursor_right", fallback: 0)
        |> Text/to_number()

    selected_timeline_zoom_center_default:
        List/find_value(waveform_file_metadata, field: "file", value: selected_timeline_metadata_file, target: "zoom_center_default", fallback: selected_timeline_cursor_default)
        |> Text/to_number()

    waveform_click_pointer_x_text:
        TEXT { 0 } |> HOLD waveform_click_pointer_x_text {
            LATEST {
                elements.waveform_click.pointer_x
                elements.load_default_file.event.press |> THEN { TEXT { 0 } }
                elements.show_empty.event.press |> THEN { TEXT { 0 } }
            }
        }

    waveform_click_pointer_width_text:
        selected_waveform_metadata_canvas_width |> HOLD waveform_click_pointer_width_text {
            LATEST {
                elements.waveform_click.pointer_width
                elements.load_default_file.event.press |> THEN { selected_waveform_metadata_canvas_width }
                elements.show_empty.event.press |> THEN { selected_waveform_metadata_canvas_width }
            }
        }

    waveform_hover_pointer_x_text:
        TEXT { 0 } |> HOLD waveform_hover_pointer_x_text {
            LATEST {
                elements.waveform_hover.pointer_x
                elements.load_default_file.event.press |> THEN { TEXT { 0 } }
                elements.show_empty.event.press |> THEN { TEXT { 0 } }
            }
        }

    waveform_hover_pointer_width_text:
        selected_waveform_metadata_canvas_width |> HOLD waveform_hover_pointer_width_text {
            LATEST {
                elements.waveform_hover.pointer_width
                elements.load_default_file.event.press |> THEN { selected_waveform_metadata_canvas_width }
                elements.show_empty.event.press |> THEN { selected_waveform_metadata_canvas_width }
            }
        }

    zoom_center_keyboard_value:
        selected_timeline_zoom_center_default |> HOLD zoom_center_keyboard_value {
            LATEST {
                elements.keyboard_capture.key |> WHEN {
                    Z => selected_timeline_range_start
                    R => selected_timeline_zoom_center_default
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { selected_timeline_zoom_center_default }
                elements.show_empty.event.press |> THEN { selected_timeline_zoom_center_default }
            }
        }

    selected_timeline_zoom_center_value:
        selected_timeline_zoom_center_default |> HOLD selected_timeline_zoom_center_value {
            LATEST {
                elements.waveform_hover.pointer_x |> THEN { Number/project_time(pointer_x: elements.waveform_hover.pointer_x, pointer_width: elements.waveform_hover.pointer_width, viewport_start: selected_timeline_range_start, viewport_end: selected_timeline_range_end, fallback: selected_timeline_zoom_center_value) }
                elements.keyboard_capture.key |> WHEN {
                    Z => zoom_center_keyboard_value
                    R => zoom_center_keyboard_value
                    __ => SKIP
                }
                elements.zoom_reset.event.press |> THEN { selected_timeline_zoom_center_default }
                elements.load_default_file.event.press |> THEN { selected_timeline_zoom_center_default }
                elements.show_empty.event.press |> THEN { selected_timeline_zoom_center_default }
            }
        }

    selected_timeline_zoom_center_number:
        selected_timeline_zoom_center_value |> Text/to_number()

    selected_timeline_tick_0:
        viewport_label_start

    selected_timeline_tick_1:
        Number/interpolate(start: viewport_label_start, end: viewport_label_end, numerator: 1, denominator: 4, fallback: viewport_label_start)

    selected_timeline_tick_2:
        Number/interpolate(start: viewport_label_start, end: viewport_label_end, numerator: 2, denominator: 4, fallback: viewport_label_start)

    selected_timeline_tick_3:
        Number/interpolate(start: viewport_label_start, end: viewport_label_end, numerator: 3, denominator: 4, fallback: viewport_label_end)

    selected_timeline_tick_4:
        viewport_label_end

    selected_timeline_cursor_value:
        selected_timeline_cursor_default |> HOLD selected_timeline_cursor_value {
            LATEST {
                elements.waveform_click.pointer_x |> THEN { Number/project_time(pointer_x: elements.waveform_click.pointer_x, pointer_width: elements.waveform_click.pointer_width, viewport_start: viewport_label_start, viewport_end: viewport_label_end, fallback: selected_timeline_cursor_value) }
                elements.cursor_left.event.press |> THEN { selected_timeline_cursor_left }
                elements.cursor_right.event.press |> THEN { selected_timeline_cursor_right }
                elements.marker_jump.event.press |> THEN { selected_timeline_cursor_default }
                elements.zoom_reset.event.press |> THEN { selected_timeline_cursor_default }
                elements.keyboard_capture.key |> WHEN {
                    D => selected_timeline_cursor_default
                    Q => selected_timeline_cursor_left
                    R => selected_timeline_cursor_default
                    E => selected_timeline_cursor_right
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { selected_timeline_cursor_default }
                elements.show_empty.event.press |> THEN { selected_timeline_cursor_default }
            }
        }

    selected_waveform_segments:
        waveform_segment_records
        |> List/filter_field_equal(field: "file", value: active_file)
        |> List/filter_field_not_equal(field: "state", value: CursorLine)
        |> List/filter_field_not_equal(field: "state", value: MarkerLine)
        |> List/retain(segment, if: waveform_segment_is_visible(segment: segment))
        |> List/map(segment, new: new_waveform_segment(segment: segment))

    active_waveform_segment_labels:
        waveform_segment_records
        |> List/filter_field_equal(field: "file", value: active_file)
        |> List/filter_field_equal(field: "signal_id", value: active_signal)
        |> List/map(segment, new: [value: NovyModel/format_signal_value(value: segment.label, bit_width: active_signal_bit_width, format: active_signal_format)])
        |> List/join_field(field: "value", separator: ",", empty: "none")

    active_waveform_segment_count:
        waveform_segment_records
        |> List/filter_field_equal(field: "file", value: active_file)
        |> List/filter_field_equal(field: "signal_id", value: active_signal)
        |> List/length()

    timeline_axis_tick_0:
        selected_timeline_tick_0 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_1:
        selected_timeline_tick_1 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_2:
        selected_timeline_tick_2 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_3:
        selected_timeline_tick_3 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_4:
        selected_timeline_tick_4 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    data_bus_alias:
        List/find_value(signal_catalog, field: key, value: TEXT { data_bus }, target: alias, fallback: Text/empty())

    signal_search_text:
        Text/empty() |> HOLD signal_search_text {
            LATEST {
                elements.signal_search_input.text |> Text/trim()
            }
        }

    search_results:
        signal_catalog
        |> List/filter_text_contains(field: "name", needle: signal_search_text, prefer_field: "family", empty_field: "scope", empty_value: active_scope_label)

    variable_rows:
        List/chunk(search_results, size: 1, items: signals, label: row_number)

    search_results_count:
        search_results |> List/length()

    search_results_key_summary:
        search_results |> List/join_field(field: "key", separator: ",", empty: "none")

    search_results_name_summary:
        search_results |> List/join_field(field: "name", separator: ", ", empty: "none")

    focused_control_label:
        TEXT { none } |> HOLD focused_control_label {
            LATEST {
                elements.signal_search_focus_probe.event.click |> THEN { TEXT { signal search } }
                elements.scope_cpu.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_expand.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_collapse.event.press |> THEN { TEXT { none } }
                elements.scope_uart.event.press |> THEN { TEXT { none } }
                elements.scope_analog.event.press |> THEN { TEXT { none } }
                elements.select_counter_file.event.press |> THEN { TEXT { none } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
                elements.select_ghw_file.event.press |> THEN { TEXT { none } }
                elements.load_default_file.event.press |> THEN { TEXT { none } }
                elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    focused_control_material_label:
        focused_control_label == TEXT { signal search } |> WHEN {
            True => TEXT { FocusedControl }
            False => TEXT { RestingControl }
        }

    pressed_control_label:
        TEXT { none } |> HOLD pressed_control_label {
            LATEST {
                elements.format_cycle.event.press |> THEN { TEXT { Fmt } }
                elements.format_dropdown_toggle.event.press |> THEN { TEXT { none } }
                elements.format_binary.event.press |> THEN { TEXT { none } }
                elements.format_hex.event.press |> THEN { TEXT { none } }
                elements.format_grouped.event.press |> THEN { TEXT { none } }
                elements.format_octal.event.press |> THEN { TEXT { none } }
                elements.format_signed.event.press |> THEN { TEXT { none } }
                elements.format_unsigned.event.press |> THEN { TEXT { none } }
                elements.format_ascii.event.press |> THEN { TEXT { none } }
                elements.mode_to_light.event.press |> THEN { TEXT { none } }
                elements.mode_to_dark.event.press |> THEN { TEXT { none } }
                elements.load_default_file.event.press |> THEN { TEXT { none } }
                elements.show_empty.event.press |> THEN { TEXT { none } }
                elements.signal_search_focus_probe.event.click |> THEN { TEXT { none } }
                elements.scope_cpu.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_expand.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_collapse.event.press |> THEN { TEXT { none } }
                elements.scope_uart.event.press |> THEN { TEXT { none } }
                elements.scope_analog.event.press |> THEN { TEXT { none } }
                elements.select_counter_file.event.press |> THEN { TEXT { none } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
                elements.select_ghw_file.event.press |> THEN { TEXT { none } }
                elements.select_clk.event.press |> THEN { TEXT { none } }
                elements.select_reset.event.press |> THEN { TEXT { none } }
                elements.select_data.event.press |> THEN { TEXT { none } }
                elements.select_temperature.event.press |> THEN { TEXT { none } }
                elements.zoom_in.event.press |> THEN { TEXT { none } }
                elements.zoom_out.event.press |> THEN { TEXT { none } }
                elements.pan_left.event.press |> THEN { TEXT { none } }
                elements.pan_right.event.press |> THEN { TEXT { none } }
                elements.cursor_left.event.press |> THEN { TEXT { none } }
                elements.cursor_right.event.press |> THEN { TEXT { none } }
                elements.marker_toggle.event.press |> THEN { TEXT { none } }
                elements.marker_remove.event.press |> THEN { TEXT { none } }
                elements.group_create.event.press |> THEN { TEXT { none } }
                elements.group_toggle.event.press |> THEN { TEXT { none } }
                elements.group_expand.event.press |> THEN { TEXT { none } }
                elements.row_taller.event.press |> THEN { TEXT { none } }
                elements.row_shorter.event.press |> THEN { TEXT { none } }
            }
        }

    pressed_control_material_label:
        pressed_control_label == TEXT { none } |> WHEN {
            True => TEXT { RestingControl }
            False => TEXT { PressedControl }
        }

    format_dropdown_state:
        Closed |> HOLD format_dropdown_state {
            LATEST {
                elements.format_dropdown_toggle.event.press |> THEN {
                    format_dropdown_state |> WHEN {
                        Open => Closed
                        __ => Open
                    }
                }
                elements.format_cycle.event.press |> THEN { Closed }
                elements.format_binary.event.press |> THEN { Closed }
                elements.format_hex.event.press |> THEN { Closed }
                elements.format_grouped.event.press |> THEN { Closed }
                elements.format_octal.event.press |> THEN { Closed }
                elements.format_signed.event.press |> THEN { Closed }
                elements.format_unsigned.event.press |> THEN { Closed }
                elements.format_ascii.event.press |> THEN { Closed }
                elements.load_default_file.event.press |> THEN { Closed }
                elements.show_empty.event.press |> THEN { Closed }
                elements.select_counter_file.event.press |> THEN { Closed }
                elements.select_uart_compare_file.event.press |> THEN { Closed }
                elements.select_ghw_file.event.press |> THEN { Closed }
            }
        }

    search_result_label:
        signal_search_text |> Text/is_empty() |> WHEN {
            True =>
                search_results_count
                |> Text/concat(with: TEXT { results in }, separator: " ")
                |> Text/concat(with: active_scope_label, separator: " ")
            False => search_results_count == 1 |> WHEN {
                True =>
                    TEXT { 1 result: }
                    |> Text/concat(with: search_results_name_summary, separator: " ")
                False => search_results_count == 0 |> WHEN {
                    True =>
                        TEXT { 0 results: }
                        |> Text/concat(with: signal_search_text, separator: " ")
                    False => search_results_count > 12 |> WHEN {
                        True =>
                            search_results_count
                            |> Text/concat(with: TEXT { results: scroll variables list }, separator: " ")
                        False =>
                            search_results_count
                            |> Text/concat(with: TEXT { results: }, separator: " ")
                            |> Text/concat(with: search_results_name_summary, separator: " ")
                    }
                }
            }
        }

    search_scope_mode: TEXT { Global }

    keyboard_last_key:
        Text/empty() |> HOLD keyboard_last_key {
            LATEST {
                elements.keyboard_capture.key
                elements.waveform_hover.pointer_x |> THEN { Text/empty() }
                elements.waveform_click.pointer_x |> THEN { Text/empty() }
                elements.load_default_file.event.press |> THEN { Text/empty() }
                elements.show_empty.event.press |> THEN { Text/empty() }
                elements.select_counter_file.event.press |> THEN { Text/empty() }
                elements.select_uart_compare_file.event.press |> THEN { Text/empty() }
                elements.select_ghw_file.event.press |> THEN { Text/empty() }
                elements.select_clk.event.press |> THEN { Text/empty() }
                elements.select_reset.event.press |> THEN { Text/empty() }
                elements.select_data.event.press |> THEN { Text/empty() }
                elements.select_temperature.event.press |> THEN { Text/empty() }
                elements.format_dropdown_toggle.event.press |> THEN { Text/empty() }
                elements.format_cycle.event.press |> THEN { Text/empty() }
                elements.format_binary.event.press |> THEN { Text/empty() }
                elements.format_hex.event.press |> THEN { Text/empty() }
                elements.format_grouped.event.press |> THEN { Text/empty() }
                elements.format_octal.event.press |> THEN { Text/empty() }
                elements.format_signed.event.press |> THEN { Text/empty() }
                elements.format_unsigned.event.press |> THEN { Text/empty() }
                elements.format_ascii.event.press |> THEN { Text/empty() }
            }
        }

    selected_group:
        LATEST {
            Expanded
            elements.group_create.event.press |> THEN { Expanded }
            elements.group_toggle.event.press |> THEN { Collapsed }
            elements.group_expand.event.press |> THEN { Expanded }
            elements.group_remove.event.press |> THEN { None }
            elements.load_default_file.event.press |> THEN { Expanded }
            elements.show_empty.event.press |> THEN { None }
        }

    group_creation_state:
        LATEST {
            Created
            elements.group_create.event.press |> THEN { Created }
            elements.group_remove.event.press |> THEN { None }
            elements.load_default_file.event.press |> THEN { Created }
            elements.show_empty.event.press |> THEN { None }
        }

    group_name:
        LATEST {
            TEXT { simple_tb.s group }
            elements.group_create.event.press |> THEN { TEXT { simple_tb.s group } }
            elements.group_remove.event.press |> THEN { TEXT { No group } }
            elements.load_default_file.event.press |> THEN { TEXT { simple_tb.s group } }
            elements.show_empty.event.press |> THEN { TEXT { No group } }
        }

    group_count_label:
        LATEST {
            TEXT { 1 group }
            elements.group_create.event.press |> THEN { TEXT { 1 group } }
            elements.group_remove.event.press |> THEN { TEXT { 0 groups } }
            elements.load_default_file.event.press |> THEN { TEXT { 1 group } }
            elements.show_empty.event.press |> THEN { TEXT { 0 groups } }
        }

    group_members_label:
        LATEST {
            TEXT { A[3:0], B[3:0] }
            elements.group_create.event.press |> THEN { TEXT { A[3:0], B[3:0] } }
            elements.group_remove.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { A[3:0], B[3:0] } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    group_status_label:
        LATEST {
            TEXT { 1 group }
            elements.group_create.event.press |> THEN { TEXT { 1 group } }
            elements.group_remove.event.press |> THEN { TEXT { no group } }
            elements.load_default_file.event.press |> THEN { TEXT { 1 group } }
            elements.show_empty.event.press |> THEN { TEXT { no group } }
        }

    group_to_create:
        LATEST {
            elements.group_create.event.press |> THEN { TEXT { simple_tb.s group } }
        }

    groups:
        LIST {}
        |> List/append(item: group_to_create |> THEN {
            [
                name: group_to_create
                members_label: TEXT { A[3:0], B[3:0] }
            ]
        })
        |> List/map(group, new: new_signal_group(group: group, store: store))
        |> List/remove(group, when:
            LATEST {
                elements.group_remove.event.press |> THEN { True }
                elements.load_default_file.event.press |> THEN { True }
                elements.show_empty.event.press |> THEN { True }
            }
        )

    selected_rows_count:
        selected_signal_rows |> List/length()

    selected_rows_order_label:
        selected_signal_rows |> List/join_field(field: "name", separator: ", ", empty: "none")

    selected_signal_count_label:
        selected_rows_count |> Text/concat(with: TEXT { selected }, separator: " ")

    analog_limit_kind:
        Auto |> HOLD analog_limit_kind {
            LATEST {
            elements.analog_limits_auto.event.press |> THEN { Auto }
            elements.analog_limits_manual.event.press |> THEN { Manual }
            elements.load_default_file.event.press |> THEN { Auto }
            }
        }

    analog_limit_validity:
        Valid |> HOLD analog_limit_validity {
            LATEST {
            elements.analog_limits_auto.event.press |> THEN { Valid }
            elements.analog_limits_manual.event.press |> THEN { Valid }
            elements.analog_limits_invalid.event.press |> THEN { Rejected }
            elements.load_default_file.event.press |> THEN { Valid }
            }
        }

    analog_limit_min:
        TEXT { 39 C } |> HOLD analog_limit_min {
            LATEST {
            elements.analog_limits_manual.event.press |> THEN { TEXT { -10 C } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { 39 C } }
            elements.zoom_in.event.press |> THEN { TEXT { 40 C } }
            elements.zoom_out.event.press |> THEN { TEXT { 38 C } }
            elements.pan_left.event.press |> THEN { TEXT { 39 C } }
            elements.pan_right.event.press |> THEN { TEXT { 40 C } }
            elements.load_default_file.event.press |> THEN { TEXT { 39 C } }
            }
        }

    analog_limit_max:
        TEXT { 44 C } |> HOLD analog_limit_max {
            LATEST {
            elements.analog_limits_manual.event.press |> THEN { TEXT { 80 C } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { 44 C } }
            elements.zoom_in.event.press |> THEN { TEXT { 43 C } }
            elements.zoom_out.event.press |> THEN { TEXT { 45 C } }
            elements.pan_left.event.press |> THEN { TEXT { 43 C } }
            elements.pan_right.event.press |> THEN { TEXT { 44 C } }
            elements.load_default_file.event.press |> THEN { TEXT { 44 C } }
            }
        }

    analog_range_label:
        TEXT { Auto 39 C .. 44 C } |> HOLD analog_range_label {
            LATEST {
            elements.analog_limits_manual.event.press |> THEN { TEXT { Manual -10 C .. 80 C } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { Auto 39 C .. 44 C } }
            elements.zoom_in.event.press |> THEN { TEXT { Auto 40 C .. 43 C } }
            elements.zoom_out.event.press |> THEN { TEXT { Auto 38 C .. 45 C } }
            elements.pan_left.event.press |> THEN { TEXT { Auto 39 C .. 43 C } }
            elements.pan_right.event.press |> THEN { TEXT { Auto 40 C .. 44 C } }
            elements.load_default_file.event.press |> THEN { TEXT { Auto 39 C .. 44 C } }
            }
        }

    analog_limit_error:
        TEXT { none } |> HOLD analog_limit_error {
            LATEST {
            elements.analog_limits_invalid.event.press |> THEN { TEXT { rejected min >= max } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { none } }
            elements.analog_limits_manual.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            }
        }

    analog_limit_descriptor:
        [
            limit_kind: analog_limit_kind
            validity: analog_limit_validity
            min: analog_limit_min
            max: analog_limit_max
            visible_window: keyboard_viewport_label
            source: TEXT { Boon-visible analog limits }
        ]

    marker_visibility:
        Visible |> HOLD marker_visibility {
            LATEST {
            elements.marker_remove.event.press |> THEN { Hidden }
            elements.marker_toggle.event.press |> THEN { Visible }
            elements.load_default_file.event.press |> THEN { Visible }
            elements.show_empty.event.press |> THEN { Hidden }
            }
        }

    marker_current_label:
        TEXT { 50 s } |> HOLD marker_current_label {
            LATEST {
            elements.marker_rename.event.press |> THEN { TEXT { data stable } }
            elements.marker_remove.event.press |> THEN { TEXT { No markers } }
            elements.marker_toggle.event.press |> THEN { TEXT { 0 s } }
            elements.load_default_file.event.press |> THEN { TEXT { 50 s } }
            elements.show_empty.event.press |> THEN { TEXT { No markers } }
            }
        }

    marker_state:
        Default |> HOLD marker_state {
            LATEST {
            elements.marker_rename.event.press |> THEN { Renamed }
            elements.marker_remove.event.press |> THEN { Empty }
            elements.marker_toggle.event.press |> THEN { Added }
            elements.load_default_file.event.press |> THEN { Default }
            elements.show_empty.event.press |> THEN { Empty }
            }
        }

    marker_label:
        TEXT { M 50 s } |> HOLD marker_label {
            LATEST {
            elements.marker_rename.event.press |> THEN { TEXT { M simple transition } }
            elements.marker_remove.event.press |> THEN { TEXT { No markers } }
            elements.marker_jump.event.press |> THEN { marker_label }
            elements.marker_toggle.event.press |> THEN { TEXT { M 0 s } }
            elements.load_default_file.event.press |> THEN { TEXT { M 50 s } }
            elements.show_empty.event.press |> THEN { TEXT { No markers } }
            }
        }

    marker_focus_label:
        TEXT { marker at 50 s } |> HOLD marker_focus_label {
            LATEST {
            elements.marker_rename.event.press |> THEN { TEXT { simple transition at 50 s } }
            elements.marker_jump.event.press |> THEN {
                marker_state |> WHEN {
                    Renamed => TEXT { jumped to simple transition at 50 s }
                    Default => TEXT { jumped to 50 s }
                    Added => TEXT { jumped to 0 s }
                    __ => TEXT { jumped to 50 s }
                }
            }
            elements.marker_remove.event.press |> THEN { TEXT { no marker selected } }
            elements.marker_toggle.event.press |> THEN { TEXT { added marker at 0 s } }
            elements.load_default_file.event.press |> THEN { TEXT { marker at 50 s } }
            elements.show_empty.event.press |> THEN { TEXT { no marker selected } }
            }
        }

    marker_default_label:
        TEXT { 50 s }

    marker_to_add:
        LATEST {
            elements.marker_toggle.event.press |> THEN { TEXT { 0 s } }
            elements.load_default_file.event.press |> THEN { TEXT { 50 s } }
        }

    marker_add_from_toggle:
        LATEST {
            elements.marker_toggle.event.press |> THEN { TEXT { 0 s } }
        }

    marker_add_from_load:
        LATEST {
            elements.load_default_file.event.press |> THEN { TEXT { 50 s } }
        }

    markers:
        LIST {
            [label: TEXT { 50 s }]
        }
        |> List/append(item: marker_add_from_toggle |> THEN {
            [label: TEXT { 0 s }]
        })
        |> List/append(item: marker_add_from_load |> THEN {
            [label: TEXT { 50 s }]
        })
        |> List/map(marker, new: new_marker(marker: marker, store: store))
        |> List/remove(marker, when:
            LATEST {
                marker.marker_elements.remove_marker.event.press |> THEN { True }
                elements.marker_remove.event.press |> THEN { True }
                elements.show_empty.event.press |> THEN { True }
            }
        )

    active_marker_count:
        markers
        |> List/retain(marker, if: marker.has_label)
        |> List/count()

    marker_count_label:
        active_marker_count |> WHEN {
            0 => TEXT { 0 markers }
            1 => TEXT { 1 marker }
            __ => active_marker_count |> Text/concat(with: TEXT { markers }, separator: " ")
        }

    row_size:
        Normal |> HOLD row_size {
            LATEST {
                elements.row_taller.event.press |> THEN { Tall }
                elements.row_shorter.event.press |> THEN { Compact }
                elements.signal_row_resize_drag.text |> THEN {
                    elements.signal_row_resize_drag.text |> WHEN {
                        TEXT { Grow } => row_size |> WHEN {
                            Compact => Normal
                            __ => Tall
                        }
                        TEXT { Shrink } => row_size |> WHEN {
                            Tall => Normal
                            __ => Compact
                        }
                        __ => row_size
                    }
                }
            }
        }

    value_format:
        LATEST {
            Hexadecimal
            elements.format_cycle.event.press |> THEN { NovyModel/next_format(format: value_format) }
            elements.format_binary.event.press |> THEN { Binary }
            elements.format_hex.event.press |> THEN { Hexadecimal }
            elements.format_grouped.event.press |> THEN { GroupedBinary }
            elements.format_octal.event.press |> THEN { Octal }
            elements.format_signed.event.press |> THEN { Signed }
            elements.format_unsigned.event.press |> THEN { Unsigned }
            elements.format_ascii.event.press |> THEN { ASCII }
            elements.load_default_file.event.press |> THEN { Hexadecimal }
        }

    active_signal_format:
        List/find_value(selected_signal_format_rows, field: "id", value: active_signal, target: "formatter", fallback: value_format)

    active_signal_bit_width:
        List/find_value(selected_signal_format_rows, field: "id", value: active_signal, target: "bit_width", fallback: TEXT { 1-bit })

    data_bus_row_format:
        List/find_value(selected_signal_format_rows, field: "id", value: TEXT { data_bus }, target: "formatter", fallback: value_format)

    zoom_step:
        0 |> HOLD zoom_step {
            LATEST {
                elements.zoom_in.event.press |> THEN {
                    zoom_step >= 3 |> WHEN {
                        True => 3
                        False => zoom_step + 1
                    }
                }
                elements.zoom_out.event.press |> THEN {
                    zoom_step <= -2 |> WHEN {
                        True => -2
                        False => zoom_step - 1
                    }
                }
                elements.zoom_reset.event.press |> THEN { 0 }
                elements.keyboard_capture.key |> WHEN {
                    W => zoom_step >= 3 |> WHEN {
                        True => 3
                        False => zoom_step + 1
                    }
                    S => zoom_step <= -2 |> WHEN {
                        True => -2
                        False => zoom_step - 1
                    }
                    R => 0
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { 0 }
                elements.show_empty.event.press |> THEN { 0 }
            }
        }

    zoom_level:
        NovyModel/zoom_level_from_step(step: zoom_step)

    waveform_projection_zoom_level:
        zoom_level |> WHEN {
            Wide => Wide
            Widest => Widest
            __ => Fit
        }

    pan_window:
        Center |> HOLD pan_window {
            LATEST {
                elements.pan_left.event.press |> THEN { LeftWindow }
                elements.pan_right.event.press |> THEN { RightWindow }
                elements.zoom_reset.event.press |> THEN { Center }
                elements.keyboard_capture.key |> WHEN {
                    A => LeftWindow
                    D => RightWindow
                    R => Center
                    Q => RightWindow
                    E => RightWindow
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { Center }
                elements.show_empty.event.press |> THEN { Center }
            }
        }

    cursor_position:
        selected_timeline_cursor_value <= selected_timeline_cursor_left |> WHEN {
            True => Cursor36
            False => selected_timeline_cursor_value >= selected_timeline_cursor_right |> WHEN {
                True => Cursor48
                False => Cursor42
            }
        }

    viewport_window_key:
        selected_timeline_metadata_file
        |> Text/concat(with: zoom_level, separator: "|")
        |> Text/concat(with: pan_window, separator: "|")

    viewport_initial_span_value:
        Number/max(left: selected_timeline_window_end - selected_timeline_window_start, right: 0)

    viewport_range_span_value:
        Number/max(left: selected_timeline_range_end - selected_timeline_range_start, right: 0)

    viewport_close_unit_value:
        viewport_initial_span_value / 5

    viewport_closer_unit_value:
        viewport_initial_span_value / 25

    viewport_duration_value:
        zoom_level |> WHEN {
            Widest => viewport_range_span_value
            Wide => viewport_range_span_value
            Fit => viewport_initial_span_value
            Close => Number/max(left: viewport_close_unit_value * 3, right: 1)
            Closer => Number/max(left: viewport_closer_unit_value * 4, right: 1)
            Closest => Number/max(left: viewport_closer_unit_value, right: 1)
            __ => viewport_initial_span_value
        }

    viewport_anchor_center_value:
        pan_window |> WHEN {
            LeftWindow => selected_timeline_zoom_center_number - viewport_duration_value / 2
            RightWindow => selected_timeline_zoom_center_number + viewport_duration_value / 2
            __ => selected_timeline_zoom_center_number
        }

    viewport_desired_start_value:
        viewport_anchor_center_value - viewport_duration_value / 2

    viewport_label_start:
        Number/max(left: selected_timeline_range_start, right: Number/min(left: viewport_desired_start_value, right: selected_timeline_range_end - viewport_duration_value))

    viewport_label_end:
        Number/min(left: selected_timeline_range_end, right: viewport_label_start + viewport_duration_value)

    viewport_label:
        viewport_label_start
        |> Text/time_range_label(end: viewport_label_end, unit: selected_timeline_time_unit)

    keyboard_viewport_label:
        viewport_label

    cursor_label:
        selected_timeline_cursor_value |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    keyboard_cursor_label:
        selected_timeline_cursor_value |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    zoom_center_label:
        selected_timeline_zoom_center_value |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    waveform_cursor_offset:
        Number/project_offset(time: selected_timeline_cursor_value, viewport_start: viewport_label_start, viewport_end: viewport_label_end, canvas_width: selected_waveform_canvas_width, fallback: 0, zoom: waveform_projection_zoom_level)

    waveform_zoom_center_offset:
        Number/project_offset(time: selected_timeline_zoom_center_value, viewport_start: viewport_label_start, viewport_end: viewport_label_end, canvas_width: selected_waveform_canvas_width, fallback: 0, zoom: waveform_projection_zoom_level)

    active_signal_label:
        TEXT { simple_tb.s.A[3:0] } |> HOLD active_signal_label {
            LATEST {
                signal_catalog
                    |> List/map(signal_catalog_item, new:
                        signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN {
                            signal_catalog_item.key |> WHEN {
                                clk => TEXT { simple_tb.s.A[3:0] }
                                reset_n => TEXT { simple_tb.s.B[3:0] }
                                data_bus => TEXT { top.cpu.data_bus[7:0] }
                                temperature => TEXT { top.analog.temperature }
                                __ => SKIP
                            }
                        }
                    )
                    |> List/latest()
                elements.select_clk.event.press |> THEN { TEXT { simple_tb.s.A[3:0] } }
                elements.select_reset.event.press |> THEN { TEXT { simple_tb.s.B[3:0] } }
                elements.select_data.event.press |> THEN {
                    active_signal_key |> WHEN {
                        DATA_BUS => TEXT { none }
                        __ => TEXT { top.cpu.data_bus[7:0] }
                    }
                }
                elements.select_temperature.event.press |> THEN { TEXT { top.analog.temperature } }
                elements.select_counter_file.event.press |> THEN { TEXT { simple_tb.s.A[3:0] } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { top.uart.tx_data[7:0] } }
                elements.select_ghw_file.event.press |> THEN { TEXT { ghw.simple.counter[3:0] } }
                elements.load_default_file.event.press |> THEN { TEXT { simple_tb.s.A[3:0] } }
                elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    active_scope_key:
        active_scope |> WHEN {
            TEXT { simple_tb_s } => TEXT { SIMPLE_TB_S }
            TEXT { top_uart } => TEXT { TOP_UART }
            TEXT { top_analog } => TEXT { TOP_ANALOG }
            TEXT { ghw_simple } => TEXT { GHW_SIMPLE }
            __ => TEXT { NONE }
        }

    active_scope_label:
        active_scope |> WHEN {
            TEXT { simple_tb_s } => TEXT { simple_tb.s }
            TEXT { top_uart } => TEXT { top.uart }
            TEXT { top_analog } => TEXT { top.analog }
            TEXT { ghw_simple } => TEXT { ghw.simple }
            __ => TEXT { none }
        }

    active_scope_signal_count:
        active_scope |> WHEN {
            TEXT { simple_tb_s } => TEXT { 2 signals }
            TEXT { top_uart } => TEXT { 5 signals }
            TEXT { top_analog } => TEXT { 2 signals }
            TEXT { ghw_simple } => TEXT { 4 signals }
            __ => TEXT { 0 signals }
        }

    scope_cpu_expansion_state:
        LATEST {
            Expanded
            elements.scope_cpu.event.press |> THEN { Expanded }
            elements.scope_cpu_expand.event.press |> THEN { Expanded }
            elements.scope_cpu_collapse.event.press |> THEN { Collapsed }
            elements.select_counter_file.event.press |> THEN { Expanded }
            elements.load_default_file.event.press |> THEN { Expanded }
            elements.show_empty.event.press |> THEN { Collapsed }
        }

    active_scope_expansion_label:
        active_scope == TEXT { simple_tb_s } |> WHEN {
            True => scope_cpu_expansion_state
            False => active_scope == TEXT { none } |> WHEN {
                True => None
                False => Expanded
            }
        }

    active_scope_visible_signal_count:
        active_scope == TEXT { simple_tb_s } |> WHEN {
            True => scope_cpu_expansion_state == Expanded |> WHEN {
                True => TEXT { 2 visible }
                False => TEXT { 0 visible }
            }
            False => active_scope == TEXT { top_uart } |> WHEN {
                True => TEXT { 5 visible }
                False => active_scope == TEXT { top_analog } |> WHEN {
                    True => TEXT { 2 visible }
                    False => active_scope == TEXT { ghw_simple } |> WHEN {
                        True => TEXT { 4 visible }
                        False => TEXT { 0 visible }
                    }
                }
            }
        }

    data_signal_toggle_state:
        TEXT { Off } |> HOLD data_signal_toggle_state {
            LATEST {
                elements.select_data.event.press |> THEN {
                    data_signal_toggle_state |> WHEN {
                        On => TEXT { Off }
                        Off => TEXT { On }
                        __ => TEXT { On }
                    }
                }
                elements.select_clk.event.press |> THEN { TEXT { Off } }
                elements.select_reset.event.press |> THEN { TEXT { Off } }
                elements.select_temperature.event.press |> THEN { TEXT { Off } }
                elements.load_default_file.event.press |> THEN { TEXT { Off } }
                elements.show_empty.event.press |> THEN { TEXT { Off } }
            }
        }

    active_signal_key:
        TEXT { A_SIGNAL } |> HOLD active_signal_key {
            LATEST {
                signal_catalog
                    |> List/map(signal_catalog_item, new:
                        signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN {
                            signal_catalog_item.key |> WHEN {
                                clk => TEXT { A_SIGNAL }
                                reset_n => TEXT { B_SIGNAL }
                                data_bus => TEXT { DATA_BUS }
                                temperature => TEXT { TEMPERATURE }
                                __ => SKIP
                            }
                        }
                    )
                    |> List/latest()
                elements.select_clk.event.press |> THEN { TEXT { A_SIGNAL } }
                elements.select_reset.event.press |> THEN { TEXT { B_SIGNAL } }
                elements.select_data.event.press |> THEN {
                    active_signal_key |> WHEN {
                        DATA_BUS => TEXT { NONE }
                        __ => TEXT { DATA_BUS }
                    }
                }
                elements.select_temperature.event.press |> THEN { TEXT { TEMPERATURE } }
                elements.select_counter_file.event.press |> THEN { TEXT { A_SIGNAL } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TX_DATA } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_COUNTER } }
                elements.load_default_file.event.press |> THEN { TEXT { A_SIGNAL } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    format_label:
        NovyModel/format_label(format: active_signal_format)

    data_bus_rendered_value:
        NovyModel/selected_data_value_at_cursor(format: data_bus_row_format, cursor: cursor_position)

    temperature_rendered_value:
        NovyModel/selected_temperature_value_at_cursor(format: active_signal_format, cursor: cursor_position)

    row_height:
        NovyModel/row_height(size: row_size)

    bridge_request_fingerprint:
        bridge_request_descriptor_label

    bridge_request_page:
        bridge_request_compact_label

    bridge_response_scope:
        TEXT { SIMPLE_TB_S } |> HOLD bridge_response_scope {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { SIMPLE_TB_S } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TOP_UART } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_SIMPLE } }
                elements.scope_cpu.event.press |> THEN { TEXT { SIMPLE_TB_S } }
                elements.scope_uart.event.press |> THEN { TEXT { TOP_UART } }
                elements.scope_analog.event.press |> THEN { TEXT { TOP_ANALOG } }
                elements.stale_response_probe.event.press |> THEN { TEXT { SIMPLE_TB_S } }
                elements.load_default_file.event.press |> THEN { TEXT { SIMPLE_TB_S } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_signal:
        TEXT { A_SIGNAL } |> HOLD bridge_response_signal {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { A_SIGNAL } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TX_DATA } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_COUNTER } }
                elements.select_clk.event.press |> THEN { TEXT { A_SIGNAL } }
                elements.select_reset.event.press |> THEN { TEXT { B_SIGNAL } }
                elements.select_data.event.press |> THEN { TEXT { DATA_BUS } }
                elements.select_temperature.event.press |> THEN { TEXT { TEMPERATURE } }
                elements.stale_response_probe.event.press |> THEN { TEXT { A_SIGNAL } }
                elements.load_default_file.event.press |> THEN { TEXT { A_SIGNAL } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_zoom:
        Fit |> HOLD bridge_response_zoom {
            LATEST {
                elements.select_counter_file.event.press |> THEN { Fit }
                elements.select_uart_compare_file.event.press |> THEN { Fit }
                elements.select_ghw_file.event.press |> THEN { Fit }
                elements.zoom_in.event.press |> THEN { Close }
                elements.zoom_out.event.press |> THEN { Wide }
                elements.zoom_reset.event.press |> THEN { Fit }
                elements.cursor_left.event.press |> THEN { Close }
                elements.stale_response_probe.event.press |> THEN { Fit }
                elements.load_default_file.event.press |> THEN { Fit }
                elements.show_empty.event.press |> THEN { None }
            }
        }

    bridge_response_pan:
        Center |> HOLD bridge_response_pan {
            LATEST {
                elements.select_counter_file.event.press |> THEN { Center }
                elements.select_uart_compare_file.event.press |> THEN { Center }
                elements.select_ghw_file.event.press |> THEN { Center }
                elements.pan_left.event.press |> THEN { LeftWindow }
                elements.pan_right.event.press |> THEN { RightWindow }
                elements.zoom_reset.event.press |> THEN { Center }
                elements.cursor_left.event.press |> THEN { RightWindow }
                elements.stale_response_probe.event.press |> THEN { Center }
                elements.load_default_file.event.press |> THEN { Center }
                elements.show_empty.event.press |> THEN { None }
            }
        }

    bridge_response_window_key:
        selected_timeline_metadata_file
        |> Text/concat(with: bridge_response_zoom, separator: "|")
        |> Text/concat(with: bridge_response_pan, separator: "|")

    bridge_response_viewport_duration:
        bridge_response_zoom |> WHEN {
            Widest => viewport_range_span_value
            Wide => viewport_range_span_value
            Fit => viewport_initial_span_value
            Close => Number/max(left: viewport_close_unit_value * 3, right: 1)
            Closer => Number/max(left: viewport_closer_unit_value * 4, right: 1)
            Closest => Number/max(left: viewport_closer_unit_value, right: 1)
            __ => viewport_initial_span_value
        }

    bridge_response_viewport_anchor_center:
        bridge_response_pan |> WHEN {
            LeftWindow => selected_timeline_zoom_center_number - bridge_response_viewport_duration / 2
            RightWindow => selected_timeline_zoom_center_number + bridge_response_viewport_duration / 2
            __ => selected_timeline_zoom_center_number
        }

    bridge_response_viewport_desired_start:
        bridge_response_viewport_anchor_center - bridge_response_viewport_duration / 2

    bridge_response_window_start:
        Number/max(left: selected_timeline_range_start, right: Number/min(left: bridge_response_viewport_desired_start, right: selected_timeline_range_end - bridge_response_viewport_duration))

    bridge_response_window_end:
        Number/min(left: selected_timeline_range_end, right: bridge_response_window_start + bridge_response_viewport_duration)

    bridge_response_cursor:
        Cursor42 |> HOLD bridge_response_cursor {
            LATEST {
                elements.select_counter_file.event.press |> THEN { Cursor42 }
                elements.select_uart_compare_file.event.press |> THEN { Cursor42 }
                elements.select_ghw_file.event.press |> THEN { Cursor42 }
                elements.cursor_left.event.press |> THEN { Cursor36 }
                elements.cursor_right.event.press |> THEN { Cursor48 }
                elements.stale_response_probe.event.press |> THEN { Cursor42 }
                elements.load_default_file.event.press |> THEN { Cursor42 }
                elements.show_empty.event.press |> THEN { None }
            }
        }

    bridge_response_format:
        Hexadecimal |> HOLD bridge_response_format {
            LATEST {
                elements.select_counter_file.event.press |> THEN { Hexadecimal }
                elements.select_uart_compare_file.event.press |> THEN { Hexadecimal }
                elements.select_ghw_file.event.press |> THEN { Hexadecimal }
                elements.format_cycle.event.press |> THEN { NovyModel/next_format(format: bridge_response_format) }
                elements.stale_response_probe.event.press |> THEN { Hexadecimal }
                elements.load_default_file.event.press |> THEN { Hexadecimal }
                elements.show_empty.event.press |> THEN { None }
            }
        }

    bridge_response_window_label:
        active_signal_key == TEXT { NONE } |> WHEN {
            True => TEXT { no response window }
            False => bridge_response_window_start |> Text/time_range_label(end: bridge_response_window_end, unit: selected_timeline_time_unit)
        }

    bridge_request_window_label:
        active_signal_key == TEXT { NONE } |> WHEN {
            True => TEXT { no request window }
            False => keyboard_viewport_label
        }

    bridge_request_structural_key:
        bridge_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { no-request }
            False =>
                bridge_file_digest
                |> Text/concat(with: bridge_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_request_descriptor_label, separator: "|")
                |> Text/concat(with: bridge_request_window_label, separator: "|")
        }

    bridge_response_file_digest:
        TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } |> HOLD bridge_response_file_digest {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { sha256:aa4a6993101ff31601e12d613b746d8753f20448d78e8b720f708403047dc172 } }
                elements.select_ghw_file.event.press |> THEN { TEXT { sha256:3485b4b9a423ce61e54a9bd4a2c525cf7576f0e36d39ad73b208c2e38e980491 } }
                elements.cursor_left.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.stale_response_probe.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.load_default_file.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.external_file_loaded_digest.text
                elements.show_empty.event.press |> THEN { TEXT { sha256:none } }
            }
        }

    bridge_response_waveform_ref:
        TEXT { wave:vcd:simple:0-250s } |> HOLD bridge_response_waveform_ref {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { wave:fst:wave-27:0-240ns } }
                elements.select_ghw_file.event.press |> THEN { TEXT { wave:ghw:simple-test:0-100ns } }
                elements.cursor_left.event.press |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.stale_response_probe.event.press |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.load_default_file.event.press |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.external_file_loaded_waveform_ref.text
                elements.show_empty.event.press |> THEN { TEXT { wave:none } }
            }
        }

    bridge_response_structural_key:
        bridge_response_descriptor_label == TEXT { No response available } |> WHEN {
            True => TEXT { no-request }
            False =>
                bridge_response_file_digest
                |> Text/concat(with: bridge_response_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_response_descriptor_label, separator: "|")
                |> Text/concat(with: bridge_response_window_label, separator: "|")
        }

    bridge_response_fingerprint:
        bridge_response_descriptor_label

    bridge_response_page:
        bridge_response_compact_label

    bridge_request_descriptor_label:
        NovyModel/descriptor_label(scope: active_scope_key, signal: active_signal_key, zoom: zoom_level, pan: pan_window, cursor: cursor_position, format: active_signal_format)

    bridge_response_descriptor_label:
        TEXT { SIMPLE_TB_S/A_SIGNAL/Fit/Center/Cursor42/Hexadecimal } |> HOLD bridge_response_descriptor_label {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { SIMPLE_TB_S/A_SIGNAL/Fit/Center/Cursor42/Hexadecimal } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } }
                elements.cursor_left.event.press |> THEN { TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } }
                elements.stale_response_probe.event.press |> THEN { TEXT { SIMPLE_TB_S/A_SIGNAL/Fit/Center/Cursor42/Hexadecimal } }
                elements.load_default_file.event.press |> THEN { TEXT { SIMPLE_TB_S/A_SIGNAL/Fit/Center/Cursor42/Hexadecimal } }
                elements.show_empty.event.press |> THEN { TEXT { No response available } }
            }
        }

    bridge_request_descriptor:
        [
            page: bridge_request_page
            descriptor: bridge_request_descriptor_label
            fingerprint: bridge_request_fingerprint
            identity: [
                module: TEXT { wellen.v1 }
                file_digest: bridge_file_digest
                waveform_ref: bridge_waveform_ref
                selected_file: selected_variable_file
                timeline_metadata_file: selected_timeline_metadata_file
                metadata_source: selected_timeline_metadata_source
                range_source: selected_timeline_range_source
                time_unit: selected_timeline_time_unit
                timescale: selected_timeline_timescale
                file_range: selected_timeline_full_range
                scope: active_scope_key
                signal: active_signal_key
                zoom: zoom_level
                pan: pan_window
                cursor: cursor_label
                format: active_signal_format
                window: bridge_request_window_label
            ]
            window: bridge_page_window_label
            hierarchy_cursor: bridge_hierarchy_page_cursor_label
            payload_limit_bytes: bridge_payload_limit_bytes
            transition_limit: bridge_transition_limit
            visible_row_limit: bridge_visible_row_limit
            segment_limit: bridge_segment_limit
            materialization: bridge_materialization_bound_label
        ]

    bridge_response_descriptor:
        [
            page: bridge_response_page
            descriptor: bridge_response_descriptor_label
            fingerprint: bridge_response_fingerprint
            identity: [
                module: TEXT { wellen.v1 }
                file_digest: bridge_response_file_digest
                waveform_ref: bridge_response_waveform_ref
                timeline_metadata_file: selected_timeline_metadata_file
                metadata_source: selected_timeline_metadata_source
                range_source: selected_timeline_range_source
                time_unit: selected_timeline_time_unit
                timescale: selected_timeline_timescale
                file_range: selected_timeline_full_range
                scope: bridge_descriptor_scope_label(descriptor: bridge_response_descriptor_label)
                signal: bridge_descriptor_signal_label(descriptor: bridge_response_descriptor_label)
                zoom: bridge_descriptor_zoom_label(descriptor: bridge_response_descriptor_label)
                pan: bridge_descriptor_pan_label(descriptor: bridge_response_descriptor_label)
                cursor: bridge_descriptor_cursor_label(descriptor: bridge_response_descriptor_label)
                format: bridge_descriptor_format_label(descriptor: bridge_response_descriptor_label)
                window: bridge_descriptor_window_label(descriptor: bridge_response_descriptor_label)
            ]
            payload_limit_bytes: bridge_payload_limit_bytes
            transition_limit: bridge_transition_limit
            visible_row_limit: bridge_visible_row_limit
            segment_limit: bridge_segment_limit
        ]

    bridge_signal_page_label:
        bridge_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { no-request }
            False => bridge_request_descriptor_label
        }

    bridge_cursor_values_label:
        selected_cursor_pair_rows
        |> List/join_field(field: "label", separator: " ", empty: "unavailable")
        |> Text/concat(with: keyboard_cursor_label, separator: " at ")

    bridge_open_descriptor:
        [
            module: TEXT { wellen.v1 }
            provider: NovyBridge/provider_version()
            schema: NovyBridge/schema_version()
            export: TEXT { open }
            file: bridge_descriptor_file
            format: bridge_file_format
            digest: bridge_file_digest
            waveform_ref: bridge_waveform_ref
            metadata_file: active_metadata_file
            metadata_source: active_metadata_source
            range_source: active_metadata_range_source
            time_unit: active_metadata_time_unit
            timescale: active_metadata_timescale
            file_range: active_metadata_full_range
            status: bridge_open_status
            policy: NovyBridge/data_policy_label()
        ]

    bridge_request_label:
        bridge_request_fingerprint

    bridge_request_compact_label_raw:
        TEXT { A_FIT } |> HOLD bridge_request_compact_label_raw {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { A_FIT } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { CMP_UART } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_MAIN } }
                elements.select_clk.event.press |> THEN { TEXT { A_FIT } }
                elements.select_reset.event.press |> THEN { TEXT { B_FIT } }
                elements.select_data.event.press |> THEN {
                    data_signal_toggle_state |> WHEN {
                        On => TEXT { DATA_FIT }
                        Off => TEXT { NONE }
                    }
                }
                elements.select_temperature.event.press |> THEN { TEXT { TEMP_FIT } }
                signal_catalog
                    |> List/map(signal_catalog_item, new:
                        signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN {
                            signal_catalog_item.key |> WHEN {
                                clk => TEXT { A_FIT }
                                reset_n => TEXT { B_FIT }
                                data_bus => TEXT { DATA_FIT }
                                temperature => TEXT { TEMP_FIT }
                                __ => SKIP
                            }
                        }
                    )
                    |> List/latest()
                elements.format_cycle.event.press |> THEN { TEXT { DATA_BIN } }
                elements.format_binary.event.press |> THEN { TEXT { DATA_BIN } }
                elements.format_hex.event.press |> THEN { TEXT { DATA_HEX } }
                elements.format_grouped.event.press |> THEN { TEXT { DATA_GROUP } }
                elements.format_octal.event.press |> THEN { TEXT { DATA_OCT } }
                elements.format_signed.event.press |> THEN { TEXT { DATA_SGN } }
                elements.format_unsigned.event.press |> THEN { TEXT { DATA_UNS } }
                elements.format_ascii.event.press |> THEN { TEXT { DATA_ASC } }
                elements.zoom_in.event.press |> THEN { TEXT { DATA_CLOSE } }
                elements.zoom_out.event.press |> THEN { TEXT { DATA_WIDE } }
                elements.zoom_reset.event.press |> THEN { TEXT { DATA_FIT } }
                elements.pan_right.event.press |> THEN { TEXT { DATA_RIGHT } }
                elements.cursor_left.event.press |> THEN { TEXT { DATA_36NS } }
                elements.cursor_right.event.press |> THEN { TEXT { DATA_48NS } }
                elements.keyboard_capture.key |> WHEN {
                    W => TEXT { DATA_CLOSE }
                    S => TEXT { DATA_WIDE }
                    R => TEXT { DATA_FIT }
                    Q => TEXT { DATA_36NS }
                    E => TEXT { DATA_48NS }
                    D => TEXT { DATA_RIGHT }
                    A => TEXT { DATA_LEFT }
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { TEXT { A_FIT } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_request_compact_label:
        NovyModel/request_page(compact: bridge_request_compact_label_raw, format: active_signal_format, zoom: zoom_level)

    bridge_response_compact_label:
        TEXT { A_FIT } |> HOLD bridge_response_compact_label {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { A_FIT } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { CMP_UART } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_MAIN } }
                elements.cursor_left.event.press |> THEN { TEXT { A_0S } }
                elements.keyboard_capture.key |> WHEN {
                    D => TEXT { A_FIT }
                    Q => TEXT { A_0S }
                    S => TEXT { A_0S }
                    W => TEXT { A_0S }
                    R => TEXT { A_FIT }
                    E => TEXT { A_150S }
                    A => TEXT { A_0S }
                    __ => SKIP
                }
                elements.stale_response_probe.event.press |> THEN { TEXT { A_FIT } }
                elements.load_default_file.event.press |> THEN { TEXT { A_FIT } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_status:
        bridge_page_match_status(request: bridge_request_structural_key, response: bridge_response_structural_key)

    bridge_response_status_compact_label:
        bridge_page_match_compact_label(request: bridge_request_structural_key, response: bridge_response_structural_key)

    stale_response_policy: TEXT { canonical structural request equality required }
    bridge_contract: TEXT { wellen.v1 pure-data contract draft: open, hierarchy_page, signal_page, cursor_values, file_stats }
    bridge_provider_version: TEXT { planned official wellen 0.24.x provider }
    bridge_schema_version: TEXT { wellen.v1 waveform schema; real file hashes in descriptors }
    bridge_effect_exports: TEXT { open/hierarchy/signal/cursor/stats }
    bridge_data_policy: TEXT { comparable descriptors only; no Rust handles }
]

FUNCTION bridge_page_match_status(request, response) {
    request == TEXT { no-request } |> WHEN {
        True => TEXT { NOT_REQUESTED }
        False => request == response |> WHEN {
            True => TEXT { ACCEPTED_CURRENT_PAGE }
            False => TEXT { REJECTED_STALE_PAGE }
        }
    }
}

FUNCTION bridge_page_match_compact_label(request, response) {
    request == TEXT { no-request } |> WHEN {
        True => TEXT { NONE }
        False => request == response |> WHEN {
            True => TEXT { CURRENT }
            False => TEXT { STALE }
        }
    }
}

FUNCTION bridge_descriptor_scope_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } => TEXT { TOP_UART }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { GHW_SIMPLE }
        TEXT { No response available } => TEXT { NONE }
        __ => TEXT { SIMPLE_TB_S }
    }
}

FUNCTION bridge_descriptor_signal_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } => TEXT { TX_DATA }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { GHW_COUNTER }
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => TEXT { A_SIGNAL }
        TEXT { No response available } => TEXT { NONE }
        __ => TEXT { A_SIGNAL }
    }
}

FUNCTION bridge_descriptor_zoom_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => Close
        TEXT { No response available } => None
        __ => Fit
    }
}

FUNCTION bridge_descriptor_pan_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => RightWindow
        TEXT { No response available } => None
        __ => Center
    }
}

FUNCTION bridge_descriptor_cursor_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => Cursor36
        TEXT { No response available } => None
        __ => Cursor42
    }
}

FUNCTION bridge_descriptor_format_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => Binary
        TEXT { No response available } => None
        __ => Hexadecimal
    }
}

FUNCTION bridge_descriptor_window_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => TEXT { 50 s - 150 s }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { 0 ns - 100 ns }
        TEXT { No response available } => TEXT { no response window }
        __ => TEXT { 0 s - 250 s }
    }
}

FUNCTION new_signal(signal) {
    [
        signal_elements: [
            select_signal: SOURCE
            alias_input: SOURCE
        ]
        row_elements: [
            remove_signal: SOURCE
        ]
        key: signal.key
        scope: signal.scope
        name: signal.name
        kind: signal.kind
        bit_width: signal.bit_width
        direction: signal.direction
        family: signal.family
        selected_initial: signal.selected_initial
        selected_once:
            signal.selected_initial |> HOLD selected_once {
                LATEST {
                    signal_elements.select_signal.event.press |> THEN { True }
                    row_elements.remove_signal.event.press |> THEN { False }
                    elements.select_clk.event.press |> THEN { signal.key == TEXT { clk } |> WHEN { True => True False => selected_once } }
                    elements.select_reset.event.press |> THEN { signal.key == TEXT { reset_n } |> WHEN { True => True False => selected_once } }
                    elements.select_data.event.press |> THEN { signal.key == TEXT { data_bus } |> WHEN { True => True False => selected_once } }
                    elements.select_temperature.event.press |> THEN { signal.key == TEXT { temperature } |> WHEN { True => True False => selected_once } }
                    elements.selected_remove_clk.event.press |> THEN { signal.key == TEXT { clk } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_reset.event.press |> THEN { signal.key == TEXT { reset_n } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_data.event.press |> THEN { signal.key == TEXT { data_bus } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_data_valid.event.press |> THEN { signal.key == TEXT { data_valid } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_data_ready.event.press |> THEN { signal.key == TEXT { data_ready } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_state.event.press |> THEN { signal.key == TEXT { state } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_error_count.event.press |> THEN { signal.key == TEXT { error_count } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_temperature.event.press |> THEN { signal.key == TEXT { temperature } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_tx_data.event.press |> THEN { signal.key == TEXT { tx_data } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_rx_data.event.press |> THEN { signal.key == TEXT { rx_data } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_baud_tick.event.press |> THEN { signal.key == TEXT { baud_tick } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_uart_busy.event.press |> THEN { signal.key == TEXT { uart_busy } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_ghw_counter.event.press |> THEN { signal.key == TEXT { ghw_counter } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_ghw_enable.event.press |> THEN { signal.key == TEXT { ghw_enable } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_ghw_state.event.press |> THEN { signal.key == TEXT { ghw_state } |> WHEN { True => False False => selected_once } }
                    selected_signal_defaults
                        |> List/filter_field_equal(field: "item_kind", value: VariableRow)
                        |> List/map(selected_signal, new:
                            selected_signal.row_elements.remove_signal.event.press
                                |> THEN {
                                    selected_signal.id == signal.key |> WHEN {
                                        True => selected_signal.family == signal.family |> WHEN {
                                            True => False
                                            False => selected_once
                                        }
                                        False => selected_once
                                    }
                                }
                        )
                        |> List/latest()
                    elements.selected_clear_all.event.press |> THEN { False }
                    elements.selected_restore_data.event.press |> THEN { signal.selected_initial }
                    elements.select_counter_file.event.press |> THEN { signal.selected_initial }
                    elements.select_uart_compare_file.event.press |> THEN { signal.selected_initial }
                    elements.select_ghw_file.event.press |> THEN { signal.selected_initial }
                    elements.load_default_file.event.press |> THEN { signal.selected_initial }
                    elements.show_empty.event.press |> THEN { False }
                }
            }
        alias:
            Text/empty() |> HOLD alias {
                LATEST {
                    signal_elements.alias_input.text
                }
            }
    ]
}

FUNCTION new_selected_visible_item(row) {
    row.item_kind |> WHEN {
        VariableRow => new_selected_signal(selected_signal: row)
        __ => row
    }
}

FUNCTION selected_row_is_visible(row) {
    row.item_kind |> WHEN {
        GroupHeader => store.signal_catalog |> List/any(signal, if: signal.family == row.family |> Bool/and(signal.selected_once))
        VariableRow => store.signal_catalog |> List/any(signal, if: signal.key == row.id |> Bool/and(signal.selected_once))
        __ => True
    }
}

FUNCTION new_selected_signal(selected_signal) {
    [
        row_elements: [
            remove_signal: SOURCE
        ]
        format_elements: [
            format_dropdown_toggle: SOURCE
            format_binary: SOURCE
            format_hex: SOURCE
            format_grouped: SOURCE
            format_octal: SOURCE
            format_signed: SOURCE
            format_unsigned: SOURCE
            format_ascii: SOURCE
        ]
        family: selected_signal.family
        file: selected_signal.file
        id: selected_signal.id
        remove_kind: selected_signal.remove_kind
        name: selected_signal.name
        bit_width: selected_signal.bit_width
        kind: selected_signal.kind
        enabled: selected_signal.enabled
        item_kind: selected_signal.item_kind
        grouped: selected_signal.grouped
        hidden_when_group: selected_signal.hidden_when_group
        member_count_label: selected_signal.member_count_label
        row_count_label: selected_signal.row_count_label
        divider_height_after: selected_signal.divider_height_after
        formatter:
            selected_signal.formatter |> HOLD formatter {
                LATEST {
                    format_elements.format_binary.event.press |> THEN { Binary }
                    format_elements.format_hex.event.press |> THEN { Hexadecimal }
                    format_elements.format_grouped.event.press |> THEN { GroupedBinary }
                    format_elements.format_octal.event.press |> THEN { Octal }
                    format_elements.format_signed.event.press |> THEN { Signed }
                    format_elements.format_unsigned.event.press |> THEN { Unsigned }
                    format_elements.format_ascii.event.press |> THEN { ASCII }
                    elements.load_default_file.event.press |> THEN { selected_signal.formatter }
                    elements.show_empty.event.press |> THEN { selected_signal.formatter }
                }
            }
        format_label:
            NovyModel/format_short_label(format: formatter)
        format_dropdown_state:
            Closed |> HOLD format_dropdown_state {
                LATEST {
                    format_elements.format_dropdown_toggle.event.press |> THEN {
                        format_dropdown_state |> WHEN {
                            Open => Closed
                            __ => Open
                        }
                    }
                    format_elements.format_binary.event.press |> THEN { Closed }
                    format_elements.format_hex.event.press |> THEN { Closed }
                    format_elements.format_grouped.event.press |> THEN { Closed }
                    format_elements.format_octal.event.press |> THEN { Closed }
                    format_elements.format_signed.event.press |> THEN { Closed }
                    format_elements.format_unsigned.event.press |> THEN { Closed }
                    format_elements.format_ascii.event.press |> THEN { Closed }
                    elements.load_default_file.event.press |> THEN { Closed }
                    elements.show_empty.event.press |> THEN { Closed }
                }
            }
        current_value:
            selected_cursor_value_for_signal(signal: selected_signal, format: formatter)
    ]
}

FUNCTION selected_cursor_value_for_signal(signal, format) {
    store.waveform_segment_records
        |> List/filter_field_equal(field: "file", value: signal.file)
        |> List/filter_field_equal(field: "signal_id", value: signal.id)
        |> List/filter_field_not_equal(field: "state", value: CursorLine)
        |> List/filter_field_not_equal(field: "state", value: MarkerLine)
        |> List/retain(segment, if: segment.start_time_value <= store.selected_timeline_cursor_value)
        |> List/retain(segment, if: segment.end_time_value > store.selected_timeline_cursor_value)
        |> List/map(segment, new: [value: NovyModel/format_signal_value(value: segment.label, bit_width: signal.bit_width, format: format)])
        |> List/join_field(field: "value", separator: "", empty: NovyModel/format_signal_value(value: signal.current_value, bit_width: signal.bit_width, format: format))
}

FUNCTION selected_cursor_pair_row(signal) {
    [
        label: signal.name |> Text/concat(with: signal.current_value, separator: "=")
    ]
}

FUNCTION new_waveform_segment(segment) {
    [
        file: segment.file
        signal_id: segment.signal_id
        start_time_value: segment.start_time_value
        end_time_value: segment.end_time_value
        visible_start_time_value: Number/max(left: segment.start_time_value, right: store.viewport_label_start)
        visible_end_time_value: Number/min(left: segment.end_time_value, right: store.viewport_label_end)
        projection_source: RuntimeTimelineMetadata
        width: segment.file == store.active_file |> WHEN {
            True => segment.state |> WHEN {
                CursorLine => 0
                MarkerLine => 0
                __ => Number/project_width(start_time: Number/max(left: segment.start_time_value, right: store.viewport_label_start), end_time: Number/min(left: segment.end_time_value, right: store.viewport_label_end), viewport_start: store.viewport_label_start, viewport_end: store.viewport_label_end, canvas_width: store.selected_waveform_canvas_width, fallback: 0, zoom: store.waveform_projection_zoom_level)
            }
            __ => 0
        }
        state: segment.state
        raw_label: segment.label
        label: segment.label
        click_time: segment.click_time
    ]
}

FUNCTION waveform_segment_is_visible(segment) {
    segment.state |> WHEN {
        CursorLine => False
        MarkerLine => False
        __ => segment.end_time_value > store.viewport_label_start |> WHEN {
            True => segment.start_time_value < store.viewport_label_end
            False => False
        }
    }
}

FUNCTION new_marker(marker, store) {
    [
        marker_elements: [
            remove_marker: SOURCE
        ]
        label:
            marker.label
        has_label: True
    ]
}

FUNCTION new_signal_group(group, store) {
    [
        group_elements: [
            collapse_group: SOURCE
            expand_group: SOURCE
        ]
        name: group.name
        members_label: group.members_label
        collapsed:
            False |> HOLD collapsed {
                LATEST {
                    store.elements.group_toggle.event.press |> THEN { True }
                    store.elements.group_expand.event.press |> THEN { False }
                }
            }
        state_label:
            collapsed |> WHEN {
                True => Collapsed
                False => Expanded
            }
        row_count_label: TEXT { 4 grouped signals }
    ]
}

scene: NovyView/main_scene(PASS: [store: store])
