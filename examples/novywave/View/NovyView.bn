FUNCTION waveform_row(signal) {
    BLOCK {
        active: signal.id == PASSED.store.active_signal

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 0
                rounded_corners: 0
                background: [color: TEXT { #0b1220 }]
                border: [color: TEXT { #243449 }]
                material: active |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
                }
            ]
            items: LIST {
                signal_select_button(signal: signal)
                variables_name_divider()
                value_cell(signal: signal, value_text: signal.current_value)
                variables_value_divider()
                wave_area(signal: signal)
            }
        )
    }
}

FUNCTION selected_name_cell(signal) {
    signal_select_button(signal: signal)
}

FUNCTION selected_value_cell(signal) {
    value_cell(signal: signal, value_text: signal.current_value)
}

FUNCTION selected_wave_cell(signal) {
    selected_wave_area(signal: signal)
}

FUNCTION selected_wave_area(signal) {
    Scene/Element/block(
        element: [
            event: [
                key_down: PASSED.store.elements.keyboard_capture
            ]
            hovered: PASSED.store.elements.waveform_hover
        ]
        style: [
            width: Fill
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #020817 }]
            border: [color: TEXT { #1f2a3c }]
            glow: [color: TEXT { #3b82f62a }, intensity: 0.03]
        ]
        child: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 2
            style: [
                width: Fill
                height: Fill
                padding: [left: 8, right: 8]
                paint: False
            ]
            items: LIST {
                waveform_segment_lane(signal: signal)
            }
        )
    )
}

FUNCTION signal_select_button(signal) {
    Scene/Element/label(
        element: []
        style: [
            width: PASSED.store.selected_name_column_width
            height: Fill
            padding: [left: signal_name_left_padding(signal: signal), right: 8]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0A1322 }
                Light => TEXT { #FFFFFF }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #B8C8DF }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                selected_signal_remove_x_button(signal: signal)
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                        width: Fill
                        height: Fill
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: signal.name
                )
            }
        )
    )
}

FUNCTION selected_signal_remove_x_button(signal) {
    Scene/Element/button(
        element: [
            event: [press: signal.row_elements.remove_signal]
            hovered: signal.row_elements.remove_signal
        ]
        style: row_remove_button_style(hovered: element.hovered)
        label: row_remove_label()
        target: signal.name
        address: signal.id
    )
}

FUNCTION row_remove_button_style(hovered) {
    [
        width: 22
        height: 22
        rounded_corners: 4
        padding: 0
        background: [color: hovered |> WHEN {
            True => PASSED.store.mode |> WHEN {
                Dark => TEXT { #4b1f2d }
                Light => TEXT { #fee2e2 }
            }
            False => PASSED.store.mode |> WHEN {
                Dark => TEXT { #1a2434 }
                Light => TEXT { #f5f8fc }
            }
        }]
        border: [color: hovered |> WHEN {
            True => PASSED.store.mode |> WHEN {
                Dark => TEXT { #f87171 }
                Light => TEXT { #dc2626 }
            }
            False => PASSED.store.mode |> WHEN {
                Dark => TEXT { #344158 }
                Light => TEXT { #c9d7ea }
            }
        }]
        material: hovered |> WHEN {
            True => NovyTheme/material(mode: PASSED.store.mode, of: PressedControl)
            False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
        }
    ]
}

FUNCTION row_remove_label() {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: Fill
            height: Fill
            center: True
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #fca5a5 }
                Light => TEXT { #991b1b }
            }
        ]
        text: TEXT { x }
    )
}

