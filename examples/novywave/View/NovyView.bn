FUNCTION left_panel() {
    left_panel_base(panel_width: PASSED.store.files_panel_width, panel_height: Fill)
}

FUNCTION left_panel_docked() {
    left_panel_base(panel_width: Fill, panel_height: PASSED.store.files_panel_height)
}

FUNCTION left_panel_base(panel_width, panel_height) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 6
        style: [
            width: panel_width
            height: panel_height
            padding: 14
            depth: 10
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #304057 }
                Light => TEXT { #c9d7ea }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            files_panel_header()
            file_status_card()
            files_list()
        }
    )
}

FUNCTION files_panel_header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 28, paint: False]
        items: LIST {
            panel_title(title_text: TEXT { Files & Scopes })
            file_load_button()
            file_clear_all_button()
        }
    )
}

FUNCTION file_status_card() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 38
            padding: [left: 8, right: 8]
            rounded_corners: 7
            background: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.diagnostic_state == Unsupported |> WHEN {
                    True => TEXT { #422006 }
                    False => TEXT { #101a2b }
                }
                Light => PASSED.store.diagnostic_state == Unsupported |> WHEN {
                    True => TEXT { #fff7ed }
                    False => TEXT { #ffffff }
                }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.diagnostic_state == Unsupported |> WHEN {
                    True => TEXT { #f59e0b }
                    False => TEXT { #263753 }
                }
                Light => PASSED.store.diagnostic_state == Unsupported |> WHEN {
                    True => TEXT { #fb923c }
                    False => TEXT { #d7dde8 }
                }
            }]
            material: PASSED.store.diagnostic_state == Unsupported |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: Warning)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 1
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                file_status_text(line_text: PASSED.store.file_compare_status, line_height: 17)
                file_status_text(
                    line_text: PASSED.store.bridge_open_summary
                    line_height: 15
                )
            }
        )
    )
}

FUNCTION file_status_text(line_text, line_height) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: line_height
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #24364b }
            }
        ]
        text: line_text
    )
}

FUNCTION files_list() {
    PASSED.store.waveform_status |> WHEN {
        Empty => files_list_empty()
        __ => files_list_loaded()
    }
}

FUNCTION files_list_loaded() {
    PASSED.store.external_file_active == Yes |> WHEN {
        True => files_list_external_loaded()
        False => files_list_default_workspace()
    }
}

FUNCTION files_list_default_workspace() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [width: Fill, height: 224, paint: False, scroll_y: True, scrollbars: True]
        items: LIST {
            file_tree_counter_file_button(row: [label: TEXT { - simple.vcd }, indent_width: 0, selected_file: TEXT { simple.vcd }])
            file_tree_simple_scope_button(row: [scope_key: TEXT { simple_tb_s }, label: TEXT { + simple_tb.s }, expanded_label: TEXT { - simple_tb.s }, collapsed_label: TEXT { + simple_tb.s }, indent_width: 18])
            file_tree_uart_file_button(row: [label: TEXT { - wave_27.fst }, indent_width: 0, selected_file: TEXT { wave_27.fst }])
            file_tree_uart_scope_button(row: [scope_key: TEXT { top_uart }, label: TEXT { + top.uart }, indent_width: 18])
            file_tree_analog_scope_button(row: [scope_key: TEXT { top_analog }, label: TEXT { + top.analog }, indent_width: 18])
            file_tree_ghw_file_button(row: [label: TEXT { - simple_test.ghw }, indent_width: 0, selected_file: TEXT { simple_test.ghw }])
            file_tree_ghw_scope_button(row: [scope_key: TEXT { ghw_simple }, label: TEXT { - ghw.simple }, indent_width: 18])
        }
    )
}

FUNCTION files_list_external_loaded() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [width: Fill, height: 224, paint: False, scroll_y: True, scrollbars: True]
        items: LIST {
            file_tree_loaded_file_button(row: [label: PASSED.store.external_file_tree_label, indent_width: 0, selected_file: PASSED.store.active_file])
            PASSED.store.active_file == TEXT { simple.vcd } |> WHEN {
                True => file_tree_simple_scope_button(row: [scope_key: TEXT { simple_tb_s }, label: TEXT { + simple_tb.s }, expanded_label: TEXT { - simple_tb.s }, collapsed_label: TEXT { + simple_tb.s }, indent_width: 18])
                False => NoElement
            }
        }
    )
}

FUNCTION files_list_empty() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 224
            padding: 8
            rounded_corners: 7
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0b1220 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #90a4bf }
                    Light => TEXT { #60748b }
                }
            ]
            text: TEXT { No files loaded }
        )
    )
}

FUNCTION file_load_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.open_load_files_dialog]
            hovered: PASSED.store.elements.open_load_files_dialog
        ]
        style: compact_button_style(button_width: 92, hovered: element.hovered)
