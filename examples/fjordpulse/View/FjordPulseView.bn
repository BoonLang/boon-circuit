                    FjordPulseComponents/metric(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Forkastet utdaterte }, english: TEXT { Stale rejected }), value: TEXT { 1 }, status: Fresh)
                }
