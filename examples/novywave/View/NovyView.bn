FUNCTION selected_signal_remove_button(signal) {
    signal.remove_kind |> WHEN {
        RemoveClk => selected_signal_remove_clk_button()
        RemoveReset => selected_signal_remove_reset_button()
        RemoveData => selected_signal_remove_data_button()
        RemoveDataValid => selected_signal_remove_data_valid_button()
        RemoveDataReady => selected_signal_remove_data_ready_button()
        RemoveState => selected_signal_remove_state_button()
        RemoveErrorCount => selected_signal_remove_error_count_button()
        RemoveTemperature => selected_signal_remove_temperature_button()
        RemoveTxData => selected_signal_remove_tx_data_button()
        RemoveRxData => selected_signal_remove_rx_data_button()
        RemoveBaudTick => selected_signal_remove_baud_tick_button()
        RemoveUartBusy => selected_signal_remove_uart_busy_button()
        RemoveGhwCounter => selected_signal_remove_ghw_counter_button()
        RemoveGhwEnable => selected_signal_remove_ghw_enable_button()
        RemoveGhwState => selected_signal_remove_ghw_state_button()
        __ => selected_signal_remove_data_button()
    }
}

