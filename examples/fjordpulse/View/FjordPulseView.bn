                    FjordPulseComponents/metric(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Venter }, english: TEXT { Pending }), value: TEXT { 0 }, status: Ready)
                    FjordPulseComponents/metric(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Feil }, english: TEXT { Errors }), value: TEXT { 0 }, status: Ready)
