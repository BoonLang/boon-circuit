FUNCTION admin_session_content() {
    PASSED.store.admin_session_state |> WHEN {
        SignedOut => admin_login()
        __ => admin_resource()
    }
}

FUNCTION admin_login() {
    Scene/Element/block(
        element: []
        style: [width: Fill, height: Fill, padding: [top: 54, left: 34, right: 34], paint: False]
        child: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 12
            style: [...FjordPulseTheme/panel(), width: Fill, padding: 20]
            items: LIST {
                FjordPulseComponents/section_heading(
                    eyebrow: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { BESKYTTET DRIFTSFLATE }, english: TEXT { PROTECTED OPERATOR SURFACE })
                    title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Administratorinnlogging }, english: TEXT { Admin sign in })
                )
                FjordPulseComponents/text(value: FjordPulseModel/locale_text(
                    language: PASSED.store.language
                    norwegian: TEXT { Denne deterministiske skjelettflaten bruker en skrivebeskyttet fixture-operatør. }
                    english: TEXT { This deterministic skeleton uses a read-only fixture operator. }
                ))
                FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Brukernavn }, english: TEXT { Username }), value: TEXT { Fixture operator })
                FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Tilgang }, english: TEXT { Access }), value: TEXT { read-only })
                FjordPulseComponents/button(
                    label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Logg inn }, english: TEXT { Sign in })
                    selected: True
                    width: Fill
                ) |> SOURCE { PASSED.store.elements.admin.login }
            }
        )
    )
}

FUNCTION admin_resource() {
    PASSED.store.admin_resource_state |> WHEN {
        Fresh => admin_page_surface(stale: False)
        Stale => admin_page_surface(stale: True)
        Loading => admin_state_surface(
            status: Loading
            title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Laster administrasjonssiden }, english: TEXT { Loading Admin page })
            message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Den forrige siden beholdes ikke som fersk. }, english: TEXT { The prior page is not presented as fresh. })
            retry: False
        )
        Retrying => admin_state_surface(
            status: Retrying
            title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Prøver administrasjonssiden igjen }, english: TEXT { Retrying Admin page })
            message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Venter på et nytt skrivebeskyttet øyeblikksbilde. }, english: TEXT { Waiting for a new read-only snapshot. })
            retry: False
        )
        Empty => admin_state_surface(
            status: Empty
            title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Ingen rader på denne siden }, english: TEXT { No rows on this page })
            message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Forespørselen lyktes og returnerte en tom samling. }, english: TEXT { The request succeeded with an empty collection. })
            retry: True
        )
        Error => admin_state_surface(
            status: Error
            title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Administrasjonssiden er ikke tilgjengelig }, english: TEXT { Admin page unavailable })
            message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Den offentlige transportflaten påvirkes ikke. }, english: TEXT { The public transport surface is unaffected. })
            retry: True
        )
        __ => admin_page_surface(stale: False)
    }
}

FUNCTION admin_state_surface(status, title, message, retry) {
    Scene/Element/block(
        element: []
        style: [width: Fill, height: Fill, padding: [top: 28, left: 24, right: 24], paint: False]
        child: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 10
            style: [width: Fill, paint: False]
            items: LIST {
                FjordPulseComponents/state_message(status: status, title: title, message: message)
                retry |> WHEN {
                    True => FjordPulseComponents/button(
                        label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Prøv igjen }, english: TEXT { Retry })
                        selected: False
                        width: 180
                    ) |> SOURCE { PASSED.store.elements.admin.retry }
                    False => Scene/Element/text(element: [], style: [width: Fill, height: 0, paint: False], text: Text/empty())
                }
            }
        )
    )
}

FUNCTION admin_page_surface(stale) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 12
        style: [width: Fill, height: Fill, padding: [left: 22, right: 22, top: 16, bottom: 20], scroll_y: True, scrollbars: True, paint: False]
        items: LIST {
            stale |> WHEN {
                True => FjordPulseComponents/state_message(
                    status: Stale
                    title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Viser siste måling }, english: TEXT { Showing last measurement })
                    message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { En nyere diagnostikkmåling kunne ikke fullføres. }, english: TEXT { A newer diagnostics measurement could not complete. })
                )
                False => FjordPulseComponents/status_pill(
                    status: Fresh
                    label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Målt 10:00 Oslo }, english: TEXT { Measured 10:00 Oslo })
                )
            }
            admin_page_content()
        }
    )
}

FUNCTION admin_page_content() {
    PASSED.store.route |> WHEN {
        AdminStatus => admin_status_page()
        AdminInfrastructure => admin_infrastructure_page()
        AdminWatches => admin_watches_page()
        AdminEnturLog => admin_entur_page()
        AdminRealtime => admin_realtime_page()
        AdminEvents => admin_events_page()
        AdminDatabaseSchema => admin_database_schema_page()
        AdminDatabaseMigrations => admin_database_migrations_page()
        __ => admin_status_page()
    }
}

FUNCTION admin_status_page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [width: Fill, paint: False]
        items: LIST {
            FjordPulseComponents/section_heading(
                eyebrow: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { SYSTEMOVERSIKT }, english: TEXT { SYSTEM OVERVIEW })
                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Tjenestene er operative }, english: TEXT { Services are operational })
            )
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 8
                style: [width: Fill, paint: False]
                items: LIST {
                    FjordPulseComponents/metric(label: TEXT { Boon Server }, value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Klar }, english: TEXT { Ready }), status: Fresh)
                    FjordPulseComponents/metric(label: TEXT { redb }, value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Klar }, english: TEXT { Ready }), status: Fresh)
                    FjordPulseComponents/metric(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Sanntid }, english: TEXT { Realtime }), value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Fixture }, english: TEXT { Fixture }), status: Ready)
                }
            )
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Kjøringsmodus }, english: TEXT { Run mode }), value: TEXT { Deterministic })
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Byggreferanse }, english: TEXT { Build reference }), value: TEXT { dd6e750 · Boon slice })
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Beredskap }, english: TEXT { Readiness }), value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Klar for deterministiske scenarioer }, english: TEXT { Ready for deterministic scenarios }))
        }
    )
}

FUNCTION admin_infrastructure_page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 9
        style: [width: Fill, paint: False]
        items: LIST {
            FjordPulseComponents/section_heading(
                eyebrow: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { TOPOLOGI }, english: TEXT { TOPOLOGY })
                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Én Boon-serverprosess }, english: TEXT { One Boon Server process })
            )
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Klient }, english: TEXT { Client }), value: TEXT { Boon document · retained WebGPU })
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Server }, english: TEXT { Server }), value: TEXT { Boon Server · generic HTTP/WS host })
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Lagring }, english: TEXT { Storage }), value: TEXT { redb · single writer · durable volume })
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Utgående HTTP }, english: TEXT { Outbound HTTP }), value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Deaktivert i deterministisk modus }, english: TEXT { Disabled in deterministic mode }))
            FjordPulseComponents/state_message(
                status: Ready
                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Sannferdig topologi }, english: TEXT { Truthful topology })
                message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Denne visningen later ikke som SurrealDB, FrankenPHP eller AMPHP finnes i Boon-distribusjonen. }, english: TEXT { This view does not pretend SurrealDB, FrankenPHP, or AMPHP exist in the Boon deployment. })
            )
        }
    )
}

FUNCTION admin_watches_page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [width: Fill, paint: False]
        items: LIST {
            FjordPulseComponents/section_heading(
