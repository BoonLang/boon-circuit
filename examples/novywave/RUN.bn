            [signal_id: TEXT { tx_data }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { tx_data }, width: 48, state: Unknown, label: TEXT { idle }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { tx_data }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { tx_data }, width: 88, state: High, label: TEXT { 0x55 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { tx_data }, width: 72, state: Low, label: TEXT { gap }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { tx_data }, width: 104, state: High, label: TEXT { 0xa5 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { rx_data }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { rx_data }, width: 64, state: Low, label: TEXT { start }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { rx_data }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { rx_data }, width: 96, state: High, label: TEXT { 0xaa }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { rx_data }, width: 72, state: Low, label: TEXT { stop }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { rx_data }, width: 80, state: High, label: TEXT { idle }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { baud_tick }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { baud_tick }, width: 44, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { baud_tick }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { baud_tick }, width: 22, state: High, label: TEXT { tick }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { baud_tick }, width: 78, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { baud_tick }, width: 22, state: High, label: TEXT { tick }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { baud_tick }, width: 120, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { uart_busy }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { uart_busy }, width: 86, state: Low, label: TEXT { idle }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { uart_busy }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { uart_busy }, width: 156, state: High, label: TEXT { busy }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { uart_busy }, width: 92, state: Low, label: TEXT { idle }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { ghw_counter }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { ghw_counter }, width: 64, state: Unknown, label: TEXT { init }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { ghw_counter }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { ghw_counter }, width: 70, state: High, label: TEXT { 1 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { ghw_counter }, width: 70, state: High, label: TEXT { 2 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { ghw_counter }, width: 98, state: High, label: TEXT { 3 }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { ghw_enable }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { ghw_enable }, width: 72, state: Low, label: TEXT { 0 }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { ghw_enable }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { ghw_enable }, width: 216, state: High, label: TEXT { enable }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { ghw_state }, width: 0, state: CursorLine, label: TEXT { cursor }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { ghw_state }, width: 72, state: Unknown, label: TEXT { Reset }, click_time: TEXT { 36 ns }]
            [signal_id: TEXT { ghw_state }, width: 0, state: MarkerLine, label: TEXT { marker }, click_time: TEXT { 42 ns }]
            [signal_id: TEXT { ghw_state }, width: 184, state: High, label: TEXT { Count }, click_time: TEXT { 48 ns }]
            [signal_id: TEXT { ghw_state }, width: 72, state: Low, label: TEXT { Hold }, click_time: TEXT { 36 ns }]
        }
        |> List/map(segment, new: new_waveform_segment(segment: segment, store: store))

    active_waveform_segment_labels:
        selected_waveform_segments
        |> List/filter_field_equal(field: "signal_id", value: active_signal)
        |> List/join_field(field: "label", separator: ",", empty: "none")

    active_waveform_segment_count:
        selected_waveform_segments
        |> List/filter_field_equal(field: "signal_id", value: active_signal)
        |> List/length()

    selected_rows_enabled_value:
        waveform_status == TEXT { Loaded } |> WHEN {
            True => TEXT { loaded }
            False => TEXT { none }
        }

    selected_rows_profile:
        LATEST {
            TEXT { DefaultOrder }
            elements.selected_remove_data.event.press |> THEN { TEXT { WithoutData } }
            elements.selected_remove_clk.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_reset.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_data_valid.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_data_ready.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_state.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_error_count.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_temperature.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_tx_data.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_rx_data.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_baud_tick.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_uart_busy.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_ghw_counter.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_ghw_enable.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_remove_ghw_state.event.press |> THEN { TEXT { WithoutSelection } }
            elements.selected_restore_data.event.press |> THEN { TEXT { DefaultOrder } }
            elements.selected_data_up.event.press |> THEN { TEXT { DataFirst } }
            elements.selected_data_down.event.press |> THEN { TEXT { DataLast } }
            elements.select_counter_file.event.press |> THEN { TEXT { DefaultOrder } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { DefaultOrder } }
            elements.select_ghw_file.event.press |> THEN { TEXT { DefaultOrder } }
            elements.load_default_file.event.press |> THEN { TEXT { DefaultOrder } }
            elements.show_empty.event.press |> THEN { TEXT { Empty } }
        }

    selected_rows_removed_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_remove_data.event.press |> THEN { TEXT { data_bus } }
            elements.selected_remove_clk.event.press |> THEN { TEXT { clk } }
            elements.selected_remove_reset.event.press |> THEN { TEXT { reset_n } }
            elements.selected_remove_data_valid.event.press |> THEN { TEXT { data_valid } }
            elements.selected_remove_data_ready.event.press |> THEN { TEXT { data_ready } }
            elements.selected_remove_state.event.press |> THEN { TEXT { state } }
            elements.selected_remove_error_count.event.press |> THEN { TEXT { error_count } }
            elements.selected_remove_temperature.event.press |> THEN { TEXT { temperature } }
            elements.selected_remove_tx_data.event.press |> THEN { TEXT { tx_data } }
            elements.selected_remove_rx_data.event.press |> THEN { TEXT { rx_data } }
            elements.selected_remove_baud_tick.event.press |> THEN { TEXT { baud_tick } }
            elements.selected_remove_uart_busy.event.press |> THEN { TEXT { uart_busy } }
            elements.selected_remove_ghw_counter.event.press |> THEN { TEXT { ghw_counter } }
            elements.selected_remove_ghw_enable.event.press |> THEN { TEXT { ghw_enable } }
            elements.selected_remove_ghw_state.event.press |> THEN { TEXT { ghw_state } }
            elements.selected_restore_data.event.press |> THEN { TEXT { none } }
            elements.selected_data_up.event.press |> THEN { TEXT { none } }
            elements.selected_data_down.event.press |> THEN { TEXT { none } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    selected_rows_first_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_data_up.event.press |> THEN { TEXT { data_bus } }
            elements.selected_remove_data.event.press |> THEN { TEXT { none } }
            elements.selected_restore_data.event.press |> THEN { TEXT { none } }
            elements.selected_data_down.event.press |> THEN { TEXT { none } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    selected_rows_last_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_data_down.event.press |> THEN { TEXT { data_bus } }
            elements.selected_remove_data.event.press |> THEN { TEXT { none } }
            elements.selected_restore_data.event.press |> THEN { TEXT { none } }
            elements.selected_data_up.event.press |> THEN { TEXT { none } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    selected_signal_rows:
        selected_signal_defaults
        |> List/filter_field_equal(field: "family", value: selected_signal_family)
        |> List/filter_field_equal(field: "enabled", value: selected_rows_enabled_value)
        |> List/filter_field_not_equal(field: "id", value: selected_rows_removed_signal_id)
        |> List/move_field_first(field: "id", value: selected_rows_first_signal_id)
        |> List/move_field_last(field: "id", value: selected_rows_last_signal_id)

    selected_signals:
        selected_signal_rows

    data_bus_alias:
        List/find_value(signal_catalog, field: key, value: TEXT { data_bus }, target: alias, fallback: Text/empty())

    signal_search_text:
        Text/empty() |> HOLD signal_search_text {
            LATEST {
                elements.signal_search_input.text |> Text/trim()
            }
        }

    search_results:
        signal_catalog
        |> List/filter_text_contains(field: "name", needle: signal_search_text, prefer_field: "family", empty_field: "scope", empty_value: active_scope_label)

    variable_rows:
        List/chunk(search_results, size: 1, items: signals, label: row_number)

    search_results_count:
        search_results |> List/length()

    search_results_key_summary:
        search_results |> List/join_field(field: "key", separator: ",", empty: "none")

    search_results_name_summary:
        search_results |> List/join_field(field: "name", separator: ", ", empty: "none")

    focused_control_label:
        TEXT { none } |> HOLD focused_control_label {
            LATEST {
                elements.signal_search_focus_probe.event.click |> THEN { TEXT { signal search } }
                elements.scope_cpu.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_expand.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_collapse.event.press |> THEN { TEXT { none } }
                elements.scope_uart.event.press |> THEN { TEXT { none } }
                elements.scope_analog.event.press |> THEN { TEXT { none } }
                elements.select_counter_file.event.press |> THEN { TEXT { none } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
                elements.select_ghw_file.event.press |> THEN { TEXT { none } }
                elements.load_default_file.event.press |> THEN { TEXT { none } }
                elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    focused_control_material_label:
        focused_control_label == TEXT { signal search } |> WHEN {
            True => TEXT { FocusedControl }
            False => TEXT { RestingControl }
        }

    pressed_control_label:
        TEXT { none } |> HOLD pressed_control_label {
            LATEST {
                elements.diagnostic_probe.event.press |> THEN { TEXT { Probe } }
                elements.format_cycle.event.press |> THEN { TEXT { Fmt } }
                elements.format_dropdown_toggle.event.press |> THEN { TEXT { none } }
                elements.format_binary.event.press |> THEN { TEXT { none } }
                elements.format_hex.event.press |> THEN { TEXT { none } }
                elements.format_grouped.event.press |> THEN { TEXT { none } }
                elements.format_octal.event.press |> THEN { TEXT { none } }
                elements.format_signed.event.press |> THEN { TEXT { none } }
                elements.format_unsigned.event.press |> THEN { TEXT { none } }
                elements.format_ascii.event.press |> THEN { TEXT { none } }
                elements.mode_to_light.event.press |> THEN { TEXT { none } }
                elements.mode_to_dark.event.press |> THEN { TEXT { none } }
                elements.load_default_file.event.press |> THEN { TEXT { none } }
                elements.show_empty.event.press |> THEN { TEXT { none } }
                elements.signal_search_focus_probe.event.click |> THEN { TEXT { none } }
                elements.scope_cpu.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_expand.event.press |> THEN { TEXT { none } }
                elements.scope_cpu_collapse.event.press |> THEN { TEXT { none } }
                elements.scope_uart.event.press |> THEN { TEXT { none } }
                elements.scope_analog.event.press |> THEN { TEXT { none } }
                elements.select_counter_file.event.press |> THEN { TEXT { none } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
                elements.select_ghw_file.event.press |> THEN { TEXT { none } }
                elements.select_clk.event.press |> THEN { TEXT { none } }
                elements.select_reset.event.press |> THEN { TEXT { none } }
                elements.select_data.event.press |> THEN { TEXT { none } }
                elements.select_temperature.event.press |> THEN { TEXT { none } }
                elements.zoom_in.event.press |> THEN { TEXT { none } }
                elements.zoom_out.event.press |> THEN { TEXT { none } }
                elements.pan_left.event.press |> THEN { TEXT { none } }
                elements.pan_right.event.press |> THEN { TEXT { none } }
                elements.cursor_left.event.press |> THEN { TEXT { none } }
                elements.cursor_right.event.press |> THEN { TEXT { none } }
                elements.marker_toggle.event.press |> THEN { TEXT { none } }
                elements.marker_remove.event.press |> THEN { TEXT { none } }
                elements.group_create.event.press |> THEN { TEXT { none } }
                elements.group_toggle.event.press |> THEN { TEXT { none } }
                elements.group_expand.event.press |> THEN { TEXT { none } }
                elements.row_taller.event.press |> THEN { TEXT { none } }
                elements.row_shorter.event.press |> THEN { TEXT { none } }
            }
        }

    pressed_control_material_label:
        pressed_control_label == TEXT { none } |> WHEN {
            True => TEXT { RestingControl }
            False => TEXT { PressedControl }
        }

    format_dropdown_state:
        TEXT { Closed } |> HOLD format_dropdown_state {
            LATEST {
                elements.format_dropdown_toggle.event.press |> THEN {
                    format_dropdown_state |> WHEN {
                        Open => TEXT { Closed }
                        __ => TEXT { Open }
                    }
                }
                elements.format_cycle.event.press |> THEN { TEXT { Closed } }
                elements.format_binary.event.press |> THEN { TEXT { Closed } }
                elements.format_hex.event.press |> THEN { TEXT { Closed } }
                elements.format_grouped.event.press |> THEN { TEXT { Closed } }
                elements.format_octal.event.press |> THEN { TEXT { Closed } }
                elements.format_signed.event.press |> THEN { TEXT { Closed } }
                elements.format_unsigned.event.press |> THEN { TEXT { Closed } }
                elements.format_ascii.event.press |> THEN { TEXT { Closed } }
                elements.load_default_file.event.press |> THEN { TEXT { Closed } }
                elements.show_empty.event.press |> THEN { TEXT { Closed } }
                elements.select_counter_file.event.press |> THEN { TEXT { Closed } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { Closed } }
                elements.select_ghw_file.event.press |> THEN { TEXT { Closed } }
            }
        }

    search_result_label:
        signal_search_text |> Text/is_empty() |> WHEN {
            True =>
                search_results_count
                |> Text/concat(with: TEXT { results in }, separator: " ")
                |> Text/concat(with: active_scope_label, separator: " ")
            False => search_results_count == 1 |> WHEN {
                True =>
                    TEXT { 1 result: }
                    |> Text/concat(with: search_results_name_summary, separator: " ")
                False => search_results_count == 0 |> WHEN {
                    True =>
                        TEXT { 0 results: }
                        |> Text/concat(with: signal_search_text, separator: " ")
                    False => search_results_count > 12 |> WHEN {
                        True =>
                            search_results_count
                            |> Text/concat(with: TEXT { results: scroll variables list }, separator: " ")
                        False =>
                            search_results_count
                            |> Text/concat(with: TEXT { results: }, separator: " ")
                            |> Text/concat(with: search_results_name_summary, separator: " ")
                    }
                }
            }
        }

    search_scope_mode: TEXT { Global }

    keyboard_last_key:
        Text/empty() |> HOLD keyboard_last_key {
            LATEST {
                elements.keyboard_capture.key
                elements.load_default_file.event.press |> THEN { Text/empty() }
                elements.show_empty.event.press |> THEN { Text/empty() }
                elements.select_counter_file.event.press |> THEN { Text/empty() }
                elements.select_uart_compare_file.event.press |> THEN { Text/empty() }
                elements.select_ghw_file.event.press |> THEN { Text/empty() }
                elements.select_clk.event.press |> THEN { Text/empty() }
                elements.select_reset.event.press |> THEN { Text/empty() }
                elements.select_data.event.press |> THEN { Text/empty() }
                elements.select_temperature.event.press |> THEN { Text/empty() }
                elements.format_dropdown_toggle.event.press |> THEN { Text/empty() }
                elements.format_cycle.event.press |> THEN { Text/empty() }
                elements.format_binary.event.press |> THEN { Text/empty() }
                elements.format_hex.event.press |> THEN { Text/empty() }
                elements.format_grouped.event.press |> THEN { Text/empty() }
                elements.format_octal.event.press |> THEN { Text/empty() }
                elements.format_signed.event.press |> THEN { Text/empty() }
                elements.format_unsigned.event.press |> THEN { Text/empty() }
                elements.format_ascii.event.press |> THEN { Text/empty() }
            }
        }

    selected_group:
        LATEST {
            TEXT { None }
            elements.group_create.event.press |> THEN { TEXT { Expanded } }
            elements.group_toggle.event.press |> THEN { TEXT { Collapsed } }
            elements.group_expand.event.press |> THEN { TEXT { Expanded } }
            elements.load_default_file.event.press |> THEN { TEXT { Expanded } }
            elements.show_empty.event.press |> THEN { TEXT { None } }
        }

    group_creation_state:
        LATEST {
            TEXT { None }
            elements.group_create.event.press |> THEN { TEXT { Created } }
            elements.load_default_file.event.press |> THEN { TEXT { None } }
            elements.show_empty.event.press |> THEN { TEXT { None } }
        }

    group_name:
        LATEST {
            TEXT { No group }
            elements.group_create.event.press |> THEN { TEXT { Core bus group } }
            elements.load_default_file.event.press |> THEN { TEXT { No group } }
            elements.show_empty.event.press |> THEN { TEXT { No group } }
        }

    group_count_label:
        LATEST {
            TEXT { 0 groups }
            elements.group_create.event.press |> THEN { TEXT { 1 group } }
            elements.load_default_file.event.press |> THEN { TEXT { 0 groups } }
            elements.show_empty.event.press |> THEN { TEXT { 0 groups } }
        }

    group_members_label:
        LATEST {
            TEXT { none }
            elements.group_create.event.press |> THEN { TEXT { clk, reset_n, data_bus[7:0], temperature } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    group_status_label:
        LATEST {
            TEXT { no group }
            elements.group_create.event.press |> THEN { TEXT { 1 group } }
            elements.load_default_file.event.press |> THEN { TEXT { no group } }
            elements.show_empty.event.press |> THEN { TEXT { no group } }
        }

    group_to_create:
        LATEST {
            elements.group_create.event.press |> THEN { TEXT { Core bus group } }
        }

    groups:
        LIST {}
        |> List/append(item: group_to_create |> THEN {
            [
                name: group_to_create
                members_label: TEXT { clk, reset_n, data_bus[7:0], temperature }
            ]
        })
        |> List/map(group, new: new_signal_group(group: group, store: store))
        |> List/remove(group, when:
            LATEST {
                elements.load_default_file.event.press |> THEN { True }
                elements.show_empty.event.press |> THEN { True }
            }
        )

    selected_rows_count:
        selected_signal_rows |> List/length()

    selected_rows_order_label:
        selected_signal_rows |> List/join_field(field: "name", separator: ", ", empty: "none")

    selected_signal_count_label:
        selected_rows_count |> Text/concat(with: TEXT { selected }, separator: " ")

    analog_limit_kind:
        TEXT { Auto } |> HOLD analog_limit_kind {
            LATEST {
            elements.analog_limits_auto.event.press |> THEN { TEXT { Auto } }
            elements.analog_limits_manual.event.press |> THEN { TEXT { Manual } }
            elements.load_default_file.event.press |> THEN { TEXT { Auto } }
            }
        }

    analog_limit_validity:
        TEXT { Valid } |> HOLD analog_limit_validity {
            LATEST {
            elements.analog_limits_auto.event.press |> THEN { TEXT { Valid } }
            elements.analog_limits_manual.event.press |> THEN { TEXT { Valid } }
            elements.analog_limits_invalid.event.press |> THEN { TEXT { Rejected } }
            elements.load_default_file.event.press |> THEN { TEXT { Valid } }
            }
        }

    analog_limit_min:
        TEXT { 39 C } |> HOLD analog_limit_min {
            LATEST {
            elements.analog_limits_manual.event.press |> THEN { TEXT { -10 C } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { 39 C } }
            elements.zoom_in.event.press |> THEN { TEXT { 40 C } }
            elements.zoom_out.event.press |> THEN { TEXT { 38 C } }
            elements.pan_left.event.press |> THEN { TEXT { 39 C } }
            elements.pan_right.event.press |> THEN { TEXT { 40 C } }
            elements.load_default_file.event.press |> THEN { TEXT { 39 C } }
            }
        }

    analog_limit_max:
        TEXT { 44 C } |> HOLD analog_limit_max {
            LATEST {
            elements.analog_limits_manual.event.press |> THEN { TEXT { 80 C } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { 44 C } }
            elements.zoom_in.event.press |> THEN { TEXT { 43 C } }
            elements.zoom_out.event.press |> THEN { TEXT { 45 C } }
            elements.pan_left.event.press |> THEN { TEXT { 43 C } }
            elements.pan_right.event.press |> THEN { TEXT { 44 C } }
            elements.load_default_file.event.press |> THEN { TEXT { 44 C } }
            }
        }

    analog_range_label:
        TEXT { Auto 39 C .. 44 C } |> HOLD analog_range_label {
            LATEST {
            elements.analog_limits_manual.event.press |> THEN { TEXT { Manual -10 C .. 80 C } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { Auto 39 C .. 44 C } }
            elements.zoom_in.event.press |> THEN { TEXT { Auto 40 C .. 43 C } }
            elements.zoom_out.event.press |> THEN { TEXT { Auto 38 C .. 45 C } }
            elements.pan_left.event.press |> THEN { TEXT { Auto 39 C .. 43 C } }
            elements.pan_right.event.press |> THEN { TEXT { Auto 40 C .. 44 C } }
            elements.load_default_file.event.press |> THEN { TEXT { Auto 39 C .. 44 C } }
            }
        }

    analog_limit_error:
        TEXT { none } |> HOLD analog_limit_error {
            LATEST {
            elements.analog_limits_invalid.event.press |> THEN { TEXT { rejected min >= max } }
            elements.analog_limits_auto.event.press |> THEN { TEXT { none } }
            elements.analog_limits_manual.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            }
        }

    analog_limit_descriptor:
        [
            limit_kind: analog_limit_kind
            validity: analog_limit_validity
            min: analog_limit_min
            max: analog_limit_max
            visible_window: keyboard_viewport_label
            source: TEXT { Boon-visible analog limits }
        ]

    marker_visibility:
        TEXT { Visible } |> HOLD marker_visibility {
            LATEST {
            elements.marker_remove.event.press |> THEN { TEXT { Hidden } }
            elements.marker_toggle.event.press |> THEN { TEXT { Visible } }
            elements.waveform_click.text |> THEN { TEXT { Visible } }
            elements.load_default_file.event.press |> THEN { TEXT { Visible } }
            elements.show_empty.event.press |> THEN { TEXT { Hidden } }
            }
        }

    marker_current_label:
        TEXT { 42 ns } |> HOLD marker_current_label {
            LATEST {
            elements.marker_rename.event.press |> THEN { TEXT { data stable } }
            elements.marker_remove.event.press |> THEN { TEXT { No markers } }
            elements.marker_toggle.event.press |> THEN { TEXT { 36 ns } }
            elements.waveform_click.text
            elements.load_default_file.event.press |> THEN { TEXT { 42 ns } }
            elements.show_empty.event.press |> THEN { TEXT { No markers } }
            }
        }

    marker_state:
        Default |> HOLD marker_state {
            LATEST {
            elements.marker_rename.event.press |> THEN { Renamed }
            elements.marker_remove.event.press |> THEN { Empty }
            elements.marker_toggle.event.press |> THEN { Added }
            elements.waveform_click.text |> THEN { Added }
            elements.load_default_file.event.press |> THEN { Default }
            elements.show_empty.event.press |> THEN { Empty }
            }
        }

    marker_label:
        TEXT { M 42 ns } |> HOLD marker_label {
            LATEST {
            elements.marker_rename.event.press |> THEN { TEXT { M data stable } }
            elements.marker_remove.event.press |> THEN { TEXT { No markers } }
            elements.marker_jump.event.press |> THEN { marker_label }
            elements.marker_toggle.event.press |> THEN { TEXT { M 36 ns } }
            elements.waveform_click.text |> THEN {
                TEXT { M } |> Text/concat(with: elements.waveform_click.text, separator: " ")
            }
            elements.load_default_file.event.press |> THEN { TEXT { M 42 ns } }
            elements.show_empty.event.press |> THEN { TEXT { No markers } }
            }
        }

    marker_focus_label:
        TEXT { marker at 42 ns } |> HOLD marker_focus_label {
            LATEST {
            elements.marker_rename.event.press |> THEN { TEXT { data stable at 42 ns } }
            elements.marker_jump.event.press |> THEN {
                marker_state |> WHEN {
                    Renamed => TEXT { jumped to data stable at 42 ns }
                    Default => TEXT { jumped to 42 ns }
                    Added => TEXT { jumped to 36 ns }
                    __ => TEXT { jumped to 42 ns }
                }
            }
            elements.marker_remove.event.press |> THEN { TEXT { no marker selected } }
            elements.marker_toggle.event.press |> THEN { TEXT { added marker at 36 ns } }
            elements.waveform_click.text |> THEN {
                TEXT { added marker at } |> Text/concat(with: elements.waveform_click.text, separator: " ")
            }
            elements.load_default_file.event.press |> THEN { TEXT { marker at 42 ns } }
            elements.show_empty.event.press |> THEN { TEXT { no marker selected } }
            }
        }

    marker_default_label:
        TEXT { 42 ns }

    marker_to_add:
        LATEST {
            elements.marker_toggle.event.press |> THEN { TEXT { 36 ns } }
            elements.waveform_click.text
            elements.load_default_file.event.press |> THEN { TEXT { 42 ns } }
        }

    marker_add_from_toggle:
        LATEST {
            elements.marker_toggle.event.press |> THEN { TEXT { 36 ns } }
        }

    marker_add_from_waveform:
        LATEST {
            elements.waveform_click.text |> THEN { elements.waveform_click.text }
        }

    marker_add_from_load:
        LATEST {
            elements.load_default_file.event.press |> THEN { TEXT { 42 ns } }
        }

    markers:
        LIST {
            [label: TEXT { 42 ns }]
        }
        |> List/append(item: marker_add_from_toggle |> THEN {
            [label: marker_add_from_toggle]
        })
        |> List/append(item: marker_add_from_waveform |> THEN {
            [label: marker_add_from_waveform]
        })
        |> List/append(item: marker_add_from_load |> THEN {
            [label: marker_add_from_load]
        })
        |> List/map(marker, new: new_marker(marker: marker, store: store))
        |> List/remove(marker, when:
            LATEST {
                marker.marker_elements.remove_marker.event.press |> THEN { True }
                elements.marker_remove.event.press |> THEN { True }
                elements.show_empty.event.press |> THEN { True }
            }
        )

    active_marker_count:
        markers
        |> List/retain(marker, if: marker.has_label)
        |> List/count()

    marker_count_label:
        active_marker_count |> WHEN {
            0 => TEXT { 0 markers }
            1 => TEXT { 1 marker }
            __ => active_marker_count |> Text/concat(with: TEXT { markers }, separator: " ")
        }

    row_size:
        TEXT { Normal } |> HOLD row_size {
            LATEST {
                elements.row_taller.event.press |> THEN { TEXT { Tall } }
                elements.row_shorter.event.press |> THEN { TEXT { Compact } }
                elements.signal_row_resize_drag.text |> THEN {
                    elements.signal_row_resize_drag.text |> WHEN {
                        TEXT { Grow } => row_size |> WHEN {
                            TEXT { Compact } => TEXT { Normal }
                            __ => TEXT { Tall }
                        }
                        TEXT { Shrink } => row_size |> WHEN {
                            TEXT { Tall } => TEXT { Normal }
                            __ => TEXT { Compact }
                        }
                        __ => row_size
                    }
                }
            }
        }

    value_format:
        LATEST {
            TEXT { Hexadecimal }
            elements.format_cycle.event.press |> THEN { NovyModel/next_format(format: value_format) }
            elements.format_binary.event.press |> THEN { TEXT { Binary } }
            elements.format_hex.event.press |> THEN { TEXT { Hexadecimal } }
            elements.format_grouped.event.press |> THEN { TEXT { GroupedBinary } }
            elements.format_octal.event.press |> THEN { TEXT { Octal } }
            elements.format_signed.event.press |> THEN { TEXT { Signed } }
            elements.format_unsigned.event.press |> THEN { TEXT { Unsigned } }
            elements.format_ascii.event.press |> THEN { TEXT { ASCII } }
            elements.load_default_file.event.press |> THEN { TEXT { Hexadecimal } }
        }

    zoom_step:
        0 |> HOLD zoom_step {
            LATEST {
                elements.zoom_in.event.press |> THEN {
                    zoom_step >= 3 |> WHEN {
                        True => 3
                        False => zoom_step + 1
                    }
                }
                elements.zoom_out.event.press |> THEN {
                    zoom_step <= -2 |> WHEN {
                        True => -2
                        False => zoom_step - 1
                    }
                }
                elements.zoom_reset.event.press |> THEN { 0 }
                elements.keyboard_capture.key |> WHEN {
                    W => zoom_step >= 3 |> WHEN {
                        True => 3
                        False => zoom_step + 1
                    }
                    S => zoom_step <= -2 |> WHEN {
                        True => -2
                        False => zoom_step - 1
                    }
                    R => 0
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { 0 }
                elements.show_empty.event.press |> THEN { 0 }
            }
        }

    zoom_level:
        NovyModel/zoom_level_from_step(step: zoom_step)

    pan_window:
        TEXT { Center } |> HOLD pan_window {
            LATEST {
                elements.pan_left.event.press |> THEN { TEXT { LeftWindow } }
                elements.pan_right.event.press |> THEN { TEXT { RightWindow } }
                elements.zoom_reset.event.press |> THEN { TEXT { Center } }
                elements.keyboard_capture.key |> WHEN {
                    A => TEXT { LeftWindow }
                    D => TEXT { RightWindow }
                    R => TEXT { Center }
                    Q => TEXT { RightWindow }
                    E => TEXT { RightWindow }
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { TEXT { Center } }
                elements.show_empty.event.press |> THEN { TEXT { Center } }
            }
        }

    cursor_position:
        LATEST {
            TEXT { Cursor42 }
            elements.cursor_left.event.press |> THEN { TEXT { Cursor36 } }
            elements.cursor_right.event.press |> THEN { TEXT { Cursor48 } }
            elements.waveform_click.text |> THEN { NovyModel/cursor_from_label(label: elements.waveform_click.text) }
            elements.marker_jump.event.press |> THEN { TEXT { Cursor42 } }
            elements.zoom_reset.event.press |> THEN { TEXT { Cursor42 } }
            elements.keyboard_capture.key |> WHEN {
                D => TEXT { Cursor42 }
                Q => TEXT { Cursor36 }
                R => TEXT { Cursor42 }
                E => TEXT { Cursor48 }
                __ => SKIP
            }
            elements.load_default_file.event.press |> THEN { TEXT { Cursor42 } }
            elements.show_empty.event.press |> THEN { TEXT { Cursor42 } }
        }

    viewport_label:
        NovyModel/viewport_label(zoom: zoom_level, pan: pan_window)

    keyboard_viewport_label:
        NovyModel/viewport_label(zoom: zoom_level, pan: pan_window)

    cursor_label:
        NovyModel/cursor_label(cursor: cursor_position)

    keyboard_cursor_label:
        NovyModel/cursor_label(cursor: cursor_position)

    active_signal_label:
        TEXT { top.cpu.clk } |> HOLD active_signal_label {
            LATEST {
                signal_catalog
                    |> List/map(signal_catalog_item, new:
                        signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN {
                            signal_catalog_item.key |> WHEN {
                                clk => TEXT { top.cpu.clk }
                                reset_n => TEXT { top.cpu.reset_n }
                                data_bus => TEXT { top.cpu.data_bus[7:0] }
                                temperature => TEXT { top.analog.temperature }
                                __ => SKIP
                            }
                        }
                    )
                    |> List/latest()
                elements.select_clk.event.press |> THEN { TEXT { top.cpu.clk } }
                elements.select_reset.event.press |> THEN { TEXT { top.cpu.reset_n } }
                elements.select_data.event.press |> THEN {
                    active_signal_key |> WHEN {
                        DATA_BUS => TEXT { none }
                        __ => TEXT { top.cpu.data_bus[7:0] }
                    }
                }
                elements.select_temperature.event.press |> THEN { TEXT { top.analog.temperature } }
                elements.select_counter_file.event.press |> THEN { TEXT { top.cpu.clk } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { top.uart.tx_data[7:0] } }
                elements.select_ghw_file.event.press |> THEN { TEXT { ghw.simple.counter[3:0] } }
                elements.load_default_file.event.press |> THEN { TEXT { top.cpu.clk } }
                elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    active_scope_key:
        LATEST {
            TEXT { TOP_CPU }
            elements.scope_cpu.event.press |> THEN { TEXT { TOP_CPU } }
            elements.scope_cpu_expand.event.press |> THEN { TEXT { TOP_CPU } }
            elements.scope_cpu_collapse.event.press |> THEN { TEXT { TOP_CPU } }
            elements.scope_uart.event.press |> THEN { TEXT { TOP_UART } }
            elements.scope_analog.event.press |> THEN { TEXT { TOP_ANALOG } }
            elements.select_counter_file.event.press |> THEN { TEXT { TOP_CPU } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { TOP_UART } }
            elements.select_ghw_file.event.press |> THEN { TEXT { GHW_SIMPLE } }
            elements.load_default_file.event.press |> THEN { TEXT { TOP_CPU } }
            elements.show_empty.event.press |> THEN { TEXT { NONE } }
        }

    active_scope_label:
        LATEST {
            TEXT { top.cpu }
            elements.scope_cpu.event.press |> THEN { TEXT { top.cpu } }
            elements.scope_cpu_expand.event.press |> THEN { TEXT { top.cpu } }
            elements.scope_cpu_collapse.event.press |> THEN { TEXT { top.cpu } }
            elements.scope_uart.event.press |> THEN { TEXT { top.uart } }
            elements.scope_analog.event.press |> THEN { TEXT { top.analog } }
            elements.select_counter_file.event.press |> THEN { TEXT { top.cpu } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { top.uart } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw.simple } }
            elements.load_default_file.event.press |> THEN { TEXT { top.cpu } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    active_scope_signal_count:
        LATEST {
            TEXT { 8 signals }
            elements.scope_cpu.event.press |> THEN { TEXT { 8 signals } }
            elements.scope_cpu_expand.event.press |> THEN { TEXT { 8 signals } }
            elements.scope_cpu_collapse.event.press |> THEN { TEXT { 8 signals } }
            elements.scope_uart.event.press |> THEN { TEXT { 5 signals } }
            elements.scope_analog.event.press |> THEN { TEXT { 2 signals } }
            elements.select_counter_file.event.press |> THEN { TEXT { 8 signals } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { 5 signals } }
            elements.select_ghw_file.event.press |> THEN { TEXT { 4 signals } }
            elements.load_default_file.event.press |> THEN { TEXT { 8 signals } }
            elements.show_empty.event.press |> THEN { TEXT { 0 signals } }
        }

    scope_cpu_expansion_state:
        LATEST {
            TEXT { Expanded }
            elements.scope_cpu.event.press |> THEN { TEXT { Expanded } }
            elements.scope_cpu_expand.event.press |> THEN { TEXT { Expanded } }
            elements.scope_cpu_collapse.event.press |> THEN { TEXT { Collapsed } }
            elements.select_counter_file.event.press |> THEN { TEXT { Expanded } }
            elements.load_default_file.event.press |> THEN { TEXT { Expanded } }
            elements.show_empty.event.press |> THEN { TEXT { Collapsed } }
        }

    active_scope_expansion_label:
        active_scope == TEXT { top_cpu } |> WHEN {
            True => scope_cpu_expansion_state
            False => active_scope == TEXT { none } |> WHEN {
                True => TEXT { None }
                False => TEXT { Expanded }
            }
        }

    active_scope_visible_signal_count:
        active_scope == TEXT { top_cpu } |> WHEN {
            True => scope_cpu_expansion_state == TEXT { Expanded } |> WHEN {
                True => TEXT { 8 visible }
                False => TEXT { 0 visible }
            }
            False => active_scope == TEXT { top_uart } |> WHEN {
                True => TEXT { 5 visible }
                False => active_scope == TEXT { top_analog } |> WHEN {
                    True => TEXT { 2 visible }
                    False => active_scope == TEXT { ghw_simple } |> WHEN {
                        True => TEXT { 4 visible }
                        False => TEXT { 0 visible }
                    }
                }
            }
        }

    data_signal_toggle_state:
        TEXT { Off } |> HOLD data_signal_toggle_state {
            LATEST {
                elements.select_data.event.press |> THEN {
                    data_signal_toggle_state |> WHEN {
                        On => TEXT { Off }
                        Off => TEXT { On }
                        __ => TEXT { On }
                    }
                }
                elements.select_clk.event.press |> THEN { TEXT { Off } }
                elements.select_reset.event.press |> THEN { TEXT { Off } }
                elements.select_temperature.event.press |> THEN { TEXT { Off } }
                elements.load_default_file.event.press |> THEN { TEXT { Off } }
                elements.show_empty.event.press |> THEN { TEXT { Off } }
            }
        }

    active_signal_key:
        TEXT { CLK } |> HOLD active_signal_key {
            LATEST {
                signal_catalog
                    |> List/map(signal_catalog_item, new:
                        signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN {
                            signal_catalog_item.key |> WHEN {
                                clk => TEXT { CLK }
                                reset_n => TEXT { RESET_N }
                                data_bus => TEXT { DATA_BUS }
                                temperature => TEXT { TEMPERATURE }
                                __ => SKIP
                            }
                        }
                    )
                    |> List/latest()
                elements.select_clk.event.press |> THEN { TEXT { CLK } }
                elements.select_reset.event.press |> THEN { TEXT { RESET_N } }
                elements.select_data.event.press |> THEN {
                    active_signal_key |> WHEN {
                        DATA_BUS => TEXT { NONE }
                        __ => TEXT { DATA_BUS }
                    }
                }
                elements.select_temperature.event.press |> THEN { TEXT { TEMPERATURE } }
                elements.select_counter_file.event.press |> THEN { TEXT { CLK } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TX_DATA } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_COUNTER } }
                elements.load_default_file.event.press |> THEN { TEXT { CLK } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    format_label:
        NovyModel/format_label(format: value_format)

    data_bus_rendered_value:
        NovyModel/selected_data_value_at_cursor(format: value_format, cursor: cursor_position)

    temperature_rendered_value:
        NovyModel/selected_temperature_value_at_cursor(format: value_format, cursor: cursor_position)

    row_height:
        NovyModel/row_height(size: row_size)

    bridge_request_fingerprint:
        bridge_request_descriptor_label

    bridge_request_page:
        bridge_request_compact_label

    bridge_response_scope:
        TEXT { TOP_CPU } |> HOLD bridge_response_scope {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { TOP_CPU } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TOP_UART } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_SIMPLE } }
                elements.scope_cpu.event.press |> THEN { TEXT { TOP_CPU } }
                elements.scope_uart.event.press |> THEN { TEXT { TOP_UART } }
                elements.scope_analog.event.press |> THEN { TEXT { TOP_ANALOG } }
                elements.stale_response_probe.event.press |> THEN { TEXT { TOP_CPU } }
                elements.load_default_file.event.press |> THEN { TEXT { TOP_CPU } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_signal:
        TEXT { CLK } |> HOLD bridge_response_signal {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { CLK } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TX_DATA } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_COUNTER } }
                elements.select_clk.event.press |> THEN { TEXT { CLK } }
                elements.select_reset.event.press |> THEN { TEXT { RESET_N } }
                elements.select_data.event.press |> THEN { TEXT { DATA_BUS } }
                elements.select_temperature.event.press |> THEN { TEXT { TEMPERATURE } }
                elements.stale_response_probe.event.press |> THEN { TEXT { CLK } }
                elements.load_default_file.event.press |> THEN { TEXT { CLK } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_zoom:
        TEXT { Fit } |> HOLD bridge_response_zoom {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { Fit } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { Fit } }
                elements.select_ghw_file.event.press |> THEN { TEXT { Fit } }
                elements.zoom_in.event.press |> THEN { TEXT { Close } }
                elements.zoom_out.event.press |> THEN { TEXT { Wide } }
                elements.zoom_reset.event.press |> THEN { TEXT { Fit } }
                elements.cursor_left.event.press |> THEN { TEXT { Close } }
                elements.stale_response_probe.event.press |> THEN { TEXT { Fit } }
                elements.load_default_file.event.press |> THEN { TEXT { Fit } }
                elements.show_empty.event.press |> THEN { TEXT { None } }
            }
        }

    bridge_response_pan:
        TEXT { Center } |> HOLD bridge_response_pan {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { Center } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { Center } }
                elements.select_ghw_file.event.press |> THEN { TEXT { Center } }
                elements.pan_left.event.press |> THEN { TEXT { LeftWindow } }
                elements.pan_right.event.press |> THEN { TEXT { RightWindow } }
                elements.zoom_reset.event.press |> THEN { TEXT { Center } }
                elements.cursor_left.event.press |> THEN { TEXT { RightWindow } }
                elements.stale_response_probe.event.press |> THEN { TEXT { Center } }
                elements.load_default_file.event.press |> THEN { TEXT { Center } }
                elements.show_empty.event.press |> THEN { TEXT { None } }
            }
        }

    bridge_response_cursor:
        TEXT { Cursor42 } |> HOLD bridge_response_cursor {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { Cursor42 } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { Cursor42 } }
                elements.select_ghw_file.event.press |> THEN { TEXT { Cursor42 } }
                elements.cursor_left.event.press |> THEN { TEXT { Cursor36 } }
                elements.cursor_right.event.press |> THEN { TEXT { Cursor48 } }
                elements.stale_response_probe.event.press |> THEN { TEXT { Cursor42 } }
                elements.load_default_file.event.press |> THEN { TEXT { Cursor42 } }
                elements.show_empty.event.press |> THEN { TEXT { None } }
            }
        }

    bridge_response_format:
        TEXT { Hexadecimal } |> HOLD bridge_response_format {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { Hexadecimal } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { Hexadecimal } }
                elements.select_ghw_file.event.press |> THEN { TEXT { Hexadecimal } }
                elements.format_cycle.event.press |> THEN { NovyModel/next_format(format: bridge_response_format) }
                elements.stale_response_probe.event.press |> THEN { TEXT { Hexadecimal } }
                elements.load_default_file.event.press |> THEN { TEXT { Hexadecimal } }
                elements.show_empty.event.press |> THEN { TEXT { None } }
            }
        }

    bridge_response_window_label:
        TEXT { 0 ns - 120 ns } |> HOLD bridge_response_window_label {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { 0 ns - 120 ns } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { 0 ns - 120 ns } }
                elements.select_ghw_file.event.press |> THEN { TEXT { 0 ns - 100 ns } }
                elements.zoom_in.event.press |> THEN {
                    NovyModel/viewport_label(zoom: NovyModel/zoom_in_level(zoom: zoom_level), pan: pan_window)
                }
                elements.zoom_out.event.press |> THEN {
                    NovyModel/viewport_label(zoom: NovyModel/zoom_out_level(zoom: zoom_level), pan: pan_window)
                }
                elements.zoom_reset.event.press |> THEN { TEXT { 0 ns - 120 ns } }
                elements.pan_left.event.press |> THEN { TEXT { 0 ns - 80 ns } }
                elements.pan_right.event.press |> THEN { TEXT { 80 ns - 160 ns } }
                elements.cursor_left.event.press |> THEN { TEXT { 48 ns - 72 ns } }
                elements.stale_response_probe.event.press |> THEN { TEXT { 0 ns - 120 ns } }
                elements.load_default_file.event.press |> THEN { TEXT { 0 ns - 120 ns } }
                elements.show_empty.event.press |> THEN { TEXT { no response window } }
            }
        }

    bridge_request_window_label:
        active_signal_key == TEXT { NONE } |> WHEN {
            True => TEXT { no request window }
            False => active_file == TEXT { simple_test.ghw } |> WHEN {
                True => TEXT { 0 ns - 100 ns }
                False => keyboard_viewport_label
            }
        }

    bridge_request_structural_key:
        bridge_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { no-request }
            False =>
                bridge_file_digest
                |> Text/concat(with: bridge_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_request_descriptor_label, separator: "|")
                |> Text/concat(with: bridge_request_window_label, separator: "|")
        }

    bridge_response_file_digest:
        TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } |> HOLD bridge_response_file_digest {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { sha256:aa4a6993101ff31601e12d613b746d8753f20448d78e8b720f708403047dc172 } }
                elements.select_ghw_file.event.press |> THEN { TEXT { sha256:3485b4b9a423ce61e54a9bd4a2c525cf7576f0e36d39ad73b208c2e38e980491 } }
                elements.cursor_left.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.stale_response_probe.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.load_default_file.event.press |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.external_file_loaded_digest.text
                elements.show_empty.event.press |> THEN { TEXT { sha256:none } }
            }
        }

    bridge_response_waveform_ref:
        TEXT { wave:vcd:simple:0-240ns } |> HOLD bridge_response_waveform_ref {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { wave:vcd:simple:0-240ns } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { wave:fst:wave-27:0-240ns } }
                elements.select_ghw_file.event.press |> THEN { TEXT { wave:ghw:simple-test:0-100ns } }
                elements.cursor_left.event.press |> THEN { TEXT { wave:vcd:simple:0-240ns } }
                elements.stale_response_probe.event.press |> THEN { TEXT { wave:vcd:simple:0-240ns } }
                elements.load_default_file.event.press |> THEN { TEXT { wave:vcd:simple:0-240ns } }
                elements.external_file_loaded_waveform_ref.text
                elements.show_empty.event.press |> THEN { TEXT { wave:none } }
            }
        }

    bridge_response_structural_key:
        bridge_response_descriptor_label == TEXT { No response available } |> WHEN {
            True => TEXT { no-request }
            False =>
                bridge_response_file_digest
                |> Text/concat(with: bridge_response_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_response_descriptor_label, separator: "|")
                |> Text/concat(with: bridge_response_window_label, separator: "|")
        }

    bridge_response_fingerprint:
        bridge_response_descriptor_label

    bridge_response_page:
        bridge_response_compact_label

    bridge_request_descriptor_label:
        NovyModel/descriptor_label(scope: active_scope_key, signal: active_signal_key, zoom: zoom_level, pan: pan_window, cursor: cursor_position, format: value_format)

    bridge_response_descriptor_label:
        TEXT { TOP_CPU/CLK/Fit/Center/Cursor42/Hexadecimal } |> HOLD bridge_response_descriptor_label {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { TOP_CPU/CLK/Fit/Center/Cursor42/Hexadecimal } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } }
                elements.cursor_left.event.press |> THEN { TEXT { TOP_CPU/DATA_BUS/Close/RightWindow/Cursor36/Binary } }
                elements.stale_response_probe.event.press |> THEN { TEXT { TOP_CPU/CLK/Fit/Center/Cursor42/Hexadecimal } }
                elements.load_default_file.event.press |> THEN { TEXT { TOP_CPU/CLK/Fit/Center/Cursor42/Hexadecimal } }
                elements.show_empty.event.press |> THEN { TEXT { No response available } }
            }
        }

    bridge_request_descriptor:
        [
            page: bridge_request_page
            descriptor: bridge_request_descriptor_label
            fingerprint: bridge_request_fingerprint
            identity: [
                module: TEXT { wellen.v1 }
                file_digest: bridge_file_digest
                waveform_ref: bridge_waveform_ref
                scope: active_scope_key
                signal: active_signal_key
                zoom: zoom_level
                pan: pan_window
                cursor: cursor_position
                format: value_format
                window: bridge_request_window_label
            ]
            window: bridge_page_window_label
            hierarchy_cursor: bridge_hierarchy_page_cursor_label
            payload_limit_bytes: bridge_payload_limit_bytes
            transition_limit: bridge_transition_limit
            visible_row_limit: bridge_visible_row_limit
            segment_limit: bridge_segment_limit
            materialization: bridge_materialization_bound_label
        ]

    bridge_response_descriptor:
        [
            page: bridge_response_page
            descriptor: bridge_response_descriptor_label
            fingerprint: bridge_response_fingerprint
            identity: [
                module: TEXT { wellen.v1 }
                file_digest: bridge_response_file_digest
                waveform_ref: bridge_response_waveform_ref
                scope: bridge_descriptor_scope_label(descriptor: bridge_response_descriptor_label)
                signal: bridge_descriptor_signal_label(descriptor: bridge_response_descriptor_label)
                zoom: bridge_descriptor_zoom_label(descriptor: bridge_response_descriptor_label)
                pan: bridge_descriptor_pan_label(descriptor: bridge_response_descriptor_label)
                cursor: bridge_descriptor_cursor_label(descriptor: bridge_response_descriptor_label)
                format: bridge_descriptor_format_label(descriptor: bridge_response_descriptor_label)
                window: bridge_descriptor_window_label(descriptor: bridge_response_descriptor_label)
            ]
            payload_limit_bytes: bridge_payload_limit_bytes
            transition_limit: bridge_transition_limit
            visible_row_limit: bridge_visible_row_limit
            segment_limit: bridge_segment_limit
        ]

    bridge_signal_page_label:
        LATEST {
            TEXT { TOP_CPU/CLK/Fit/Center/Cursor42/Hexadecimal }
            elements.select_counter_file.event.press |> THEN { bridge_request_descriptor_label }
            elements.select_uart_compare_file.event.press |> THEN { bridge_request_descriptor_label }
            elements.select_ghw_file.event.press |> THEN { bridge_request_descriptor_label }
            elements.diagnostic_probe.event.press |> THEN { TEXT { no-request } }
            elements.show_empty.event.press |> THEN { TEXT { no-request } }
        }

    bridge_cursor_values_label:
        LATEST {
            TEXT { clk=1 reset_n=1 data=0x2a temp=42C }
            elements.select_counter_file.event.press |> THEN { TEXT { clk=1 reset_n=1 data=0x2a temp=42C } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { tx_data=0x55 busy=0 at 42 ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw_counter=3 at 42 ns } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { unavailable } }
            elements.show_empty.event.press |> THEN { TEXT { unavailable } }
            elements.load_default_file.event.press |> THEN { TEXT { clk=1 reset_n=1 data=0x2a temp=42C } }
            elements.cursor_left.event.press |> THEN { TEXT { clk=1 reset_n=1 data=0x2a temp=42C } }
            elements.cursor_right.event.press |> THEN { TEXT { clk=1 reset_n=1 data=0x2a temp=42C } }
        }

    bridge_open_descriptor:
        [
            module: TEXT { wellen.v1 }
            provider: NovyBridge/provider_version()
            schema: NovyBridge/schema_version()
            export: TEXT { open }
            file: bridge_descriptor_file
            format: bridge_file_format
            digest: bridge_file_digest
            waveform_ref: bridge_waveform_ref
            status: bridge_open_status
            policy: NovyBridge/data_policy_label()
        ]

    bridge_request_label:
        bridge_request_fingerprint

    bridge_request_compact_label_raw:
        TEXT { CLK_FIT } |> HOLD bridge_request_compact_label_raw {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { CLK_FIT } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { CMP_UART } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_MAIN } }
                elements.select_clk.event.press |> THEN { TEXT { CLK_FIT } }
                elements.select_reset.event.press |> THEN { TEXT { RESET_FIT } }
                elements.select_data.event.press |> THEN {
                    data_signal_toggle_state |> WHEN {
                        On => TEXT { DATA_FIT }
                        Off => TEXT { NONE }
                    }
                }
                elements.select_temperature.event.press |> THEN { TEXT { TEMP_FIT } }
                signal_catalog
                    |> List/map(signal_catalog_item, new:
                        signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN {
                            signal_catalog_item.key |> WHEN {
                                clk => TEXT { CLK_FIT }
                                reset_n => TEXT { RESET_FIT }
                                data_bus => TEXT { DATA_FIT }
                                temperature => TEXT { TEMP_FIT }
                                __ => SKIP
                            }
                        }
                    )
                    |> List/latest()
                elements.format_cycle.event.press |> THEN { TEXT { DATA_BIN } }
                elements.format_binary.event.press |> THEN { TEXT { DATA_BIN } }
                elements.format_hex.event.press |> THEN { TEXT { DATA_HEX } }
                elements.format_grouped.event.press |> THEN { TEXT { DATA_GROUP } }
                elements.format_octal.event.press |> THEN { TEXT { DATA_OCT } }
                elements.format_signed.event.press |> THEN { TEXT { DATA_SGN } }
                elements.format_unsigned.event.press |> THEN { TEXT { DATA_UNS } }
                elements.format_ascii.event.press |> THEN { TEXT { DATA_ASC } }
                elements.zoom_in.event.press |> THEN { TEXT { DATA_CLOSE } }
                elements.zoom_out.event.press |> THEN { TEXT { DATA_WIDE } }
                elements.zoom_reset.event.press |> THEN { TEXT { DATA_FIT } }
                elements.pan_right.event.press |> THEN { TEXT { DATA_RIGHT } }
                elements.cursor_left.event.press |> THEN { TEXT { DATA_36NS } }
                elements.cursor_right.event.press |> THEN { TEXT { DATA_48NS } }
                elements.keyboard_capture.key |> WHEN {
                    W => TEXT { DATA_CLOSE }
                    S => TEXT { DATA_WIDE }
                    R => TEXT { DATA_FIT }
                    Q => TEXT { DATA_36NS }
                    E => TEXT { DATA_48NS }
                    D => TEXT { DATA_RIGHT }
                    A => TEXT { DATA_LEFT }
                    __ => SKIP
                }
                elements.load_default_file.event.press |> THEN { TEXT { CLK_FIT } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_request_compact_label:
        NovyModel/request_page(compact: bridge_request_compact_label_raw, format: value_format, zoom: zoom_level)

    bridge_response_compact_label:
        TEXT { CLK_FIT } |> HOLD bridge_response_compact_label {
            LATEST {
                elements.select_counter_file.event.press |> THEN { TEXT { CLK_FIT } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { CMP_UART } }
                elements.select_ghw_file.event.press |> THEN { TEXT { GHW_MAIN } }
                elements.cursor_left.event.press |> THEN { TEXT { DATA_36NS } }
                elements.keyboard_capture.key |> WHEN {
                    D => TEXT { CLK_FIT }
                    Q => TEXT { DATA_36NS }
                    S => TEXT { DATA_36NS }
                    W => TEXT { DATA_36NS }
                    R => TEXT { CLK_FIT }
                    E => TEXT { DATA_36NS }
                    A => TEXT { DATA_36NS }
                    __ => SKIP
                }
                elements.stale_response_probe.event.press |> THEN { TEXT { CLK_FIT } }
                elements.load_default_file.event.press |> THEN { TEXT { CLK_FIT } }
                elements.show_empty.event.press |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_status:
        bridge_page_match_status(request: bridge_request_structural_key, response: bridge_response_structural_key)

    bridge_response_status_compact_label:
        bridge_page_match_compact_label(request: bridge_request_structural_key, response: bridge_response_structural_key)

    stale_response_policy: TEXT { canonical structural request equality required }
    bridge_contract: TEXT { wellen.v1 pure-data contract draft: open, hierarchy_page, signal_page, cursor_values, file_stats }
    bridge_provider_version: TEXT { planned official wellen 0.24.x provider }
    bridge_schema_version: TEXT { wellen.v1 waveform schema; real file hashes in descriptors }
    bridge_effect_exports: TEXT { open/hierarchy/signal/cursor/stats }
    bridge_data_policy: TEXT { comparable descriptors only; no Rust handles }
]

FUNCTION bridge_page_match_status(request, response) {
    request == TEXT { no-request } |> WHEN {
        True => TEXT { NOT_REQUESTED }
        False => request == response |> WHEN {
            True => TEXT { ACCEPTED_CURRENT_PAGE }
            False => TEXT { REJECTED_STALE_PAGE }
        }
    }
}

FUNCTION bridge_page_match_compact_label(request, response) {
    request == TEXT { no-request } |> WHEN {
        True => TEXT { NONE }
        False => request == response |> WHEN {
            True => TEXT { CURRENT }
            False => TEXT { STALE }
        }
    }
}

FUNCTION bridge_descriptor_scope_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } => TEXT { TOP_UART }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { GHW_SIMPLE }
        TEXT { No response available } => TEXT { NONE }
        __ => TEXT { TOP_CPU }
    }
}

FUNCTION bridge_descriptor_signal_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } => TEXT { TX_DATA }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { GHW_COUNTER }
        TEXT { TOP_CPU/DATA_BUS/Close/RightWindow/Cursor36/Binary } => TEXT { DATA_BUS }
        TEXT { No response available } => TEXT { NONE }
        __ => TEXT { CLK }
    }
}

FUNCTION bridge_descriptor_zoom_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_CPU/DATA_BUS/Close/RightWindow/Cursor36/Binary } => TEXT { Close }
        TEXT { No response available } => TEXT { None }
        __ => TEXT { Fit }
    }
}

FUNCTION bridge_descriptor_pan_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_CPU/DATA_BUS/Close/RightWindow/Cursor36/Binary } => TEXT { RightWindow }
        TEXT { No response available } => TEXT { None }
        __ => TEXT { Center }
    }
}

FUNCTION bridge_descriptor_cursor_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_CPU/DATA_BUS/Close/RightWindow/Cursor36/Binary } => TEXT { Cursor36 }
        TEXT { No response available } => TEXT { None }
        __ => TEXT { Cursor42 }
    }
}

FUNCTION bridge_descriptor_format_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_CPU/DATA_BUS/Close/RightWindow/Cursor36/Binary } => TEXT { Binary }
        TEXT { No response available } => TEXT { None }
        __ => TEXT { Hexadecimal }
    }
}

FUNCTION bridge_descriptor_window_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_CPU/DATA_BUS/Close/RightWindow/Cursor36/Binary } => TEXT { 48 ns - 72 ns }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { 0 ns - 100 ns }
        TEXT { No response available } => TEXT { no response window }
        __ => TEXT { 0 ns - 120 ns }
    }
}

FUNCTION new_signal(signal) {
    [
        signal_elements: [
            select_signal: SOURCE
            alias_input: SOURCE
        ]
        key: signal.key
        scope: signal.scope
        name: signal.name
        kind: signal.kind
        bit_width: signal.bit_width
        direction: signal.direction
        family: signal.family
        selected_once:
            LATEST {
                False
            }
            |> Bool/toggle(when: signal_elements.select_signal.event.press)
        alias:
            Text/empty() |> HOLD alias {
                LATEST {
                    signal_elements.alias_input.text
                }
            }
    ]
}

FUNCTION new_waveform_segment(segment, store) {
    [
        signal_id: segment.signal_id
        width: segment.state |> WHEN {
            CursorLine => NovyModel/cursor_offset_width(cursor: store.cursor_position, zoom: store.zoom_level)
            __ => NovyModel/zoomed_waveform_width(width: segment.width, zoom: store.zoom_level)
        }
        state: segment.state
        label: segment.label
        click_time: segment.click_time
    ]
}

FUNCTION new_marker(marker, store) {
    [
        marker_elements: [
            remove_marker: SOURCE
        ]
        label:
            marker.label |> HOLD label {
                LATEST {
                    store.elements.marker_rename.event.press |> THEN { TEXT { data stable } }
                }
            }
        has_label: True
    ]
}

FUNCTION new_signal_group(group, store) {
    [
        group_elements: [
            collapse_group: SOURCE
            expand_group: SOURCE
        ]
        name: group.name
        members_label: group.members_label
        collapsed:
            False |> HOLD collapsed {
                LATEST {
                    store.elements.group_toggle.event.press |> THEN { True }
                    store.elements.group_expand.event.press |> THEN { False }
                }
            }
        state_label:
            collapsed |> WHEN {
                True => TEXT { Collapsed }
                False => TEXT { Expanded }
            }
        row_count_label: TEXT { 4 grouped signals }
    ]
}

scene: NovyView/main_scene(PASS: [store: store])
