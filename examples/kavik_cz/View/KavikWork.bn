FUNCTION page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 24
        style: [width: Fill, paint: False]
        items: LIST {
            KavikComponents/page_hero(title: TEXT { Work }, tagline: TEXT { Things I design & build. }, PASS: [store: PASSED.store])
            KavikComponents/muted(text: TEXT { Boon / NovyWave / MoonZoon / BoonComputer / RayBox / Prompter / LocalSearch / UI Parser / Persons.pro }, PASS: [store: PASSED.store])
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 18
                style: [width: Fill, wrap: True, wrap_min_width: 340, paint: False]
                items: LIST {
                    boon_card()
                    novywave_card()
                    moonzoon_card()
                    boon_computer_card()
                    raybox_card()
                    prompter_card()
                    localsearch_card()
                    ui_parser_card()
                    persons_card()
                }
            )
            KavikComponents/contact_section(PASS: [store: PASSED.store])
        }
    )
}

FUNCTION boon_card() {
    KavikComponents/project_card(
        title: TEXT { Boon }
        description: TEXT { One language for web apps, CLIs and hardware }
        body: TEXT { A declarative, statically typed language where the runtime remembers values across reloads. Boon combines persistent state, dataflow, a visual debugger, and interchangeable execution engines. Related work includes MoonZoon, UI Parser, RayBox, and BoonComputer. }
        tags: TEXT { language / rust / declarative / persistent / WIP }
        image_url: TEXT { asset://kavik_cz/images/boon_logo.png }
        image_alt: TEXT { Boon - Timeless and Playful Language }
        link_label: TEXT { boon.run }
        link_url: TEXT { https://boon.run }
        PASS: [store: PASSED.store]
    )
}

FUNCTION novywave_card() {
    KavikComponents/project_card(
        title: TEXT { NovyWave }
        description: TEXT { Modern GTKWave alternative }
        body: TEXT { A modern waveform viewer for FPGA and hardware debugging. It combines WebAssembly with a portable desktop shell, supports Linux, macOS, Windows, browser and remote-server workflows, and uses a plugin-based architecture. Funded by NLnet Foundation. }
        tags: TEXT { waveform / viewer / wasm / fpga / WIP }
        image_url: TEXT { asset://kavik_cz/images/novywave_dark_linux.webp }
        image_alt: TEXT { NovyWave waveform viewer on Linux }
        link_label: TEXT { GitHub }
        link_url: TEXT { https://github.com/NovyWave/NovyWave }
        PASS: [store: PASSED.store]
    )
}

FUNCTION moonzoon_card() {
    KavikComponents/project_card(
        title: TEXT { MoonZoon }
        description: TEXT { Rust fullstack framework }
        body: TEXT { Fullstack Rust without HTML, CSS, or JavaScript. A Wasm frontend with signals and no Virtual DOM, a native Rust backend, typed routes, real-time typed messages, and automatic reload through the mzoon CLI. It powers Boon Playground and NovyWave. }
        tags: TEXT { rust / fullstack / wasm / signals }
        image_url: TEXT { asset://kavik_cz/images/moonzoon-logo.png }
        image_alt: TEXT { MoonZoon logo }
        link_label: TEXT { GitHub }
        link_url: TEXT { https://github.com/MoonZoon/MoonZoon }
        PASS: [store: PASSED.store]
    )
}

FUNCTION boon_computer_card() {
    KavikComponents/project_card(
        title: TEXT { BoonComputer }
        description: TEXT { RISC CPU on FPGA, designed in Boon, running Boon }
        body: TEXT { The roadmap starts with Boon-to-Verilog circuits, DigitalJS and Wasm Yosys simulation, and real FPGA peripherals. The long-term proof is a Boon program running on a CPU whose architecture is itself described in Boon. }
        tags: TEXT { boon / risc / fpga / cpu / hardware / WIP }
        image_url: TEXT { asset://kavik_cz/images/boon_computer.jpg }
        image_alt: TEXT { BoonComputer RISC CPU on FPGA }
        link_label: TEXT { Project on kavik.cz }
        link_url: TEXT { https://kavik.cz/work/#boon-computer }
        PASS: [store: PASSED.store]
    )
}

FUNCTION raybox_card() {
    KavikComponents/project_card(
        title: TEXT { RayBox }
        description: TEXT { 3D web UI renderer with SDF and PBR }
        body: TEXT { RayBox renders interface elements as real 3D objects using signed distance functions and physically based rendering. Buttons have depth, dialogs float and cast shadows, and inset effects emerge from geometry. Slang targets web and native GPU backends. }
        tags: TEXT { rust / slang / wasm / sdf / 3d / WIP }
        image_url: TEXT { asset://kavik_cz/images/raybox.jpg }
        image_alt: TEXT { RayBox physical 3D user interface }
        link_label: TEXT { Project on kavik.cz }
        link_url: TEXT { https://kavik.cz/work/#raybox }
        PASS: [store: PASSED.store]
    )
}

FUNCTION prompter_card() {
    KavikComponents/project_card(
        title: TEXT { Prompter }
        description: TEXT { Web UI for Claude Code sessions }
        body: TEXT { A Rust CLI that wraps coding agents in a pseudo-terminal and exposes a dashboard. It supports mobile access, supervises idle agents, protects deterministic test files with hashes, and preserves an audit trail of prompts and sessions. }
        tags: TEXT { rust / cli / ai / pty / axum / htmx }
        image_url: TEXT { asset://kavik_cz/images/prompter.webp }
        image_alt: TEXT { Prompter web interface }
        link_label: TEXT { Project on kavik.cz }
        link_url: TEXT { https://kavik.cz/work/#prompter }
        PASS: [store: PASSED.store]
    )
}

FUNCTION localsearch_card() {
    KavikComponents/project_card(
        title: TEXT { LocalSearch }
        description: TEXT { Rust full-text search library for the browser }
        body: TEXT { Fast client-side indexing and autocomplete without server round trips. It indexes and searches 20,000 film titles in milliseconds, reducing backend load and keeping search useful when remote services are slow or unavailable. }
        tags: TEXT { search / full-text / rust / wasm }
        image_url: TEXT { asset://kavik_cz/images/localsearch.jpg }
        image_alt: TEXT { LocalSearch client-side full-text search }
        link_label: TEXT { GitHub }
        link_url: TEXT { https://github.com/Stremio/local-search }
        PASS: [store: PASSED.store]
    )
}

FUNCTION ui_parser_card() {
    KavikComponents/project_card(
        title: TEXT { UI Parser }
        description: TEXT { Extract UI metadata from web pages }
        body: TEXT { A browser tool for UI recreation and visual testing. It captures element bounds, computed styles, text and pseudo-element sizes, actually used fonts, and layout relationships through a DevTools-style extension surface. }
        tags: TEXT { rust / extension / cdp / typescript / mcp / WIP }
        image_url: TEXT { asset://kavik_cz/images/ui_parser.webp }
        image_alt: TEXT { UI Parser overlay visualization }
        link_label: TEXT { Project on kavik.cz }
        link_url: TEXT { https://kavik.cz/work/#ui-parser }
        PASS: [store: PASSED.store]
    )
}

FUNCTION persons_card() {
    KavikComponents/project_card(
        title: TEXT { Persons.pro }
        description: TEXT { The app for freelancers and digital product makers }
        body: TEXT { A local-first direction for hiring, sponsorship, and sales with fewer platform fees. The concept combines near-zero-fee payments, visible escrow, verified identities, Boon, LocalSearch, and decentralized transports. }
        tags: TEXT { hire / sponsor / sell / figma / WIP }
        image_url: TEXT { asset://kavik_cz/images/figma_persons_pro.webp }
        image_alt: TEXT { Persons.pro dashboard concept }
        link_label: TEXT { Single-page demo }
        link_url: TEXT { https://persons.pro/ }
        PASS: [store: PASSED.store]
    )
}
