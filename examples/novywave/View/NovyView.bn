FUNCTION compact_button_style(button_width) {
    [
        width: button_width
        height: 28
        rounded_corners: 8
        spring_range: 3
        center: True
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #101a2b }
            Light => TEXT { #ffffff }
        }]
        border: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #334761 }
            Light => TEXT { #bad0e8 }
        }]
        material: NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
    ]
}

