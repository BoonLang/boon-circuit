-- NovyWave - Boon-first physical waveform viewer playground example.

store: [
    visible_editor_reference: NovyReference/visual_basis_label()
    visible_editor_pipe_probe:
        LATEST {
            TEXT { Visible editor syntax probe }
            elements.load_default_file.event.press |> THEN { TEXT { Default file path exercised } }
        }

    elements: [
        open_workspace_dialog: SOURCE
        close_workspace_dialog: SOURCE
        select_workspace_repo: SOURCE
        select_workspace_a: SOURCE
        select_workspace_b: SOURCE
        open_selected_workspace: SOURCE
        open_load_files_dialog: SOURCE
        close_load_files_dialog: SOURCE
        load_file_path_focus_probe: SOURCE
        load_file_path_input: SOURCE
        load_external_file: SOURCE
        external_file_loaded_name: SOURCE
        external_file_loaded_path: SOURCE
        external_file_loaded_format: SOURCE
        external_file_loaded_digest: SOURCE
        external_file_loaded_waveform_ref: SOURCE
        external_file_loaded_stats: SOURCE
        external_file_loaded_contract: SOURCE
        external_file_load_error: SOURCE
        begin_default_file_load: SOURCE
        load_default_file: SOURCE
        show_empty: SOURCE
        file_row_select: SOURCE
        select_counter_file: SOURCE
        select_uart_compare_file: SOURCE
        select_ghw_file: SOURCE
        signal_search_focus_probe: SOURCE
        mode_to_light: SOURCE
        mode_to_dark: SOURCE
        zoom_in: SOURCE
        zoom_out: SOURCE
        zoom_reset: SOURCE
        pan_left: SOURCE
        pan_right: SOURCE
        cursor_left: SOURCE
        cursor_right: SOURCE
        marker_toggle: SOURCE
        marker_rename: SOURCE
        marker_remove: SOURCE
        marker_jump: SOURCE
        group_create: SOURCE
        group_toggle: SOURCE
        group_expand: SOURCE
        group_remove: SOURCE
        stale_response_probe: SOURCE
        row_taller: SOURCE
        row_shorter: SOURCE
        selected_remove_data: SOURCE
        selected_remove_clk: SOURCE
        selected_remove_reset: SOURCE
        selected_remove_data_valid: SOURCE
        selected_remove_data_ready: SOURCE
        selected_remove_state: SOURCE
        selected_remove_error_count: SOURCE
        selected_remove_temperature: SOURCE
        selected_remove_tx_data: SOURCE
        selected_remove_rx_data: SOURCE
        selected_remove_baud_tick: SOURCE
        selected_remove_uart_busy: SOURCE
        selected_remove_ghw_counter: SOURCE
        selected_remove_ghw_enable: SOURCE
        selected_remove_ghw_state: SOURCE
        selected_clear_all: SOURCE
        selected_restore_data: SOURCE
        selected_data_up: SOURCE
        selected_data_down: SOURCE
        analog_limits_auto: SOURCE
        analog_limits_manual: SOURCE
        analog_limits_invalid: SOURCE
        format_dropdown_toggle: SOURCE
        format_cycle: SOURCE
        format_binary: SOURCE
        format_hex: SOURCE
        format_grouped: SOURCE
        format_octal: SOURCE
        format_signed: SOURCE
        format_unsigned: SOURCE
        format_ascii: SOURCE
        keyboard_capture: SOURCE
        waveform_click: SOURCE
        waveform_hover: SOURCE
        signal_search_input: SOURCE
        scope_cpu: SOURCE
        scope_cpu_expand: SOURCE
        scope_cpu_collapse: SOURCE
        scope_uart: SOURCE
        scope_analog: SOURCE
        select_clk: SOURCE
        select_reset: SOURCE
        select_data: SOURCE
        select_temperature: SOURCE
        panels_toggle_arrangement: SOURCE
        files_variables_resize_drag: SOURCE
        browser_selected_resize_drag: SOURCE
        variables_name_resize_drag: SOURCE
        variables_value_resize_drag: SOURCE
        signal_row_resize_drag: SOURCE
    ]

    workspace_dialog:
        LATEST {
            Closed
            elements.open_workspace_dialog.event.press |> THEN { Open }
            elements.close_workspace_dialog.event.press |> THEN { Closed }
            elements.open_selected_workspace.event.press |> THEN { Closed }
            elements.open_load_files_dialog.event.press |> THEN { Closed }
        }

    workspace_path_key:
        WorkspaceA |> HOLD workspace_path_key {
            LATEST {
                elements.open_selected_workspace.event.press |> THEN { workspace_selected_key }
            }
        }

    workspace_selected_key:
        WorkspaceA |> HOLD workspace_selected_key {
            LATEST {
                elements.open_workspace_dialog.event.press |> THEN { workspace_path_key }
                elements.select_workspace_repo.event.press |> THEN { Repo }
                elements.select_workspace_a.event.press |> THEN { WorkspaceA }
                elements.select_workspace_b.event.press |> THEN { WorkspaceB }
            }
        }

    workspace_path:
        workspace_path_key |> WHEN {
            WorkspaceB => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b }
            Repo => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a }
        }

    workspace_header_path:
        workspace_path_key |> WHEN {
            WorkspaceB => TEXT { .../test_files/my_workspaces/workspace_b }
            Repo => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { .../test_files/my_workspaces/workspace_a }
        }

    workspace_selected_path:
        workspace_selected_key |> WHEN {
            WorkspaceB => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b }
            Repo => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a }
        }

    workspace_dialog_title:
        TEXT { Workspace dialog closed } |> HOLD workspace_dialog_title {
            LATEST {
                elements.open_workspace_dialog.event.press |> THEN { TEXT { Open Workspace } }
                elements.close_workspace_dialog.event.press |> THEN { TEXT { Workspace dialog closed } }
                elements.open_selected_workspace.event.press |> THEN { TEXT { Workspace dialog closed } }
                elements.open_load_files_dialog.event.press |> THEN { TEXT { Workspace dialog closed } }
            }
        }

    workspace_dialog_hint:
        TEXT { No workspace picker } |> HOLD workspace_dialog_hint {
            LATEST {
                elements.open_workspace_dialog.event.press |> THEN { TEXT { Pick a directory to use as your workspace. NovyWave will create the .novywave file automatically if it is missing. } }
                elements.close_workspace_dialog.event.press |> THEN { TEXT { No workspace picker } }
                elements.open_selected_workspace.event.press |> THEN { TEXT { No workspace picker } }
                elements.open_load_files_dialog.event.press |> THEN { TEXT { No workspace picker } }
            }
        }

    workspace_dialog_selection:
        TEXT { none } |> HOLD workspace_dialog_selection {
            LATEST {
                elements.open_workspace_dialog.event.press |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a } }
                elements.select_workspace_repo.event.press |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave } }
                elements.select_workspace_a.event.press |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a } }
                elements.select_workspace_b.event.press |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b } }
                elements.close_workspace_dialog.event.press |> THEN { TEXT { none } }
                elements.open_selected_workspace.event.press |> THEN { TEXT { none } }
                elements.open_load_files_dialog.event.press |> THEN { TEXT { none } }
            }
        }

    workspace_status_label:
        workspace_path_key |> WHEN {
            WorkspaceB => TEXT { workspace_b ready }
            Repo => TEXT { NovyWave repo ready }
            __ => TEXT { workspace_a ready }
        }

    load_files_dialog:
        LATEST {
            Closed
            elements.open_load_files_dialog.event.press |> THEN { Open }
            elements.close_load_files_dialog.event.press |> THEN { Closed }
            elements.external_file_loaded_name.text |> THEN { Closed }
            elements.begin_default_file_load.event.press |> THEN { Closed }
            elements.load_default_file.event.press |> THEN { Closed }
            elements.show_empty.event.press |> THEN { Closed }
            elements.select_counter_file.event.press |> THEN { Closed }
            elements.select_uart_compare_file.event.press |> THEN { Closed }
            elements.select_ghw_file.event.press |> THEN { Closed }
            elements.open_workspace_dialog.event.press |> THEN { Closed }
        }

    panel_layout:
        Balanced |> HOLD panel_layout {
            LATEST {
                elements.files_variables_resize_drag.text |> THEN {
                    elements.files_variables_resize_drag.text |> WHEN {
                        TEXT { Grow } => panel_layout |> WHEN {
                            VariablesWidest => VariablesWide
                            VariablesWide => Balanced
                            Balanced => FilesWide
                            FilesWide => FilesWidest
                            __ => FilesWidest
                        }
                        TEXT { Shrink } => panel_layout |> WHEN {
                            FilesWidest => FilesWide
                            FilesWide => Balanced
                            Balanced => VariablesWide
                            VariablesWide => VariablesWidest
                            __ => VariablesWidest
                        }
                        __ => panel_layout
                    }
                }
                elements.browser_selected_resize_drag.text |> THEN {
                    elements.browser_selected_resize_drag.text |> WHEN {
                        TEXT { Grow } => panel_layout |> WHEN {
                            VariablesWidest => VariablesWide
                            VariablesWide => Balanced
                            Balanced => FilesWide
                            FilesWide => FilesWidest
                            __ => FilesWidest
                        }
                        TEXT { Shrink } => panel_layout |> WHEN {
                            FilesWidest => FilesWide
                            FilesWide => Balanced
                            Balanced => VariablesWide
                            VariablesWide => VariablesWidest
                            __ => VariablesWidest
                        }
                        __ => panel_layout
                    }
                }
                elements.show_empty.event.press |> THEN { Balanced }
                elements.load_default_file.event.press |> THEN { Balanced }
            }
        }

    panel_layout_label:
        panel_layout |> WHEN {
            FilesWidest => TEXT { Files panel widest }
            FilesWide => TEXT { Files panel wide }
            VariablesWidest => TEXT { Variables panel widest }
            VariablesWide => TEXT { Variables panel wide }
            __ => TEXT { Panels balanced }
        }

    panel_arrangement:
        Stacked |> HOLD panel_arrangement {
            LATEST {
                elements.panels_toggle_arrangement.event.press |> THEN {
                    panel_arrangement |> WHEN {
                        Docked => Stacked
                        __ => Docked
                    }
                }
                elements.show_empty.event.press |> THEN { Stacked }
                elements.load_default_file.event.press |> THEN { Stacked }
            }
        }

    panel_arrangement_label:
        panel_arrangement |> WHEN {
            Docked => TEXT { Docked panels }
            __ => TEXT { Stacked panels }
        }

    panel_arrangement_button_label:
        panel_arrangement |> WHEN {
            Docked => TEXT { Stack }
            __ => TEXT { Dock }
        }

    files_panel_width:
        panel_layout |> WHEN {
            FilesWidest => 650
            FilesWide => 520
            VariablesWidest => 260
            VariablesWide => 340
            __ => 430
        }

    variables_panel_width:
        panel_layout |> WHEN {
            FilesWidest => 300
            FilesWide => 390
            VariablesWidest => 650
            VariablesWide => 570
            __ => 480
        }

    browser_panel_width:
        panel_layout |> WHEN {
            FilesWidest => 650
            FilesWide => 520
            VariablesWidest => 260
            VariablesWide => 340
            __ => 430
        }

    files_panel_height_key:
        Balanced |> HOLD files_panel_height_key {
            LATEST {
                elements.files_variables_resize_drag.text |> THEN {
                    elements.files_variables_resize_drag.text |> WHEN {
                        TEXT { Grow } => files_panel_height_key |> WHEN {
                            Short => Balanced
                            Balanced => Tall
                            Tall => Tallest
                            __ => Tallest
                        }
                        TEXT { Shrink } => files_panel_height_key |> WHEN {
                            Tallest => Tall
                            Tall => Balanced
                            Balanced => Short
                            __ => Short
                        }
                        __ => files_panel_height_key
                    }
                }
                elements.browser_selected_resize_drag.text |> THEN {
                    elements.browser_selected_resize_drag.text |> WHEN {
                        TEXT { Grow } => files_panel_height_key |> WHEN {
                            Short => Balanced
                            Balanced => Tall
                            Tall => Tallest
                            __ => Tallest
                        }
                        TEXT { Shrink } => files_panel_height_key |> WHEN {
                            Tallest => Tall
                            Tall => Balanced
                            Balanced => Short
                            __ => Short
                        }
                        __ => files_panel_height_key
                    }
                }
                elements.show_empty.event.press |> THEN { Balanced }
                elements.load_default_file.event.press |> THEN { Balanced }
            }
        }

    files_panel_height:
        files_panel_height_key |> WHEN {
            Short => 284
            Tall => 520
            Tallest => 650
            __ => 390
        }

    selected_name_column_width_key:
        Normal |> HOLD selected_name_column_width_key {
            LATEST {
                elements.variables_name_resize_drag.text |> THEN {
                    elements.variables_name_resize_drag.text |> WHEN {
                        TEXT { Grow } => selected_name_column_width_key |> WHEN {
                            Compact => Normal
                            Normal => Wide
                            Wide => Widest
                            __ => Widest
                        }
                        TEXT { Shrink } => selected_name_column_width_key |> WHEN {
                            Widest => Wide
                            Wide => Normal
                            Normal => Compact
                            __ => Compact
                        }
                        __ => selected_name_column_width_key
                    }
                }
            }
        }

    selected_name_column_width:
        selected_name_column_width_key |> WHEN {
            Compact => 130
            Wide => 250
            Widest => 340
            __ => 190
        }

    selected_value_column_width_key:
        Normal |> HOLD selected_value_column_width_key {
            LATEST {
                elements.variables_value_resize_drag.text |> THEN {
                    elements.variables_value_resize_drag.text |> WHEN {
                        TEXT { Grow } => selected_value_column_width_key |> WHEN {
                            Compact => Normal
                            Normal => Wide
                            Wide => Widest
                            __ => Widest
                        }
                        TEXT { Shrink } => selected_value_column_width_key |> WHEN {
                            Widest => Wide
                            Wide => Normal
                            Normal => Compact
                            __ => Compact
                        }
                        __ => selected_value_column_width_key
                    }
                }
            }
        }

    selected_value_column_width:
        selected_value_column_width_key |> WHEN {
            Compact => 120
            Wide => 300
            Widest => 400
            __ => 220
        }

    startup_workspace_opened_files:
        LIST {
            [file: "simple.vcd", canonical_path: "~/repos/NovyWave/test_files/simple.vcd", family: "simple_vcd", selected_scope_key: "simple_tb_s", selected_scope_label: "simple_tb.s", primary_signal: "clk"]
            [file: "wave_27.fst", canonical_path: "~/repos/NovyWave/test_files/wave_27.fst", family: "uart", selected_scope_key: "top_uart", selected_scope_label: "top.uart", primary_signal: "tx_data"]
            [file: "simple_test.ghw", canonical_path: "~/repos/NovyWave/test_files/simple_test.ghw", family: "ghw", selected_scope_key: "ghw_simple", selected_scope_label: "ghw.simple", primary_signal: "ghw_counter"]
        }

    startup_selected_file:
        TEXT { simple.vcd }

    startup_selected_file_path:
        List/find_value(startup_workspace_opened_files, field: "file", value: startup_selected_file, target: "canonical_path", fallback: TEXT { ~/repos/NovyWave/test_files/simple.vcd })

    startup_selected_family:
        List/find_value(startup_workspace_opened_files, field: "file", value: startup_selected_file, target: "family", fallback: TEXT { simple_vcd })

    startup_selected_scope_key:
        List/find_value(startup_workspace_opened_files, field: "file", value: startup_selected_file, target: "selected_scope_key", fallback: TEXT { simple_tb_s })

    startup_selected_scope_label:
        List/find_value(startup_workspace_opened_files, field: "file", value: startup_selected_file, target: "selected_scope_label", fallback: TEXT { simple_tb.s })

    startup_primary_signal:
        List/find_value(startup_workspace_opened_files, field: "file", value: startup_selected_file, target: "primary_signal", fallback: TEXT { clk })

    startup_expanded_scopes:
        LIST {
            [file: TEXT { simple.vcd }, scope_key: TEXT { simple_tb_s }, scope_label: TEXT { simple_tb.s }]
            [file: TEXT { simple_test.ghw }, scope_key: TEXT { ghw_simple }, scope_label: TEXT { ghw.simple }]
        }

    startup_file_tree_rows:
        LIST {
            [kind: FileTreeFile, file: TEXT { simple.vcd }, label: TEXT { - simple.vcd }, indent_width: 0, selected_file: TEXT { simple.vcd }, source_key: SelectCounterFile]
            [kind: FileTreeScope, file: TEXT { simple.vcd }, scope_key: TEXT { simple_tb_s }, label: TEXT { + simple_tb.s }, expanded_label: TEXT { - simple_tb.s }, collapsed_label: TEXT { + simple_tb.s }, indent_width: 18, source_key: SelectSimpleScope]
            [kind: FileTreeFile, file: TEXT { wave_27.fst }, label: TEXT { - wave_27.fst }, indent_width: 0, selected_file: TEXT { wave_27.fst }, source_key: SelectUartCompareFile]
            [kind: FileTreeScope, file: TEXT { wave_27.fst }, scope_key: TEXT { top_uart }, label: TEXT { + top.uart }, indent_width: 18, source_key: SelectUartScope]
            [kind: FileTreeScope, file: TEXT { wave_27.fst }, scope_key: TEXT { top_analog }, label: TEXT { + top.analog }, indent_width: 18, source_key: SelectAnalogScope]
            [kind: FileTreeFile, file: TEXT { simple_test.ghw }, label: TEXT { - simple_test.ghw }, indent_width: 0, selected_file: TEXT { simple_test.ghw }, source_key: SelectGhwFile]
            [kind: FileTreeScope, file: TEXT { simple_test.ghw }, scope_key: TEXT { ghw_simple }, label: TEXT { - ghw.simple }, indent_width: 18, source_key: SelectGhwFile]
        }

    file_tree_rows:
        startup_file_tree_rows

    startup_selected_variable_config:
        LIST {
            [file: TEXT { simple.vcd }, unique_id: TEXT { ~/repos/NovyWave/test_files/simple.vcd|simple_tb.s|A[3:0] }, signal_id: TEXT { clk }, formatter: Hexadecimal, row_height: 28, group: TEXT { simple_tb.s group }]
            [file: TEXT { simple.vcd }, unique_id: TEXT { ~/repos/NovyWave/test_files/simple.vcd|simple_tb.s|B[3:0] }, signal_id: TEXT { reset_n }, formatter: Hexadecimal, row_height: 28, group: TEXT { simple_tb.s group }]
        }

    startup_signal_group_config:
        LIST {
            [name: TEXT { simple_tb.s group }, member_ids: TEXT { clk, reset_n }, collapsed: False]
        }

    startup_timeline_config:
        [
            file: startup_selected_file
            cursor: TEXT { 50 s }
            visible_range: TEXT { 0 s - 250 s }
            zoom_center: TEXT { 50 s }
            tooltip_enabled: True
        ]

    startup_marker_config:
        LIST {
            [time: TEXT { 50 s }, name: TEXT { 50 s }]
        }

    startup_restore_summary:
        TEXT { config restore: simple.vcd opened, simple_tb.s expanded, A[3:0]/B[3:0] selected, cursor 50 s }

    load_files_path:
        startup_selected_file_path |> HOLD load_files_path {
            LATEST {
                elements.load_file_path_input.text |> THEN { elements.load_file_path_input.text }
                elements.select_counter_file.event.press |> THEN { TEXT { ~/repos/NovyWave/test_files/simple.vcd } }
                elements.select_uart_compare_file.event.press |> THEN { TEXT { ~/repos/NovyWave/test_files/wave_27.fst } }
                elements.select_ghw_file.event.press |> THEN { TEXT { ~/repos/NovyWave/test_files/simple_test.ghw } }
            }
        }

    external_file_error:
        Text/empty() |> HOLD external_file_error {
            LATEST {
                elements.external_file_load_error.text
                elements.open_load_files_dialog.event.press |> THEN { Text/empty() }
                elements.load_file_path_input.text |> THEN { Text/empty() }
                elements.external_file_loaded_name.text |> THEN { Text/empty() }
                elements.close_load_files_dialog.event.press |> THEN { Text/empty() }
            }
        }

    external_file_active:
        No |> HOLD external_file_active {
            LATEST {
                elements.external_file_loaded_name.text |> THEN { Yes }
                elements.select_counter_file.event.press |> THEN { No }
                elements.select_uart_compare_file.event.press |> THEN { No }
                elements.select_ghw_file.event.press |> THEN { No }
                elements.load_default_file.event.press |> THEN { No }
                elements.show_empty.event.press |> THEN { No }
            }
        }

    external_file_tree_label:
        TEXT { - local file } |> HOLD external_file_tree_label {
            LATEST {
                elements.external_file_loaded_name.text |> THEN {
                    TEXT { - } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
                }
                elements.show_empty.event.press |> THEN { TEXT { - local file } }
            }
        }

    load_files_dialog_title:
        TEXT { No file dialog } |> HOLD load_files_dialog_title {
            LATEST {
                elements.open_load_files_dialog.event.press |> THEN { TEXT { Load files } }
                elements.close_load_files_dialog.event.press |> THEN { TEXT { No file dialog } }
                elements.external_file_loaded_name.text |> THEN { TEXT { No file dialog } }
                elements.begin_default_file_load.event.press |> THEN { TEXT { No file dialog } }
                elements.load_default_file.event.press |> THEN { TEXT { No file dialog } }
                elements.show_empty.event.press |> THEN { TEXT { No file dialog } }
                elements.open_workspace_dialog.event.press |> THEN { TEXT { No file dialog } }
            }
        }

    load_files_dialog_hint:
        TEXT { File dialog closed } |> HOLD load_files_dialog_hint {
            LATEST {
                elements.open_load_files_dialog.event.press |> THEN { TEXT { Enter a local VCD, FST, or GHW path. The native host validates the file and sends pure metadata to Boon. } }
                elements.close_load_files_dialog.event.press |> THEN { TEXT { File dialog closed } }
                elements.external_file_loaded_name.text |> THEN { TEXT { File dialog closed } }
                elements.begin_default_file_load.event.press |> THEN { TEXT { File dialog closed } }
                elements.load_default_file.event.press |> THEN { TEXT { File dialog closed } }
                elements.show_empty.event.press |> THEN { TEXT { File dialog closed } }
                elements.open_workspace_dialog.event.press |> THEN { TEXT { File dialog closed } }
            }
        }

    load_files_dialog_selection:
        TEXT { none } |> HOLD load_files_dialog_selection {
            LATEST {
                elements.open_load_files_dialog.event.press |> THEN { TEXT { Path: ~/repos/NovyWave/test_files/simple.vcd } }
                elements.load_file_path_input.text |> THEN { TEXT { Path: } |> Text/concat(with: elements.load_file_path_input.text, separator: " ") }
                elements.external_file_load_error.text |> THEN { elements.external_file_load_error.text }
                elements.close_load_files_dialog.event.press |> THEN { TEXT { none } }
                elements.external_file_loaded_name.text |> THEN { TEXT { none } }
                elements.begin_default_file_load.event.press |> THEN { TEXT { none } }
                elements.load_default_file.event.press |> THEN { TEXT { none } }
                elements.show_empty.event.press |> THEN { TEXT { none } }
                elements.open_workspace_dialog.event.press |> THEN { TEXT { none } }
            }
        }

    waveform_status:
        LATEST {
            Loaded
            elements.show_empty.event.press |> THEN { Empty }
            elements.begin_default_file_load.event.press |> THEN { Loading }
            elements.load_default_file.event.press |> THEN { Loaded }
            elements.external_file_loaded_name.text |> THEN { Loaded }
        }

    empty_state_title: TEXT { No waveform loaded }
    empty_state_hint: TEXT { Drop or load a VCD, FST, or GHW waveform to inspect signals. }
    empty_state_bridge_label: TEXT { Bridge state: no request scheduled; pure descriptor is wave:none }
    empty_state_formats_label: TEXT { Supported waveform formats: VCD, FST, GHW }
    loading_state_title: TEXT { Loading waveform }
    loading_state_hint: TEXT { Opening simple.vcd through wellen.v1 descriptor handshake. }
    reference_visual_basis: NovyReference/visual_basis_label()
    reference_loaded_basis: NovyReference/loaded_reference_label()
    reference_empty_basis: NovyReference/empty_reference_label()
    reference_workflow_basis: NovyReference/workflow_basis_label()
    reference_waveform_basis: NovyReference/waveform_basis_label()
    reference_comparison_status: NovyReference/comparison_compact_label()
    reference_descriptor: NovyReference/reference_descriptor()

    active_file:
        startup_selected_file |> HOLD active_file {
            LATEST {
            elements.select_counter_file.event.press |> THEN { TEXT { simple.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { wave_27.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { simple_test.ghw } }
            elements.scope_uart.event.press |> THEN { TEXT { wave_27.fst } }
            elements.scope_analog.event.press |> THEN { TEXT { wave_27.fst } }
            elements.file_row_select.event.press |> THEN { active_file }
            elements.begin_default_file_load.event.press |> THEN { store.startup_selected_file }
            elements.load_default_file.event.press |> THEN { store.startup_selected_file }
            elements.external_file_loaded_name.text
            elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    waveform_file_metadata:
        LIST {
            [file: "simple.vcd", format: "VCD", digest: "sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de", waveform_ref: "wave:vcd:simple:0-250s", full_range: "0 s - 250 s", initial_window: "0 s - 250 s", range_start: 0, range_end: 250, initial_start: 0, initial_end: 250, canvas_width: 360, cursor_left: 0, cursor_default: 50, cursor_right: 150, zoom_center_default: 50, stats: "VCD 2 signals, 0-250s, bounded pages", large_file_contract: "simple.vcd 311B -> bounded page requests only", hierarchy_page: "HIER:simple_tb/s", hierarchy_cursor: "hierarchy cursor simple_tb.s:0..64 next=none", materialization_bound: "visible rows 2/2, waveform segments 6/256 max", time_unit: "s", timescale: "1 s/native tick", range_source: FileHeader, metadata_source: WellenHeader]
            [file: "wave_27.fst", format: "FST", digest: "sha256:aa4a6993101ff31601e12d613b746d8753f20448d78e8b720f708403047dc172", waveform_ref: "wave:fst:wave-27:0-240ns", full_range: "0 ns - 240 ns", initial_window: "0 ns - 120 ns", range_start: 0, range_end: 240, initial_start: 0, initial_end: 120, canvas_width: 360, cursor_left: 36, cursor_default: 42, cursor_right: 48, zoom_center_default: 42, stats: "FST 5 signals, 0-240ns, bounded pages", large_file_contract: "wave_27.fst 28860652B -> bounded compare page only", hierarchy_page: "HIER:top.uart compare page", hierarchy_cursor: "hierarchy cursor top.uart:0..64 next=none", materialization_bound: "visible rows 4/5, waveform segments 28/256 max", time_unit: "ns", timescale: "inferred FST native tick", range_source: FileHeader, metadata_source: WellenHeader]
            [file: "simple_test.ghw", format: "GHW", digest: "sha256:3485b4b9a423ce61e54a9bd4a2c525cf7576f0e36d39ad73b208c2e38e980491", waveform_ref: "wave:ghw:simple-test:0-100ns", full_range: "0 ns - 100 ns", initial_window: "0 ns - 100 ns", range_start: 0, range_end: 100, initial_start: 0, initial_end: 100, canvas_width: 360, cursor_left: 36, cursor_default: 42, cursor_right: 48, zoom_center_default: 42, stats: "GHW 4 signals, 0-100ns, bounded pages", large_file_contract: "simple_test.ghw 833B -> bounded page requests only", hierarchy_page: "HIER:ghw.simple/counter", hierarchy_cursor: "hierarchy cursor ghw.simple:0..64 next=none", materialization_bound: "visible rows 3/4, waveform segments 20/256 max", time_unit: "ns", timescale: "GHW native tick", range_source: FileHeader, metadata_source: WellenHeader]
            [file: "none", format: "none", digest: "sha256:none", waveform_ref: "wave:none", full_range: "no waveform range", initial_window: "no request window", range_start: 0, range_end: 0, initial_start: 0, initial_end: 0, canvas_width: 360, cursor_left: 0, cursor_default: 0, cursor_right: 0, zoom_center_default: 0, stats: "no waveform stats", large_file_contract: "no large file materialized", hierarchy_page: "HIER:none", hierarchy_cursor: "hierarchy cursor none", materialization_bound: "visible rows 0/0, waveform segments 0/256 max", time_unit: "none", timescale: "no timescale", range_source: NoFile, metadata_source: NoFile]
        }

    active_metadata_file:
        active_file

    active_metadata_format:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "format", fallback: TEXT { none })

    active_metadata_digest:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "digest", fallback: TEXT { sha256:none })

    active_metadata_waveform_ref:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "waveform_ref", fallback: TEXT { wave:none })

    active_metadata_full_range:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "full_range", fallback: TEXT { no waveform range })

    active_metadata_initial_window:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "initial_window", fallback: TEXT { no request window })

    active_metadata_range_start:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "range_start", fallback: 0)
        |> Text/to_number()

    active_metadata_range_end:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "range_end", fallback: 0)
        |> Text/to_number()

    active_metadata_initial_start:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "initial_start", fallback: 0)
        |> Text/to_number()

    active_metadata_initial_end:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "initial_end", fallback: 0)
        |> Text/to_number()

    active_metadata_canvas_width:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "canvas_width", fallback: 360)
        |> Text/to_number()

    active_metadata_stats:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "stats", fallback: TEXT { no waveform stats })

    active_metadata_large_file_contract:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "large_file_contract", fallback: TEXT { no large file materialized })

    active_metadata_hierarchy_page:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "hierarchy_page", fallback: TEXT { HIER:none })

    active_metadata_hierarchy_cursor:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "hierarchy_cursor", fallback: TEXT { hierarchy cursor none })

    active_metadata_materialization_bound:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "materialization_bound", fallback: TEXT { visible rows 0/0, waveform segments 0/256 max })

    active_metadata_time_unit:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "time_unit", fallback: TEXT { none })

    active_metadata_timescale:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "timescale", fallback: TEXT { no timescale })

    active_metadata_range_source:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "range_source", fallback: NoFile)

    active_metadata_source:
        List/find_value(waveform_file_metadata, field: "file", value: active_metadata_file, target: "metadata_source", fallback: NoFile)

    external_loaded_metadata_format:
        elements.external_file_loaded_format.text

    external_loaded_metadata_digest:
        elements.external_file_loaded_digest.text

    external_loaded_metadata_waveform_ref:
        elements.external_file_loaded_waveform_ref.text

    external_loaded_metadata_stats:
        elements.external_file_loaded_stats.text

    external_loaded_metadata_large_file_contract:
        elements.external_file_loaded_contract.text

    effective_metadata_format:
        active_file |> WHEN {
            TEXT { none } => active_metadata_format
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_format
                False => active_metadata_format
            }
        }

    effective_metadata_digest:
        active_file |> WHEN {
            TEXT { none } => active_metadata_digest
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_digest
                False => active_metadata_digest
            }
        }

    effective_metadata_waveform_ref:
        active_file |> WHEN {
            TEXT { none } => active_metadata_waveform_ref
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_waveform_ref
                False => active_metadata_waveform_ref
            }
        }

    effective_metadata_stats:
        active_file |> WHEN {
            TEXT { none } => active_metadata_stats
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_stats
                False => active_metadata_stats
            }
        }

    effective_metadata_large_file_contract:
        active_file |> WHEN {
            TEXT { none } => active_metadata_large_file_contract
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_large_file_contract
                False => active_metadata_large_file_contract
            }
        }

    compare_file:
        LATEST {
            TEXT { none }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { simple.vcd } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.external_file_loaded_name.text |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    file_compare_status:
        LATEST {
            TEXT { single file: simple.vcd }
            elements.select_counter_file.event.press |> THEN { TEXT { single file: simple.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { comparing simple.vcd to wave_27.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { single file: simple_test.ghw } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { opening simple.vcd } }
            elements.load_default_file.event.press |> THEN { TEXT { single file: simple.vcd } }
            elements.external_file_loaded_name.text |> THEN {
                TEXT { local file: } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
            }
            elements.show_empty.event.press |> THEN { TEXT { no waveform loaded } }
        }

    file_compare_descriptor:
        [
            primary: active_file
            compare: compare_file
            status: file_compare_status
            page: compare_request_page
            source: TEXT { wellen-page-data }
            bridge_contract: TEXT { wellen.v1 }
            waveform_ref: bridge_waveform_ref
        ]

    bridge_file_format:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { VCD }
            False => effective_metadata_format
        }

    bridge_file_digest:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { sha256:78e6f482fe39dd5ae04a7162d27f513d6a57be6e9d1a948b916167459bead01e }
            False => effective_metadata_digest
        }

    bridge_waveform_ref:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { diagnostic:unsupported-corrupted-vcd }
            False => waveform_status == Loading |> WHEN {
                True => TEXT { wave:opening:simple }
                False => effective_metadata_waveform_ref
            }
        }

    bridge_descriptor_file:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { corrupted.vcd }
            False => active_file
        }

    bridge_open_status:
        LATEST {
            TEXT { FILE_READY }
            elements.select_counter_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.select_ghw_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { OPENING } }
            elements.load_default_file.event.press |> THEN { TEXT { FILE_READY } }
            elements.external_file_loaded_name.text |> THEN { TEXT { FILE_READY } }
            elements.show_empty.event.press |> THEN { TEXT { NOT_REQUESTED } }
        }

    bridge_open_summary:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { unsupported waveform file: corrupted.vcd }
            False => waveform_status |> WHEN {
                Empty => TEXT { no file loaded }
                Loading => TEXT { opening VCD simple.vcd }
                __ => external_file_active == Yes |> WHEN {
                    True => TEXT { local file } |> Text/concat(with: active_file, separator: " ")
                    False => TEXT { opened } |> Text/concat(with: bridge_file_format, separator: " ") |> Text/concat(with: bridge_waveform_ref, separator: " ")
                }
            }
        }

    bridge_hierarchy_page_label:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { HIER:none }
            False => waveform_status |> WHEN {
                Empty => TEXT { HIER:none }
                Loading => TEXT { HIER:opening }
                __ => external_file_active == Yes |> WHEN {
                    True => TEXT { HIER:local file metadata }
                    False => active_metadata_hierarchy_page
                }
            }
        }

    bridge_file_stats_label:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { no waveform stats }
            False => waveform_status |> WHEN {
                Empty => TEXT { no waveform stats }
                Loading => TEXT { loading waveform stats }
                __ => effective_metadata_stats
            }
        }

    bridge_large_file_contract:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { corrupted.vcd 25B -> diagnostic only }
            False => waveform_status |> WHEN {
                Empty => TEXT { no large file materialized }
                Loading => TEXT { simple.vcd pending -> no page materialized }
                __ => effective_metadata_large_file_contract
            }
        }

    bridge_payload_limit_bytes: 65536
    bridge_transition_limit: 256
    bridge_visible_row_limit: 32
    bridge_segment_limit: 256

    bridge_page_window_label:
        bridge_request_window_label == TEXT { no request window } |> WHEN {
            True => TEXT { no page window scheduled }
            False =>
                TEXT { window }
                |> Text/concat(with: bridge_request_window_label, separator: " ")
                |> Text/concat(with: bridge_transition_limit, separator: ", max ")
                |> Text/concat(with: TEXT { transitions, payload <= 64KiB }, separator: " ")
        }

    bridge_hierarchy_page_cursor_label:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { hierarchy cursor none }
            False => waveform_status |> WHEN {
                Empty => TEXT { hierarchy cursor none }
                Loading => TEXT { hierarchy cursor opening }
                __ => external_file_active == Yes |> WHEN {
                    True => TEXT { hierarchy cursor root:0..64 next=local }
                    False => active_metadata_hierarchy_cursor
                }
            }
        }

    bridge_materialization_bound_label:
        selected_rows_removed_signal_id == TEXT { reset_n } |> WHEN {
            True => TEXT { visible rows 1/2, waveform segments 3/256 max }
            False => waveform_status == Loading |> WHEN {
                True => TEXT { visible rows 0/2, waveform segments 0/256 max }
                False => active_metadata_materialization_bound
            }
        }

    bridge_payload_bound_label:
        TEXT { payload <= 64KiB; full waveform never enters Boon }

    compare_request_page:
        LATEST {
            TEXT { compare:simple.vcd:primary }
            elements.select_counter_file.event.press |> THEN { TEXT { compare:simple.vcd:primary } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { compare:simple.vcd+wave_27.fst:0-240ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { compare:simple_test.ghw:primary } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { compare:simple.vcd:opening } }
            elements.load_default_file.event.press |> THEN { TEXT { compare:simple.vcd:primary } }
            elements.external_file_loaded_name.text |> THEN {
                TEXT { compare: } |> Text/concat(with: elements.external_file_loaded_name.text, separator: "") |> Text/concat(with: TEXT { primary }, separator: ":")
            }
            elements.show_empty.event.press |> THEN { TEXT { compare:none } }
        }

    compare_result_label:
        LATEST {
            TEXT { primary page: simple.vcd }
            elements.select_counter_file.event.press |> THEN { TEXT { primary page: simple.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { shared window: 0 ns - 240 ns, 2 files } }
            elements.select_ghw_file.event.press |> THEN { TEXT { primary page: simple_test.ghw, GHW file } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { opening page: simple.vcd } }
            elements.load_default_file.event.press |> THEN { TEXT { primary page: simple.vcd } }
            elements.external_file_loaded_name.text |> THEN {
                TEXT { primary page: } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
            }
            elements.show_empty.event.press |> THEN { TEXT { no compare page } }
        }

    file_status_detail:
        diagnostic_state == Unsupported |> WHEN {
            True => diagnostic_label
            False => compare_result_label
        }

    diagnostic_state:
        LATEST {
            OK
            elements.select_counter_file.event.press |> THEN { OK }
            elements.select_uart_compare_file.event.press |> THEN { OK }
            elements.select_ghw_file.event.press |> THEN { OK }
            elements.begin_default_file_load.event.press |> THEN { Loading }
            elements.load_default_file.event.press |> THEN { OK }
            elements.external_file_loaded_name.text |> THEN { OK }
            elements.external_file_load_error.text |> THEN { Unsupported }
            elements.show_empty.event.press |> THEN { Idle }
        }

    diagnostic_label:
        LATEST {
            TEXT { bridge diagnostics OK }
            elements.select_counter_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_ghw_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { loading waveform } }
            elements.load_default_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.external_file_loaded_name.text |> THEN { TEXT { local file metadata OK } }
            elements.external_file_load_error.text
            elements.show_empty.event.press |> THEN { TEXT { no file loaded } }
        }

    diagnostic_file:
        LATEST {
            TEXT { none }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.begin_default_file_load.event.press |> THEN { TEXT { none } }
            elements.load_default_file.event.press |> THEN { TEXT { none } }
            elements.external_file_loaded_path.text
            elements.external_file_load_error.text |> THEN { load_files_path }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    bridge_diagnostic:
        [
            kind: diagnostic_state
            file: diagnostic_file
            library: TEXT { wellen.v1 }
            message: diagnostic_label
        ]

    mode:
        LATEST {
            Dark
            elements.mode_to_light.event.press |> THEN { Light }
            elements.mode_to_dark.event.press |> THEN { Dark }
        }

    active_scope:
        startup_selected_scope_key |> HOLD active_scope {
            LATEST {
            elements.scope_cpu.event.press |> THEN { TEXT { simple_tb_s } }
            elements.scope_uart.event.press |> THEN { TEXT { top_uart } }
            elements.scope_analog.event.press |> THEN { TEXT { top_analog } }
            elements.select_counter_file.event.press |> THEN { store.startup_selected_scope_key }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { top_uart } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw_simple } }
            elements.load_default_file.event.press |> THEN { store.startup_selected_scope_key }
            elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    active_signal:
        startup_primary_signal |> HOLD active_signal {
            LATEST {
            signal_catalog
                |> List/map(signal_catalog_item, new: LATEST {
                    signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN { signal_catalog_item.key }
                })
                |> List/latest()
            elements.select_clk.event.press |> THEN { TEXT { clk } }
            elements.select_reset.event.press |> THEN { TEXT { reset_n } }
            elements.select_data.event.press |> THEN {
                active_signal |> WHEN {
                    data_bus => TEXT { none }
                    __ => TEXT { data_bus }
                }
            }
            elements.select_temperature.event.press |> THEN { TEXT { temperature } }
            elements.select_counter_file.event.press |> THEN { TEXT { clk } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { tx_data } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw_counter } }
            elements.load_default_file.event.press |> THEN { store.startup_primary_signal }
            elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    signal_catalog:
        LIST {
            [key: TEXT { clk }, scope: TEXT { simple_tb.s }, name: TEXT { A[3:0] }, kind: TEXT { Wire }, bit_width: TEXT { 4-bit }, direction: TEXT { Signal }, family: TEXT { simple_vcd }, selected_initial: True]
            [key: TEXT { reset_n }, scope: TEXT { simple_tb.s }, name: TEXT { B[3:0] }, kind: TEXT { Wire }, bit_width: TEXT { 4-bit }, direction: TEXT { Signal }, family: TEXT { simple_vcd }, selected_initial: True]
            [key: TEXT { tx_data }, scope: TEXT { top.uart }, name: TEXT { tx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }, family: TEXT { uart }, selected_initial: True]
            [key: TEXT { rx_data }, scope: TEXT { top.uart }, name: TEXT { rx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Input }, family: TEXT { uart }, selected_initial: True]
            [key: TEXT { baud_tick }, scope: TEXT { top.uart }, name: TEXT { baud_tick }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { Clock }, family: TEXT { uart }, selected_initial: True]
            [key: TEXT { uart_busy }, scope: TEXT { top.uart }, name: TEXT { uart_busy }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { State }, family: TEXT { uart }, selected_initial: True]
            [key: TEXT { framing_error }, scope: TEXT { top.uart }, name: TEXT { framing_error }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Error }, family: TEXT { uart }, selected_initial: False]
            [key: TEXT { temperature }, scope: TEXT { top.analog }, name: TEXT { temperature }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Input }, family: TEXT { analog }, selected_initial: True]
            [key: TEXT { voltage }, scope: TEXT { top.analog }, name: TEXT { vcore }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Sense }, family: TEXT { analog }, selected_initial: False]
            [key: TEXT { ghw_counter }, scope: TEXT { ghw.simple }, name: TEXT { ghw.counter[3:0] }, kind: TEXT { Reg }, bit_width: TEXT { 4-bit }, direction: TEXT { Counter }, family: TEXT { ghw }, selected_initial: True]
            [key: TEXT { ghw_enable }, scope: TEXT { ghw.simple }, name: TEXT { ghw.enable }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }, family: TEXT { ghw }, selected_initial: True]
            [key: TEXT { ghw_state }, scope: TEXT { ghw.simple }, name: TEXT { ghw.state }, kind: TEXT { Reg }, bit_width: TEXT { 2-bit }, direction: TEXT { State }, family: TEXT { ghw }, selected_initial: True]
            [key: TEXT { ghw_clk }, scope: TEXT { ghw.simple }, name: TEXT { ghw.clk }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Clock }, family: TEXT { ghw }, selected_initial: False]
        }
        |> List/map(signal, new: new_signal(signal: signal))

    selected_signal_count:
        selected_rows_count

    row_selected_signal_key:
        signal_catalog
        |> List/map(signal_catalog_item, new: LATEST {
            signal_catalog_item.signal_elements.select_signal.event.press
                |> THEN { signal_catalog_item.key }
        })
        |> List/latest()

    selected_signal_family:
        startup_selected_family |> HOLD selected_signal_family {
            LATEST {
            elements.select_counter_file.event.press |> THEN { TEXT { simple_vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { uart } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw } }
            elements.scope_cpu.event.press |> THEN { TEXT { simple_vcd } }
            elements.scope_uart.event.press |> THEN { TEXT { uart } }
            elements.scope_analog.event.press |> THEN { TEXT { analog } }
            elements.load_default_file.event.press |> THEN { store.startup_selected_family }
            elements.show_empty.event.press |> THEN { store.startup_selected_family }
            }
        }

    selected_signal_defaults:
        LIST {
