FUNCTION waveform_trace_cell_dark(segment) {
    Scene/Element/label(
        element: []
        style: [width: Fill, height: NovyTheme/trace_height(state: segment.state), align: [column: Center], rounded_corners: 2, background: [color: TEXT { #06111F }], border: [color: TEXT { #1D4ED8 }], material: NovyTheme/trace_material(mode: PASSED.store.mode, state: segment.state)]
        label: Scene/Element/text(element: [], style: [...NovyTheme/font(mode: PASSED.store.mode, of: Mono), width: Fill, height: Fill, center: True, vertical_align: Center, color: TEXT { #7EA6D9 }], text: segment.label)
    )
}

FUNCTION waveform_trace_cell_sky(segment) {
    Scene/Element/label(
        element: []
        style: [width: Fill, height: NovyTheme/trace_height(state: segment.state), align: [column: Center], rounded_corners: 2, background: [color: TEXT { #0EA5E9 }], border: [color: TEXT { #BAE6FD }], material: NovyTheme/trace_material(mode: PASSED.store.mode, state: segment.state)]
        label: Scene/Element/text(element: [], style: [...NovyTheme/font(mode: PASSED.store.mode, of: Mono), width: Fill, height: Fill, center: True, vertical_align: Center, color: TEXT { #EAF4FF }], text: segment.label)
    )
}

