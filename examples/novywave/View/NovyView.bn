FUNCTION file_tree_row(row) {
    row.kind |> WHEN {
        FileTreeFile => file_tree_file_button(row: row)
        FileTreeScope => file_tree_scope_button(row: row)
        FileTreeSignals => NoElement
        __ => tree_child_row(label_text: file_tree_row_label(row: row), indent_width: row.indent_width)
    }
}

FUNCTION file_tree_file_button(row) {
    row.source_key |> WHEN {
        SelectCounterFile => file_tree_counter_file_button(row: row)
        SelectUartCompareFile => file_tree_uart_file_button(row: row)
        SelectGhwFile => file_tree_ghw_file_button(row: row)
        __ => file_tree_counter_file_button(row: row)
    }
}

FUNCTION file_tree_counter_file_button(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_counter_file], hovered: PASSED.store.elements.select_counter_file]
        style: [width: Fill, height: 22, paint: False]
        label: tree_row(label_text: row.label, indent_width: row.indent_width, selected: PASSED.store.active_file == row.selected_file)
    )
}

FUNCTION file_tree_loaded_file_button(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.file_row_select], hovered: PASSED.store.elements.file_row_select]
        style: [width: Fill, height: 22, paint: False]
        label: tree_row(label_text: row.label, indent_width: row.indent_width, selected: PASSED.store.active_file == row.selected_file)
    )
}

FUNCTION file_tree_uart_file_button(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_uart_compare_file], hovered: PASSED.store.elements.select_uart_compare_file]
        style: [width: Fill, height: 22, paint: False]
        label: tree_row(label_text: row.label, indent_width: row.indent_width, selected: PASSED.store.active_file == row.selected_file)
    )
}

FUNCTION file_tree_ghw_file_button(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_ghw_file], hovered: PASSED.store.elements.select_ghw_file]
        style: [width: Fill, height: 22, paint: False]
        label: tree_row(label_text: row.label, indent_width: row.indent_width, selected: PASSED.store.active_file == row.selected_file)
    )
}

FUNCTION file_tree_scope_button(row) {
    row.source_key |> WHEN {
        SelectSimpleScope => file_tree_simple_scope_button(row: row)
        SelectUartScope => file_tree_uart_scope_button(row: row)
        SelectAnalogScope => file_tree_analog_scope_button(row: row)
        SelectGhwFile => file_tree_ghw_scope_button(row: row)
        __ => file_tree_simple_scope_button(row: row)
    }
