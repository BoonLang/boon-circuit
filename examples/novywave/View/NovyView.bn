FUNCTION variables_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: Fill
            height: Fill
            padding: 10
            depth: 10
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #2563eb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 10
                style: [width: Fill, height: 38, paint: False]
                items: LIST {
                    panel_title(title_text: TEXT { Variables })
                    search_box()
                }
            )
            variables_list()
            search_result_line()
            inspector_strip()
            format_palette()
        }
    )
}

FUNCTION variables_list() {
    PASSED.store.signal_search_text == TEXT { data } |> WHEN {
        True => variables_list_data()
        False => PASSED.store.signal_search_text == TEXT { reset } |> WHEN {
            True => variables_list_reset()
            False => PASSED.store.signal_search_text == TEXT { temp } |> WHEN {
                True => variables_list_temperature()
                False => PASSED.store.signal_search_text == TEXT { clk } |> WHEN {
                    True => variables_list_clk()
                    False => PASSED.store.signal_search_text == TEXT { tx } |> WHEN {
                        True => variables_list_tx()
                        False => PASSED.store.signal_search_text == TEXT { vcore } |> WHEN {
                            True => variables_list_vcore()
                            False => PASSED.store.signal_search_text == TEXT { zzz } |> WHEN {
                                True => variables_list_empty()
                                False => variables_list_for_scope()
                            }
                        }
                    }
                }
            }
        }
    }
}

FUNCTION variables_list_for_scope() {
    PASSED.store.active_scope == TEXT { top_uart } |> WHEN {
        True => variables_list_uart()
        False => PASSED.store.active_scope == TEXT { top_analog } |> WHEN {
            True => variables_list_analog()
            False => variables_list_all()
        }
    }
}

FUNCTION variables_list_all() {
    variables_signal_list(list: NovyFixtures/scope_cpu_visible_signals(), height_value: 150)
}

FUNCTION variables_list_clk() {
    variables_signal_list(list: NovyFixtures/search_clock_signals(), height_value: 116)
}

FUNCTION variables_list_reset() {
    variables_signal_list(list: NovyFixtures/search_reset_signals(), height_value: 116)
}

FUNCTION variables_list_data() {
    variables_signal_list(list: NovyFixtures/search_data_signals(), height_value: 150)
}

FUNCTION variables_list_temperature() {
    variables_signal_list(list: NovyFixtures/search_temperature_signals(), height_value: 116)
}

FUNCTION variables_list_tx() {
    variables_signal_list(list: NovyFixtures/search_tx_signals(), height_value: 116)
}

FUNCTION variables_list_vcore() {
    variables_signal_list(list: NovyFixtures/search_vcore_signals(), height_value: 116)
}

FUNCTION variables_list_uart() {
    variables_signal_list(list: NovyFixtures/scope_uart_signals(), height_value: 150)
}

FUNCTION variables_list_analog() {
    variables_signal_list(list: NovyFixtures/scope_analog_signals(), height_value: 150)
}

FUNCTION variables_signal_list(list, height_value) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 4
        style: [width: Fill, height: height_value, paint: False, scroll_y: True, scrollbars: True]
        items:
            list |> List/map(signal, new: variable_result_row(signal: signal))
    )
}

FUNCTION variable_result_row(signal) {
    signal.id == TEXT { clk } |> WHEN {
        True => variable_clk_button()
        False => signal.id == TEXT { reset_n } |> WHEN {
            True => variable_reset_button()
            False => signal.id == TEXT { data_bus } |> WHEN {
                True => variable_data_button()
                False => signal.id == TEXT { temperature } |> WHEN {
                    True => variable_temperature_button()
                    False => variable_result_static_row(signal: signal)
                }
            }
        }
    }
}

FUNCTION variable_result_static_row(signal) {
    signal.id == TEXT { data_valid } |> WHEN {
        True => variable_data_valid_row()
        False => signal.id == TEXT { data_ready } |> WHEN {
            True => variable_data_ready_row()
            False => signal.id == TEXT { data_parity } |> WHEN {
                True => variable_data_parity_row()
                False => signal.id == TEXT { state } |> WHEN {
                    True => variable_state_row()
                    False => signal.id == TEXT { error_count } |> WHEN {
                        True => variable_error_count_row()
                        False => signal.id == TEXT { tx_data } |> WHEN {
                            True => variable_uart_tx_row()
                            False => signal.id == TEXT { rx_data } |> WHEN {
                                True => variable_uart_rx_row()
                                False => signal.id == TEXT { baud_tick } |> WHEN {
                                    True => variable_baud_tick_row()
                                    False => signal.id == TEXT { uart_busy } |> WHEN {
                                        True => variable_uart_busy_row()
                                        False => signal.id == TEXT { framing_error } |> WHEN {
                                            True => variable_framing_error_row()
                                            False => signal.id == TEXT { voltage } |> WHEN {
                                                True => variable_vcore_row()
                                                False => variable_static_row(
                                                    name_text: signal.name
                                                    chip_a: signal.kind
                                                    chip_b: signal.bit_width
                                                    chip_c: signal.direction
                                                )
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

FUNCTION variables_list_empty() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 116
            padding: 8
            rounded_corners: 8
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #90a4bf }
                    Light => TEXT { #60748b }
                }
            ]
            text: TEXT { No matching signals }
        )
    )
}

FUNCTION variable_clk_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_clk], hovered: PASSED.store.elements.select_clk]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_clk()
    )
}

FUNCTION variable_reset_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_reset], hovered: PASSED.store.elements.select_reset]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_reset()
    )
}

FUNCTION variable_data_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_data], hovered: PASSED.store.elements.select_data]
        style: [
            width: Fill
            height: 24
            rounded_corners: 8
            material: PASSED.store.active_signal == TEXT { data_bus } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
        ]
        label: variable_row_data()
    )
}

FUNCTION variable_temperature_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_temperature], hovered: PASSED.store.elements.select_temperature]
        style: [width: Fill, height: 24, paint: False]
        label: variable_row_temperature()
    )
}

FUNCTION variable_signal_button(signal) {
    Scene/Element/button(
        element: [
            event: [press: SOURCE]
            hovered: SOURCE
        ]
        style: [
            width: Fill
            height: 20
            rounded_corners: 8
            material: signal.selected_once |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => PASSED.store.active_signal == signal.key |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
                }
            }
        ]
        label: variable_static_row(
            name_text: signal.alias |> Text/is_empty() |> WHEN {
                True => signal.name
                False => signal.alias
            }
            chip_a: signal.kind
            chip_b: signal.bit_width
            chip_c: signal.direction
        )
    )
    |> SOURCE { signal.signal_elements.select_signal }
}

FUNCTION variable_data_valid_row() {
    variable_static_row(
        name_text: TEXT { data_valid }
        chip_a: TEXT { Wire }
        chip_b: TEXT { 1-bit }
        chip_c: TEXT { Output }
    )
}

