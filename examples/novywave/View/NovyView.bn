            element: []
            direction: Row
            gap: 4
            style: [width: 180, height: 28, paint: False, scroll_x: True, scrollbars: True]
            items:
                PASSED.store.markers |> List/map(marker, new: marker_row(marker: marker))
        )
        False => Scene/Element/label(
            element: []
            style: [width: 180, height: 28, paint: False]
            label: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
        )
