        element: []
        style: [width: Fill, height: NovyTheme/trace_height(state: segment.state), align: [column: Center], rounded_corners: 2, background: [color: TEXT { #1D4ED8 }], border: [color: TEXT { #60A5FA }], material: NovyTheme/trace_material(state: segment.state)]
        label: Scene/Element/text(element: [], style: [...NovyTheme/font(of: Mono), width: Fill, height: Fill, center: True, vertical_align: Center, color: TEXT { #DBEAFE }], text: segment.label)
    )
}

FUNCTION waveform_trace_cell_cyan(segment) {
    Scene/Element/label(
        element: []
        style: [width: Fill, height: NovyTheme/trace_height(state: segment.state), align: [column: Center], rounded_corners: 2, background: [color: TEXT { #0891B2 }], border: [color: TEXT { #A5F3FC }], material: NovyTheme/trace_material(state: segment.state)]
