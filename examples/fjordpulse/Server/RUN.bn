ArrivalAt\":\"2026-07-10T10:07:00Z\",\"aimedDepartureAt\":\"2026-07-10T10:06:00Z\",\"expectedDepartureAt\":\"2026-07-10T10:08:00Z\",\"realtime\":true,\"cancellation\":false}],\"refreshedAt\":\"2026-07-10T09:59:57Z\",\"lastSuccessfulAt\":\"2026-07-10T09:59:57Z\",\"warning\":null},\"upcomingStops\":[{\"stopPlaceId\":\"NSR:StopPlace:549\",\"quayId\":\"NSR:Quay:549\",\"name\":\"Førde sentrum\",\"order\":1,\"latitude\":61.456,\"longitude\":5.861,\"aimedArrivalAt\":\"2026-07-10T10:05:00Z\",\"expectedArrivalAt\":\"2026-07-10T10:07:00Z\",\"aimedDepartureAt\":\"2026-07-10T10:06:00Z\",\"expectedDepartureAt\":\"2026-07-10T10:08:00Z\",\"realtime\":true,\"cancellation\":false}]},\"meta\":{\"requestId\":\"req_vehicle\",\"updatedAt\":\"2026-07-10T10:00:00Z\"}}"
