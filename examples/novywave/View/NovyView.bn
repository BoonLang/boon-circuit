    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(of: Muted)
            width: Fill
            height: 18
            vertical_align: Center
            color: TEXT { #90A4BF }
        ]
        text: PASSED.store.search_result_label
    )
}

FUNCTION variable_name_text(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(of: Mono)
            width: 180
            height: Fill
            vertical_align: Center
            color: TEXT { #DBEAFE }
        ]
        text: label_text
    )
}

FUNCTION variable_chip_wire() {
    variable_chip_literal(label_text: TEXT { Wire })
}

FUNCTION variable_chip_analog() {
    variable_chip_literal(label_text: TEXT { Analog })
}

FUNCTION variable_chip_1bit() {
    variable_chip_literal(label_text: TEXT { 1-bit })
}

FUNCTION variable_chip_8bit() {
    variable_chip_literal(label_text: TEXT { 8-bit })
}

FUNCTION variable_chip_16bit() {
    variable_chip_literal(label_text: TEXT { 16-bit })
}

FUNCTION variable_chip_input() {
    variable_chip_literal(label_text: TEXT { Input })
}

FUNCTION variable_chip_output() {
    variable_chip_literal(label_text: TEXT { Output })
}

FUNCTION variable_chip_literal(label_text) {
    Scene/Element/label(
        element: []
        style: [
            width: 54
            height: 20
            rounded_corners: 10
            background: [color: TEXT { #1D4ED8 }]
            material: NovyTheme/material(of: MarkerChip)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Muted)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: label_text
        )
    )
}

FUNCTION inspector_strip() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 54, paint: False]
        items: LIST {
            inspector_row(row_label: TEXT { Active }, row_value: PASSED.store.active_signal_label)
            inspector_row(row_label: TEXT { Format }, row_value: PASSED.store.format_label)
            inspector_row(row_label: TEXT { Request }, row_value: PASSED.store.bridge_request_label)
            row_resize_controls()
        }
    )
}

FUNCTION inspector_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: 275
            height: Fill
            padding: 10
            depth: 10
            rounded_corners: 14
            material: NovyTheme/material(of: PanelSurface)
        ]
        items: LIST {
            panel_title(title_text: TEXT { Inspector })
            inspector_row(row_label: TEXT { Active signal }, row_value: PASSED.store.active_signal_label)
            inspector_row(row_label: TEXT { Format }, row_value: PASSED.store.format_label)
            inspector_row(row_label: TEXT { Viewport }, row_value: PASSED.store.viewport_label)
            inspector_row(row_label: TEXT { Request }, row_value: PASSED.store.bridge_request_label)
            inspector_row(row_label: TEXT { Bridge }, row_value: PASSED.store.bridge_contract)
            row_resize_controls()
        }
    )
}

FUNCTION inspector_row(row_label, row_value) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 52
            padding: 8
            rounded_corners: 9
            background: [color: TEXT { #101A2B }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: row_label, font: Muted, width: Fill, height: 16)
            text_line(label_text: row_value, font: Mono, width: Fill, height: 22)
        }
    )
}

FUNCTION row_resize_controls() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 36, paint: False]
        items: LIST {
            row_shorter_button()
            row_taller_button()
        }
    )
}

FUNCTION panel_title(title_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(of: Heading)
            width: Fill
            height: 24
            vertical_align: Center
            color: TEXT { #DCEAFF }
        ]
        text: title_text
    )
}

FUNCTION button_label(button_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(of: Body)
            width: Fill
            height: Fill
            center: True
            vertical_align: Center
            color: TEXT { #DBEAFE }
        ]
        text: button_text
    )
}

FUNCTION compact_button_style(button_width) {
    [
        width: button_width
        height: 32
        rounded_corners: 8
        spring_range: 3
        center: True
        background: [color: TEXT { #101A2B }]
        border: [color: TEXT { #334761 }]
        material: NovyTheme/material(of: HoverControl)
    ]
}

