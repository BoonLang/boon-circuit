FUNCTION library_source() {
    "FUNCTION render(profile) {\n    Scene/Element/stripe(\n        element: []\n        direction: Column\n        gap: 20\n        style: [\n            width: Fill\n            height: Fill\n            padding: [left: 34, right: 34, top: 38, bottom: 30]\n            background: [color: page_background()]\n        ]\n        items: LIST {\n            Scene/Element/text(\n                element: [tag: Heading]\n                style: [width: Fill, text_wrap: True, size: 38, weight: 700, color: heading_color()]\n                text: profile.name\n            )\n            Scene/Element/text(\n                element: []\n                style: [width: Fill, text_wrap: True, size: 19, line_height: 28, color: body_color()]\n                text: profile.introduction\n            )\n            Scene/Element/text(\n                element: []\n                style: [width: Fill, height: 24, size: 14, color: muted_color()]\n                text: profile.location\n            )\n            Scene/Element/block(\n                element: []\n                style: [width: Fill, height: 1, background: [color: divider_color()]]\n                child: Scene/Element/text(element: [], style: [height: 1], text: Text/empty())\n            )\n            Scene/Element/text(\n                element: [tag: Heading]\n                style: [width: Fill, height: 28, size: 19, weight: 700, color: heading_color()]\n                text: TEXT { Projects }\n            )\n            Scene/Element/stripe(\n                element: []\n                direction: Column\n                gap: 12\n                style: [width: Fill, paint: False]\n                items: profile.projects\n                    |> List/map(project, new: project_card(project: project))\n            )\n        }\n    )\n}\n\nFUNCTION project_card(project) {\n    Scene/Element/stripe(\n        element: []\n        direction: Column\n        gap: 5\n        style: [\n            width: Fill\n            padding: 12\n            rounded_corners: 5\n            background: [color: project_background()]\n            border: [color: divider_color()]\n            border_width: 1\n        ]\n        items: LIST {\n            Scene/Element/text(\n                element: []\n                style: [width: Fill, height: 24, size: 16, weight: 700, color: heading_color()]\n                text: project.title\n            )\n            Scene/Element/text(\n                element: []\n                style: [width: Fill, text_wrap: True, size: 14, line_height: 21, color: body_color()]\n                text: project.summary\n            )\n        }\n    )\n}\n\nFUNCTION page_background() {\n    Oklch[lightness:0.99,chroma:0.01,hue:150]\n}\n\nFUNCTION project_background() {\n    Oklch[lightness:1,chroma:0.005,hue:150]\n}\n\nFUNCTION heading_color() {\n    Oklch[lightness:0.23,chroma:0.04,hue:150]\n}\n\nFUNCTION body_color() {\n    Oklch[lightness:0.31,chroma:0.03,hue:150]\n}\n\nFUNCTION muted_color() {\n    Oklch[lightness:0.48,chroma:0.04,hue:150]\n}\n\nFUNCTION divider_color() {\n    Oklch[lightness:0.88,chroma:0.02,hue:150]\n}\n"
}
