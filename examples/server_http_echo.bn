store: [
    request: SOURCE

    first_path_segment:
        TEXT { none } |> HOLD first_path_segment {
            request.method |> THEN {
                List/get(request.path_segments, index: 0)
            }
        }

    request_method:
        TEXT { NONE } |> HOLD request_method {
            request.method |> THEN { request.method }
        }
]

outputs: [
    response: [
        status: 200
        body: store.request_method
            |> Text/concat(with: store.first_path_segment, separator: ":")
            |> Text/to_bytes(encoding: Utf8)
    ]
]

host_ports: [
    http: [
        request: store.request
        response: response
    ]
]
