FUNCTION waveform_transition_edge_blue() {
    Scene/Element/block(
        element: []
        style: [
            width: 1
            height: Fill
            background: [color: TEXT { #93C5FD }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: CursorGlow)
        ]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION waveform_transition_edge_dark() {
    Scene/Element/block(
        element: []
        style: [width: 1, height: Fill, background: [color: TEXT { #1D4ED8 }], material: NovyTheme/material(mode: PASSED.store.mode, of: CursorGlow)]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

