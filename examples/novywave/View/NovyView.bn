FUNCTION inspector_strip() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [width: Fill, height: 62, paint: False]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 6
                style: [width: Fill, height: 30, paint: False]
                items: LIST {
                    compact_inspector_row(row_label: TEXT { Active }, row_value: PASSED.store.active_signal_label, row_width: 118)
                    compact_inspector_row(row_label: TEXT { Format }, row_value: PASSED.store.format_label, row_width: 76)
                    compact_inspector_row(row_label: TEXT { View }, row_value: PASSED.store.keyboard_viewport_label, row_width: 118)
                    row_resize_controls_compact()
                }
            )
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 6
                style: [width: Fill, height: 30, paint: False]
                items: LIST {
                    compact_inspector_row(row_label: TEXT { Cursor }, row_value: PASSED.store.keyboard_cursor_label, row_width: 76)
                    compact_inspector_row(row_label: TEXT { Request }, row_value: PASSED.store.bridge_request_compact_label, row_width: 118)
                    compact_inspector_row(row_label: TEXT { Response }, row_value: PASSED.store.bridge_response_compact_label, row_width: 104)
                    compact_inspector_row(row_label: TEXT { Match }, row_value: PASSED.store.bridge_response_status_compact_label, row_width: 82)
                }
            )
        }
    )
}

FUNCTION inspector_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: 275
            height: Fill
            padding: 10
            depth: 10
            rounded_corners: 14
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            panel_title(title_text: TEXT { Inspector })
            inspector_row(row_label: TEXT { Active signal }, row_value: PASSED.store.active_signal_label)
            inspector_row(row_label: TEXT { Format }, row_value: PASSED.store.format_label)
            inspector_row(row_label: TEXT { Cursor }, row_value: PASSED.store.keyboard_cursor_label)
            inspector_row(row_label: TEXT { Viewport }, row_value: PASSED.store.keyboard_viewport_label)
            inspector_row(row_label: TEXT { Open result }, row_value: PASSED.store.bridge_waveform_ref)
            inspector_row(row_label: TEXT { Hierarchy }, row_value: PASSED.store.bridge_hierarchy_page_label)
            inspector_row(row_label: TEXT { Page request }, row_value: PASSED.store.bridge_request_label)
            inspector_row(row_label: TEXT { Page response }, row_value: PASSED.store.bridge_response_fingerprint)
            inspector_row(row_label: TEXT { Page match }, row_value: PASSED.store.bridge_response_status)
            inspector_row(row_label: TEXT { Cursor values }, row_value: PASSED.store.bridge_cursor_values_label)
            inspector_row(row_label: TEXT { Bridge policy }, row_value: PASSED.store.bridge_data_policy)
            inspector_row(row_label: TEXT { Payload bound }, row_value: PASSED.store.bridge_payload_bound_label)
            row_resize_controls()
        }
    )
}

FUNCTION inspector_row(row_label, row_value) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 52
            padding: 8
            rounded_corners: 9
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: row_label, font: Muted, width: Fill, height: 16)
            text_line(label_text: row_value, font: Mono, width: Fill, height: 22)
        }
    )
}

FUNCTION compact_inspector_row(row_label, row_value, row_width) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: row_width
            height: 29
            padding: [left: 8, right: 8, top: 2, bottom: 2]
            rounded_corners: 9
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: row_label, font: Muted, width: Fill, height: 10)
            text_line(label_text: row_value, font: Mono, width: Fill, height: 14)
        }
    )
}

FUNCTION row_resize_controls() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 36, paint: False]
        items: LIST {
            row_shorter_button()
            row_taller_button()
        }
    )
}

FUNCTION row_resize_controls_compact() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: 104, height: 28, paint: False]
        items: LIST {
            row_shorter_button_compact()
            row_taller_button_compact()
        }
    )
}

FUNCTION format_palette() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 4
        style: [
            width: Fill
            height: PASSED.store.format_dropdown_state == Open |> WHEN {
                True => 154
                False => 32
            }
            paint: False
        ]
        items: LIST {
            format_dropdown_button()
            format_dropdown_state_menu()
        }
    )
}

FUNCTION format_dropdown_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.format_dropdown_toggle]
            hovered: PASSED.store.elements.format_dropdown_toggle
        ]
        style: [
            width: Fill
            height: 30
            padding: [left: 10, right: 10]
            rounded_corners: 8
            spring_range: 3
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            __hover_background: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1a2b44 }
                Light => TEXT { #e9f3ff }
            }
            border: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.format_dropdown_state == Open |> WHEN {
                    True => TEXT { #65b8ff }
                    False => TEXT { #334761 }
                }
                Light => PASSED.store.format_dropdown_state == Open |> WHEN {
                    True => TEXT { #2474bb }
                    False => TEXT { #bad0e8 }
                }
            }]
            material: PASSED.store.format_dropdown_state == Open |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: FocusedControl)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
            __hover_gloss: 0.08
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 8
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                text_line(label_text: TEXT { Formatter }, font: Muted, width: 78, height: Fill)
                text_line(label_text: PASSED.store.format_label, font: Mono, width: Fill, height: Fill)
                text_line(label_text: TEXT { v }, font: Body, width: 18, height: Fill)
            }
        )
    )
}

FUNCTION format_dropdown_state_menu() {
    PASSED.store.format_dropdown_state == Open |> WHEN {
        True => format_dropdown_menu()
        False => format_dropdown_closed_menu()
    }
}

FUNCTION format_dropdown_closed_menu() {
    Scene/Element/label(
        element: []
        style: [width: Fill, height: 0, paint: False]
        label: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION format_dropdown_menu() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 120
            padding: 4
            rounded_corners: 8
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0b1424 }
                Light => TEXT { #edf4fb }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #304057 }
                Light => TEXT { #bad0e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            scroll_y: True
            scrollbars: True
        ]
        items: LIST {
            format_hex_dropdown_option()
            format_binary_dropdown_option()
            format_grouped_dropdown_option()
            format_octal_dropdown_option()
            format_signed_dropdown_option()
            format_unsigned_dropdown_option()
            format_ascii_dropdown_option()
        }
    )
}

FUNCTION format_hex_dropdown_option() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.format_hex], hovered: PASSED.store.elements.format_hex]
        style: format_dropdown_option_style(selected: PASSED.store.value_format == Hexadecimal)
        label: format_dropdown_option_label(option_text: TEXT { Hex }, selected: PASSED.store.value_format == Hexadecimal)
    )
}

