FUNCTION tree_section_header(label_text) {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 22
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0b1424 }
                Light => TEXT { #edf4fb }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1e2e45 }
                Light => TEXT { #d2dfec }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #93c5fd }
                    Light => TEXT { #25577f }
                }
            ]
            text: label_text
        )
    )
}

FUNCTION tree_child_row(label_text, indent_width) {
    tree_row(label_text: label_text, indent_width: indent_width, selected: False)
}

FUNCTION tree_row(label_text, indent_width, selected) {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 22
            padding: [left: 5, right: 6]
            rounded_corners: 4
            background: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #203B62 }
                    Light => TEXT { #d7e9ff }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #101a2b }
                    Light => TEXT { #ffffff }
                }
            }]
            border: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #3B82F6 }
                    Light => TEXT { #2474bb }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #263753 }
                    Light => TEXT { #d7dde8 }
                }
            }]
            material: selected |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 5
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                tree_indent(width_value: indent_width)
                tree_bullet(selected: selected)
                tree_row_text(label_text: label_text, selected: selected)
            }
        )
    )
}

FUNCTION tree_row_text(label_text, selected) {
    selected |> WHEN {
        True => PASSED.store.mode |> WHEN {
            Dark => tree_row_text_selected_dark(label_text: label_text)
            Light => tree_row_text_selected_light(label_text: label_text)
        }
        False => PASSED.store.mode |> WHEN {
            Dark => tree_row_text_resting_dark(label_text: label_text)
            Light => tree_row_text_resting_light(label_text: label_text)
        }
    }
}

FUNCTION tree_row_text_selected_dark(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #f4fbff }
        ]
        text: label_text
    )
}

FUNCTION tree_row_text_selected_light(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #10243a }
        ]
        text: label_text
    )
}

FUNCTION tree_row_text_resting_dark(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #eaf3ff }
        ]
        text: label_text
    )
}

FUNCTION tree_row_text_resting_light(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #172033 }
        ]
        text: label_text
    )
}

FUNCTION tree_indent(width_value) {
    Scene/Element/label(
        element: []
        style: [
            width: width_value
            height: Fill
            paint: False
        ]
        label: Scene/Element/text(
            element: []
            style: [width: Fill, height: Fill, color: TEXT { #00000000 }]
            text: Text/empty()
        )
    )
}

FUNCTION tree_bullet(selected) {
    Scene/Element/label(
        element: []
        style: [
            width: 5
            height: Fill
            rounded_corners: 1
            background: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #7dd3fc }
                    Light => TEXT { #2474bb }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #5f7898 }
                    Light => TEXT { #b8cbe0 }
