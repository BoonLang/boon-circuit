FUNCTION file_tree_simple_scope_button(row) {
    PASSED.store.scope_cpu_expansion_state |> WHEN {
        Collapsed => file_tree_simple_scope_expand_button(row: row)
        __ => file_tree_simple_scope_expanded_row(row: row)
    }
}

FUNCTION file_tree_simple_scope_select_button(row) {
