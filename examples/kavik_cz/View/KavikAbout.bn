FUNCTION page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 36
        style: [width: Fill, paint: False]
        items: LIST {
            about_hero()
            beginning()
            drawings()
            poetry()
            emptiness()
            hardware_detours()
            testing_gravity()
            life()
            partner()
            KavikComponents/contact_section(PASS: [store: PASSED.store])
        }
    )
}

FUNCTION section(title, subtitle, items) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 16
        style: [
            ...KavikTheme/panel_alt(mode: PASSED.store.mode)
            width: Fill
            padding: [left: 20, right: 20, top: 24, bottom: 24]
        ]
        items: LIST {
            KavikComponents/section_header(title: title, subtitle: subtitle, PASS: [store: PASSED.store])
            Scene/Element/stripe(
                element: []
                direction: Column
                gap: 16
                style: [width: Fill, paint: False]
                items: items
            )
        }
    )
}

FUNCTION about_hero() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 28
        style: [
            width: Fill
            wrap: True
            wrap_min_width: 330
            padding: [top: 44, bottom: 24]
            paint: False
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Column
                gap: 10
                style: [width: Fill, padding: 14, paint: False]
                items: LIST {
                    KavikComponents/heading(text: TEXT { About Martin }, size: 50, PASS: [store: PASSED.store])
                    KavikComponents/muted(text: TEXT { Toolmaker. Explorer. }, PASS: [store: PASSED.store])
                    KavikComponents/paragraph(text: TEXT { I build tools across product design, Rust, WebAssembly, native graphics, programming languages, and hardware experiments. }, PASS: [store: PASSED.store])
                }
            )
            KavikComponents/image(
                url: TEXT { asset://kavik_cz/images/martin_trondheim.jpg }
                alt: TEXT { Martin Kavik in a forest near Trondheim }
                aspect: 1.5
                PASS: [store: PASSED.store]
            )
        }
    )
}

FUNCTION beginning() {
    section(
        title: TEXT { The Beginning }
        subtitle: TEXT { Coming full circle. }
        items: LIST {
            KavikComponents/paragraph(text: TEXT { When I returned from kindergarten, I noticed a weird box in our living room. Dad whispered magic spells a wizard had taught him: restart in MS-DOS mode, then write cd games. The curse started with Supaplex. A couple of years later I killed the computer by trying to compress its hard disk. }, PASS: [store: PASSED.store])
            KavikComponents/paragraph(text: TEXT { At thirteen I built an antenna holder to finally get internet, then learned C# from a Czech school website. I chose programming over 3D graphics because making something out of nothing felt like the ultimate creativity. Now RayBox brings me back to 3D, and AI in terminals brings me back to MS-DOS. }, PASS: [store: PASSED.store])
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 14
                style: [width: Fill, wrap: True, wrap_min_width: 300, paint: False]
                items: LIST {
                    KavikComponents/media(
                        title: TEXT { 3D Kitchen, 2008 }
                        video_id: TEXT { FAJVs5GcArQ }
                        poster_url: TEXT { asset://kavik_cz/images/videos/kitchen.jpg }
                        to: TEXT { https://www.youtube.com/watch?v=FAJVs5GcArQ }
                        PASS: [store: PASSED.store]
                    )
                    KavikComponents/media(
                        title: TEXT { Case modding, 2009 }
                        video_id: TEXT { Ics_QWPZATk }
                        poster_url: TEXT { asset://kavik_cz/images/videos/case-modding.jpg }
                        to: TEXT { https://www.youtube.com/watch?v=Ics_QWPZATk }
                        PASS: [store: PASSED.store]
                    )
                }
            )
        }
    )
}

FUNCTION drawings() {
    section(
        title: TEXT { Drawings }
        subtitle: TEXT { Drawn from the rough. }
        items: LIST {
            KavikComponents/paragraph(text: TEXT { At fifteen I moved with my mum and sister from a small spa town to a grittier corner of Ostrava. The following years looped through school, gym, programming, games, and attempts at art. Drawing became a quiet escape and a brutal teacher: when you create, the gaps expose what you do not know. }, PASS: [store: PASSED.store])
            KavikComponents/paragraph(text: TEXT { I slowly learned to struggle well and trust my decisions. Soon I could help mum pay our rent from my first programming jobs, and the collection of drawings grew with me. }, PASS: [store: PASSED.store])
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 10
                style: [width: Fill, wrap: True, wrap_min_width: 220, paint: False]
                items: LIST {
                    gallery_image(file: TEXT { blue_eye.jpg }, alt: TEXT { Portrait drawing })
                    gallery_image(file: TEXT { mirror_boxer.jpg }, alt: TEXT { Boxer drawing })
                    gallery_image(file: TEXT { puzzle_man.jpg }, alt: TEXT { Puzzle man drawing })
                    gallery_image(file: TEXT { rain_girl.jpg }, alt: TEXT { Rain drawing })
                    gallery_image(file: TEXT { running_man.jpg }, alt: TEXT { Runner drawing })
                    gallery_image(file: TEXT { sunset_city.jpg }, alt: TEXT { Sunset city drawing })
                    gallery_image(file: TEXT { dino_rainbow_combined.jpg }, alt: TEXT { Rainbow dinosaur drawing })
                }
            )
        }
    )
}

FUNCTION gallery_image(file, alt) {
    KavikComponents/image(
        url: TEXT { asset://kavik_cz/images/about/{file} }
        alt: alt
        aspect: 1.15
        PASS: [store: PASSED.store]
    )
}

FUNCTION poetry() {
    section(
        title: TEXT { Poetry }
        subtitle: TEXT { Words and lines. }
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 16
                style: [width: Fill, wrap: True, wrap_min_width: 300, paint: False]
                items: LIST {
                    KavikComponents/image(url: TEXT { asset://kavik_cz/images/about/street.jpg }, alt: TEXT { Street drawing }, aspect: 0.78, PASS: [store: PASSED.store])
                    Scene/Element/stripe(
                        element: []
                        direction: Column
                        gap: 12
                        style: [width: Fill, paint: False]
                        items: LIST {
                            KavikComponents/paragraph(text: TEXT { Silhouette in the window. Watching street lamp in the moonlight. Holding the cup of cocoa. The clock's bell strikes the midnight. }, PASS: [store: PASSED.store])
                            Scene/Element/text(
                                element: []
                                style: [
                                    font: [family: TEXT { Liberation Mono }, weight: 500]
                                    width: Fill
                                    text_wrap: True
                                    padding: 14
                                    rounded_corners: 6
                                    background: [color: TEXT { #141925 }]
                                    color: TEXT { #c3cadb }
                                    size: 14
                                    line_height: 21
                                ]
                                text: TEXT { Duration[seconds: 4] |> Timer/interval() |> THEN Bell/strike() |> THEN 1 |> Math/sum() |> Scene/render() }
                            )
                        }
                    )
                }
            )
        }
    )
}

FUNCTION emptiness() {
    section(
        title: TEXT { The Emptiness }
        subtitle: TEXT { A guitar composition. }
        items: LIST {
            KavikComponents/media(
                title: TEXT { The Emptiness - guitar composition }
                video_id: TEXT { 3mNv0QXfPhE }
                poster_url: TEXT { asset://kavik_cz/images/videos/emptiness.jpg }
                to: TEXT { https://www.youtube.com/watch?v=3mNv0QXfPhE }
                PASS: [store: PASSED.store]
            )
            KavikComponents/paragraph(text: TEXT { There are three kinds of emptiness: the sad one when you miss something, the better one when fear of frustration is gone, and the best one when time distorts and everything but one thing ceases to exist. You enter flow while balancing on the edge of your skill and doing something you believe in. }, PASS: [store: PASSED.store])
            KavikComponents/paragraph(text: TEXT { I work in bursts and let the unconscious mind continue during pauses. Guitar became a quiet filler for those pauses. The urge to compose eventually won over the motivation to become technically good, so I wrote The Emptiness with pencil, tested it on a cheap guitar, and recreated the score years later. }, PASS: [store: PASSED.store])
            KavikComponents/image(url: TEXT { asset://kavik_cz/images/about/burlaks_on_volga.jpg }, alt: TEXT { Burlaks on the Volga by Ilya Repin }, aspect: 1.58, PASS: [store: PASSED.store])
        }
    )
}

FUNCTION hardware_detours() {
    section(
        title: TEXT { Hardware Detours }
        subtitle: TEXT { The universe pushes back. Since high school. }
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 14
                style: [width: Fill, wrap: True, wrap_min_width: 330, paint: False]
                items: LIST {
                    hardware_card(
                        title: TEXT { Car Diagnostics }
                        image_url: TEXT { asset://kavik_cz/images/about/car_diagnostics.jpg }
                        text: TEXT { My student car sometimes started and sometimes did not. Mechanics could not reproduce the heisenbug, so I learned OBD diagnostics, read forums, and eventually found a humidity-sensitive fuel-pump relay after a rainy night. Swapping it with the wiper relay downgraded Russian roulette to hoping it did not rain. }
                    )
                    hardware_card(
                        title: TEXT { Football Launcher }
                        image_url: TEXT { asset://kavik_cz/images/about/football_launcher_studio.jpg }
                        text: TEXT { An Atmel controller in C, a C# app, a PHP backend, Facebook integration, livestreaming, and an old concrete mixer became a football cannon. Capacitor discharges often killed the controller and required manual defibrillation, but the campaign reached 1.2 million Czech viewers. }
                    )
                }
            )
            KavikComponents/paragraph(text: TEXT { Both projects whispered the same lesson: hardware is subtle and quick to punish. Ten years later I am developing a language to write software and design hardware. I will create my own roulettes. }, PASS: [store: PASSED.store])
        }
    )
}

FUNCTION hardware_card(title, image_url, text) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [...KavikTheme/panel(mode: PASSED.store.mode), width: Fill, padding: 14]
        items: LIST {
            KavikComponents/image(url: image_url, alt: title, aspect: 1.5, PASS: [store: PASSED.store])
            KavikComponents/heading(text: title, size: 23, PASS: [store: PASSED.store])
            KavikComponents/paragraph(text: text, PASS: [store: PASSED.store])
        }
    )
}

