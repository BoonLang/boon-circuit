FUNCTION scope_cpu_button() {
    PASSED.store.active_scope == TEXT { top_cpu } |> WHEN {
        True => PASSED.store.scope_cpu_expansion_state == TEXT { Expanded } |> WHEN {
            True => scope_cpu_row_button(source: PASSED.store.elements.scope_cpu_collapse, label_text: TEXT { - top.cpu }, selected: True)
            False => scope_cpu_row_button(source: PASSED.store.elements.scope_cpu_expand, label_text: TEXT { + top.cpu }, selected: True)
        }
        False => scope_cpu_row_button(source: PASSED.store.elements.scope_cpu, label_text: TEXT { + top.cpu }, selected: False)
    }
}

FUNCTION scope_cpu_signal_rows() {
    PASSED.store.scope_cpu_expansion_state == TEXT { Expanded } |> WHEN {
        True => Scene/Element/stripe(
            element: []
            direction: Column
            gap: 2
            style: [width: Fill, height: 46, paint: False]
            items: LIST {
                tree_child_row(label_text: TEXT { clk reset_n data_bus }, indent_width: 28)
                tree_child_row(label_text: TEXT { data_valid data_ready state }, indent_width: 28)
            }
        )
        False => tree_child_row(label_text: TEXT { collapsed }, indent_width: 28)
    }
}

FUNCTION scope_cpu_row_button(source, label_text, selected) {
    Scene/Element/button(
        element: [event: [press: source], hovered: source]
        style: [
            width: Fill
            height: 22
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #203B62 }
                Light => TEXT { #d7e9ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #3B82F6 }
                Light => TEXT { #2474bb }
            }]
            spring_range: 3
            material: selected |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 8
            style: [paint: False]
            items: LIST {
                text_line(label_text: label_text, font: Body, width: Fill, height: 18)
                text_line(label_text: TEXT { 8 signals }, font: Muted, width: 70, height: 18)
            }
        )
    )
}

