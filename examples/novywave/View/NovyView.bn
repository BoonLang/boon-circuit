FUNCTION control_separator() {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: 12
            height: Fill
            center: True
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #90a4bf }
                Light => TEXT { #60748b }
            }
        ]
        text: TEXT { | }
    )
}

FUNCTION analog_limit_summary_text() {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: 118
            height: Fill
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #24364b }
            }
        ]
        text: PASSED.store.analog_limit_validity == TEXT { Rejected } |> WHEN {
            True => PASSED.store.analog_limit_error
            False => PASSED.store.analog_range_label
        }
    )
}

FUNCTION keyboard_capture() {
    Scene/Element/text_input(
        element: [
            event: [key_down: PASSED.store.elements.keyboard_capture]
        ]
        style: [
            width: 1
            height: 1
            paint: False
            padding: 0
            rounded_corners: 8
            font: NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Hidden[text: TEXT { keyboard capture }]
        text: Text/empty()
        placeholder: []
    )
}

FUNCTION timeline_axis() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 3
        style: [
            width: Fill
            height: 38
            padding: 5
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #eef5ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #93b4e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 0
                style: [width: Fill, height: 20, paint: False]
                items: LIST {
                    axis_tick(label: TEXT { 0 ns })
                    axis_tick(label: TEXT { 40 ns })
                    axis_tick(label: TEXT { 80 ns })
                    axis_tick(label: TEXT { 120 ns })
                    axis_tick(label: TEXT { 160 ns })
                }
            )
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 4
                style: [width: Fill, height: 16, paint: False]
                items: LIST {
                    cursor_chip()
                    PASSED.store.marker_count_label == TEXT { 1 marker } |> WHEN {
                        True => marker_chip()
                        False => NoElement
                    }
                }
            )
        }
    )
}

FUNCTION axis_tick(label) {
    Scene/Element/text(
