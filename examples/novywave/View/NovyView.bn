FUNCTION format_dropdown_option_style(selected) {
    [
            width: Fill
            height: 24
            padding: [left: 8, right: 8]
            rounded_corners: 6
            spring_range: 2
            background: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #203B62 }
                    Light => TEXT { #d7e9ff }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #101a2b }
                    Light => TEXT { #ffffff }
                }
            }]
            __hover_background: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1a2b44 }
                Light => TEXT { #e9f3ff }
            }
            border: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #65b8ff }
                    Light => TEXT { #2474bb }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #263753 }
                    Light => TEXT { #d7dde8 }
                }
            }]
            material: selected |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
            __hover_gloss: 0.08
    ]
}

FUNCTION format_dropdown_option_label(option_text, selected) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: Fill, paint: False]
        items: LIST {
            text_line(
                label_text: selected |> WHEN {
                    True => TEXT { * }
                    False => Text/empty()
                }
                font: Body
                width: 12
                height: Fill
            )
            text_line(label_text: option_text, font: Mono, width: Fill, height: Fill)
        }
    )
}

