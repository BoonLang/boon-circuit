[[step]]
id = "row-compact"
user_action = { kind = "click", target = "row shorter" }
expected_source_event = { source = "store.elements.row_shorter" }
expect_root_text = { "row_size" = "Compact", "row_height" = "34" }

[[step]]
id = "switch-light"
user_action = { kind = "click", target = "theme mode" }
expected_source_event = { source = "store.elements.mode_to_light" }
expect_root_text = { "mode" = "Light" }

[[step]]
id = "show-empty-state"
user_action = { kind = "click", target = "empty" }
expected_source_event = { source = "store.elements.show_empty" }
expect_root_text = { "fixture_status" = "Empty" }

[[step]]
id = "reload-fixture"
user_action = { kind = "click", target = "load fixture" }
expected_source_event = { source = "store.elements.load_fixture" }
expect_root_text = { "fixture_status" = "Loaded", "marker_visibility" = "Visible", "bridge_request_fingerprint" = "FP_CPU_DATA_CLOSE_RIGHT_36_BIN", "bridge_response_fingerprint" = "FP_CPU_DATA_CLOSE_RIGHT_36_BIN", "bridge_response_status_compact_label" = "CURRENT", "bridge_response_status" = "ACCEPTED_CURRENT_PAGE", "data_bus_rendered_value" = "00101010" }

[[step]]
id = "format-grouped-binary"
user_action = { kind = "click", target = "Grp" }
expected_source_event = { source = "store.elements.format_grouped" }
expect_root_text = { "value_format" = "GroupedBinary", "format_label" = "Grouped bin", "data_bus_rendered_value" = "0010 1010", "bridge_response_status_compact_label" = "STALE", "bridge_response_status" = "REJECTED_STALE_PAGE" }

[[step]]
id = "format-octal"
user_action = { kind = "click", target = "Oct" }
expected_source_event = { source = "store.elements.format_octal" }
expect_root_text = { "value_format" = "Octal", "format_label" = "Octal", "data_bus_rendered_value" = "052" }

[[step]]
id = "format-signed"
user_action = { kind = "click", target = "Sgn" }
expected_source_event = { source = "store.elements.format_signed" }
expect_root_text = { "value_format" = "Signed", "format_label" = "Signed", "data_bus_rendered_value" = "42" }

[[step]]
id = "format-unsigned"
user_action = { kind = "click", target = "Uns" }
expected_source_event = { source = "store.elements.format_unsigned" }
expect_root_text = { "value_format" = "Unsigned", "format_label" = "Unsigned", "data_bus_rendered_value" = "42" }

[[step]]
id = "format-ascii"
user_action = { kind = "click", target = "Asc" }
expected_source_event = { source = "store.elements.format_ascii" }
expect_root_text = { "value_format" = "ASCII", "format_label" = "ASCII", "data_bus_rendered_value" = "*" }

[[step]]
id = "format-hex"
user_action = { kind = "click", target = "Hex" }
expected_source_event = { source = "store.elements.format_hex" }
expect_root_text = { "value_format" = "Hexadecimal", "format_label" = "Hex", "data_bus_rendered_value" = "0x2a" }

[[step]]
id = "switch-dark"
user_action = { kind = "click", target = "theme mode" }
expected_source_event = { source = "store.elements.mode_to_dark" }
expect_root_text = { "mode" = "Dark" }

[[step]]
id = "final-marker-jump"
user_action = { kind = "click", target = "marker control", target_text = "Jump M" }
expected_source_event = { source = "store.elements.marker_jump", target_text = "Jump M" }
expect_root_text = { "mode" = "Dark", "marker_visibility" = "Visible", "marker_label" = "M data stable", "marker_focus_label" = "jumped to data stable at 42 ns", "cursor_position" = "Cursor42", "keyboard_cursor_label" = "42 ns" }
