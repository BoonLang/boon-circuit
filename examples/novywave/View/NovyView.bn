                        width: Fill
                        height: Fill
                        center: True
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: TEXT { Core bus group collapsed }
                )
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                        width: 112
                        height: Fill
                        center: True
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: TEXT { Expand group }
                )
            }
        )
    )
}

FUNCTION waveform_rows() {
    PASSED.store.selected_group == TEXT { Collapsed } |> WHEN {
        True => collapsed_group()
        False => waveform_rows_expanded()
    }
}

FUNCTION waveform_rows_expanded() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: Fill
            height: 124
            padding: 0
            rounded_corners: 0
            scroll_y: True
            scrollbars: True
            background: [color: TEXT { #020817 }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1f2a3c }
                Light => TEXT { #1f2a3c }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: WaveformGlass)
        ]
        items:
            PASSED.store.selected_signals |> List/map(row, new: selected_waveform_row(row: row))
    )
}

FUNCTION selected_waveform_row(row) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [width: Fill, height: PASSED.store.row_height + 3, paint: False]
        items: LIST {
            waveform_row(signal: row)
            signal_row_divider(signal: row)
        }
    )
}

FUNCTION waveform_cursor_line(segment) {
    Scene/Element/stripe(
        element: [event: [press: PASSED.store.elements.waveform_click, key_down: PASSED.store.elements.keyboard_capture], hovered: PASSED.store.elements.waveform_click, target: PASSED.store.keyboard_cursor_label]
        direction: Row
        gap: 0
        style: [
            width: segment.width + 3
            height: Fill
            paint: False
        ]
        items: LIST {
            waveform_cursor_spacer(width_value: segment.width)
            waveform_cursor_line_core()
        }
    )
}

FUNCTION waveform_cursor_spacer(width_value) {
    Scene/Element/block(
        element: []
        style: [width: width_value, height: Fill, paint: False]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION waveform_cursor_line_core() {
    Scene/Element/block(
        element: [target: PASSED.store.keyboard_cursor_label]
        style: [
            width: 3
            height: Fill
            rounded_corners: 1
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #FDE68A }
                Light => TEXT { #B45309 }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #FEF3C7 }
                Light => TEXT { #FDE68A }
            }]
            glow: [color: TEXT { #FDE68A99 }, intensity: 0.22]
            material: NovyTheme/material(mode: PASSED.store.mode, of: CursorGlow)
        ]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION waveform_marker_line() {
    PASSED.store.marker_visibility == TEXT { Visible } |> WHEN {
        True => Scene/Element/block(
            element: [event: [press: PASSED.store.elements.waveform_click, key_down: PASSED.store.elements.keyboard_capture], hovered: PASSED.store.elements.waveform_click, target: TEXT { 42 ns }]
            style: [
                width: 2
                height: Fill
                rounded_corners: 1
                background: [color: TEXT { #A78BFA }]
                material: NovyTheme/material(mode: PASSED.store.mode, of: MarkerChip)
            ]
            child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
        )
        __ => NoElement
    }
}

FUNCTION waveform_row(signal) {
    BLOCK {
        active: signal.id == PASSED.store.active_signal

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 0
                rounded_corners: 0
                background: [color: TEXT { #0b1220 }]
                border: [color: TEXT { #243449 }]
                material: active |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
                }
            ]
            items: LIST {
                signal_select_button(signal: signal)
                variables_name_divider()
                signal.id == TEXT { clk } |> WHEN {
                    True => value_pill_text(value_text: NovyModel/selected_clk_value_at_cursor(format: PASSED.store.value_format, cursor: PASSED.store.cursor_position))
                    False => signal.id == TEXT { reset_n } |> WHEN {
                        True => value_pill_text(value_text: NovyModel/selected_reset_value_at_cursor(format: PASSED.store.value_format, cursor: PASSED.store.cursor_position))
                        False => signal.id == TEXT { data_bus } |> WHEN {
                            True => value_pill_text(value_text: PASSED.store.data_bus_rendered_value)
                            False => signal.id == TEXT { temperature } |> WHEN {
                                True => value_pill_text(value_text: PASSED.store.temperature_rendered_value)
                                False => value_pill_text(value_text: NovyModel/cursor_signal_value(signal_id: signal.id, cursor: PASSED.store.cursor_position, format: PASSED.store.value_format, fallback: signal.current_value))
                            }
                        }
                    }
                }
                variables_value_divider()
                wave_area(signal: signal)
            }
        )
    }
}

FUNCTION signal_select_button(signal) {
    Scene/Element/label(
        element: []
        style: [
            width: PASSED.store.selected_name_column_width
            height: Fill
            padding: [left: 10, right: 8]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0A1322 }
                Light => TEXT { #FFFFFF }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #B8C8DF }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #dbeafe }
                    Light => TEXT { #172033 }
                }
            ]
            text: signal.name
        )
    )
}

FUNCTION selected_signal_remove_button(signal) {
    signal.id |> WHEN {
        TEXT { clk } => selected_signal_remove_clk_button()
        TEXT { reset_n } => selected_signal_remove_reset_button()
        TEXT { data_bus } => selected_signal_remove_data_button()
        TEXT { data_valid } => selected_signal_remove_data_valid_button()
        TEXT { data_ready } => selected_signal_remove_data_ready_button()
        TEXT { state } => selected_signal_remove_state_button()
        TEXT { error_count } => selected_signal_remove_error_count_button()
        TEXT { temperature } => selected_signal_remove_temperature_button()
        TEXT { tx_data } => selected_signal_remove_tx_data_button()
        TEXT { rx_data } => selected_signal_remove_rx_data_button()
        TEXT { baud_tick } => selected_signal_remove_baud_tick_button()
        TEXT { uart_busy } => selected_signal_remove_uart_busy_button()
        TEXT { ghw_counter } => selected_signal_remove_ghw_counter_button()
        TEXT { ghw_enable } => selected_signal_remove_ghw_enable_button()
        TEXT { ghw_state } => selected_signal_remove_ghw_state_button()
        __ => selected_signal_remove_data_button()
    }
}

