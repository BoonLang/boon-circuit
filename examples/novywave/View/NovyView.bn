FUNCTION collapsed_group() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.group_expand]
            hovered: PASSED.store.elements.group_expand
        ]
        style: [
            width: Fill
            height: 48
            rounded_corners: 10
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 12
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                        width: Fill
                        height: Fill
                        center: True
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: TEXT { Core bus group collapsed }
                )
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                        width: 112
                        height: Fill
                        center: True
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: TEXT { Expand group }
                )
            }
        )
    )
}

FUNCTION waveform_rows() {
    PASSED.store.selected_group == Collapsed |> WHEN {
        True => collapsed_group()
        False => waveform_rows_expanded()
    }
}

FUNCTION waveform_rows_expanded() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: Fill
            height: Fill
            padding: 0
            rounded_corners: 0
            scroll_y: True
            background: [color: TEXT { #020817 }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1f2a3c }
                Light => TEXT { #1f2a3c }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: WaveformGlass)
        ]
        items:
            PASSED.store.selected_signal_rows |> List/map(selected_signal, new: selected_waveform_row(row: selected_signal))
    )
}

