            )
        }
    )
}

FUNCTION wave_cell_analog_low(width_value, label_text) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [width: width_value, height: Fill, paint: False]
        items: LIST {
            waveform_transition_edge_indigo()
            Scene/Element/block(
                element: []
                style: [
                    width: Fill
                    height: 12
                    align: [column: Center]
                    rounded_corners: 3
                    background: [color: TEXT { #1D4ED8 }]
                    border: [color: TEXT { #60A5FA }]
                    material: NovyTheme/material(mode: PASSED.store.mode, of: AnalogTrace)
                ]
                child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
            )
        }
    )
}

FUNCTION wave_cell_analog_mid(width_value, label_text) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [width: width_value, height: Fill, paint: False]
        items: LIST {
            waveform_transition_edge_cyan()
            Scene/Element/block(
                element: []
                style: [
                    width: Fill
                    height: 20
                    align: [column: Center]
                    rounded_corners: 3
                    background: [color: TEXT { #0891B2 }]
                    border: [color: TEXT { #A5F3FC }]
                    material: NovyTheme/material(mode: PASSED.store.mode, of: AnalogTrace)
                ]
                child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
            )
        }
    )
}

FUNCTION wave_cell_analog_high(width_value, label_text) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [width: width_value, height: Fill, paint: False]
        items: LIST {
            waveform_transition_edge_pale()
            Scene/Element/block(
                element: []
                style: [
                    width: Fill
                    height: 28
                    align: [column: Center]
                    rounded_corners: 3
                    background: [color: TEXT { #7DD3FC }]
                    border: [color: TEXT { #E0F2FE }]
                    material: NovyTheme/material(mode: PASSED.store.mode, of: AnalogTrace)
                ]
                child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
            )
        }
    )
}

FUNCTION waveform_row(signal) {
    BLOCK {
        active: signal.id == PASSED.store.active_signal

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 9
                background: [color: TEXT { #101A2B }]
                border: [color: TEXT { #263753 }]
                material: active |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
                }
            ]
            items: LIST {
                signal_select_button(signal: signal)
                value_pill(signal: signal)
                wave_area(signal: signal)
            }
        )
    }
}

FUNCTION signal_select_button(signal) {
    Scene/Element/label(
        element: []
        style: [
            width: 145
            height: Fill
            padding: 6
            rounded_corners: 8
            background: [color: TEXT { #0A1322 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: signal.name
        )
    )
}

FUNCTION value_pill(signal) {
    Scene/Element/label(
        element: []
        style: [
            width: 86
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #111827 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: PASSED.store.value_format |> WHEN {
                TEXT { Binary } => signal.id |> WHEN {
                    TEXT { clk } => TEXT { 1b }
                    TEXT { reset_n } => TEXT { 1b }
                    TEXT { data_bus } => TEXT { 00101010 }
                    TEXT { temperature } => TEXT { analog }
                    __ => signal.current_value
                }
                __ => signal.current_value
            }
        )
    )
}

FUNCTION wave_area(signal) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 2
        style: [
            width: Fill
            height: Fill
            padding: [top: 6, bottom: 6, left: 8, right: 8]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #020817 }
                Light => TEXT { #f8fbff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1f2a3c }
                Light => TEXT { #b7c9e6 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TimelineGlass)
            scroll_x: True
            scrollbars: True
        ]
        items:
            NovyFixtures/segments(of: signal.id)
            |> List/map(segment, new: waveform_segment(segment: segment))
    )
}

FUNCTION waveform_segment(segment) {
    segment.state |> WHEN {
        High => waveform_segment_blue(segment: segment)
        Low => waveform_segment_dark(segment: segment)
        Unknown => waveform_segment_sky(segment: segment)
        AnalogLow => waveform_segment_indigo(segment: segment)
        AnalogMid => waveform_segment_cyan(segment: segment)
        AnalogHigh => waveform_segment_pale(segment: segment)
        __ => waveform_segment_sky(segment: segment)
    }
}

FUNCTION waveform_segment_blue(segment) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [
            width: segment.width
            height: Fill
            paint: False
        ]
        items: LIST {
            waveform_transition_edge_blue()
            waveform_trace_cell_blue(segment: segment)
        }
    )
}

FUNCTION waveform_segment_dark(segment) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [width: segment.width, height: Fill, paint: False]
        items: LIST {
            waveform_transition_edge_dark()
            waveform_trace_cell_dark(segment: segment)
        }
