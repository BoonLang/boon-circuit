}

FUNCTION mobile_station_sheet() {
    Scene/Element/block(
        element: []
        style: [
            width: Fill
            height: Fill
            padding: [
                top: PASSED.store.mobile_sheet |> WHEN {
                    Peek => 390
                    Half => 220
                    Full => 24
                }
                left: 8
                right: 8
            ]
            paint: False
        ]
        child: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 8
            style: [...FjordPulseTheme/panel(), width: Fill, height: Fill, padding: 12, scroll_y: True]
            items: LIST {
                mobile_sheet_controls()
                Scene/Element/stripe(
                    element: []
                    direction: Row
                    gap: 8
                    style: [width: Fill, paint: False]
                    items: LIST {
                        Scene/Element/stripe(
                            element: []
                            direction: Column
                            gap: 1
                            style: [width: Fill, paint: False]
                            items: LIST {
                                FjordPulseComponents/heading(value: FjordPulseModel/station_name(station: PASSED.store.selected_station), size: 21)
                                FjordPulseComponents/muted(value: FjordPulseModel/station_place(station: PASSED.store.selected_station))
                            }
                        )
                        FjordPulseComponents/icon_button(label: TEXT { × }, selected: False)
                            |> SOURCE { PASSED.store.elements.station.close }
                    }
                )
                station_body()
            }
        )
    )
}

FUNCTION mobile_vehicle_sheet() {
    Scene/Element/block(
        element: []
        style: [
            width: Fill
            height: Fill
            padding: [
                top: PASSED.store.mobile_sheet |> WHEN {
                    Peek => 390
                    Half => 220
                    Full => 24
                }
                left: 8
