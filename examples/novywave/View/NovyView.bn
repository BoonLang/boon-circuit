        style: [width: Fill, height: NovyTheme/trace_height(state: segment.state), align: [column: Center], rounded_corners: 2, background: [color: TEXT { #7DD3FC }], border: [color: TEXT { #E0F2FE }], material: NovyTheme/trace_material(mode: PASSED.store.mode, state: segment.state)]
        label: Scene/Element/text(element: [], style: [...NovyTheme/font(mode: PASSED.store.mode, of: Mono), width: Fill, height: Fill, center: True, vertical_align: Center, color: TEXT { #EAF4FF }], text: segment.label)
    )
