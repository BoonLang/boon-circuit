FUNCTION file_clear_all_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.show_empty]
            hovered: PASSED.store.elements.show_empty
        ]
        style: compact_button_style(button_width: 76, hovered: element.hovered)
        label: button_label(button_text: TEXT { Clear All })
    )
