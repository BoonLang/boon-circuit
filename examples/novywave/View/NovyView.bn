FUNCTION left_panel() {
    left_panel_base(panel_width: PASSED.store.files_panel_width, panel_height: Fill)
}

FUNCTION left_panel_docked() {
    left_panel_base(panel_width: Fill, panel_height: PASSED.store.files_panel_height)
}

FUNCTION left_panel_base(panel_width, panel_height) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 6
        style: [
            width: panel_width
            height: panel_height
            padding: 14
            depth: 10
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #304057 }
                Light => TEXT { #c9d7ea }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            panel_title(title_text: TEXT { Files and scopes })
            file_toolbar()
            file_status_card()
            files_list()
        }
    )
}

FUNCTION file_toolbar() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 28, paint: False]
        items: LIST {
            file_load_button()
            file_diagnostic_button()
        }
    )
}

FUNCTION file_status_card() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 38
            padding: [left: 8, right: 8]
            rounded_corners: 7
            background: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #422006 }
                    False => TEXT { #101a2b }
                }
                Light => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #fff7ed }
                    False => TEXT { #ffffff }
                }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #f59e0b }
                    False => TEXT { #263753 }
                }
                Light => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #fb923c }
                    False => TEXT { #d7dde8 }
                }
            }]
            material: PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: Warning)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 1
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                file_status_text(line_text: PASSED.store.file_compare_status, line_height: 17)
                file_status_text(
                    line_text: PASSED.store.bridge_open_summary
                    line_height: 15
                )
            }
        )
    )
}

FUNCTION file_status_text(line_text, line_height) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: line_height
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #24364b }
            }
        ]
        text: line_text
    )
}

FUNCTION files_list() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [width: Fill, height: 224, paint: False, scroll_y: True, scrollbars: True]
        items: LIST {
            tree_section_header(label_text: TEXT { Files })
            external_file_row()
            file_counter_button()
            file_uart_compare_button()
            file_ghw_button()
            tree_section_header(label_text: TEXT { Scopes })
            scope_cpu_button()
            scope_cpu_signal_rows()
            scope_uart_button()
            scope_analog_button()
        }
    )
}

FUNCTION external_file_row() {
    PASSED.store.external_file_active == TEXT { Yes } |> WHEN {
        True => tree_row(label_text: PASSED.store.external_file_tree_label, indent_width: 0, selected: True)
        __ => NoElement
    }
}

FUNCTION file_load_button() {
