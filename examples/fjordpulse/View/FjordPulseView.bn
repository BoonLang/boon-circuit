                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { 3 deterministiske overvåkinger }, english: TEXT { 3 deterministic watches })
            )
            FjordPulseComponents/data_row(label: TEXT { station:NSR:StopPlace:337 }, value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Aktiv · normal prioritet }, english: TEXT { Active · normal priority }))
            FjordPulseComponents/data_row(label: TEXT { vehicle:VEH:R10:1042 }, value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Aktiv · høy prioritet }, english: TEXT { Active · high priority }))
            FjordPulseComponents/data_row(label: TEXT { focus:VEH:R10:1042 }, value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Satt på pause av klienten }, english: TEXT { Paused by client }))
            FjordPulseComponents/muted(value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Visningen er skrivebeskyttet. Prioritet og livssyklus eies av Boon-serveren. }, english: TEXT { This view is read-only. Priority and lifecycle are owned by the Boon Server. }))
        }
    )
}

