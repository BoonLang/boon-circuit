            width: 1
            height: Fill
            background: [color: TEXT { #60A5FA }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TraceEdge)
        ]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
