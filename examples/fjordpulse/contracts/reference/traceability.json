  "nonWireStories": [
    { "story": "FP-001", "reason": "Public shell rendering has no additional wire shape." },
    { "story": "FP-006", "reason": "Selected-marker highlighting is frontend state." },
    { "story": "FP-031", "reason": "Focus-pill presentation consumes already-traced focus messages." },
    { "story": "FP-072", "reason": "Mobile default layout is a visual acceptance surface." },
    { "story": "FP-073", "reason": "Mobile half-sheet layout is a visual acceptance surface." },
    { "story": "FP-074", "reason": "Mobile full-sheet layout is a visual acceptance surface." },
    { "story": "FP-075", "reason": "Mobile Focus layout consumes already-traced vehicle and focus messages." },
    { "story": "FP-076", "reason": "Mobile lost layout consumes the already-traced vehicle_lost message." },
    { "story": "FP-077", "reason": "Design-system component reuse is not a wire contract." },
    { "story": "FP-083", "reason": "Privacy and no-account behavior are policy and UI requirements." },
    { "story": "FP-085", "reason": "Sharptech and Coolify deployment is an operator black-box surface, not an HTTP or realtime wire shape." },
    { "story": "FP-086", "reason": "Actual DNS, HTTPS, and WSS rollout is outside the local goal." },
    { "story": "FP-092", "reason": "Scheduled maintenance is an operational orchestration behavior." },
    { "story": "FP-093", "reason": "Static analysis is a repository quality gate." },
    { "story": "FP-100", "reason": "Accessibility is a UI and black-box quality surface." },
    { "story": "FP-101", "reason": "Performance is a runtime quality budget." },
    { "story": "FP-103", "reason": "Architecture documentation is a handoff artifact." },
    { "story": "FP-104", "reason": "Local-development documentation is a handoff artifact." },
    { "story": "FP-105", "reason": "Deployment documentation is a handoff artifact." },
    { "story": "FP-106", "reason": "Entur usage documentation is a handoff artifact." },
    { "story": "FP-107", "reason": "UI state documentation is a handoff artifact." },
    { "story": "FP-108", "reason": "Production readiness is the aggregate completion audit." }
