-- NovyWave - Boon-first physical waveform viewer playground example.

store: [
    visible_editor_reference: NovyReference/visual_basis_label()
    visible_editor_pipe_probe:
        LATEST {
            TEXT { Visible editor syntax probe }
            elements.load_fixture.event.press |> THEN { TEXT { Fixture syntax path exercised } }
        }

    elements: [
        begin_load_fixture: SOURCE
        load_fixture: SOURCE
        show_empty: SOURCE
        select_counter_file: SOURCE
        select_uart_compare_file: SOURCE
        select_ghw_file: SOURCE
        diagnostic_probe: SOURCE
        signal_search_focus_probe: SOURCE
        mode_to_light: SOURCE
        mode_to_dark: SOURCE
        zoom_in: SOURCE
        zoom_out: SOURCE
        pan_left: SOURCE
        pan_right: SOURCE
        cursor_left: SOURCE
        cursor_right: SOURCE
        marker_toggle: SOURCE
        marker_rename: SOURCE
        marker_remove: SOURCE
        marker_jump: SOURCE
        group_create: SOURCE
        group_toggle: SOURCE
        group_expand: SOURCE
        stale_response_probe: SOURCE
        row_taller: SOURCE
        row_shorter: SOURCE
        selected_remove_data: SOURCE
        selected_restore_data: SOURCE
        selected_data_up: SOURCE
        selected_data_down: SOURCE
        analog_limits_auto: SOURCE
        analog_limits_manual: SOURCE
        analog_limits_invalid: SOURCE
        format_cycle: SOURCE
        format_hex: SOURCE
        format_grouped: SOURCE
        format_octal: SOURCE
        format_signed: SOURCE
        format_unsigned: SOURCE
        format_ascii: SOURCE
        keyboard_capture: SOURCE
        signal_search_input: SOURCE
        scope_cpu: SOURCE
        scope_cpu_expand: SOURCE
        scope_cpu_collapse: SOURCE
        scope_uart: SOURCE
        scope_analog: SOURCE
        select_clk: SOURCE
        select_reset: SOURCE
        select_data: SOURCE
        select_temperature: SOURCE
    ]

    fixture_status:
        LATEST {
            TEXT { Empty }
            elements.show_empty.event.press |> THEN { TEXT { Empty } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { Loading } }
            elements.load_fixture.event.press |> THEN { TEXT { Loaded } }
        }

    empty_state_title: TEXT { No waveform loaded }
    empty_state_hint: TEXT { Drop or load a VCD, FST, or GHW waveform to inspect signals. }
    empty_state_bridge_label: TEXT { Bridge state: no request scheduled; pure descriptor is wave:none }
    empty_state_formats_label: TEXT { Supported fixture contracts: VCD, FST, GHW }
    loading_state_title: TEXT { Loading waveform }
    loading_state_hint: TEXT { Opening counter.vcd through wellen.v1 descriptor handshake. }
    reference_visual_basis: NovyReference/visual_basis_label()
    reference_loaded_basis: NovyReference/loaded_reference_label()
    reference_empty_basis: NovyReference/empty_reference_label()
    reference_workflow_basis: NovyReference/workflow_basis_label()
    reference_waveform_basis: NovyReference/waveform_basis_label()
    reference_comparison_status: NovyReference/comparison_compact_label()
    reference_descriptor: NovyReference/reference_descriptor()

    active_file:
        LATEST {
            TEXT { none }
            elements.select_counter_file.event.press |> THEN { TEXT { counter.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { uart_compare.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { simple_test.ghw } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { counter.vcd } }
            elements.load_fixture.event.press |> THEN { TEXT { counter.vcd } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    compare_file:
        LATEST {
            TEXT { none }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { counter.vcd } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { none } }
            elements.load_fixture.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    file_compare_status:
        LATEST {
            TEXT { no waveform loaded }
            elements.select_counter_file.event.press |> THEN { TEXT { single fixture: counter.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { comparing counter.vcd to uart_compare.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { single fixture: simple_test.ghw } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { opening counter.vcd } }
            elements.load_fixture.event.press |> THEN { TEXT { single fixture: counter.vcd } }
            elements.show_empty.event.press |> THEN { TEXT { no waveform loaded } }
        }

    file_compare_descriptor:
        [
            primary: active_file
            compare: compare_file
            status: file_compare_status
            page: compare_request_page
            source: TEXT { generated-fixture-page }
            bridge_contract: TEXT { wellen.v1 }
            waveform_ref: bridge_waveform_ref
        ]

    bridge_file_format:
        LATEST {
            TEXT { none }
            elements.select_counter_file.event.press |> THEN { TEXT { VCD } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { FST } }
            elements.select_ghw_file.event.press |> THEN { TEXT { GHW } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { VCD } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { VCD } }
            elements.load_fixture.event.press |> THEN { TEXT { VCD } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    bridge_file_digest:
        LATEST {
            TEXT { sha256:none }
            elements.select_counter_file.event.press |> THEN { TEXT { sha256:fixture-counter-vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { sha256:fixture-uart-fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { sha256:fixture-simple-ghw } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { sha256:fixture-corrupted-vcd } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { sha256:fixture-counter-vcd } }
            elements.load_fixture.event.press |> THEN { TEXT { sha256:fixture-counter-vcd } }
            elements.show_empty.event.press |> THEN { TEXT { sha256:none } }
        }

    bridge_waveform_ref:
        LATEST {
            TEXT { wave:none }
            elements.select_counter_file.event.press |> THEN { TEXT { wave:vcd:counter:0-240ns } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { wave:fst:uart-compare:0-240ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { wave:ghw:simple-test:0-100ns } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { diagnostic:unsupported-corrupted-vcd } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { wave:opening:counter } }
            elements.load_fixture.event.press |> THEN { TEXT { wave:vcd:counter:0-240ns } }
            elements.show_empty.event.press |> THEN { TEXT { wave:none } }
        }

    bridge_descriptor_file:
        LATEST {
            TEXT { none }
            elements.select_counter_file.event.press |> THEN { TEXT { counter.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { uart_compare.fst } }
            elements.select_ghw_file.event.press |> THEN { TEXT { simple_test.ghw } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { corrupted.vcd } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { counter.vcd } }
            elements.load_fixture.event.press |> THEN { TEXT { counter.vcd } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    bridge_open_status:
        LATEST {
            TEXT { NOT_REQUESTED }
            elements.select_counter_file.event.press |> THEN { TEXT { FIXTURE_READY } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { FIXTURE_READY } }
            elements.select_ghw_file.event.press |> THEN { TEXT { FIXTURE_READY } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { DIAGNOSTIC } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { OPENING } }
            elements.load_fixture.event.press |> THEN { TEXT { FIXTURE_READY } }
            elements.show_empty.event.press |> THEN { TEXT { NOT_REQUESTED } }
        }

    bridge_open_summary:
        LATEST {
            TEXT { no file loaded }
            elements.select_counter_file.event.press |> THEN { TEXT { fixture VCD wave:vcd:counter:0-240ns } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { fixture FST wave:fst:uart-compare:0-240ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { fixture GHW wave:ghw:simple-test:0-100ns } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { unsupported fixture: corrupted.vcd } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { opening VCD counter.vcd } }
            elements.load_fixture.event.press |> THEN { TEXT { fixture VCD wave:vcd:counter:0-240ns } }
            elements.show_empty.event.press |> THEN { TEXT { no file loaded } }
        }

    bridge_hierarchy_page_label:
        LATEST {
            TEXT { HIER:none }
            elements.select_counter_file.event.press |> THEN { TEXT { HIER:top.cpu/top.uart/top.analog } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { HIER:top.uart compare page } }
            elements.select_ghw_file.event.press |> THEN { TEXT { HIER:ghw.simple/counter } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { HIER:none } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { HIER:opening } }
            elements.load_fixture.event.press |> THEN { TEXT { HIER:top.cpu/top.uart/top.analog } }
            elements.show_empty.event.press |> THEN { TEXT { HIER:none } }
        }

    bridge_file_stats_label:
        LATEST {
            TEXT { no waveform stats }
            elements.select_counter_file.event.press |> THEN { TEXT { VCD 15 signals, 0-240ns, bounded pages } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { FST 5 signals, 0-240ns, bounded pages } }
            elements.select_ghw_file.event.press |> THEN { TEXT { GHW 4 signals, 0-100ns, bounded pages } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { no waveform stats } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { loading waveform stats } }
            elements.load_fixture.event.press |> THEN { TEXT { VCD 15 signals, 0-240ns, bounded pages } }
            elements.show_empty.event.press |> THEN { TEXT { no waveform stats } }
        }

    bridge_large_fixture_contract:
        LATEST {
            TEXT { no large file materialized }
            elements.select_counter_file.event.press |> THEN { TEXT { counter.vcd 311B -> bounded page requests only } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { wave_27.fst 28860652B -> bounded compare page only } }
            elements.select_ghw_file.event.press |> THEN { TEXT { simple_test.ghw 833B -> bounded page requests only } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { corrupted.vcd 25B -> diagnostic only } }
            elements.show_empty.event.press |> THEN { TEXT { no large file materialized } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { counter.vcd pending -> no page materialized } }
            elements.load_fixture.event.press |> THEN { TEXT { counter.vcd 311B -> bounded page requests only } }
        }

    bridge_payload_limit_bytes: 65536
    bridge_transition_limit: 256
    bridge_visible_row_limit: 32
    bridge_segment_limit: 256

    bridge_page_window_label:
        LATEST {
            TEXT { no page window scheduled }
            elements.select_counter_file.event.press |> THEN { TEXT { window 0-120ns, max 256 transitions, payload <= 64KiB } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { window 0-120ns, max 256 transitions, payload <= 64KiB } }
            elements.select_ghw_file.event.press |> THEN { TEXT { window 0-100ns, max 256 transitions, payload <= 64KiB } }
            elements.zoom_in.event.press |> THEN { TEXT { window 36-60ns, max 256 transitions, payload <= 64KiB } }
            elements.zoom_out.event.press |> THEN { TEXT { window 0-240ns, max 256 transitions, payload <= 64KiB } }
            elements.pan_left.event.press |> THEN { TEXT { window 24-48ns, max 256 transitions, payload <= 64KiB } }
            elements.pan_right.event.press |> THEN { TEXT { window 48-72ns, max 256 transitions, payload <= 64KiB } }
            elements.show_empty.event.press |> THEN { TEXT { no page window scheduled } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { no page window scheduled } }
            elements.load_fixture.event.press |> THEN { TEXT { window 0-120ns, max 256 transitions, payload <= 64KiB } }
        }

    bridge_hierarchy_page_cursor_label:
        LATEST {
            TEXT { hierarchy cursor none }
            elements.select_counter_file.event.press |> THEN { TEXT { hierarchy cursor root:0..64 next=top.cpu } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { hierarchy cursor top.uart:0..64 next=none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { hierarchy cursor ghw.simple:0..64 next=none } }
            elements.diagnostic_probe.event.press |> THEN { TEXT { hierarchy cursor none } }
            elements.show_empty.event.press |> THEN { TEXT { hierarchy cursor none } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { hierarchy cursor opening } }
            elements.load_fixture.event.press |> THEN { TEXT { hierarchy cursor root:0..64 next=top.cpu } }
        }

    bridge_materialization_bound_label:
        LATEST {
            TEXT { visible rows 0/0, waveform segments 0/256 max }
            elements.select_counter_file.event.press |> THEN { TEXT { visible rows 8/15, waveform segments 64/256 max } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { visible rows 4/5, waveform segments 28/256 max } }
            elements.select_ghw_file.event.press |> THEN { TEXT { visible rows 3/4, waveform segments 20/256 max } }
            elements.selected_remove_data.event.press |> THEN { TEXT { visible rows 7/15, waveform segments 56/256 max } }
            elements.show_empty.event.press |> THEN { TEXT { visible rows 0/0, waveform segments 0/256 max } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { visible rows 0/15, waveform segments 0/256 max } }
            elements.load_fixture.event.press |> THEN { TEXT { visible rows 8/15, waveform segments 64/256 max } }
        }

    bridge_payload_bound_label:
        TEXT { payload <= 64KiB; full waveform never enters Boon }

    compare_request_page:
        LATEST {
            TEXT { compare:none }
            elements.select_counter_file.event.press |> THEN { TEXT { compare:counter.vcd:primary } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { compare:counter.vcd+uart_compare.fst:0-240ns } }
            elements.select_ghw_file.event.press |> THEN { TEXT { compare:simple_test.ghw:primary } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { compare:counter.vcd:opening } }
            elements.load_fixture.event.press |> THEN { TEXT { compare:counter.vcd:primary } }
            elements.show_empty.event.press |> THEN { TEXT { compare:none } }
        }

    compare_result_label:
        LATEST {
            TEXT { no compare page }
            elements.select_counter_file.event.press |> THEN { TEXT { primary page: counter.vcd } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { shared window: 0 ns - 240 ns, 2 files } }
            elements.select_ghw_file.event.press |> THEN { TEXT { primary page: simple_test.ghw, GHW fixture } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { opening page: counter.vcd } }
            elements.load_fixture.event.press |> THEN { TEXT { primary page: counter.vcd } }
            elements.show_empty.event.press |> THEN { TEXT { no compare page } }
        }

    file_status_detail:
        diagnostic_state == TEXT { Unsupported } |> WHEN {
            True => diagnostic_label
            False => compare_result_label
        }

    diagnostic_state:
        LATEST {
            TEXT { Idle }
            elements.diagnostic_probe.event.press |> THEN { TEXT { Unsupported } }
            elements.select_counter_file.event.press |> THEN { TEXT { OK } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { OK } }
            elements.select_ghw_file.event.press |> THEN { TEXT { OK } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { Loading } }
            elements.load_fixture.event.press |> THEN { TEXT { OK } }
            elements.show_empty.event.press |> THEN { TEXT { Idle } }
        }

    diagnostic_label:
        LATEST {
            TEXT { no file loaded }
            elements.diagnostic_probe.event.press |> THEN { TEXT { unsupported fixture: corrupted.vcd } }
            elements.select_counter_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_ghw_file.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { loading waveform } }
            elements.load_fixture.event.press |> THEN { TEXT { bridge diagnostics OK } }
            elements.show_empty.event.press |> THEN { TEXT { no file loaded } }
        }

    diagnostic_file:
        LATEST {
            TEXT { none }
            elements.diagnostic_probe.event.press |> THEN { TEXT { corrupted.vcd } }
            elements.select_counter_file.event.press |> THEN { TEXT { none } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { none } }
            elements.select_ghw_file.event.press |> THEN { TEXT { none } }
            elements.begin_load_fixture.event.press |> THEN { TEXT { none } }
            elements.load_fixture.event.press |> THEN { TEXT { none } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    bridge_diagnostic:
        [
            kind: diagnostic_state
            file: diagnostic_file
            library: TEXT { wellen.v1 }
            message: diagnostic_label
        ]

    mode:
        LATEST {
            Dark
            elements.mode_to_light.event.press |> THEN { Light }
            elements.mode_to_dark.event.press |> THEN { Dark }
        }

    active_scope:
        LATEST {
            TEXT { none }
            elements.scope_cpu.event.press |> THEN { TEXT { top_cpu } }
            elements.scope_cpu_expand.event.press |> THEN { TEXT { top_cpu } }
            elements.scope_cpu_collapse.event.press |> THEN { TEXT { top_cpu } }
            elements.scope_uart.event.press |> THEN { TEXT { top_uart } }
            elements.scope_analog.event.press |> THEN { TEXT { top_analog } }
            elements.select_counter_file.event.press |> THEN { TEXT { top_cpu } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { top_uart } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw_simple } }
            elements.load_fixture.event.press |> THEN { TEXT { top_cpu } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
        }

    active_signal:
        TEXT { none } |> HOLD active_signal {
            LATEST {
            signal_catalog
                |> List/map(signal_catalog_item, new: LATEST {
                    signal_catalog_item.signal_elements.select_signal.event.press
                        |> THEN { signal_catalog_item.key }
                })
                |> List/latest()
            elements.select_clk.event.press |> THEN { TEXT { clk } }
            elements.select_reset.event.press |> THEN { TEXT { reset_n } }
            elements.select_data.event.press |> THEN {
                active_signal |> WHEN {
                    data_bus => TEXT { none }
                    __ => TEXT { data_bus }
                }
            }
            elements.select_temperature.event.press |> THEN { TEXT { temperature } }
            elements.select_counter_file.event.press |> THEN { TEXT { clk } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { tx_data } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw_counter } }
            elements.load_fixture.event.press |> THEN { TEXT { clk } }
            elements.show_empty.event.press |> THEN { TEXT { none } }
            }
        }

    signal_catalog:
        LIST {
            [key: TEXT { clk }, scope: TEXT { top.cpu }, name: TEXT { clk }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }, family: TEXT { clock }]
            [key: TEXT { reset_n }, scope: TEXT { top.cpu }, name: TEXT { reset_n }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }, family: TEXT { reset }]
            [key: TEXT { data_bus }, scope: TEXT { top.cpu }, name: TEXT { data_bus[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }, family: TEXT { data }]
            [key: TEXT { data_valid }, scope: TEXT { top.cpu }, name: TEXT { data_valid }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }, family: TEXT { data }]
            [key: TEXT { data_ready }, scope: TEXT { top.cpu }, name: TEXT { data_ready }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }, family: TEXT { data }]
            [key: TEXT { data_parity }, scope: TEXT { top.cpu }, name: TEXT { data_parity }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }, family: TEXT { data }]
            [key: TEXT { state }, scope: TEXT { top.cpu }, name: TEXT { state[2:0] }, kind: TEXT { Reg }, bit_width: TEXT { 3-bit }, direction: TEXT { State }, family: TEXT { state }]
            [key: TEXT { error_count }, scope: TEXT { top.cpu }, name: TEXT { error_count[15:0] }, kind: TEXT { Reg }, bit_width: TEXT { 16-bit }, direction: TEXT { Counter }, family: TEXT { state }]
            [key: TEXT { tx_data }, scope: TEXT { top.uart }, name: TEXT { tx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }, family: TEXT { uart }]
            [key: TEXT { rx_data }, scope: TEXT { top.uart }, name: TEXT { rx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Input }, family: TEXT { uart }]
            [key: TEXT { baud_tick }, scope: TEXT { top.uart }, name: TEXT { baud_tick }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { Clock }, family: TEXT { uart }]
            [key: TEXT { uart_busy }, scope: TEXT { top.uart }, name: TEXT { uart_busy }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { State }, family: TEXT { uart }]
            [key: TEXT { framing_error }, scope: TEXT { top.uart }, name: TEXT { framing_error }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Error }, family: TEXT { uart }]
            [key: TEXT { temperature }, scope: TEXT { top.analog }, name: TEXT { temperature }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Input }, family: TEXT { analog }]
            [key: TEXT { voltage }, scope: TEXT { top.analog }, name: TEXT { vcore }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Sense }, family: TEXT { analog }]
            [key: TEXT { ghw_counter }, scope: TEXT { ghw.simple }, name: TEXT { ghw.counter[3:0] }, kind: TEXT { Reg }, bit_width: TEXT { 4-bit }, direction: TEXT { Counter }, family: TEXT { ghw }]
            [key: TEXT { ghw_enable }, scope: TEXT { ghw.simple }, name: TEXT { ghw.enable }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }, family: TEXT { ghw }]
            [key: TEXT { ghw_state }, scope: TEXT { ghw.simple }, name: TEXT { ghw.state }, kind: TEXT { Reg }, bit_width: TEXT { 2-bit }, direction: TEXT { State }, family: TEXT { ghw }]
            [key: TEXT { ghw_clk }, scope: TEXT { ghw.simple }, name: TEXT { ghw.clk }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Clock }, family: TEXT { ghw }]
        }
        |> List/map(signal, new: new_signal(signal: signal))

    selected_signal_count:
        selected_rows_count

    row_selected_signal_key:
        signal_catalog
        |> List/map(signal_catalog_item, new: LATEST {
            signal_catalog_item.signal_elements.select_signal.event.press
                |> THEN { signal_catalog_item.key }
        })
        |> List/latest()

    selected_signal_fixture:
        LATEST {
            TEXT { counter }
            elements.select_counter_file.event.press |> THEN { TEXT { counter } }
            elements.select_uart_compare_file.event.press |> THEN { TEXT { uart } }
            elements.select_ghw_file.event.press |> THEN { TEXT { ghw } }
            elements.load_fixture.event.press |> THEN { TEXT { counter } }
            elements.show_empty.event.press |> THEN { TEXT { counter } }
        }

    selected_signal_defaults:
        LIST {
            [fixture: TEXT { counter }, id: TEXT { clk }, name: TEXT { clk }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { counter }, id: TEXT { reset_n }, name: TEXT { reset_n }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { counter }, id: TEXT { data_bus }, name: TEXT { data_bus[7:0] }, current_value: TEXT { 0x2a }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { counter }, id: TEXT { data_valid }, name: TEXT { data_valid }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { counter }, id: TEXT { data_ready }, name: TEXT { data_ready }, current_value: TEXT { 0 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { counter }, id: TEXT { state }, name: TEXT { state[2:0] }, current_value: TEXT { Run }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { counter }, id: TEXT { error_count }, name: TEXT { error_count[15:0] }, current_value: TEXT { 0 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { counter }, id: TEXT { temperature }, name: TEXT { temperature }, current_value: TEXT { 42.8 C }, kind: Analog, enabled: TEXT { loaded }]
            [fixture: TEXT { uart }, id: TEXT { tx_data }, name: TEXT { tx_data[7:0] }, current_value: TEXT { 0x55 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { uart }, id: TEXT { rx_data }, name: TEXT { rx_data[7:0] }, current_value: TEXT { 0xaa }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { uart }, id: TEXT { baud_tick }, name: TEXT { baud_tick }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { uart }, id: TEXT { uart_busy }, name: TEXT { uart_busy }, current_value: TEXT { 0 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { ghw }, id: TEXT { ghw_counter }, name: TEXT { ghw.counter[3:0] }, current_value: TEXT { 3 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { ghw }, id: TEXT { ghw_enable }, name: TEXT { ghw.enable }, current_value: TEXT { 1 }, kind: Digital, enabled: TEXT { loaded }]
            [fixture: TEXT { ghw }, id: TEXT { ghw_state }, name: TEXT { ghw.state }, current_value: TEXT { Count }, kind: Digital, enabled: TEXT { loaded }]
        }

    selected_waveform_segments:
        LIST {
            [signal_id: TEXT { clk }, width: 0, state: CursorLine, label: TEXT { cursor }]
            [signal_id: TEXT { clk }, width: 28, state: High, label: TEXT { 1 }]
            [signal_id: TEXT { clk }, width: 0, state: MarkerLine, label: TEXT { marker }]
