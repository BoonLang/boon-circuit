-- Generated fixture waveform data for the static NovyWave playground phase.

FUNCTION files() {
    LIST {
        [
            name: TEXT { counter.vcd }
            format: TEXT { VCD }
            range: TEXT { 0 ns - 240 ns }
            status: TEXT { loaded }
        ]
        [
            name: TEXT { uart_compare.fst }
            format: TEXT { FST }
            range: TEXT { 0 ns - 240 ns }
            status: TEXT { fixture }
        ]
        [
            name: TEXT { simple_test.ghw }
            format: TEXT { GHW }
            range: TEXT { 0 ns - 100 ns }
            status: TEXT { fixture }
        ]
    }
}

FUNCTION scopes() {
    LIST {
        [id: TEXT { top.cpu }, name: TEXT { top.cpu }, signal_count: TEXT { 8 signals }]
        [id: TEXT { top.uart }, name: TEXT { top.uart }, signal_count: TEXT { 5 signals }]
        [id: TEXT { top.analog }, name: TEXT { top.analog }, signal_count: TEXT { 2 signals }]
    }
}

FUNCTION scope_cpu_signals() {
    LIST {
        [id: TEXT { clk }, name: TEXT { clk }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }]
        [id: TEXT { reset_n }, name: TEXT { reset_n }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }]
        [id: TEXT { data_bus }, name: TEXT { data_bus[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }]
        [id: TEXT { data_valid }, name: TEXT { data_valid }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }]
        [id: TEXT { data_ready }, name: TEXT { data_ready }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }]
        [id: TEXT { data_parity }, name: TEXT { data_parity }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }]
        [id: TEXT { state }, name: TEXT { state[2:0] }, kind: TEXT { Reg }, bit_width: TEXT { 3-bit }, direction: TEXT { State }]
        [id: TEXT { error_count }, name: TEXT { error_count[15:0] }, kind: TEXT { Reg }, bit_width: TEXT { 16-bit }, direction: TEXT { Counter }]
    }
}

FUNCTION scope_cpu_visible_signals() {
    LIST {
        [id: TEXT { clk }, key: TEXT { clk }, name: TEXT { clk }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }]
        [id: TEXT { reset_n }, key: TEXT { reset_n }, name: TEXT { reset_n }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }]
        [id: TEXT { data_bus }, key: TEXT { data_bus }, name: TEXT { data_bus[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }]
        [id: TEXT { data_valid }, key: TEXT { data_valid }, name: TEXT { data_valid }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Output }]
        [id: TEXT { data_ready }, key: TEXT { data_ready }, name: TEXT { data_ready }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Input }]
    }
}

FUNCTION scope_uart_signals() {
    LIST {
        [id: TEXT { tx_data }, key: TEXT { tx_data }, name: TEXT { tx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Output }]
        [id: TEXT { rx_data }, key: TEXT { rx_data }, name: TEXT { rx_data[7:0] }, kind: TEXT { Wire }, bit_width: TEXT { 8-bit }, direction: TEXT { Input }]
        [id: TEXT { baud_tick }, key: TEXT { baud_tick }, name: TEXT { baud_tick }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { Clock }]
        [id: TEXT { uart_busy }, key: TEXT { uart_busy }, name: TEXT { uart_busy }, kind: TEXT { Reg }, bit_width: TEXT { 1-bit }, direction: TEXT { State }]
        [id: TEXT { framing_error }, key: TEXT { framing_error }, name: TEXT { framing_error }, kind: TEXT { Wire }, bit_width: TEXT { 1-bit }, direction: TEXT { Error }]
    }
}

FUNCTION scope_analog_signals() {
    LIST {
        [id: TEXT { temperature }, key: TEXT { temperature }, name: TEXT { temperature }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Input }]
        [id: TEXT { voltage }, key: TEXT { voltage }, name: TEXT { vcore }, kind: TEXT { Analog }, bit_width: TEXT { 16-bit }, direction: TEXT { Sense }]
    }
}

