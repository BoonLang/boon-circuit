-- Physical NovyWave scene view.

FUNCTION main_scene() {
    Scene/new(
        root: root()
        lights: [
            key: [x: -0.4, y: -0.8, z: 1.0, intensity: 0.78]
            rim: [x: 0.8, y: 0.2, z: 0.5, intensity: 0.22]
        ]
        geometry: [depth_scale: 1.0]
    )
}

FUNCTION root() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: Fill
            height: [sizing: Fill, minimum: Screen]
            padding: 0
            overlay_children: True
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f4f7fb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: AppBackground)
        ]
        items: LIST {
            app_shell_for_dialog_state()
            workspace_dialog()
            load_files_dialog()
        }
    )
}

FUNCTION app_shell_for_dialog_state() {
    PASSED.store.workspace_dialog == Open |> WHEN {
        True => modal_app_shell()
        False => PASSED.store.load_files_dialog == Open |> WHEN {
            True => modal_app_shell()
            False => app_shell()
        }
    }
}

FUNCTION app_shell() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [
            width: Fill
            height: [sizing: Fill, minimum: Screen]
            padding: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f4f7fb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: AppBackground)
        ]
        items: LIST {
            header()
            PASSED.store.waveform_status == Loading |> WHEN {
                True => loading_state()
                False => loaded_app()
            }
        }
    )
}

FUNCTION modal_app_shell() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [
            width: Fill
            height: [sizing: Fill, minimum: Screen]
            padding: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f4f7fb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: AppBackground)
        ]
        items: LIST {
            header()
            modal_content_underlay()
        }
    )
}

FUNCTION modal_content_underlay() {
    Scene/Element/block(
        element: []
        style: [
            width: Fill
            height: Fill
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f4f7fb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: AppBackground)
        ]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: 34
            depth: 4
            move: [closer: 2]
            rounded_corners: 8
            padding: [left: 10, right: 10, top: 5, bottom: 5]
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0f172a }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #25344f }
                Light => TEXT { #cbd5e1 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                    width: 104
                    height: Fill
                    vertical_align: Center
                    size: 18
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #d2def0 }
                        Light => TEXT { #475569 }
                    }
                ]
                text: TEXT { NovyWave }
            )
            header_workspace_button()
            header_workspace_path()
            header_panel_arrangement_button()
            header_mode_button()
        }
    )
}

FUNCTION workspace_dialog() {
    PASSED.store.workspace_dialog == Open |> WHEN {
        True => Scene/Element/stripe(
            element: []
            direction: Column
            gap: 12
            style: [
                width: Fill
                height: [sizing: Fill, minimum: Screen]
                padding: [left: 28, right: 28, top: 70, bottom: 28]
                background: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #020817e8 }
                    Light => TEXT { #e2e8f0e0 }
                }]
                material: NovyTheme/material(mode: PASSED.store.mode, of: DialogBackdrop)
            ]
            items: LIST {
                workspace_dialog_panel()
            }
        )
        __ => NoElement
    }
}

FUNCTION workspace_dialog_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [
            width: [sizing: Fill, maximum: 820]
            height: 610
            center: True
            depth: 30
            move: [closer: 13]
            rounded_corners: 14
            padding: [left: 16, right: 16, top: 14, bottom: 14]
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #07111fff }
                Light => TEXT { #ffffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #365a83 }
                Light => TEXT { #b7c9dd }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: Dialog)
        ]
        items: LIST {
            workspace_dialog_title()
            workspace_dialog_hint()
            workspace_recent_section()
            workspace_tree_section()
            workspace_dialog_selection()
            workspace_dialog_actions()
        }
    )
}

FUNCTION workspace_dialog_title() {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Heading)
            width: Fill
            height: 30
            vertical_align: Center
            size: 18
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #10243a }
            }
        ]
        text: PASSED.store.workspace_dialog_title
    )
}

FUNCTION workspace_dialog_hint() {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
            width: Fill
            height: 42
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #92a4bb }
                Light => TEXT { #42566d }
            }
        ]
        text: PASSED.store.workspace_dialog_hint
    )
}

FUNCTION workspace_recent_section() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [
            width: Fill
            height: 118
            padding: [left: 10, right: 10, top: 8, bottom: 8]
            rounded_corners: 8
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #09111f }
                Light => TEXT { #f4f8fc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #152236 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            workspace_section_title(label_text: TEXT { Recent workspaces })
            workspace_recent_repo_button()
            workspace_recent_b_button()
        }
    )
}

FUNCTION workspace_tree_section() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 292
            padding: [left: 10, right: 10, top: 8, bottom: 8]
            rounded_corners: 8
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #030813 }
                Light => TEXT { #f8fbff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1d2d45 }
                Light => TEXT { #c9d7ea }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            workspace_tree_static_row(label_text: TEXT { > target }, indent_width: 92)
            workspace_tree_static_row(label_text: TEXT { v test_files }, indent_width: 92)
            workspace_tree_static_row(label_text: TEXT { > dir_a }, indent_width: 116)
            workspace_tree_static_row(label_text: TEXT { > dir_b }, indent_width: 116)
            workspace_tree_static_row(label_text: TEXT { v my_workspaces }, indent_width: 116)
            workspace_tree_workspace_a_button()
            workspace_tree_workspace_b_button()
            workspace_tree_static_row(label_text: TEXT { > nested_dir }, indent_width: 116)
            workspace_tree_static_row(label_text: TEXT { > to_discover }, indent_width: 116)
            workspace_tree_repo_button()
        }
    )
}

FUNCTION workspace_section_title(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Heading)
            width: Fill
            height: 22
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #10243a }
            }
        ]
        text: label_text
    )
}

FUNCTION workspace_recent_repo_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.select_workspace_repo]
            hovered: PASSED.store.elements.select_workspace_repo
        ]
        style: [width: Fill, height: 34, paint: False]
        label: workspace_recent_label(label_text: TEXT { /home/martinkavik/repos/NovyWave })
    )
}

FUNCTION workspace_recent_b_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.select_workspace_b]
            hovered: PASSED.store.elements.select_workspace_b
        ]
        style: [width: Fill, height: 34, paint: False]
        label: workspace_recent_label(label_text: TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b })
    )
}

FUNCTION workspace_recent_label(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #38a6ff }
                Light => TEXT { #1267aa }
            }
        ]
        text: label_text
    )
}

FUNCTION workspace_tree_static_row(label_text, indent_width) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 27, padding: [left: 0, right: 6], paint: False]
        items: LIST {
            workspace_tree_indent(width_value: indent_width)
            workspace_tree_static_label(label_text: label_text)
        }
    )
}

FUNCTION workspace_tree_static_label(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 14
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #c6d7ee }
                Light => TEXT { #334155 }
            }
        ]
        text: label_text
    )
}

FUNCTION workspace_tree_workspace_a_button() {
    PASSED.store.workspace_selected_key == WorkspaceA |> WHEN {
        True => workspace_tree_workspace_a_selected()
        False => workspace_tree_workspace_a_resting()
    }
}

FUNCTION workspace_tree_workspace_a_selected() {
    Scene/Element/stripe(
        element: [
            event: [press: PASSED.store.elements.select_workspace_a]
            hovered: PASSED.store.elements.select_workspace_a
        ]
        direction: Row
        gap: 6
        style: workspace_tree_selected_button_style()
        items: LIST {
            workspace_tree_indent(width_value: 140)
            workspace_tree_check(selected: True)
            workspace_tree_selected_label(label_text: TEXT { workspace_a })
        }
    )
}

FUNCTION workspace_tree_workspace_a_resting() {
    Scene/Element/stripe(
        element: [
            event: [press: PASSED.store.elements.select_workspace_a]
            hovered: PASSED.store.elements.select_workspace_a
        ]
        direction: Row
        gap: 6
        style: workspace_tree_resting_button_style()
        items: LIST {
            workspace_tree_indent(width_value: 140)
            workspace_tree_check(selected: False)
            workspace_tree_label(label_text: TEXT { workspace_a })
        }
    )
}

FUNCTION workspace_tree_workspace_b_button() {
    PASSED.store.workspace_selected_key == WorkspaceB |> WHEN {
        True => workspace_tree_workspace_b_selected()
        False => workspace_tree_workspace_b_resting()
    }
}

FUNCTION workspace_tree_workspace_b_selected() {
    Scene/Element/stripe(
        element: [
            event: [press: PASSED.store.elements.select_workspace_b]
