store: [
    save: [press: SOURCE]
    bytes: BYTES[4] { 16u01, 16u02, 16u03, 16u04 } |> HOLD bytes { LATEST {} }
    result:
        TEXT { not written }
        |> HOLD result {
            store.save.press |> THEN {
                File/write_bytes(input: store.bytes, path: TEXT { output.bin })
            }
        }
]

document: Document/new(
    root: Element/label(
        element: []
        style: []
        text: store.result
    )
)
