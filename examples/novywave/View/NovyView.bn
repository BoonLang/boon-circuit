        style: [width: Fill, height: 20, paint: False]
        items: LIST {
            variable_name_text(label_text: name_text)
            variable_chip_literal(label_text: chip_a)
            variable_chip_literal(label_text: chip_b)
            variable_chip_literal(label_text: chip_c)
        }
    )
}

