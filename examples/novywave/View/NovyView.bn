FUNCTION variable_static_row(name_text, chip_a, chip_b, chip_c) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 20, paint: False]
        items: LIST {
            variable_name_text(label_text: name_text)
            variable_chip_literal(label_text: chip_a)
            variable_chip_literal(label_text: chip_b)
            variable_chip_literal(label_text: chip_c)
        }
    )
}

FUNCTION variable_row_clk() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 24, paint: False]
        items: LIST {
            variable_name_text(label_text: TEXT { clk })
            variable_chip_wire()
            variable_chip_1bit()
            variable_chip_input()
        }
    )
}

FUNCTION variable_row_reset() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 24, paint: False]
        items: LIST {
            variable_name_text(label_text: TEXT { reset_n })
            variable_chip_wire()
            variable_chip_1bit()
            variable_chip_input()
        }
    )
}

