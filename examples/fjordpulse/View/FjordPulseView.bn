            FjordPulseComponents/muted(value: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Dette er semantisk fixture-publisering, ikke en åpen WebSocket. }, english: TEXT { This is semantic fixture publication, not an open WebSocket. }))
        }
