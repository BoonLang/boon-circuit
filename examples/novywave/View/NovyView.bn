        ]
        direction: Row
        gap: 6
        style: workspace_tree_selected_button_style()
        items: LIST {
            workspace_tree_indent(width_value: 140)
            workspace_tree_check(selected: True)
            workspace_tree_selected_label(label_text: TEXT { workspace_b })
        }
    )
}

FUNCTION workspace_tree_workspace_b_resting() {
    Scene/Element/stripe(
        element: [
            event: [press: PASSED.store.elements.select_workspace_b]
            hovered: PASSED.store.elements.select_workspace_b
        ]
