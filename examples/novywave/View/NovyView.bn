FUNCTION waveform_trace_cell_sky_base(segment) {
    Scene/Element/label(
        element: [event: [key_down: PASSED.store.elements.keyboard_capture], hovered: PASSED.store.elements.waveform_click]
        style: [width: Fill, height: NovyTheme/trace_height_for_row(state: segment.state, row_size: PASSED.store.row_size), align: [column: Center], rounded_corners: 0, background: [color: TEXT { #0EA5E9 }], border: [color: TEXT { #BAE6FD }], material: NovyTheme/material(mode: PASSED.store.mode, of: TraceUnknown)]
        label: Scene/Element/text(element: [], style: [...NovyTheme/trace_label_font(mode: PASSED.store.mode, tone: Sky), width: Fill, height: Fill, center: True, vertical_align: Center], text: segment.label)
    )
}

