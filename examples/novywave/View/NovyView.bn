-- Physical NovyWave scene view.

FUNCTION main_scene() {
    Scene/new(
        root: root()
        lights: [
            key: [x: -0.4, y: -0.8, z: 1.0, intensity: 0.78]
            rim: [x: 0.8, y: 0.2, z: 0.5, intensity: 0.22]
        ]
        geometry: [depth_scale: 1.0]
    )
}

FUNCTION root() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [
            width: Fill
            height: [sizing: Fill, minimum: Screen]
            padding: 0
            background: [color: TEXT { #111827 }]
            material: NovyTheme/material(of: AppBackground)
        ]
        items: LIST {
            header()
            PASSED.store.fixture_status |> WHEN {
                TEXT { Empty } => empty_state()
                __ => loaded_app()
            }
        }
    )
}

FUNCTION header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: 34
            depth: 4
            move: [closer: 2]
            rounded_corners: 8
            padding: [left: 10, right: 10, top: 5, bottom: 5]
            background: [color: TEXT { #F8FAFC }]
            border: [color: TEXT { #CBD5E1 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(of: Muted)
                    width: 72
                    height: Fill
                    vertical_align: Center
                    color: TEXT { #475569 }
                ]
                text: TEXT { ● ● ● }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(of: Body)
                    width: Fill
                    height: Fill
                    center: True
                    vertical_align: Center
                    color: TEXT { #475569 }
                ]
                text: TEXT { NovyWave.io }
            )
            header_load_button()
            header_empty_button()
            header_mode_button()
        }
    )
}

FUNCTION header_stat(stat_label, stat_value) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: 150
            height: Fill
            padding: 8
            rounded_corners: 10
            material: NovyTheme/material(of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: stat_label, font: Muted, width: Fill, height: 18)
            text_line(label_text: stat_value, font: Mono, width: Fill, height: 24)
        }
    )
}

FUNCTION loaded_app() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: Fill
            height: Fill
            paint: False
        ]
        items: LIST {
            browser_band()
            selected_waveform_band()
        }
    )
}

FUNCTION browser_band() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: 322
            paint: False
        ]
        items: LIST {
            left_panel()
            variables_panel()
        }
    )
}

FUNCTION selected_waveform_band() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: Fill
            gap: 0
            paint: False
        ]
        items: LIST {
            timeline_panel()
        }
    )
}

FUNCTION empty_state() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 14
        style: [
            width: Fill
            height: 650
            align: [row: Center]
            padding: 80
            depth: 10
            move: [closer: 2]
            rounded_corners: 18
            material: NovyTheme/material(of: TimelineGlass)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(of: Title)
                    width: Fill
                    height: 44
                    center: True
                ]
                text: TEXT { No waveform loaded }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(of: Body)
                    width: Fill
                    height: 28
                    center: True
                ]
                text: TEXT { Load the generated counter fixture to inspect signals. }
            )
            empty_load_button()
        }
    )
}

FUNCTION left_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: 430
            height: Fill
            padding: 22
            depth: 10
            rounded_corners: 0
            background: [color: TEXT { #172033 }]
            border: [color: TEXT { #2F80ED }]
            material: NovyTheme/material(of: PanelSurface)
        ]
        items: LIST {
            panel_title(title_text: TEXT { Files and scopes })
            load_files_button()
            files_list()
            search_box()
        }
    )
}

FUNCTION files_list() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [width: Fill, paint: False]
        items: LIST {
            tree_row(label_text: TEXT { - counter.vcd }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {   + top.cpu }, indent_width: 0, selected: True)
            tree_row(label_text: TEXT {     clk }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {     reset_n }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {     data_bus[7:0] }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {   + top.uart }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT { - uart_compare.fst }, indent_width: 0, selected: False)
        }
    )
}

FUNCTION tree_row(label_text, indent_width, selected) {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 22
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: selected |> WHEN {
                True => TEXT { #203B62 }
                False => TEXT { #101A2B }
            }]
            border: [color: selected |> WHEN {
                True => TEXT { #3B82F6 }
                False => TEXT { #263753 }
            }]
            material: selected |> WHEN {
                True => NovyTheme/material(of: SelectedRow)
                False => NovyTheme/material(of: PanelInset)
            }
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: label_text
        )
    )
}

FUNCTION file_row(file) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 42
            padding: 6
            rounded_corners: 9
            background: [color: TEXT { #101A2B }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: file.name, font: Mono, width: Fill, height: 18)
            text_line(label_text: file.range, font: Muted, width: Fill, height: 16)
        }
    )
}

FUNCTION search_box() {
    Scene/Element/text_input(
        element: [
            event: [change: PASSED.store.elements.signal_search_input]
        ]
        style: [
            width: Fill
            height: 36
            padding: [left: 10, right: 10]
            text_inset: 4
            rounded_corners: 9
            font: NovyTheme/font(of: Body)
            color: TEXT { #DBEAFE }
            background: [color: TEXT { #0A1322 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Hidden[text: TEXT { signal search }]
        text: PASSED.store.signal_search_text
        placeholder: [text: TEXT { search signals }]
    )
}

FUNCTION scope_cpu_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_cpu], hovered: PASSED.store.elements.scope_cpu]
        style: [
            width: Fill
            height: 32
            padding: 5
            rounded_corners: 9
            background: [color: TEXT { #203B62 }]
            border: [color: TEXT { #3B82F6 }]
            spring_range: 3
            material: PASSED.store.active_scope == TEXT { top_cpu } |> WHEN {
                True => NovyTheme/material(of: SelectedRow)
                False => NovyTheme/material(of: HoverControl)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 1
            style: [paint: False]
            items: LIST {
                text_line(label_text: TEXT { top.cpu }, font: Body, width: Fill, height: 16)
                text_line(label_text: TEXT { 8 signals }, font: Muted, width: Fill, height: 12)
            }
        )
    )
}

FUNCTION scope_uart_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_uart], hovered: PASSED.store.elements.scope_uart]
        style: [
            width: Fill
            height: 32
            padding: 5
            rounded_corners: 9
            background: [color: TEXT { #101A2B }]
            border: [color: TEXT { #263753 }]
            spring_range: 3
            material: PASSED.store.active_scope == TEXT { top_uart } |> WHEN {
                True => NovyTheme/material(of: SelectedRow)
                False => NovyTheme/material(of: HoverControl)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 1
            style: [paint: False]
            items: LIST {
                text_line(label_text: TEXT { top.uart }, font: Body, width: Fill, height: 16)
                text_line(label_text: TEXT { 5 signals }, font: Muted, width: Fill, height: 12)
            }
        )
    )
}

FUNCTION timeline_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: Fill
            height: Fill
            padding: 10
            depth: 4
            move: [closer: 1]
            rounded_corners: 0
            background: [color: TEXT { #172033 }]
            border: [color: TEXT { #2F80ED }]
            material: NovyTheme/material(of: PanelSurface)
        ]
        items: LIST {
            timeline_header()
            timeline_toolbar()
            timeline_axis()
            waveform_rows()
        }
    )
}

FUNCTION timeline_header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 30, paint: False]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(of: Heading)
                    width: 240
                    height: Fill
                    vertical_align: Center
                    color: TEXT { #DCEAFF }
                ]
                text: TEXT { Selected Variables }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(of: Muted)
                    width: Fill
                    height: Fill
                    center: True
                    vertical_align: Center
                    color: TEXT { #90A4BF }
                ]
                text: TEXT { Dock to Right }
            )
            remove_all_button()
        }
    )
}

FUNCTION timeline_toolbar() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 38, paint: False]
        items: LIST {
            zoom_in_button()
            zoom_out_button()
            pan_left_button()
            pan_right_button()
            cursor_left_button()
            cursor_right_button()
            marker_button()
            group_button()
            format_button()
            keyboard_capture()
        }
    )
}

FUNCTION keyboard_capture() {
    Scene/Element/text_input(
        element: [
            event: [key_down: PASSED.store.elements.keyboard_capture]
        ]
        style: [
            width: 1
            height: 1
            paint: False
            padding: 0
            rounded_corners: 8
            font: NovyTheme/font(of: Muted)
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Hidden[text: TEXT { keyboard capture }]
        text: Text/empty()
        placeholder: []
    )
}

FUNCTION timeline_axis() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 3
        style: [
            width: Fill
            height: 48
            padding: 6
            rounded_corners: 0
            background: [color: TEXT { #0A1322 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 0
                style: [width: Fill, height: 20, paint: False]
                items: LIST {
                    axis_tick(label: TEXT { 0 ns })
                    axis_tick(label: TEXT { 40 ns })
                    axis_tick(label: TEXT { 80 ns })
                    axis_tick(label: TEXT { 120 ns })
                    axis_tick(label: TEXT { 160 ns })
                }
            )
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 4
                style: [width: Fill, height: 16, paint: False]
                items: LIST {
                    cursor_chip()
                    PASSED.store.marker_visibility |> WHEN {
                        TEXT { Visible } => marker_chip()
                        TEXT { Hidden } => NoElement
                    }
                }
            )
        }
    )
}

FUNCTION axis_tick(label) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(of: Muted)
            width: 120
            height: 18
            center: True
            color: TEXT { #90A4BF }
        ]
        text: label
    )
}

FUNCTION cursor_chip() {
    Scene/Element/label(
        element: []
        style: [
            width: 118
            height: 18
            rounded_corners: 8
            background: [color: TEXT { #1D4ED8 }]
            material: NovyTheme/material(of: CursorGlow)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
            ]
            text: PASSED.store.cursor_label
        )
    )
}

FUNCTION marker_chip() {
    Scene/Element/label(
        element: []
        style: [
            width: 150
            height: 18
            rounded_corners: 8
            background: [color: TEXT { #4F46E5 }]
            material: NovyTheme/material(of: MarkerChip)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
            ]
            text: TEXT { M reset released }
        )
    )
}

FUNCTION collapsed_group() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 48
            rounded_corners: 10
            background: [color: TEXT { #0A1322 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Body)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: TEXT { Core bus group collapsed }
        )
    )
}

FUNCTION waveform_rows() {
    PASSED.store.selected_group |> WHEN {
        TEXT { Collapsed } => collapsed_group()
        __ => waveform_rows_expanded()
    }
}

FUNCTION waveform_rows_expanded() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: Fill, paint: False]
        items: LIST {
            waveform_row_clk()
            waveform_row_reset()
            waveform_row_data()
            waveform_row_temperature()
        }
    )
}

FUNCTION waveform_row_clk() {
    BLOCK {
        active: PASSED.store.active_signal == TEXT { clk }

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 2
                background: [color: TEXT { #101A2B }]
                border: [color: TEXT { #263753 }]
                material: active |> WHEN {
                    True => NovyTheme/material(of: SelectedRow)
                    False => NovyTheme/material(of: PanelInset)
                }
            ]
            items: LIST {
                fixed_signal_label(label_text: NovyFixtures/selected_clk_name())
                fixed_value_clk()
                fixed_wave_area_clk()
            }
        )
    }
}

FUNCTION waveform_row_reset() {
    BLOCK {
        active: PASSED.store.active_signal == TEXT { reset_n }

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 2
                background: [color: TEXT { #101A2B }]
                border: [color: TEXT { #263753 }]
                material: active |> WHEN {
                    True => NovyTheme/material(of: SelectedRow)
                    False => NovyTheme/material(of: PanelInset)
                }
            ]
            items: LIST {
                fixed_signal_label(label_text: NovyFixtures/selected_reset_name())
                fixed_value_reset()
                fixed_wave_area_reset()
            }
        )
    }
}

FUNCTION waveform_row_data() {
    BLOCK {
        active: PASSED.store.active_signal == TEXT { data_bus }

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 2
                background: [color: TEXT { #101A2B }]
                border: [color: TEXT { #263753 }]
                material: active |> WHEN {
                    True => NovyTheme/material(of: SelectedRow)
                    False => NovyTheme/material(of: PanelInset)
                }
            ]
            items: LIST {
                fixed_signal_label(label_text: NovyFixtures/selected_data_name())
                fixed_value_data()
                fixed_wave_area_data()
            }
        )
    }
}

FUNCTION waveform_row_temperature() {
    BLOCK {
        active: PASSED.store.active_signal == TEXT { temperature }

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 2
                background: [color: TEXT { #101A2B }]
                border: [color: TEXT { #263753 }]
                material: active |> WHEN {
                    True => NovyTheme/material(of: SelectedRow)
                    False => NovyTheme/material(of: PanelInset)
                }
            ]
            items: LIST {
                fixed_signal_label(label_text: NovyFixtures/selected_temperature_name())
                fixed_value_temperature()
                fixed_wave_area_temperature()
            }
        )
    }
}

FUNCTION fixed_signal_label(label_text) {
    Scene/Element/label(
        element: []
        style: [
            width: 145
            height: Fill
            padding: 6
            rounded_corners: 2
            background: [color: TEXT { #0A1322 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: label_text
        )
    )
}

FUNCTION fixed_value_clk() {
    Scene/Element/label(
        element: []
        style: [
            width: 86
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #111827 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: PASSED.store.value_format |> WHEN {
                TEXT { Binary } => NovyFixtures/selected_clk_value_binary()
                __ => NovyFixtures/selected_clk_value_hex()
            }
        )
    )
}

FUNCTION fixed_value_reset() {
    Scene/Element/label(
        element: []
        style: [
            width: 86
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #111827 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: PASSED.store.value_format |> WHEN {
                TEXT { Binary } => NovyFixtures/selected_reset_value_binary()
                __ => NovyFixtures/selected_reset_value_hex()
            }
        )
    )
}

FUNCTION fixed_value_data() {
    Scene/Element/label(
        element: []
        style: [
            width: 86
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #111827 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: PASSED.store.value_format |> WHEN {
                TEXT { Binary } => NovyFixtures/selected_data_value_binary()
                __ => NovyFixtures/selected_data_value_hex()
            }
        )
    )
}

FUNCTION fixed_value_temperature() {
    Scene/Element/label(
        element: []
        style: [
            width: 86
            height: Fill
            rounded_corners: 0
            background: [color: TEXT { #111827 }]
            border: [color: TEXT { #263753 }]
            material: NovyTheme/material(of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: PASSED.store.value_format |> WHEN {
                TEXT { Binary } => NovyFixtures/selected_temperature_value_binary()
                __ => NovyFixtures/selected_temperature_value_hex()
            }
        )
    )
}

FUNCTION fixed_wave_area(signal_id) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 2
        style: [
            width: Fill
            height: Fill
            padding: [top: 6, bottom: 6, left: 8, right: 8]
            rounded_corners: 0
            background: [color: TEXT { #020817 }]
            border: [color: TEXT { #1D4ED8 }]
            material: NovyTheme/material(of: TimelineGlass)
        ]
        items:
            NovyFixtures/segments(of: signal_id)
            |> List/map(segment, new: waveform_segment(segment: segment))
    )
}

FUNCTION fixed_wave_area_clk() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 2
        style: [
            width: Fill
            height: Fill
            padding: [top: 6, bottom: 6, left: 8, right: 8]
            rounded_corners: 0
            background: [color: TEXT { #020817 }]
            border: [color: TEXT { #1D4ED8 }]
            material: NovyTheme/material(of: TimelineGlass)
        ]
        items: LIST {
            waveform_cursor_line()
            wave_cell_high(width_value: 32, label_text: TEXT { 1 })
            wave_cell_low(width_value: 32, label_text: TEXT { 0 })
            wave_cell_high(width_value: 32, label_text: TEXT { 1 })
            wave_cell_low(width_value: 32, label_text: TEXT { 0 })
            wave_cell_high(width_value: 32, label_text: TEXT { 1 })
            wave_cell_low(width_value: 32, label_text: TEXT { 0 })
            wave_cell_high(width_value: 32, label_text: TEXT { 1 })
            wave_cell_low(width_value: 32, label_text: TEXT { 0 })
            wave_cell_high(width_value: 32, label_text: TEXT { 1 })
            wave_cell_low(width_value: 32, label_text: TEXT { 0 })
            wave_cell_high(width_value: 32, label_text: TEXT { 1 })
            wave_cell_low(width_value: 32, label_text: TEXT { 0 })
