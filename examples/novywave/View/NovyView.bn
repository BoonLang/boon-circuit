FUNCTION workspace_tree_repo_button() {
    PASSED.store.workspace_selected_key == Repo |> WHEN {
        True => workspace_tree_repo_selected()
        False => workspace_tree_repo_resting()
    }
}

FUNCTION workspace_tree_repo_selected() {
    Scene/Element/stripe(
        element: [
            event: [press: PASSED.store.elements.select_workspace_repo]
            hovered: PASSED.store.elements.select_workspace_repo
        ]
        direction: Row
        gap: 6
        style: workspace_tree_selected_button_style()
        items: LIST {
            workspace_tree_indent(width_value: 92)
            workspace_tree_check(selected: True)
            workspace_tree_selected_label(label_text: TEXT { NovyWave repo })
        }
    )
}

FUNCTION workspace_tree_repo_resting() {
    Scene/Element/stripe(
        element: [
            event: [press: PASSED.store.elements.select_workspace_repo]
            hovered: PASSED.store.elements.select_workspace_repo
        ]
        direction: Row
        gap: 6
        style: workspace_tree_resting_button_style()
        items: LIST {
            workspace_tree_indent(width_value: 92)
            workspace_tree_check(selected: False)
            workspace_tree_label(label_text: TEXT { NovyWave repo })
        }
    )
}

FUNCTION workspace_tree_selected_button_style() {
    [
        width: Fill
        height: 27
        padding: 0
        rounded_corners: 5
        background: [color: TEXT { #0b3f78 }]
        border: [color: TEXT { #66c4ff }]
        material: NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
    ]
}

FUNCTION workspace_tree_resting_button_style() {
    [
        width: Fill
        height: 27
        padding: 0
        rounded_corners: 5
        paint: False
    ]
}

FUNCTION workspace_tree_indent(width_value) {
    Scene/Element/label(
        element: []
        style: [width: width_value, height: Fill, paint: False]
        label: Scene/Element/text(
            element: []
            style: [width: Fill, height: Fill, color: TEXT { #00000000 }]
            text: Text/empty()
        )
    )
}

FUNCTION workspace_tree_check(selected) {
    Scene/Element/label(
        element: []
        style: [
            width: 24
            height: 24
            rounded_corners: 5
            background: [color: selected |> WHEN {
                True => TEXT { #169cff }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #07316e }
                    Light => TEXT { #d8ecff }
                }
            }]
            border: [color: selected |> WHEN {
                True => TEXT { #66c4ff }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #144a90 }
                    Light => TEXT { #90bfe8 }
                }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: selected |> WHEN {
                    True => TEXT { #ffffff }
                    False => TEXT { #00000000 }
                }
            ]
            text: selected |> WHEN {
                True => TEXT { ✓ }
                False => Text/empty()
            }
        )
    )
}

FUNCTION workspace_tree_label(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 14
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #eaf4ff }
                Light => TEXT { #10243a }
            }
        ]
        text: label_text
    )
}

FUNCTION workspace_tree_selected_label(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 14
            color: TEXT { #ffffff }
        ]
        text: label_text
    )
}

FUNCTION workspace_dialog_selection() {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: 28
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #8fa0b5 }
                Light => TEXT { #42566d }
            }
        ]
        text: PASSED.store.workspace_dialog_selection
    )
}

FUNCTION workspace_dialog_actions() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 34, paint: False]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [width: Fill, height: Fill, color: TEXT { #00000000 }]
                text: Text/empty()
            )
            workspace_cancel_button()
            workspace_open_button()
        }
    )
}

FUNCTION workspace_cancel_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.close_workspace_dialog]
            hovered: PASSED.store.elements.close_workspace_dialog
        ]
        style: compact_button_style(button_width: 104, hovered: element.hovered)
        label: button_label(button_text: TEXT { Cancel })
    )
}

FUNCTION workspace_open_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.open_selected_workspace]
            hovered: PASSED.store.elements.open_selected_workspace
        ]
        style: compact_button_style(button_width: 96, hovered: element.hovered)
        label: button_label(button_text: TEXT { Open })
    )
}

FUNCTION load_files_dialog() {
    PASSED.store.load_files_dialog == Open |> WHEN {
        True => Scene/Element/stripe(
            element: []
            direction: Column
            gap: 12
            style: [
                width: Fill
                height: [sizing: Fill, minimum: Screen]
                padding: [left: 28, right: 28, top: 92, bottom: 28]
                background: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #020817e0 }
                    Light => TEXT { #e2e8f0d8 }
                }]
                material: NovyTheme/material(mode: PASSED.store.mode, of: DialogBackdrop)
            ]
            items: LIST {
                load_files_dialog_panel()
            }
        )
        __ => NoElement
    }
}

FUNCTION load_files_dialog_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [
            width: [sizing: Fill, maximum: 720]
            height: 246
            center: True
            depth: 28
            move: [closer: 12]
            rounded_corners: 14
            padding: [left: 16, right: 16, top: 14, bottom: 14]
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #07111fff }
                Light => TEXT { #ffffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #65b8ff }
                Light => TEXT { #2474bb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: Dialog)
        ]
        items: LIST {
            load_files_dialog_title()
            load_files_dialog_hint()
            load_files_path_input()
            load_files_dialog_selection()
            load_files_dialog_actions()
        }
    )
}

FUNCTION load_files_path_input() {
    Scene/Element/text_input(
        element: [
            event: [
                click: PASSED.store.elements.load_file_path_focus_probe
                change: PASSED.store.elements.load_file_path_input
            ]
        ]
        style: [
            width: Fill
            height: 38
            padding: [left: 10, right: 10]
            text_inset: 4
            rounded_corners: 9
            font: NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #eaf4ff }
                Light => TEXT { #172033 }
            }
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #08111f }
                Light => TEXT { #f3f7fc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #65b8ff }
                Light => TEXT { #2474bb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Hidden[text: TEXT { waveform file path }]
        text: PASSED.store.load_files_path
        placeholder: [text: TEXT { /path/to/waveform.vcd }]
    )
}

