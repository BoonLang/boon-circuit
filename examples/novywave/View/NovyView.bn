FUNCTION file_tree_simple_scope_collapse_control(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_cpu_collapse], hovered: PASSED.store.elements.scope_cpu_collapse]
        style: [width: 6, height: 22, paint: False, spring_range: 3]
        label: tree_scope_disclosure_row(selected: PASSED.store.active_scope == TEXT { simple_tb_s })
    )
}

FUNCTION file_tree_simple_scope_select_label(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_cpu], hovered: PASSED.store.elements.scope_cpu]
        style: [width: Fill, height: 22, paint: False, spring_range: 3]
        label: tree_scope_label_row(label_text: row.expanded_label, selected: PASSED.store.active_scope == TEXT { simple_tb_s })
    )
}

FUNCTION tree_scope_disclosure_row(selected) {
    Scene/Element/label(
        element: []
        style: [width: Fill, height: Fill, paint: False]
        label: Scene/Element/text(
            element: []
            style: [width: Fill, height: Fill]
            text: Text/empty()
        )
    )
}

FUNCTION tree_scope_label_row(label_text, selected) {
    tree_row(label_text: label_text, indent_width: 0, selected: selected)
}

FUNCTION file_tree_uart_scope_button(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_uart], hovered: PASSED.store.elements.scope_uart]
        style: [width: Fill, height: 22, paint: False, spring_range: 3]
        label: tree_row(label_text: file_tree_row_label(row: row), indent_width: row.indent_width, selected: PASSED.store.active_scope == row.scope_key)
    )
}

FUNCTION file_tree_analog_scope_button(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_analog], hovered: PASSED.store.elements.scope_analog]
        style: [width: Fill, height: 22, paint: False, spring_range: 3]
        label: tree_row(label_text: file_tree_row_label(row: row), indent_width: row.indent_width, selected: PASSED.store.active_scope == row.scope_key)
    )
}

FUNCTION file_tree_ghw_scope_button(row) {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_ghw_file], hovered: PASSED.store.elements.select_ghw_file]
        style: [width: Fill, height: 22, paint: False, spring_range: 3]
        label: tree_row(label_text: file_tree_row_label(row: row), indent_width: row.indent_width, selected: PASSED.store.active_scope == row.scope_key)
    )
}

FUNCTION file_tree_row_label(row) {
    row.scope_key == TEXT { simple_tb_s } |> WHEN {
        True => PASSED.store.scope_cpu_expansion_state |> WHEN {
            Expanded => row.expanded_label
            __ => row.collapsed_label
        }
        False => row.label
    }
}

FUNCTION simple_scope_row_label(row) {
    PASSED.store.scope_cpu_expansion_state |> WHEN {
        Expanded => row.expanded_label
        __ => row.collapsed_label
    }
}

FUNCTION tree_child_row(label_text, indent_width) {
    tree_row(label_text: label_text, indent_width: indent_width, selected: False)
}

FUNCTION tree_row(label_text, indent_width, selected) {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 22
            padding: [left: 5, right: 6]
            rounded_corners: 4
            background: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #203B62 }
                    Light => TEXT { #d7e9ff }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #101a2b }
                    Light => TEXT { #ffffff }
                }
            }]
            border: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #3B82F6 }
                    Light => TEXT { #2474bb }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #263753 }
                    Light => TEXT { #d7dde8 }
                }
            }]
            material: selected |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 5
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                tree_indent(width_value: indent_width)
                tree_bullet(selected: selected)
                tree_row_text(label_text: label_text, selected: selected)
            }
        )
    )
}

FUNCTION tree_row_text(label_text, selected) {
    selected |> WHEN {
        True => PASSED.store.mode |> WHEN {
            Dark => tree_row_text_selected_dark(label_text: label_text)
            Light => tree_row_text_selected_light(label_text: label_text)
        }
        False => PASSED.store.mode |> WHEN {
            Dark => tree_row_text_resting_dark(label_text: label_text)
            Light => tree_row_text_resting_light(label_text: label_text)
        }
    }
}

FUNCTION tree_row_text_selected_dark(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #f4fbff }
        ]
        text: label_text
    )
}

FUNCTION tree_row_text_selected_light(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #10243a }
        ]
        text: label_text
    )
}

FUNCTION tree_row_text_resting_dark(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #eaf3ff }
        ]
        text: label_text
    )
}

FUNCTION tree_row_text_resting_light(label_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: Fill
            vertical_align: Center
            size: 12
            color: TEXT { #172033 }
        ]
        text: label_text
    )
}

FUNCTION tree_indent(width_value) {
    Scene/Element/label(
        element: []
        style: [
            width: width_value
            height: Fill
            paint: False
        ]
        label: Scene/Element/text(
            element: []
            style: [width: Fill, height: Fill, color: TEXT { #00000000 }]
            text: Text/empty()
        )
    )
}

FUNCTION tree_bullet(selected) {
    Scene/Element/label(
        element: []
        style: [
            width: 5
            height: Fill
            rounded_corners: 1
            background: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #7dd3fc }
                    Light => TEXT { #2474bb }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #5f7898 }
                    Light => TEXT { #b8cbe0 }
                }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [width: Fill, height: Fill, color: TEXT { #00000000 }]
            text: Text/empty()
        )
    )
}

FUNCTION file_row(file_name, file_range) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 42
            padding: 6
            rounded_corners: 9
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: file_name, font: Mono, width: Fill, height: 18)
            text_line(label_text: file_range, font: Muted, width: Fill, height: 16)
        }
    )
}

FUNCTION search_box() {
    PASSED.store.focused_control_label == TEXT { signal search } |> WHEN {
        True => search_box_focused()
        False => search_box_resting()
    }
}

FUNCTION search_box_resting() {
    Scene/Element/text_input(
        element: [
            event: [
                click: PASSED.store.elements.signal_search_focus_probe
                change: PASSED.store.elements.signal_search_input
            ]
        ]
        style: [
            width: Fill
            height: 36
            padding: [left: 10, right: 10]
            text_inset: 4
            rounded_corners: 9
            font: NovyTheme/font(mode: PASSED.store.mode, of: Body)
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #f3f7fc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Hidden[text: TEXT { signal search }]
        text: PASSED.store.signal_search_text
        placeholder: [text: TEXT { search signals }]
    )
}

FUNCTION search_box_focused() {
    Scene/Element/text_input(
        element: [
            event: [
                click: PASSED.store.elements.signal_search_focus_probe
                change: PASSED.store.elements.signal_search_input
            ]
        ]
        style: [
            width: Fill
            height: 36
            padding: [left: 10, right: 10]
            text_inset: 4
            rounded_corners: 9
            font: NovyTheme/font(mode: PASSED.store.mode, of: Body)
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #11243b }
                Light => TEXT { #e9f3ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #65b8ff }
                Light => TEXT { #2474bb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: FocusedControl)
        ]
        label: Hidden[text: TEXT { signal search }]
        text: PASSED.store.signal_search_text
        placeholder: [text: TEXT { search signals }]
    )
}

FUNCTION timeline_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 6
        style: [
            width: Fill
            height: Fill
            padding: 8
            depth: 4
            move: [closer: 1]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #304057 }
                Light => TEXT { #c9d7ea }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            timeline_header()
            selected_variables_body()
            selected_variables_footer()
            keyboard_capture()
        }
    )
}

FUNCTION timeline_header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 30, paint: False]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Heading)
                    width: 240
                    height: Fill
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dceaff }
                        Light => TEXT { #182a3d }
                    }
                ]
                text: TEXT { Selected Variables }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                    width: Fill
                    height: Fill
                    center: True
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #90a4bf }
                        Light => TEXT { #60748b }
                    }
                ]
                text: PASSED.store.selected_signal_count_label
            )
            selected_clear_all_button()
        }
    )
}

FUNCTION timeline_toolbar() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 5
        style: [width: Fill, height: 100, paint: False]
        items: LIST {
            timeline_navigation_controls()
            selected_data_controls()
            selected_marker_controls()
            analog_limit_controls()
            keyboard_capture()
        }
    )
}

FUNCTION selected_variables_body() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: Fill
            height: 188
            padding: 0
            rounded_corners: 0
            scroll_y: True
            background: [color: TEXT { #020817 }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #1f2a3c }
                Light => TEXT { #1f2a3c }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: WaveformGlass)
        ]
        items: LIST {
            selected_variables_column_header()
            selected_variables_grid()
        }
    )
}

FUNCTION selected_variables_grid() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 0
        style: [
            width: Fill
            height: Fill
            paint: False
        ]
        items: LIST {
            selected_name_column_body()
            variables_name_divider()
            selected_value_column_body()
            variables_value_divider()
            selected_wave_column_body()
        }
    )
}

FUNCTION selected_name_column_body() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: PASSED.store.selected_name_column_width
            height: Fill
            paint: False
        ]
        items:
            PASSED.store.selected_visible_items |> List/map(row, new: selected_name_column_row(row: row))
    )
}

FUNCTION selected_value_column_body() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: PASSED.store.selected_value_column_width
            height: Fill
            paint: False
        ]
        items:
            PASSED.store.selected_visible_items |> List/map(row, new: selected_value_column_row(row: row))
    )
}

FUNCTION selected_wave_column_body() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: Fill
            height: Fill
            paint: False
            overlay_children: True
        ]
        items: LIST {
            selected_wave_rows_column()
            waveform_interaction_surface()
            waveform_full_height_zoom_center_overlay()
            waveform_full_height_cursor_overlay()
        }
    )
}

FUNCTION waveform_interaction_surface() {
    Scene/Element/block(
        element: [
            event: [
                press: PASSED.store.elements.waveform_click
                pointer_move: PASSED.store.elements.waveform_hover
                key_down: PASSED.store.elements.keyboard_capture
            ]
            hovered: PASSED.store.elements.waveform_hover
            target: TEXT { waveform canvas }
        ]
        style: [
            width: Fill
            height: Fill
            paint: False
        ]
        child: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION selected_wave_rows_column() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [
            width: Fill
            height: Fill
            paint: False
        ]
        items:
            PASSED.store.selected_visible_items |> List/map(row, new: selected_wave_column_row(row: row))
    )
}

FUNCTION waveform_full_height_zoom_center_overlay() {
    Scene/Element/stripe(
        element: [target: PASSED.store.zoom_center_label]
        direction: Row
        gap: 0
        style: [
            width: PASSED.store.waveform_zoom_center_offset + 2
            height: Fill
            paint: False
        ]
        items: LIST {
            waveform_cursor_spacer(width_value: PASSED.store.waveform_zoom_center_offset)
            waveform_zoom_center_line_core()
        }
    )
}

FUNCTION waveform_full_height_cursor_overlay() {
    Scene/Element/stripe(
        element: [target: PASSED.store.keyboard_cursor_label]
        direction: Row
        gap: 0
        style: [
            width: PASSED.store.waveform_cursor_offset + 2
            height: Fill
            paint: False
        ]
        items: LIST {
            waveform_cursor_spacer(width_value: PASSED.store.waveform_cursor_offset)
            waveform_cursor_line_core()
        }
    )
}

FUNCTION selected_name_column_row(row) {
    row.item_kind |> WHEN {
        GroupHeader => selected_name_group_header_row(row: row)
        __ => selected_name_variable_row(row: row)
    }
}

FUNCTION selected_name_variable_row(row) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [width: Fill, height: PASSED.store.row_height + row.divider_height_after, paint: False]
        items: LIST {
            selected_name_cell(signal: row)
            selected_row_separator()
        }
    )
}

FUNCTION selected_value_column_row(row) {
    row.item_kind |> WHEN {
        GroupHeader => selected_value_group_header_row(row: row)
        __ => selected_value_variable_row(row: row)
    }
}

FUNCTION selected_value_variable_row(row) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [width: Fill, height: PASSED.store.row_height + row.divider_height_after, paint: False]
        items: LIST {
            selected_value_cell(signal: row)
            selected_row_separator()
        }
    )
}

FUNCTION selected_wave_column_row(row) {
    row.item_kind |> WHEN {
        GroupHeader => selected_wave_group_header_row(row: row)
        __ => selected_wave_variable_row(row: row)
    }
}

FUNCTION selected_wave_variable_row(row) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 0
        style: [width: Fill, height: PASSED.store.row_height + row.divider_height_after, paint: False]
        items: LIST {
            selected_wave_cell(signal: row)
            signal_row_divider(signal: row)
        }
    )
}

FUNCTION selected_name_group_header_row(row) {
    Scene/Element/label(
        element: []
        style: selected_group_header_style(row_width: PASSED.store.selected_name_column_width)
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [width: Fill, height: Fill, paint: False, align: [row: Center]]
            items: LIST {
                group_header_chevron_button(row: row)
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                        width: Fill
                        height: Fill
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: row.name
                )
                group_header_count_text(row: row)
                group_header_rename_button()
                group_header_remove_button()
            }
        )
    )
}

FUNCTION selected_value_group_header_row(row) {
    Scene/Element/text(
        element: []
        style: [
            ...selected_group_header_style(row_width: Fill)
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            padding: [left: 10, right: 8]
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #9fb3d8 }
                Light => TEXT { #56657a }
            }
        ]
        text: row.current_value
    )
}

FUNCTION selected_wave_group_header_row(row) {
    Scene/Element/text(
        element: []
        style: [
            ...selected_group_header_style(row_width: Fill)
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            padding: [left: 10, right: 8]
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #9fb3d8 }
                Light => TEXT { #56657a }
            }
        ]
        text: row.row_count_label
    )
}

FUNCTION selected_group_header_style(row_width) {
    [
        width: row_width
        height: 30
        rounded_corners: 0
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #111b2b }
            Light => TEXT { #e8eef7 }
        }]
        border: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #2c3d5a }
            Light => TEXT { #b8c8df }
        }]
        material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
    ]
}

FUNCTION group_header_chevron_button(row) {
    PASSED.store.group_header_collapsed |> WHEN {
        True => Scene/Element/button(
            element: [event: [press: PASSED.store.elements.group_expand], hovered: PASSED.store.elements.group_expand]
            style: row_remove_button_style(hovered: element.hovered)
            label: group_header_button_text(button_text: PASSED.store.group_header_chevron)
        )
        False => Scene/Element/button(
            element: [event: [press: PASSED.store.elements.group_toggle], hovered: PASSED.store.elements.group_toggle]
            style: row_remove_button_style(hovered: element.hovered)
            label: group_header_button_text(button_text: PASSED.store.group_header_chevron)
        )
    }
}

FUNCTION group_header_rename_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.group_create], hovered: PASSED.store.elements.group_create]
        style: compact_button_style(button_width: 56, hovered: element.hovered)
        label: button_label(button_text: TEXT { Rename })
    )
}

FUNCTION group_header_count_text(row) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: 20
            height: Fill
            center: True
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #9fb3d8 }
                Light => TEXT { #56657a }
            }
        ]
        text: row.member_count_label
    )
}

FUNCTION group_header_remove_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.group_remove], hovered: PASSED.store.elements.group_remove]
        style: row_remove_button_style(hovered: element.hovered)
        label: row_remove_label()
    )
}

