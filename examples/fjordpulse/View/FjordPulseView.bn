FUNCTION admin_database_navigation() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 42, paint: False]
        items: LIST {
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Skjema }, english: TEXT { Schema })
                selected: PASSED.store.route == AdminDatabaseSchema
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.database_schema }
            FjordPulseComponents/button(
                label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Migreringer }, english: TEXT { Migrations })
                selected: PASSED.store.route == AdminDatabaseMigrations
                width: Fill
            ) |> SOURCE { PASSED.store.elements.admin.database_migrations }
        }
    )
}

FUNCTION admin_database_schema_page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 9
        style: [width: Fill, paint: False]
        items: LIST {
            FjordPulseComponents/state_message(
                status: Ready
                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Skrivebeskyttet redb-diagnostikk }, english: TEXT { Read-only redb diagnostics })
                message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Viser Boon-samlinger og indekser, ikke SurrealDB-objekter. }, english: TEXT { Reports Boon collections and indexes, not SurrealDB objects. })
            )
            admin_database_navigation()
            FjordPulseComponents/section_heading(
                eyebrow: TEXT { REDB SCHEMA }
                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { 5 samlinger · 4 indekser }, english: TEXT { 5 collections · 4 indexes })
            )
            FjordPulseComponents/data_row(label: TEXT { stations }, value: TEXT { primary id · name index · bounds index })
            FjordPulseComponents/data_row(label: TEXT { vehicles }, value: TEXT { primary id · observed_at index })
            FjordPulseComponents/data_row(label: TEXT { watches }, value: TEXT { type + entity · priority })
            FjordPulseComponents/data_row(label: TEXT { events }, value: TEXT { semantic version · created_at index })
            FjordPulseComponents/data_row(label: TEXT { timetables }, value: TEXT { station + service date · immutable pages })
        }
    )
}

FUNCTION admin_database_migrations_page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 9
        style: [width: Fill, paint: False]
        items: LIST {
            FjordPulseComponents/state_message(
                status: Fresh
                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Skjemaet er kompatibelt }, english: TEXT { Schema is compatible })
                message: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Alle deterministiske migreringer er registrert. Kontroller er skrivebeskyttet. }, english: TEXT { All deterministic migrations are recorded. Controls are read-only. })
            )
            admin_database_navigation()
            FjordPulseComponents/section_heading(
                eyebrow: TEXT { SCHEMA MIGRATION }
                title: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Migreringshistorikk }, english: TEXT { Migration history })
            )
            FjordPulseComponents/data_row(label: TEXT { 001_bootstrap }, value: TEXT { applied · collections + identities })
            FjordPulseComponents/data_row(label: TEXT { 002_semantic_events }, value: TEXT { applied · versions + retention })
            FjordPulseComponents/data_row(label: TEXT { 003_station_indexes }, value: TEXT { applied · name + bounds })
            FjordPulseComponents/data_row(label: FjordPulseModel/locale_text(language: PASSED.store.language, norwegian: TEXT { Nåværende versjon }, english: TEXT { Current version }), value: TEXT { 3 · compatible })
        }
    )
}
