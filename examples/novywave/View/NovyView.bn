            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Hidden[text: TEXT { keyboard capture }]
        text: Text/empty()
        placeholder: []
    )
}

FUNCTION timeline_axis() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 3
        style: [
            width: Fill
            height: 38
            padding: [top: 5, bottom: 5, left: 0, right: 0]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #eef5ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #93b4e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 0
                style: [width: Fill, height: 20, paint: False]
                items: LIST {
                    axis_tick_left(label: PASSED.store.timeline_axis_tick_0)
                    axis_tick(label: PASSED.store.timeline_axis_tick_1)
                    axis_tick(label: PASSED.store.timeline_axis_tick_2)
                    axis_tick(label: PASSED.store.timeline_axis_tick_3)
                    axis_tick_right(label: PASSED.store.timeline_axis_tick_4)
                }
            )
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 4
                style: [width: Fill, height: 16, paint: False]
                items: LIST {
                    cursor_chip()
                    PASSED.store.marker_visibility == Visible |> WHEN {
                        True => marker_chip()
                        False => NoElement
                    }
                }
            )
        }
    )
}

