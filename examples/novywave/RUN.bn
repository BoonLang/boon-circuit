            [signal_id: TEXT { baud_tick }, width: 44, state: Low, label: TEXT { 0 }]
            [signal_id: TEXT { baud_tick }, width: 0, state: MarkerLine, label: TEXT { marker }]
            [signal_id: TEXT { baud_tick }, width: 22, state: High, label: TEXT { tick }]
            [signal_id: TEXT { baud_tick }, width: 78, state: Low, label: TEXT { 0 }]
            [signal_id: TEXT { baud_tick }, width: 22, state: High, label: TEXT { tick }]
            [signal_id: TEXT { baud_tick }, width: 120, state: Low, label: TEXT { 0 }]
            [signal_id: TEXT { uart_busy }, width: 0, state: CursorLine, label: TEXT { cursor }]
            [signal_id: TEXT { uart_busy }, width: 86, state: Low, label: TEXT { idle }]
