FUNCTION value_pill_text(value_text) {
    Scene/Element/label(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: PASSED.store.selected_value_column_width
            height: Fill
            center: True
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #E9F0FA }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #B8C8DF }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        text: value_text
    )
}

FUNCTION value_cell(signal, value_text) {
    Scene/Element/label(
        element: []
        style: [
            width: PASSED.store.selected_value_column_width
            height: Fill
            padding: [left: 6, right: 6]
            rounded_corners: 0
            overlay_children: True
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #E9F0FA }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #B8C8DF }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                Scene/Element/text(
                    element: []
                    style: [
                        ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                        width: Fill
                        height: Fill
                        center: True
                        vertical_align: Center
                        color: PASSED.store.mode |> WHEN {
                            Dark => TEXT { #dbeafe }
                            Light => TEXT { #172033 }
                        }
                    ]
                    text: value_text
                )
                signal.kind |> WHEN {
                    Analog => row_analog_limits_button()
                    __ => row_format_control(signal: signal)
                }
            }
        )
    )
}

FUNCTION row_value_action_style(button_width, hovered) {
    [
        width: button_width
        height: 22
        rounded_corners: 4
        padding: [left: 4, right: 4]
        background: [color: hovered |> WHEN {
            True => PASSED.store.mode |> WHEN {
                Dark => TEXT { #203b62 }
                Light => TEXT { #dbeafe }
            }
            False => PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }
        }]
        border: [color: hovered |> WHEN {
            True => PASSED.store.mode |> WHEN {
                Dark => TEXT { #5aa7ff }
                Light => TEXT { #2474bb }
            }
            False => PASSED.store.mode |> WHEN {
                Dark => TEXT { #344158 }
                Light => TEXT { #c9d7ea }
            }
        }]
        material: hovered |> WHEN {
            True => NovyTheme/material(mode: PASSED.store.mode, of: PressedControl)
            False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
        }
    ]
}

FUNCTION row_format_control(signal) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: 64
            height: signal.format_dropdown_state == Open |> WHEN {
                True => 198
                False => 22
            }
            paint: False
            overlay_children: True
        ]
        items: LIST {
            row_format_button(signal: signal)
            row_format_dropdown_state_menu(signal: signal)
        }
    )
}

FUNCTION row_format_button(signal) {
    Scene/Element/button(
        element: [event: [press: signal.format_elements.format_dropdown_toggle], hovered: signal.format_elements.format_dropdown_toggle]
        style: row_value_action_style(button_width: 64, hovered: element.hovered)
        label: row_value_action_label(button_text: signal.format_label)
        target: signal.name
        address: signal.id
    )
}

FUNCTION row_format_dropdown_state_menu(signal) {
    signal.format_dropdown_state == Open |> WHEN {
        True => row_format_dropdown_menu(signal: signal)
        False => row_format_dropdown_closed_menu()
    }
}

FUNCTION row_format_dropdown_closed_menu() {
    Scene/Element/label(
        element: []
        style: [width: 64, height: 0, paint: False]
        label: Scene/Element/text(element: [], style: [paint: False], text: Text/empty())
    )
}

FUNCTION row_format_dropdown_menu(signal) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: 96
            height: 172
            padding: 4
            rounded_corners: 4
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0b1424 }
                Light => TEXT { #edf4fb }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #304057 }
                Light => TEXT { #bad0e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            row_format_hex_dropdown_option(signal: signal)
            row_format_binary_dropdown_option(signal: signal)
            row_format_grouped_dropdown_option(signal: signal)
            row_format_octal_dropdown_option(signal: signal)
            row_format_signed_dropdown_option(signal: signal)
            row_format_unsigned_dropdown_option(signal: signal)
            row_format_ascii_dropdown_option(signal: signal)
        }
    )
}

FUNCTION row_format_hex_dropdown_option(signal) {
    Scene/Element/button(
        element: [event: [press: signal.format_elements.format_hex], hovered: signal.format_elements.format_hex]
        style: format_dropdown_option_style(selected: signal.formatter == Hexadecimal)
        label: format_dropdown_option_label(option_text: TEXT { Hex }, selected: signal.formatter == Hexadecimal)
        target: signal.name
        address: signal.id
    )
}

FUNCTION row_format_binary_dropdown_option(signal) {
