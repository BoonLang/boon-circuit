-- Physical NovyWave scene view.

FUNCTION main_scene() {
    Scene/new(
        root: root()
        lights: [
            key: [x: -0.4, y: -0.8, z: 1.0, intensity: 0.78]
            rim: [x: 0.8, y: 0.2, z: 0.5, intensity: 0.22]
        ]
        geometry: [depth_scale: 1.0]
    )
}

FUNCTION root() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [
            width: Fill
            height: [sizing: Fill, minimum: Screen]
            padding: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f4f7fb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: AppBackground)
        ]
        items: LIST {
            header()
            PASSED.store.fixture_status == TEXT { Empty } |> WHEN {
                True => empty_state()
                False => loaded_app()
            }
        }
    )
}

FUNCTION header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: 34
            depth: 4
            move: [closer: 2]
            rounded_corners: 8
            padding: [left: 10, right: 10, top: 5, bottom: 5]
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0f172a }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #25344f }
                Light => TEXT { #cbd5e1 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                    width: 72
                    height: Fill
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #90a4bf }
                        Light => TEXT { #475569 }
                    }
                ]
                text: TEXT { ● ● ● }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                    width: Fill
                    height: Fill
                    center: True
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #d2def0 }
                        Light => TEXT { #475569 }
                    }
                ]
                text: TEXT { NovyWave.io }
            )
            header_load_button()
            header_empty_button()
            header_mode_button()
        }
    )
}

FUNCTION header_stat(stat_label, stat_value) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: 150
            height: Fill
            padding: 8
            rounded_corners: 10
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: stat_label, font: Muted, width: Fill, height: 18)
            text_line(label_text: stat_value, font: Mono, width: Fill, height: 24)
        }
    )
}

FUNCTION loaded_app() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: Fill
            height: Fill
            paint: False
        ]
        items: LIST {
            browser_band()
            selected_waveform_band()
        }
    )
}

FUNCTION browser_band() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: 322
            paint: False
        ]
        items: LIST {
            left_panel()
            variables_panel()
        }
    )
}

FUNCTION selected_waveform_band() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: Fill
            gap: 0
            paint: False
        ]
        items: LIST {
            timeline_panel()
        }
    )
}

FUNCTION empty_state() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 16
        style: [
            width: Fill
            height: 650
            align: [row: Center]
            scroll_y: True
            scrollbars: True
            padding: 72
            depth: 10
            move: [closer: 2]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #f8fbff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #93b4e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TimelineGlass)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Title)
                    width: Fill
                    height: 44
                    center: True
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dceaff }
                        Light => TEXT { #172033 }
                    }
                ]
                text: PASSED.store.empty_state_title
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                    width: Fill
                    height: 28
                    center: True
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dbeafe }
                        Light => TEXT { #24364b }
                    }
                ]
                text: PASSED.store.empty_state_hint
            )
            empty_state_fact(label_text: PASSED.store.empty_state_bridge_label)
            empty_state_fact(label_text: PASSED.store.empty_state_formats_label)
            empty_load_button()
        }
    )
}

FUNCTION empty_state_fact(label_text) {
    Scene/Element/label(
        element: []
        style: [
            width: 520
            height: 34
            padding: [left: 12, right: 12]
            rounded_corners: 10
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #dbeafe }
                    Light => TEXT { #172033 }
                }
            ]
            text: label_text
        )
    )
}

FUNCTION left_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 6
        style: [
            width: 430
            height: Fill
            padding: 14
            depth: 10
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #2563eb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            panel_title(title_text: TEXT { Files and scopes })
            file_toolbar()
            file_status_card()
            files_list()
        }
    )
}

FUNCTION file_toolbar() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 28, paint: False]
        items: LIST {
            file_load_button()
            file_diagnostic_button()
        }
    )
}

FUNCTION file_status_card() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 38
            padding: [left: 8, right: 8]
            rounded_corners: 7
            background: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #422006 }
                    False => TEXT { #101a2b }
                }
                Light => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #fff7ed }
                    False => TEXT { #ffffff }
                }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #f59e0b }
                    False => TEXT { #263753 }
                }
                Light => PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                    True => TEXT { #fb923c }
                    False => TEXT { #d7dde8 }
                }
            }]
            material: PASSED.store.diagnostic_state == TEXT { Unsupported } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: Warning)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Column
            gap: 1
            style: [width: Fill, height: Fill, paint: False]
            items: LIST {
                file_status_text(line_text: PASSED.store.file_compare_status, line_height: 17)
                file_status_text(
                    line_text: PASSED.store.bridge_open_summary
                    line_height: 15
                )
            }
        )
    )
}

FUNCTION file_status_text(line_text, line_height) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
            width: Fill
            height: line_height
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #24364b }
            }
        ]
        text: line_text
    )
}

FUNCTION files_list() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 1
        style: [width: Fill, height: 176, paint: False, scroll_y: True, scrollbars: True]
        items: LIST {
            file_counter_button()
            file_uart_compare_button()
            file_ghw_button()
            scope_cpu_button()
            tree_row(label_text: TEXT {     clk, reset_n, data_bus ... }, indent_width: 0, selected: False)
            scope_uart_button()
            scope_analog_button()
        }
    )
}

FUNCTION file_load_button() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.load_fixture]
            hovered: PASSED.store.elements.load_fixture
        ]
        style: compact_button_style(button_width: 76, hovered: element.hovered)
        label: button_label(button_text: TEXT { Load })
    )
}

FUNCTION file_diagnostic_button() {
    PASSED.store.pressed_control_label == TEXT { Probe } |> WHEN {
        True => file_diagnostic_button_pressed()
        False => file_diagnostic_button_resting()
    }
}

FUNCTION file_diagnostic_button_resting() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.diagnostic_probe]
            hovered: PASSED.store.elements.diagnostic_probe
        ]
        style: compact_button_style(button_width: 76, hovered: element.hovered)
        label: button_label(button_text: TEXT { Probe })
    )
}

FUNCTION file_diagnostic_button_pressed() {
    Scene/Element/button(
        element: [
            event: [press: PASSED.store.elements.diagnostic_probe]
            hovered: PASSED.store.elements.diagnostic_probe
        ]
        style: probe_button_pressed_style()
        label: button_label(button_text: TEXT { Probe })
    )
}

FUNCTION file_counter_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_counter_file], hovered: PASSED.store.elements.select_counter_file]
        style: [width: Fill, height: 20, paint: False]
        label: tree_row(label_text: TEXT { - counter.vcd }, indent_width: 0, selected: PASSED.store.active_file == TEXT { counter.vcd })
    )
}

FUNCTION file_uart_compare_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_uart_compare_file], hovered: PASSED.store.elements.select_uart_compare_file]
        style: [width: Fill, height: 20, paint: False]
        label: tree_row(label_text: TEXT { - uart_compare.fst }, indent_width: 0, selected: PASSED.store.active_file == TEXT { uart_compare.fst })
    )
}

FUNCTION file_ghw_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.select_ghw_file], hovered: PASSED.store.elements.select_ghw_file]
        style: [width: Fill, height: 20, paint: False]
        label: tree_row(label_text: TEXT { - simple_test.ghw }, indent_width: 0, selected: PASSED.store.active_file == TEXT { simple_test.ghw })
    )
}

FUNCTION tree_row(label_text, indent_width, selected) {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 19
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #203B62 }
                    Light => TEXT { #d7e9ff }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #101a2b }
                    Light => TEXT { #ffffff }
                }
            }]
            border: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #3B82F6 }
                    Light => TEXT { #2474bb }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #263753 }
                    Light => TEXT { #d7dde8 }
                }
            }]
            material: selected |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #dbeafe }
                    Light => TEXT { #172033 }
                }
            ]
            text: label_text
        )
    )
}

FUNCTION file_row(file) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 42
            padding: 6
            rounded_corners: 9
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: file.name, font: Mono, width: Fill, height: 18)
            text_line(label_text: file.range, font: Muted, width: Fill, height: 16)
        }
    )
}

FUNCTION search_box() {
    PASSED.store.focused_control_label == TEXT { signal search } |> WHEN {
        True => search_box_focused()
        False => search_box_resting()
    }
}

FUNCTION search_box_resting() {
    Scene/Element/text_input(
        element: [
            event: [
                click: PASSED.store.elements.signal_search_focus_probe
                change: PASSED.store.elements.signal_search_input
            ]
        ]
        style: [
            width: Fill
            height: 36
            padding: [left: 10, right: 10]
            text_inset: 4
            rounded_corners: 9
            font: NovyTheme/font(mode: PASSED.store.mode, of: Body)
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Hidden[text: TEXT { signal search }]
        text: PASSED.store.signal_search_text
        placeholder: [text: TEXT { search signals }]
    )
}

FUNCTION search_box_focused() {
    Scene/Element/text_input(
        element: [
            event: [
                click: PASSED.store.elements.signal_search_focus_probe
                change: PASSED.store.elements.signal_search_input
            ]
        ]
        style: [
            width: Fill
            height: 36
            padding: [left: 10, right: 10]
            text_inset: 4
            rounded_corners: 9
            font: NovyTheme/font(mode: PASSED.store.mode, of: Body)
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #11243b }
                Light => TEXT { #e9f3ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #65b8ff }
                Light => TEXT { #2474bb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: FocusedControl)
        ]
        label: Hidden[text: TEXT { signal search }]
        text: PASSED.store.signal_search_text
        placeholder: [text: TEXT { search signals }]
    )
}

FUNCTION scope_cpu_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_cpu], hovered: PASSED.store.elements.scope_cpu]
        style: [
            width: Fill
            height: 22
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #203B62 }
                Light => TEXT { #d7e9ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #3B82F6 }
                Light => TEXT { #2474bb }
            }]
            spring_range: 3
            material: PASSED.store.active_scope == TEXT { top_cpu } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 8
            style: [paint: False]
            items: LIST {
                text_line(label_text: TEXT { + top.cpu }, font: Body, width: Fill, height: 18)
                text_line(label_text: TEXT { 8 signals }, font: Muted, width: 70, height: 18)
            }
        )
    )
}

