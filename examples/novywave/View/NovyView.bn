    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: NovyTheme/trace_height(state: segment.state)
            align: [column: Center]
            rounded_corners: 2
            background: [color: TEXT { #2563EB }]
            border: [color: TEXT { #60A5FA }]
            material: NovyTheme/trace_material(mode: PASSED.store.mode, state: segment.state)
