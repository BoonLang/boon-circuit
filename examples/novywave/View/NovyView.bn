-- Physical NovyWave scene view.

FUNCTION main_scene() {
    Scene/new(
        root: root()
        lights: [
            key: [x: -0.4, y: -0.8, z: 1.0, intensity: 0.78]
            rim: [x: 0.8, y: 0.2, z: 0.5, intensity: 0.22]
        ]
        geometry: [depth_scale: 1.0]
    )
}

FUNCTION root() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 10
        style: [
            width: Fill
            height: [sizing: Fill, minimum: Screen]
            padding: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f4f7fb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: AppBackground)
        ]
        items: LIST {
            header()
            PASSED.store.fixture_status |> WHEN {
                TEXT { Empty } => empty_state()
                __ => loaded_app()
            }
        }
    )
}

FUNCTION header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: 34
            depth: 4
            move: [closer: 2]
            rounded_corners: 8
            padding: [left: 10, right: 10, top: 5, bottom: 5]
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0f172a }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #25344f }
                Light => TEXT { #cbd5e1 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                    width: 72
                    height: Fill
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #90a4bf }
                        Light => TEXT { #475569 }
                    }
                ]
                text: TEXT { ● ● ● }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                    width: Fill
                    height: Fill
                    center: True
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #d2def0 }
                        Light => TEXT { #475569 }
                    }
                ]
                text: TEXT { NovyWave.io }
            )
            header_load_button()
            header_empty_button()
            header_mode_button()
        }
    )
}

FUNCTION header_stat(stat_label, stat_value) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: 150
            height: Fill
            padding: 8
            rounded_corners: 10
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: stat_label, font: Muted, width: Fill, height: 18)
            text_line(label_text: stat_value, font: Mono, width: Fill, height: 24)
        }
    )
}

FUNCTION loaded_app() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: Fill
            height: Fill
            paint: False
        ]
        items: LIST {
            browser_band()
            selected_waveform_band()
        }
    )
}

FUNCTION browser_band() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: 322
            paint: False
        ]
        items: LIST {
            left_panel()
            variables_panel()
        }
    )
}

FUNCTION selected_waveform_band() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [
            width: Fill
            height: Fill
            gap: 0
            paint: False
        ]
        items: LIST {
            timeline_panel()
        }
    )
}

FUNCTION empty_state() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 14
        style: [
            width: Fill
            height: 650
            align: [row: Center]
            padding: 80
            depth: 10
            move: [closer: 2]
            rounded_corners: 18
            material: NovyTheme/material(mode: PASSED.store.mode, of: TimelineGlass)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Title)
                    width: Fill
                    height: 44
                    center: True
                ]
                text: TEXT { No waveform loaded }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                    width: Fill
                    height: 28
                    center: True
                ]
                text: TEXT { Load the generated counter fixture to inspect signals. }
            )
            empty_load_button()
        }
    )
}

FUNCTION left_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 6
        style: [
            width: 430
            height: Fill
            padding: 14
            depth: 10
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #2563eb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            panel_title(title_text: TEXT { Files and scopes })
            load_files_button()
            files_list()
        }
    )
}

FUNCTION files_list() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 1
        style: [width: Fill, paint: False]
        items: LIST {
            tree_row(label_text: TEXT { - counter.vcd }, indent_width: 0, selected: False)
            scope_cpu_button()
            tree_row(label_text: TEXT {     clk }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {     reset_n }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {     data_bus[7:0] }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {     data_valid }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {     data_ready }, indent_width: 0, selected: False)
            tree_row(label_text: TEXT {     state[2:0] }, indent_width: 0, selected: False)
            scope_uart_button()
            tree_row(label_text: TEXT {     tx_data[7:0] }, indent_width: 0, selected: False)
            scope_analog_button()
            tree_row(label_text: TEXT { - uart_compare.fst }, indent_width: 0, selected: False)
        }
    )
}

FUNCTION tree_row(label_text, indent_width, selected) {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 19
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #203B62 }
                    Light => TEXT { #d7e9ff }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #101a2b }
                    Light => TEXT { #ffffff }
                }
            }]
            border: [color: selected |> WHEN {
                True => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #3B82F6 }
                    Light => TEXT { #2474bb }
                }
                False => PASSED.store.mode |> WHEN {
                    Dark => TEXT { #263753 }
                    Light => TEXT { #d7dde8 }
                }
            }]
            material: selected |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
            }
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #dbeafe }
                    Light => TEXT { #172033 }
                }
            ]
            text: label_text
        )
    )
}

FUNCTION file_row(file) {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [
            width: Fill
            height: 42
            padding: 6
            rounded_corners: 9
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: file.name, font: Mono, width: Fill, height: 18)
            text_line(label_text: file.range, font: Muted, width: Fill, height: 16)
        }
    )
}

FUNCTION search_box() {
    Scene/Element/text_input(
        element: [
            event: [change: PASSED.store.elements.signal_search_input]
        ]
        style: [
            width: Fill
            height: 36
            padding: [left: 10, right: 10]
            text_inset: 4
            rounded_corners: 9
            font: NovyTheme/font(mode: PASSED.store.mode, of: Body)
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Hidden[text: TEXT { signal search }]
        text: PASSED.store.signal_search_text
        placeholder: [text: TEXT { search signals }]
    )
}

FUNCTION scope_cpu_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_cpu], hovered: PASSED.store.elements.scope_cpu]
        style: [
            width: Fill
            height: 22
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #203B62 }
                Light => TEXT { #d7e9ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #3B82F6 }
                Light => TEXT { #2474bb }
            }]
            spring_range: 3
            material: PASSED.store.active_scope == TEXT { top_cpu } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 8
            style: [paint: False]
            items: LIST {
                text_line(label_text: TEXT { + top.cpu }, font: Body, width: Fill, height: 18)
                text_line(label_text: TEXT { 8 signals }, font: Muted, width: 70, height: 18)
            }
        )
    )
}

FUNCTION scope_uart_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_uart], hovered: PASSED.store.elements.scope_uart]
        style: [
            width: Fill
            height: 22
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.active_scope == TEXT { top_uart } |> WHEN {
                    True => TEXT { #203B62 }
                    False => TEXT { #101a2b }
                }
                Light => PASSED.store.active_scope == TEXT { top_uart } |> WHEN {
                    True => TEXT { #d7e9ff }
                    False => TEXT { #ffffff }
                }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.active_scope == TEXT { top_uart } |> WHEN {
                    True => TEXT { #3B82F6 }
                    False => TEXT { #263753 }
                }
                Light => PASSED.store.active_scope == TEXT { top_uart } |> WHEN {
                    True => TEXT { #2474bb }
                    False => TEXT { #d7dde8 }
                }
            }]
            spring_range: 3
            material: PASSED.store.active_scope == TEXT { top_uart } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 8
            style: [paint: False]
            items: LIST {
                text_line(label_text: TEXT { + top.uart }, font: Body, width: Fill, height: 18)
                text_line(label_text: TEXT { 5 signals }, font: Muted, width: 70, height: 18)
            }
        )
    )
}

FUNCTION scope_analog_button() {
    Scene/Element/button(
        element: [event: [press: PASSED.store.elements.scope_analog], hovered: PASSED.store.elements.scope_analog]
        style: [
            width: Fill
            height: 22
            padding: [left: 6, right: 6]
            rounded_corners: 4
            background: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.active_scope == TEXT { top_analog } |> WHEN {
                    True => TEXT { #203B62 }
                    False => TEXT { #101a2b }
                }
                Light => PASSED.store.active_scope == TEXT { top_analog } |> WHEN {
                    True => TEXT { #d7e9ff }
                    False => TEXT { #ffffff }
                }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => PASSED.store.active_scope == TEXT { top_analog } |> WHEN {
                    True => TEXT { #3B82F6 }
                    False => TEXT { #263753 }
                }
                Light => PASSED.store.active_scope == TEXT { top_analog } |> WHEN {
                    True => TEXT { #2474bb }
                    False => TEXT { #d7dde8 }
                }
            }]
            spring_range: 3
            material: PASSED.store.active_scope == TEXT { top_analog } |> WHEN {
                True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                False => NovyTheme/material(mode: PASSED.store.mode, of: HoverControl)
            }
        ]
        label: Scene/Element/stripe(
            element: []
            direction: Row
            gap: 8
            style: [paint: False]
            items: LIST {
                text_line(label_text: TEXT { + top.analog }, font: Body, width: Fill, height: 18)
                text_line(label_text: TEXT { 2 signals }, font: Muted, width: 70, height: 18)
            }
        )
    )
}

FUNCTION timeline_panel() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 8
        style: [
            width: Fill
            height: Fill
            padding: 10
            depth: 4
            move: [closer: 1]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #2563eb }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelSurface)
        ]
        items: LIST {
            timeline_header()
            timeline_toolbar()
            timeline_axis()
            waveform_rows()
        }
    )
}

FUNCTION timeline_header() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 30, paint: False]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Heading)
                    width: 240
                    height: Fill
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dceaff }
                        Light => TEXT { #182a3d }
                    }
                ]
                text: TEXT { Selected Variables }
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                    width: Fill
                    height: Fill
                    center: True
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #90a4bf }
                        Light => TEXT { #60748b }
                    }
                ]
                text: TEXT { Dock to Right }
            )
            remove_all_button()
        }
    )
}

FUNCTION timeline_toolbar() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 4
        style: [width: Fill, height: 60, paint: False]
        items: LIST {
            timeline_navigation_controls()
            selected_row_controls()
            keyboard_capture()
        }
    )
}

FUNCTION timeline_navigation_controls() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 28, paint: False]
        items: LIST {
            zoom_in_button()
            zoom_out_button()
            pan_left_button()
            pan_right_button()
            cursor_left_button()
            cursor_right_button()
            marker_button()
            group_button()
            format_button()
        }
    )
}

FUNCTION selected_row_controls() {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 6
        style: [width: Fill, height: 28, paint: False]
        items: LIST {
            remove_data_button()
            restore_data_button()
            data_up_button()
            data_down_button()
            rename_marker_button()
            jump_marker_button()
            remove_marker_button()
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
                    width: Fill
                    height: Fill
                    vertical_align: Center
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #90a4bf }
                        Light => TEXT { #60748b }
                    }
                ]
                text: PASSED.store.selected_rows_order_label
            )
        }
    )
}

FUNCTION keyboard_capture() {
    Scene/Element/text_input(
        element: [
            event: [key_down: PASSED.store.elements.keyboard_capture]
        ]
        style: [
            width: 1
            height: 1
            paint: False
            padding: 0
            rounded_corners: 8
            font: NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Hidden[text: TEXT { keyboard capture }]
        text: Text/empty()
        placeholder: []
    )
}

FUNCTION timeline_axis() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 3
        style: [
            width: Fill
            height: 42
            padding: 6
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #eef5ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #93b4e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 0
                style: [width: Fill, height: 20, paint: False]
                items: LIST {
                    axis_tick(label: TEXT { 0 ns })
                    axis_tick(label: TEXT { 40 ns })
                    axis_tick(label: TEXT { 80 ns })
                    axis_tick(label: TEXT { 120 ns })
                    axis_tick(label: TEXT { 160 ns })
                }
            )
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 4
                style: [width: Fill, height: 16, paint: False]
                items: LIST {
                    cursor_chip()
                    PASSED.store.marker_visibility |> WHEN {
                        TEXT { Visible } => marker_chip()
                        TEXT { Hidden } => NoElement
                    }
                }
            )
        }
    )
}

FUNCTION axis_tick(label) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Muted)
            width: 120
            height: 18
            center: True
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #90a4bf }
                Light => TEXT { #60748b }
            }
        ]
        text: label
    )
}

FUNCTION cursor_chip() {
    Scene/Element/label(
        element: []
        style: [
            width: 118
            height: 18
            rounded_corners: 8
            background: [color: TEXT { #1D4ED8 }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: CursorGlow)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
            ]
            text: PASSED.store.keyboard_cursor_label
        )
    )
}

FUNCTION marker_chip() {
    Scene/Element/label(
        element: []
        style: [
            width: 150
            height: 18
            rounded_corners: 8
            background: [color: TEXT { #4F46E5 }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: MarkerChip)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
            ]
            text: PASSED.store.marker_label
        )
    )
}

FUNCTION collapsed_group() {
    Scene/Element/label(
        element: []
        style: [
            width: Fill
            height: 48
            rounded_corners: 10
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: TEXT { #DBEAFE }
            ]
            text: TEXT { Core bus group collapsed }
        )
    )
}

FUNCTION waveform_rows() {
    PASSED.store.selected_group |> WHEN {
        TEXT { Collapsed } => collapsed_group()
        __ => waveform_rows_expanded()
    }
}

FUNCTION waveform_rows_expanded() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 2
        style: [width: Fill, height: Fill, paint: False]
        items: LIST {
            waveform_row_clk()
            waveform_row_reset()
            waveform_row_data()
            waveform_row_temperature()
        }
    )
}

FUNCTION waveform_row_clk() {
    BLOCK {
        active: PASSED.store.active_signal == TEXT { clk }

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 2
                background: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #071120 }
                    Light => TEXT { #f7fbff }
                }]
                border: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #1c2b43 }
                    Light => TEXT { #cbd9ec }
                }]
                material: active |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
                }
            ]
            items: LIST {
                fixed_signal_label(label_text: NovyFixtures/selected_clk_name())
                fixed_value_clk()
                fixed_wave_area_clk()
            }
        )
    }
}

FUNCTION waveform_row_reset() {
    BLOCK {
        active: PASSED.store.active_signal == TEXT { reset_n }

        Scene/Element/stripe(
            element: []
            direction: Row
            gap: 6
            style: [
                width: Fill
                height: PASSED.store.row_height
                padding: 5
                rounded_corners: 2
                background: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #071120 }
                    Light => TEXT { #f7fbff }
                }]
                border: [color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #1c2b43 }
                    Light => TEXT { #cbd9ec }
                }]
                material: active |> WHEN {
                    True => NovyTheme/material(mode: PASSED.store.mode, of: SelectedRow)
                    False => NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
                }
            ]
            items: LIST {
                fixed_signal_label(label_text: NovyFixtures/selected_reset_name())
                fixed_value_reset()
                fixed_wave_area_reset()
            }
        )
    }
}

