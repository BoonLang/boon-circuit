FUNCTION page() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 24
        style: [width: Fill, paint: False]
        items: LIST {
            KavikComponents/page_hero(PASS: [store: PASSED.store], title: TEXT { Blog }, tagline: TEXT { News, notes, and build logs. })
            Scene/Element/stripe(
                element: []
                direction: Row
                gap: 16
                style: [width: Fill, wrap: True, wrap_min_width: 320, paint: False]
                items: LIST {
                    boon_post_card() |> SOURCE { PASSED.store.elements.post.boon }
                    novywave_post_card() |> SOURCE { PASSED.store.elements.post.novywave }
                    moonzoon_foundations_card() |> SOURCE { PASSED.store.elements.post.moonzoon_foundations }
                    moonzoon_history_card() |> SOURCE { PASSED.store.elements.post.moonzoon_history }
                }
            )
            KavikComponents/contact_section(PASS: [store: PASSED.store])
        }
    )
}

