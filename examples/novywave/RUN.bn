            [signal_id: TEXT { data_ready }, width: 144, state: High, label: TEXT { 1 }]
            [signal_id: TEXT { state }, width: 0, state: CursorLine, label: TEXT { cursor }]
            [signal_id: TEXT { state }, width: 72, state: Unknown, label: TEXT { IDLE }]
            [signal_id: TEXT { state }, width: 0, state: MarkerLine, label: TEXT { marker }]
            [signal_id: TEXT { state }, width: 128, state: High, label: TEXT { RUN }]
            [signal_id: TEXT { state }, width: 136, state: Low, label: TEXT { WAIT }]
            [signal_id: TEXT { error_count }, width: 0, state: CursorLine, label: TEXT { cursor }]
            [signal_id: TEXT { error_count }, width: 188, state: Low, label: TEXT { 0 }]
            [signal_id: TEXT { error_count }, width: 0, state: MarkerLine, label: TEXT { marker }]
            [signal_id: TEXT { error_count }, width: 56, state: High, label: TEXT { 1 }]
            [signal_id: TEXT { error_count }, width: 92, state: Low, label: TEXT { 0 }]
            [signal_id: TEXT { temperature }, width: 0, state: CursorLine, label: TEXT { cursor }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogLow, label: TEXT { 39 }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogMid, label: TEXT { 41 }]
            [signal_id: TEXT { temperature }, width: 0, state: MarkerLine, label: TEXT { marker }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogHigh, label: TEXT { 44 }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogMid, label: TEXT { 43 }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogLow, label: TEXT { 40 }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogMid, label: TEXT { 42 }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogHigh, label: TEXT { 44 }]
            [signal_id: TEXT { temperature }, width: 42, state: AnalogMid, label: TEXT { 43 }]
            [signal_id: TEXT { tx_data }, width: 0, state: CursorLine, label: TEXT { cursor }]
            [signal_id: TEXT { tx_data }, width: 48, state: Unknown, label: TEXT { idle }]
            [signal_id: TEXT { tx_data }, width: 0, state: MarkerLine, label: TEXT { marker }]
            [signal_id: TEXT { tx_data }, width: 88, state: High, label: TEXT { 0x55 }]
            [signal_id: TEXT { tx_data }, width: 72, state: Low, label: TEXT { gap }]
            [signal_id: TEXT { tx_data }, width: 104, state: High, label: TEXT { 0xa5 }]
            [signal_id: TEXT { rx_data }, width: 0, state: CursorLine, label: TEXT { cursor }]
            [signal_id: TEXT { rx_data }, width: 64, state: Low, label: TEXT { start }]
            [signal_id: TEXT { rx_data }, width: 0, state: MarkerLine, label: TEXT { marker }]
            [signal_id: TEXT { rx_data }, width: 96, state: High, label: TEXT { 0xaa }]
            [signal_id: TEXT { rx_data }, width: 72, state: Low, label: TEXT { stop }]
            [signal_id: TEXT { rx_data }, width: 80, state: High, label: TEXT { idle }]
