FUNCTION column_divider_style() {
    [
        width: 4
        height: Fill
        rounded_corners: 0
        cursor: TEXT { col-resize }
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #25344f }
            Light => TEXT { #c9d7ea }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #4b607c }
            Light => TEXT { #8fa8c9 }
        }
        __hover_gloss: 0.02
    ]
}

FUNCTION row_divider_style() {
    [
        width: Fill
        height: 4
        rounded_corners: 0
        cursor: TEXT { row-resize }
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #25344f }
            Light => TEXT { #c9d7ea }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #4b607c }
            Light => TEXT { #8fa8c9 }
        }
        __hover_gloss: 0.02
    ]
}

FUNCTION signal_row_divider_style() {
    [
        width: Fill
        height: 3
        rounded_corners: 0
        cursor: TEXT { row-resize }
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #162033 }
            Light => TEXT { #d7dde8 }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #334761 }
            Light => TEXT { #9fb3cf }
        }
        __hover_gloss: 0.02
    ]
}

FUNCTION empty_state() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 16
        style: [
            width: Fill
            height: 650
            align: [row: Center]
            scroll_y: True
            scrollbars: True
            padding: 72
            depth: 10
            move: [closer: 2]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #101a2b }
                Light => TEXT { #f8fbff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #93b4e8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TimelineGlass)
        ]
        items: LIST {
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Title)
                    width: Fill
                    height: 44
                    center: True
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dceaff }
                        Light => TEXT { #172033 }
                    }
                ]
                text: PASSED.store.empty_state_title
            )
            Scene/Element/text(
                element: []
                style: [
                    ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
                    width: Fill
                    height: 28
                    center: True
                    color: PASSED.store.mode |> WHEN {
                        Dark => TEXT { #dbeafe }
                        Light => TEXT { #24364b }
                    }
                ]
                text: PASSED.store.empty_state_hint
            )
            empty_state_fact(label_text: PASSED.store.empty_state_bridge_label)
            empty_state_fact(label_text: PASSED.store.empty_state_formats_label)
            empty_open_button()
            empty_load_button()
        }
    )
}

FUNCTION empty_state_fact(label_text) {
    Scene/Element/label(
        element: []
        style: [
            width: 520
            height: 34
            padding: [left: 12, right: 12]
            rounded_corners: 10
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0a1322 }
                Light => TEXT { #ffffff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #263753 }
                Light => TEXT { #d7dde8 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/font(mode: PASSED.store.mode, of: Mono)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
                color: PASSED.store.mode |> WHEN {
                    Dark => TEXT { #dbeafe }
                    Light => TEXT { #172033 }
                }
            ]
            text: label_text
        )
    )
}

FUNCTION loading_state() {
    Scene/Element/stripe(
        element: []
        direction: Column
        gap: 14
        style: [
            width: Fill
            height: 650
            align: [row: Center]
            padding: 72
            depth: 12
            move: [closer: 3]
            rounded_corners: 0
            background: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #0b1628 }
                Light => TEXT { #eef6ff }
            }]
            border: [color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #2563eb }
                Light => TEXT { #3b82f6 }
            }]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TimelineGlass)
        ]
