FUNCTION panel_title(title_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Heading)
            width: Fill
            height: 24
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dceaff }
                Light => TEXT { #182a3d }
            }
        ]
        text: title_text
    )
}

FUNCTION button_label(button_text) {
    Scene/Element/text(
        element: []
        style: [
            ...NovyTheme/font(mode: PASSED.store.mode, of: Body)
            width: Fill
            height: Fill
            center: True
            vertical_align: Center
            color: PASSED.store.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
        ]
        text: button_text
    )
}

FUNCTION compact_button_style(button_width, hovered) {
    [
        width: button_width
        height: 28
        rounded_corners: 8
        spring_range: 3
        center: True
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #101a2b }
            Light => TEXT { #ffffff }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #1a2b44 }
            Light => TEXT { #e9f3ff }
        }
        border: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #334761 }
            Light => TEXT { #bad0e8 }
        }]
        __hover_border: PASSED.store.mode |> WHEN {
            Dark => TEXT { #49617f }
            Light => TEXT { #bad0e8 }
        }
        material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        __hover_gloss: 0.08
    ]
}

FUNCTION probe_button_pressed_style() {
    [
        width: 76
        height: 28
        rounded_corners: 8
        spring_range: 3
        center: True
        background: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #28466d }
            Light => TEXT { #cce4ff }
        }]
        __hover_background: PASSED.store.mode |> WHEN {
            Dark => TEXT { #1a2b44 }
            Light => TEXT { #e9f3ff }
        }
        border: [color: PASSED.store.mode |> WHEN {
            Dark => TEXT { #65b8ff }
            Light => TEXT { #2474bb }
        }]
        __hover_border: PASSED.store.mode |> WHEN {
            Dark => TEXT { #49617f }
            Light => TEXT { #bad0e8 }
        }
        material: NovyTheme/material(mode: PASSED.store.mode, of: PressedControl)
        __hover_gloss: 0.08
    ]
}

FUNCTION format_button_pressed_style() {
