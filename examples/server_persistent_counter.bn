store: [
    request: SOURCE

    request_count:
        0 |> HOLD request_count {
            request.method |> THEN { request_count + 1 }
        }
]

outputs: [
    response: [
        status: 200
        body: store.request_count
            |> Number/to_text(radix: 10)
            |> Text/to_bytes(encoding: Utf8)
    ]
]

host_ports: [
    http: [
        request: store.request
        response: response
    ]
]
