store: [
    save: SOURCE
    bytes: BYTES[4] { 16u01, 16u02, 16u03, 16u04 } |> HOLD bytes { LATEST {} }
    result:
        NotStarted |> HOLD result {
            store.save |> THEN {
                File/write_bytes(file: store.save.file, bytes: store.bytes)
            }
        }
]

outputs: [
    result: store.result
]
