-- NovyWave - Boon-first physical waveform viewer playground example.

store: [
    visible_editor_reference: NovyReference/visual_basis_label()
    visible_editor_pipe_probe:
        LATEST {
            TEXT { Visible editor syntax probe }
            elements.load_default_file |> THEN { TEXT { Default file path exercised } }
        }

    default_waveform_asset:
        PackageAsset[url: TEXT { asset://novywave/simple.vcd }]

    fst_waveform_asset:
        PackageAsset[url: TEXT { asset://novywave/basic_test.fst }]

    ghw_waveform_asset:
        PackageAsset[url: TEXT { asset://novywave/simple_test.ghw }]

    real_waveform_file_request:
        LATEST {
            elements.begin_default_file_load |> THEN { TEXT { simple.vcd } }
            elements.load_default_file |> THEN { TEXT { simple.vcd } }
            elements.select_counter_file |> THEN { TEXT { simple.vcd } }
            elements.select_uart_compare_file |> THEN { TEXT { wave_27.fst } }
            elements.select_ghw_file |> THEN { TEXT { simple_test.ghw } }
            default_file_tree_selected_file
            load_requested_fixture_file
        }

    real_waveform_asset:
        default_waveform_asset |> HOLD real_waveform_asset {
            real_waveform_file_request |> WHEN {
                TEXT { simple.vcd } => default_waveform_asset
                TEXT { wave_27.fst } => fst_waveform_asset
                TEXT { simple_test.ghw } => ghw_waveform_asset
                __ => SKIP
            }
        }

    real_waveform_stream_mode:
        Inactive |> HOLD real_waveform_stream_mode {
            LATEST {
                real_waveform_file_request |> THEN { Active }
                elements.show_empty |> THEN { Inactive }
            }
        }

    real_file_stream_result:
        NotStarted |> HOLD real_file_stream_result {
            real_waveform_stream_mode |> WHILE {
                Active => File/read_stream(
                    file: real_waveform_asset
                    chunk_bytes: 65536
                    retain_content: True
                )
                Inactive => SKIP
            }
        }

    real_file_stream_completed_asset:
        default_waveform_asset |> HOLD real_file_stream_completed_asset {
            real_file_stream_result |> WHEN {
                Finished => real_waveform_asset
                __ => SKIP
            }
        }

    real_waveform_open_result:
        NotStarted |> HOLD real_waveform_open_result {
            real_file_stream_result |> WHEN {
                Finished => real_file_stream_result.retained |> WHEN {
                    Retained => Wellen/open(content: real_file_stream_result.retained.content)
                    __ => SKIP
                }
                __ => SKIP
            }
        }

    real_hierarchy_page_result:
        NotStarted |> HOLD real_hierarchy_page_result {
            real_waveform_open_result |> WHEN {
                WaveformOpened => Wellen/hierarchy_page(
                    artifact: real_waveform_open_result.artifact
                    request_fingerprint: TEXT { hierarchy:default:0 }
                    offset: 0
                    limit: 256
                )
                __ => SKIP
            }
        }

    real_first_signal_id:
        real_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                real_hierarchy_page_result.rows
                |> List/find(item, if: item.kind == TEXT { Signal })
                |> WHEN {
                    Found[value] => value.signal_id
                    NotFound => TEXT { none }
                }
            __ => TEXT { none }
        }

    real_signal_page_offset:
        0 |> HOLD real_signal_page_offset {
            LATEST {
                real_hierarchy_page_result |> THEN { 0 }
                row_selected_signal_key |> THEN { 0 }
                elements.zoom_in |> THEN { 0 }
                elements.zoom_out |> THEN { 0 }
                elements.zoom_reset |> THEN { 0 }
                elements.pan_left |> THEN { 0 }
                elements.pan_right |> THEN { 0 }
                elements.signal_page_next |> THEN {
                    real_signal_page_result |> WHEN {
                        SignalPage => real_signal_page_result.has_more |> WHEN {
                            True => real_signal_page_result.next_offset
                            False => SKIP
                        }
                        __ => SKIP
                    }
                }
            }
        }

    real_signal_page_request_fingerprint:
        NovyModel/descriptor_label(
            scope: active_scope
            signal: active_signal
            zoom: zoom_level
            pan: pan_window
            cursor: TEXT { page }
            format: TEXT { raw }
        )
        |> Text/concat(with: real_signal_page_offset, separator: "|offset:")

    real_signal_request_fingerprint:
        NovyModel/descriptor_label(
            scope: active_scope
            signal: active_signal
            zoom: zoom_level
            pan: pan_window
            cursor: selected_timeline_cursor_value
            format: active_signal_format
        )

    real_signal_page_signal_ids:
        real_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                real_hierarchy_page_result.signal_ids
                |> List/find(item, if: item == active_signal)
                |> WHEN {
                    Found[value] => LIST { value }
                    NotFound => real_first_signal_id == TEXT { none } |> WHEN {
                        True => LIST {}
                        False => LIST { real_first_signal_id }
                    }
                }
            __ => LIST {}
        }

    real_signal_page_request:
        LATEST {
            real_hierarchy_page_result |> WHEN {
                HierarchyPage => real_signal_page_request_fingerprint
                __ => SKIP
            }
            row_selected_signal_key |> THEN { real_signal_page_request_fingerprint }
            elements.zoom_in |> THEN { real_signal_page_request_fingerprint }
            elements.zoom_out |> THEN { real_signal_page_request_fingerprint }
            elements.zoom_reset |> THEN { real_signal_page_request_fingerprint }
            elements.pan_left |> THEN { real_signal_page_request_fingerprint }
            elements.pan_right |> THEN { real_signal_page_request_fingerprint }
            elements.signal_page_next |> THEN {
                real_signal_page_result |> WHEN {
                    SignalPage => real_signal_page_result.has_more |> WHEN {
                        True => real_signal_page_request_fingerprint
                        False => SKIP
                    }
                    __ => SKIP
                }
            }
            elements.keyboard_capture.key |> WHEN {
                W => real_signal_page_request_fingerprint
                S => real_signal_page_request_fingerprint
                A => real_signal_page_request_fingerprint
                D => real_signal_page_request_fingerprint
                R => real_signal_page_request_fingerprint
                __ => SKIP
            }
        }

    real_signal_page_result:
        NotStarted |> HOLD real_signal_page_result {
            real_signal_page_request |> THEN {
                real_hierarchy_page_result |> WHEN {
                    HierarchyPage =>
                        real_file_stream_completed_asset
                        == real_waveform_asset
                        |> WHEN {
                            True => real_file_stream_result |> WHEN {
                                Finished => real_file_stream_result.retained |> WHEN {
                                    Retained =>
                                        real_hierarchy_page_result.artifact.content
                                        == real_file_stream_result.retained.content
                                        |> WHEN {
                                            True => real_signal_page_signal_ids |> List/is_not_empty() |> WHEN {
                                                True => Wellen/signal_page(
                                                    artifact: real_hierarchy_page_result.artifact
                                                    request_fingerprint: real_signal_page_request_fingerprint
                                                    signal_ids: real_signal_page_signal_ids
                                                    start_time: viewport_label_start
                                                    end_time: viewport_label_end
                                                    offset: real_signal_page_offset
                                                    max_transitions: 2
                                                )
                                                False => SKIP
                                            }
                                            False => SKIP
                                        }
                                    __ => SKIP
                                }
                                __ => SKIP
                            }
                            False => SKIP
                        }
                    __ => SKIP
                }
            }
        }

    real_cursor_time_tick:
        selected_timeline_cursor_value |> Number/round()

    real_cursor_request_fingerprint:
        real_signal_page_request_fingerprint
        |> Text/concat(with: real_cursor_time_tick, separator: "|cursor:")

    real_cursor_values_request:
        LATEST {
            real_signal_page_result |> WHEN {
                SignalPage => real_cursor_request_fingerprint
                __ => SKIP
            }
            selected_timeline_cursor_update |> THEN { real_cursor_request_fingerprint }
        }

    real_cursor_values_result:
        NotStarted |> HOLD real_cursor_values_result {
            real_cursor_values_request |> THEN {
                real_signal_page_result |> WHEN {
                    SignalPage => real_signal_page_result.request_fingerprint == real_signal_page_request_fingerprint |> WHEN {
                        True => Wellen/cursor_values(
                            artifact: real_signal_page_result.artifact
                            request_fingerprint: real_cursor_request_fingerprint
                            cursor_time: real_cursor_time_tick
                            signal_ids: real_signal_page_result.signal_ids
                        )
                        False => SKIP
                    }
                    __ => SKIP
                }
            }
        }

    comparison_waveform_mode:
        Inactive |> HOLD comparison_waveform_mode {
            LATEST {
                elements.select_uart_compare_file |> THEN { Active }
                file_tree_selected_file |> WHEN {
                    TEXT { wave_27.fst } => Active
                    __ => Inactive
                }
                elements.select_counter_file |> THEN { Inactive }
                elements.select_ghw_file |> THEN { Inactive }
                elements.load_default_file |> THEN { Inactive }
                elements.show_empty |> THEN { Inactive }
            }
        }

    comparison_file_stream_result:
        NotStarted |> HOLD comparison_file_stream_result {
            comparison_waveform_mode |> WHILE {
                Active => File/read_stream(
                    file: default_waveform_asset
                    chunk_bytes: 65536
                    retain_content: True
                )
                Inactive => SKIP
            }
        }

    comparison_waveform_open_result:
        NotStarted |> HOLD comparison_waveform_open_result {
            comparison_file_stream_result |> WHEN {
                Finished => comparison_file_stream_result.retained |> WHEN {
                    Retained => Wellen/open(content: comparison_file_stream_result.retained.content)
                    __ => SKIP
                }
                __ => SKIP
            }
        }

    comparison_hierarchy_page_result:
        NotStarted |> HOLD comparison_hierarchy_page_result {
            comparison_waveform_open_result |> WHEN {
                WaveformOpened => Wellen/hierarchy_page(
                    artifact: comparison_waveform_open_result.artifact
                    request_fingerprint: TEXT { hierarchy:comparison:0 }
                    offset: 0
                    limit: 256
                )
                __ => SKIP
            }
        }

    comparison_first_signal_id:
        comparison_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                comparison_hierarchy_page_result.rows
                |> List/find(item, if: item.kind == TEXT { Signal })
                |> WHEN {
                    Found[value] => value.signal_id
                    NotFound => TEXT { none }
                }
            __ => TEXT { none }
        }

    comparison_signal_ids:
        comparison_first_signal_id == TEXT { none } |> WHEN {
            True => LIST {}
            False => LIST { comparison_first_signal_id }
        }

    comparison_signal_page_request_fingerprint:
        TEXT { comparison }
        |> Text/concat(with: comparison_first_signal_id, separator: "|")
        |> Text/concat(with: viewport_label_start, separator: "|start:")
        |> Text/concat(with: viewport_label_end, separator: "|end:")

    comparison_signal_page_request:
        LATEST {
            comparison_hierarchy_page_result |> WHEN {
                HierarchyPage => comparison_signal_page_request_fingerprint
                __ => SKIP
            }
            elements.zoom_in |> THEN { comparison_signal_page_request_fingerprint }
            elements.zoom_out |> THEN { comparison_signal_page_request_fingerprint }
            elements.zoom_reset |> THEN { comparison_signal_page_request_fingerprint }
            elements.pan_left |> THEN { comparison_signal_page_request_fingerprint }
            elements.pan_right |> THEN { comparison_signal_page_request_fingerprint }
            elements.keyboard_capture.key |> WHEN {
                W => comparison_signal_page_request_fingerprint
                S => comparison_signal_page_request_fingerprint
                A => comparison_signal_page_request_fingerprint
                D => comparison_signal_page_request_fingerprint
                R => comparison_signal_page_request_fingerprint
                __ => SKIP
            }
        }

    comparison_signal_page_result:
        NotStarted |> HOLD comparison_signal_page_result {
            comparison_signal_page_request |> THEN {
                comparison_waveform_mode |> WHILE {
                    Active => comparison_hierarchy_page_result |> WHEN {
                        HierarchyPage => comparison_signal_ids |> List/is_not_empty() |> WHEN {
                            True => Wellen/signal_page(
                                artifact: comparison_hierarchy_page_result.artifact
                                request_fingerprint: comparison_signal_page_request_fingerprint
                                signal_ids: comparison_signal_ids
                                start_time: viewport_label_start
                                end_time: viewport_label_end
                                offset: 0
                                max_transitions: 256
                            )
                            False => SKIP
                        }
                        __ => SKIP
                    }
                    Inactive => SKIP
                }
            }
        }

    comparison_cursor_request_fingerprint:
        comparison_signal_page_request_fingerprint
        |> Text/concat(with: real_cursor_time_tick, separator: "|cursor:")

    comparison_cursor_values_result:
        NotStarted |> HOLD comparison_cursor_values_result {
            LATEST {
                comparison_signal_page_result |> WHEN {
                    SignalPage => Wellen/cursor_values(
                        artifact: comparison_signal_page_result.artifact
                        request_fingerprint: comparison_cursor_request_fingerprint
                        cursor_time: real_cursor_time_tick
                        signal_ids: comparison_signal_page_result.signal_ids
                    )
                    __ => SKIP
                }
                selected_timeline_cursor_update |> THEN {
                    comparison_signal_page_result |> WHEN {
                        SignalPage => Wellen/cursor_values(
                            artifact: comparison_signal_page_result.artifact
                            request_fingerprint: comparison_cursor_request_fingerprint
                            cursor_time: real_cursor_time_tick
                            signal_ids: comparison_signal_page_result.signal_ids
                        )
                        __ => SKIP
                    }
                }
            }
        }

    comparison_visible:
        comparison_waveform_mode |> WHEN {
            Active => comparison_signal_page_result |> WHEN {
                SignalPage => True
                __ => False
            }
            Inactive => False
        }

    comparison_transition_count:
        comparison_signal_page_result |> WHEN {
            SignalPage =>
                comparison_signal_page_result.signals
                |> List/find(item, if: item.signal_id == comparison_first_signal_id)
                |> WHEN {
                    Found[value] => value.transitions
                    NotFound => LIST {}
                }
                |> List/length()
            __ => 0
        }

    comparison_signal_name:
        comparison_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                comparison_hierarchy_page_result.rows
                |> List/find(item, if: item.signal_id == comparison_first_signal_id)
                |> WHEN {
                    Found[value] => value.full_name
                    NotFound => TEXT { comparison signal }
                }
            __ => TEXT { comparison signal }
        }

    comparison_signal_width:
        comparison_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                comparison_hierarchy_page_result.rows
                |> List/find(item, if: item.signal_id == comparison_first_signal_id)
                |> WHEN {
                    Found[value] => value.width
                    NotFound => 1
                }
            __ => 1
        }

    comparison_current_value:
        comparison_cursor_values_result |> WHEN {
            CursorValues => real_waveform_value_text(
                value:
                    comparison_cursor_values_result.rows
                    |> List/find(item, if: item.signal_id == comparison_first_signal_id)
                    |> WHEN {
                        Found[value] => value.value
                        NotFound => StringValue[text: Text/empty()]
                    }
            )
            __ => Text/empty()
        }

    comparison_signal_row:
        [
            file: TEXT { simple.vcd }
            id: comparison_first_signal_id
            name: comparison_signal_name
            current_value: comparison_current_value
            bit_width:
                comparison_signal_width
                |> Number/to_text(radix: 10)
                |> Text/concat(with: TEXT { bit }, separator: "-")
            formatter: Hexadecimal
            grouped: False
            segments:
                comparison_signal_segments()
                |> List/map(item, new: new_waveform_segment(segment: item))
        ]

    real_bridge_format:
        real_waveform_open_result |> WHEN {
            WaveformOpened => real_waveform_open_result.format
            __ => TEXT { none }
        }

    real_bridge_stats:
        real_waveform_open_result |> WHEN {
            WaveformOpened =>
                real_waveform_open_result.format
                |> Text/concat(with: real_waveform_open_result.signal_count, separator: " ")
                |> Text/concat(with: TEXT { signals }, separator: " ")
                |> Text/concat(with: real_waveform_open_result.scope_count, separator: ", ")
                |> Text/concat(with: TEXT { scopes }, separator: " ")
            __ => TEXT { waveform not opened }
        }

    real_hierarchy_status:
        real_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                TEXT { hierarchy rows }
                |> Text/concat(with: real_hierarchy_page_result.total_rows, separator: ": ")
            WaveformFailed => real_hierarchy_page_result.diagnostic
            __ => TEXT { hierarchy not requested }
        }

    real_signal_status:
        real_signal_page_result |> WHEN {
            SignalPage =>
                TEXT { signal pages }
                |> Text/concat(with: real_signal_page_result.signals |> List/length(), separator: ": ")
            WaveformFailed => real_signal_page_result.diagnostic
            __ => TEXT { signals not requested }
        }

    real_cursor_status:
        real_cursor_values_result |> WHEN {
            CursorValues =>
                TEXT { cursor values }
                |> Text/concat(with: real_cursor_values_result.rows |> List/length(), separator: ": ")
            WaveformFailed => real_cursor_values_result.diagnostic
            __ => TEXT { cursor not requested }
        }

    real_runtime_status:
        real_hierarchy_status
        |> Text/concat(with: real_signal_status, separator: ", ")
        |> Text/concat(with: real_cursor_status, separator: ", ")

    elements: [
        open_workspace_dialog: SOURCE
        close_workspace_dialog: SOURCE
        select_workspace_repo: SOURCE
        select_workspace_a: SOURCE
        select_workspace_b: SOURCE
        open_selected_workspace: SOURCE
        open_load_files_dialog: SOURCE
        close_load_files_dialog: SOURCE
        load_file_path_focus_probe: SOURCE
        load_file_path_input: SOURCE
        load_external_file: SOURCE
        external_file_loaded_name: SOURCE
        external_file_loaded_path: SOURCE
        external_file_loaded_format: SOURCE
        external_file_loaded_digest: SOURCE
        external_file_loaded_waveform_ref: SOURCE
        external_file_loaded_stats: SOURCE
        external_file_loaded_contract: SOURCE
        external_file_load_error: SOURCE
        begin_default_file_load: SOURCE
        load_default_file: SOURCE
        show_empty: SOURCE
        file_row_select: SOURCE
        select_counter_file: SOURCE
        select_uart_compare_file: SOURCE
        select_ghw_file: SOURCE
        signal_search_focus_probe: SOURCE
        mode_to_light: SOURCE
        mode_to_dark: SOURCE
        zoom_in: SOURCE
        zoom_out: SOURCE
        zoom_reset: SOURCE
        pan_left: SOURCE
        pan_right: SOURCE
        signal_page_next: SOURCE
        cursor_left: SOURCE
        cursor_right: SOURCE
        marker_toggle: SOURCE
        marker_rename: SOURCE
        marker_remove: SOURCE
        marker_jump: SOURCE
        group_create: SOURCE
        group_rename: SOURCE
        group_toggle: SOURCE
        group_expand: SOURCE
        group_remove: SOURCE
        stale_response_probe: SOURCE
        row_taller: SOURCE
        row_shorter: SOURCE
        selected_remove_data: SOURCE
        selected_remove_clk: SOURCE
        selected_remove_reset: SOURCE
        selected_remove_data_valid: SOURCE
        selected_remove_data_ready: SOURCE
        selected_remove_state: SOURCE
        selected_remove_error_count: SOURCE
        selected_remove_temperature: SOURCE
        selected_remove_tx_data: SOURCE
        selected_remove_rx_data: SOURCE
        selected_remove_baud_tick: SOURCE
        selected_remove_uart_busy: SOURCE
        selected_remove_ghw_counter: SOURCE
        selected_remove_ghw_enable: SOURCE
        selected_remove_ghw_state: SOURCE
        selected_clear_all: SOURCE
        selected_restore_data: SOURCE
        selected_data_up: SOURCE
        selected_data_down: SOURCE
        analog_limits_auto: SOURCE
        analog_limits_manual: SOURCE
        analog_limits_invalid: SOURCE
        format_dropdown_toggle: SOURCE
        format_cycle: SOURCE
        format_binary: SOURCE
        format_hex: SOURCE
        format_grouped: SOURCE
        format_octal: SOURCE
        format_signed: SOURCE
        format_unsigned: SOURCE
        format_ascii: SOURCE
        keyboard_capture: SOURCE
        waveform_click: SOURCE
        waveform_hover: SOURCE
        signal_search_input: SOURCE
        scope_cpu: SOURCE
        scope_cpu_expand: SOURCE
        scope_cpu_collapse: SOURCE
        scope_uart: SOURCE
        scope_analog: SOURCE
        select_clk: SOURCE
        select_reset: SOURCE
        select_data: SOURCE
        select_temperature: SOURCE
        panels_toggle_arrangement: SOURCE
        files_variables_resize_drag: SOURCE
        browser_selected_resize_drag: SOURCE
        variables_name_resize_drag: SOURCE
        variables_value_resize_drag: SOURCE
        signal_row_resize_drag: SOURCE
    ]

    workspace_dialog:
        LATEST {
            Closed
            elements.open_workspace_dialog |> THEN { Open }
            elements.close_workspace_dialog |> THEN { Closed }
            elements.open_selected_workspace |> THEN { Closed }
            elements.open_load_files_dialog |> THEN { Closed }
        }

    workspace_path_key:
        WorkspaceA |> HOLD workspace_path_key {
            elements.open_selected_workspace |> THEN { workspace_selected_key }
        }

    workspace_selected_key:
        WorkspaceA |> HOLD workspace_selected_key {
            LATEST {
                elements.open_workspace_dialog |> THEN { workspace_path_key }
                elements.select_workspace_repo |> THEN { Repo }
                elements.select_workspace_a |> THEN { WorkspaceA }
                elements.select_workspace_b |> THEN { WorkspaceB }
            }
        }

    workspace_path:
        workspace_path_key |> WHEN {
            WorkspaceB => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b }
            Repo => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a }
        }

    workspace_header_path:
        workspace_path_key |> WHEN {
            WorkspaceB => TEXT { .../test_files/my_workspaces/workspace_b }
            Repo => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { .../test_files/my_workspaces/workspace_a }
        }

    workspace_selected_path:
        workspace_selected_key |> WHEN {
            WorkspaceB => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b }
            Repo => TEXT { /home/martinkavik/repos/NovyWave }
            __ => TEXT { /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a }
        }

    workspace_dialog_title:
        TEXT { Workspace dialog closed } |> HOLD workspace_dialog_title {
            LATEST {
                elements.open_workspace_dialog |> THEN { TEXT { Open Workspace } }
                elements.close_workspace_dialog |> THEN { TEXT { Workspace dialog closed } }
                elements.open_selected_workspace |> THEN { TEXT { Workspace dialog closed } }
                elements.open_load_files_dialog |> THEN { TEXT { Workspace dialog closed } }
            }
        }

    workspace_dialog_hint:
        TEXT { No workspace picker } |> HOLD workspace_dialog_hint {
            LATEST {
                elements.open_workspace_dialog |> THEN { TEXT { Pick a directory to use as your workspace. NovyWave will create the .novywave file automatically if it is missing. } }
                elements.close_workspace_dialog |> THEN { TEXT { No workspace picker } }
                elements.open_selected_workspace |> THEN { TEXT { No workspace picker } }
                elements.open_load_files_dialog |> THEN { TEXT { No workspace picker } }
            }
        }

    workspace_dialog_selection:
        TEXT { none } |> HOLD workspace_dialog_selection {
            LATEST {
                elements.open_workspace_dialog |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a } }
                elements.select_workspace_repo |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave } }
                elements.select_workspace_a |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_a } }
                elements.select_workspace_b |> THEN { TEXT { Selected: /home/martinkavik/repos/NovyWave/test_files/my_workspaces/workspace_b } }
                elements.close_workspace_dialog |> THEN { TEXT { none } }
                elements.open_selected_workspace |> THEN { TEXT { none } }
                elements.open_load_files_dialog |> THEN { TEXT { none } }
            }
        }

    workspace_status_label:
        workspace_path_key |> WHEN {
            WorkspaceB => TEXT { workspace_b ready }
            Repo => TEXT { NovyWave repo ready }
            __ => TEXT { workspace_a ready }
        }

    load_files_dialog:
        LATEST {
            Closed
            elements.open_load_files_dialog |> THEN { Open }
            elements.close_load_files_dialog |> THEN { Closed }
            load_requested_fixture_file |> WHEN {
                TEXT { none } => Open
                __ => Closed
            }
            elements.external_file_loaded_name.text |> THEN { Closed }
            elements.begin_default_file_load |> THEN { Closed }
            elements.load_default_file |> THEN { Closed }
            elements.show_empty |> THEN { Closed }
            elements.select_counter_file |> THEN { Closed }
            elements.select_uart_compare_file |> THEN { Closed }
            elements.select_ghw_file |> THEN { Closed }
            elements.open_workspace_dialog |> THEN { Closed }
        }

    panel_layout:
        Balanced |> HOLD panel_layout {
            LATEST {
                elements.files_variables_resize_drag.text |> THEN {
                    elements.files_variables_resize_drag.text |> WHEN {
                        TEXT { Grow } => panel_layout |> WHEN {
                            VariablesWidest => VariablesWide
                            VariablesWide => Balanced
                            Balanced => FilesWide
                            FilesWide => FilesWidest
                            __ => FilesWidest
                        }
                        TEXT { Shrink } => panel_layout |> WHEN {
                            FilesWidest => FilesWide
                            FilesWide => Balanced
                            Balanced => VariablesWide
                            VariablesWide => VariablesWidest
                            __ => VariablesWidest
                        }
                        __ => panel_layout
                    }
                }
                elements.browser_selected_resize_drag.text |> THEN {
                    elements.browser_selected_resize_drag.text |> WHEN {
                        TEXT { Grow } => panel_layout |> WHEN {
                            VariablesWidest => VariablesWide
                            VariablesWide => Balanced
                            Balanced => FilesWide
                            FilesWide => FilesWidest
                            __ => FilesWidest
                        }
                        TEXT { Shrink } => panel_layout |> WHEN {
                            FilesWidest => FilesWide
                            FilesWide => Balanced
                            Balanced => VariablesWide
                            VariablesWide => VariablesWidest
                            __ => VariablesWidest
                        }
                        __ => panel_layout
                    }
                }
                elements.show_empty |> THEN { Balanced }
                elements.load_default_file |> THEN { Balanced }
            }
        }

    panel_layout_label:
        panel_layout |> WHEN {
            FilesWidest => TEXT { Files panel widest }
            FilesWide => TEXT { Files panel wide }
            VariablesWidest => TEXT { Variables panel widest }
            VariablesWide => TEXT { Variables panel wide }
            __ => TEXT { Panels balanced }
        }

    panel_arrangement:
        Stacked |> HOLD panel_arrangement {
            LATEST {
                elements.panels_toggle_arrangement |> THEN {
                    panel_arrangement |> WHEN {
                        Docked => Stacked
                        __ => Docked
                    }
                }
                elements.show_empty |> THEN { Stacked }
                elements.load_default_file |> THEN { Stacked }
            }
        }

    panel_arrangement_label:
        panel_arrangement |> WHEN {
            Docked => TEXT { Docked panels }
            __ => TEXT { Stacked panels }
        }

    panel_arrangement_button_label:
        panel_arrangement |> WHEN {
            Docked => TEXT { Stack }
            __ => TEXT { Dock }
        }

    files_panel_width:
        panel_layout |> WHEN {
            FilesWidest => 650
            FilesWide => 520
            VariablesWidest => 260
            VariablesWide => 340
            __ => 430
        }

    variables_panel_width:
        panel_layout |> WHEN {
            FilesWidest => 300
            FilesWide => 390
            VariablesWidest => 650
            VariablesWide => 570
            __ => 480
        }

    browser_panel_width:
        panel_layout |> WHEN {
            FilesWidest => 650
            FilesWide => 520
            VariablesWidest => 260
            VariablesWide => 340
            __ => 430
        }

    files_panel_height_key:
        Balanced |> HOLD files_panel_height_key {
            LATEST {
                elements.files_variables_resize_drag.text |> THEN {
                    elements.files_variables_resize_drag.text |> WHEN {
                        TEXT { Grow } => files_panel_height_key |> WHEN {
                            Short => Balanced
                            Balanced => Tall
                            Tall => Tallest
                            __ => Tallest
                        }
                        TEXT { Shrink } => files_panel_height_key |> WHEN {
                            Tallest => Tall
                            Tall => Balanced
                            Balanced => Short
                            __ => Short
                        }
                        __ => files_panel_height_key
                    }
                }
                elements.browser_selected_resize_drag.text |> THEN {
                    elements.browser_selected_resize_drag.text |> WHEN {
                        TEXT { Grow } => files_panel_height_key |> WHEN {
                            Short => Balanced
                            Balanced => Tall
                            Tall => Tallest
                            __ => Tallest
                        }
                        TEXT { Shrink } => files_panel_height_key |> WHEN {
                            Tallest => Tall
                            Tall => Balanced
                            Balanced => Short
                            __ => Short
                        }
                        __ => files_panel_height_key
                    }
                }
                elements.show_empty |> THEN { Balanced }
                elements.load_default_file |> THEN { Balanced }
            }
        }

    files_panel_height:
        files_panel_height_key |> WHEN {
            Short => 284
            Tall => 520
            Tallest => 650
            __ => 390
        }

    selected_name_column_width_key:
        Normal |> HOLD selected_name_column_width_key {
            elements.variables_name_resize_drag.text |> THEN {
                elements.variables_name_resize_drag.text |> WHEN {
                    TEXT { Grow } => selected_name_column_width_key |> WHEN {
                        Compact => Normal
                        Normal => Wide
                        Wide => Widest
                        __ => Widest
                    }
                    TEXT { Shrink } => selected_name_column_width_key |> WHEN {
                        Widest => Wide
                        Wide => Normal
                        Normal => Compact
                        __ => Compact
                    }
                    __ => selected_name_column_width_key
                }
            }
        }

    selected_name_column_width:
        selected_name_column_width_key |> WHEN {
            Compact => 130
            Wide => 250
            Widest => 340
            __ => 190
        }

    selected_value_column_width_key:
        Normal |> HOLD selected_value_column_width_key {
            elements.variables_value_resize_drag.text |> THEN {
                elements.variables_value_resize_drag.text |> WHEN {
                    TEXT { Grow } => selected_value_column_width_key |> WHEN {
                        Compact => Normal
                        Normal => Wide
                        Wide => Widest
                        __ => Widest
                    }
                    TEXT { Shrink } => selected_value_column_width_key |> WHEN {
                        Widest => Wide
                        Wide => Normal
                        Normal => Compact
                        __ => Compact
                    }
                    __ => selected_value_column_width_key
                }
            }
        }

    selected_value_column_width:
        selected_value_column_width_key |> WHEN {
            Compact => 120
            Wide => 300
            Widest => 400
            __ => 220
        }

    startup_workspace_opened_files:
        LIST {
            [file: "simple.vcd", canonical_path: "~/repos/NovyWave/test_files/simple.vcd", family: "simple_vcd", selected_scope_key: "simple_tb_s", selected_scope_label: "simple_tb.s", primary_signal: "clk"]
            [file: "wave_27.fst", canonical_path: "~/repos/NovyWave/test_files/wave_27.fst", family: "uart", selected_scope_key: "top_uart", selected_scope_label: "top.uart", primary_signal: "tx_data"]
            [file: "simple_test.ghw", canonical_path: "~/repos/NovyWave/test_files/simple_test.ghw", family: "ghw", selected_scope_key: "ghw_simple", selected_scope_label: "ghw.simple", primary_signal: "ghw_counter"]
        }

    startup_selected_file:
        TEXT { simple.vcd }

    startup_selected_file_record:
        startup_workspace_opened_files
        |> List/find(item, if: item.file == startup_selected_file)

    startup_selected_file_path:
        startup_selected_file_record |> WHEN {
            Found[value] => value.canonical_path
            NotFound => TEXT { ~/repos/NovyWave/test_files/simple.vcd }
        }

    load_fixture_path_record:
        startup_workspace_opened_files
        |> List/find(item, if: item.canonical_path == load_files_path)

    load_fixture_name_record:
        startup_workspace_opened_files
        |> List/find(item, if: item.file == load_files_path)

    load_fixture_path_match:
        load_fixture_path_record |> WHEN {
            Found[value] => value.file
            NotFound => load_fixture_name_record |> WHEN {
                Found[value] => value.file
                NotFound => TEXT { none }
            }
        }

    load_requested_fixture_file:
        elements.load_external_file |> THEN { load_fixture_path_match }

    load_requested_fixture_supported:
        load_fixture_path_match != TEXT { none }

    load_requested_fixture_error:
        TEXT { Unsupported fixture path. Choose simple.vcd, wave_27.fst, or simple_test.ghw. }

    startup_selected_family:
        startup_selected_file_record |> WHEN {
            Found[value] => value.family
            NotFound => TEXT { simple_vcd }
        }

    startup_selected_scope_key:
        startup_selected_file_record |> WHEN {
            Found[value] => value.selected_scope_key
            NotFound => TEXT { simple_tb_s }
        }

    startup_selected_scope_label:
        startup_selected_file_record |> WHEN {
            Found[value] => value.selected_scope_label
            NotFound => TEXT { simple_tb.s }
        }

    startup_primary_signal:
        startup_selected_file_record |> WHEN {
            Found[value] => value.primary_signal
            NotFound => TEXT { clk }
        }

    startup_expanded_scopes:
        LIST {
            [file: TEXT { simple.vcd }, scope_key: TEXT { simple_tb_s }, scope_label: TEXT { simple_tb.s }]
            [file: TEXT { simple_test.ghw }, scope_key: TEXT { ghw_simple }, scope_label: TEXT { ghw.simple }]
        }

    file_tree_rows:
        LIST {
            [kind: FileTreeFile, file: TEXT { simple.vcd }, scope_key: TEXT { none }, label: TEXT { - simple.vcd }, expanded_label: TEXT { - simple.vcd }, collapsed_label: TEXT { - simple.vcd }, indent_width: 0, selected_file: TEXT { simple.vcd }, source_key: SelectFile]
            [kind: FileTreeScope, file: TEXT { simple.vcd }, scope_key: TEXT { simple_tb_s }, label: TEXT { + simple_tb.s }, expanded_label: TEXT { - simple_tb.s }, collapsed_label: TEXT { + simple_tb.s }, indent_width: 18, selected_file: TEXT { simple.vcd }, source_key: SelectSimpleScope]
            [kind: FileTreeFile, file: TEXT { wave_27.fst }, scope_key: TEXT { none }, label: TEXT { - wave_27.fst }, expanded_label: TEXT { - wave_27.fst }, collapsed_label: TEXT { - wave_27.fst }, indent_width: 0, selected_file: TEXT { wave_27.fst }, source_key: SelectFile]
            [kind: FileTreeScope, file: TEXT { wave_27.fst }, scope_key: TEXT { top_uart }, label: TEXT { + top.uart }, expanded_label: TEXT { + top.uart }, collapsed_label: TEXT { + top.uart }, indent_width: 18, selected_file: TEXT { wave_27.fst }, source_key: SelectUartScope]
            [kind: FileTreeScope, file: TEXT { wave_27.fst }, scope_key: TEXT { top_analog }, label: TEXT { + top.analog }, expanded_label: TEXT { + top.analog }, collapsed_label: TEXT { + top.analog }, indent_width: 18, selected_file: TEXT { wave_27.fst }, source_key: SelectAnalogScope]
            [kind: FileTreeFile, file: TEXT { simple_test.ghw }, scope_key: TEXT { none }, label: TEXT { - simple_test.ghw }, expanded_label: TEXT { - simple_test.ghw }, collapsed_label: TEXT { - simple_test.ghw }, indent_width: 0, selected_file: TEXT { simple_test.ghw }, source_key: SelectFile]
            [kind: FileTreeScope, file: TEXT { simple_test.ghw }, scope_key: TEXT { ghw_simple }, label: TEXT { - ghw.simple }, expanded_label: TEXT { - ghw.simple }, collapsed_label: TEXT { - ghw.simple }, indent_width: 18, selected_file: TEXT { simple_test.ghw }, source_key: SelectGhwScope]
        }
        |> List/map(item, new: new_file_tree_row(file_tree_row: item))

    external_file_tree_file:
        TEXT { none } |> HOLD external_file_tree_file {
            LATEST {
                elements.external_file_loaded_name.text
                elements.show_empty |> THEN { TEXT { none } }
            }
        }

    external_catalog_file_tree_rows:
        file_tree_rows
        |> List/filter(item, if: item.file == external_file_tree_file)
        |> List/map(item, new: new_file_tree_row(file_tree_row: item))

    external_fallback_file_tree_rows:
        LIST {
            [kind: FileTreeFile, file: external_file_tree_file, scope_key: TEXT { none }, label: external_file_tree_label, expanded_label: external_file_tree_label, collapsed_label: external_file_tree_label, indent_width: 0, selected_file: external_file_tree_file, source_key: SelectLoadedFile]
        }
        |> List/map(item, new: new_file_tree_row(file_tree_row: item))

    external_file_tree_rows:
        external_catalog_file_tree_rows
        |> List/is_not_empty()
        |> WHEN {
            True => external_catalog_file_tree_rows
            False => external_fallback_file_tree_rows
        }

    default_file_tree_selected_file:
        file_tree_rows
        |> List/filter(item, if: item.kind == FileTreeFile)
        |> List/map(item, new:
            item.file_row_elements.select_file |> THEN { item.file }
        )
        |> List/latest()

    external_file_tree_selected_file:
        LATEST {
            external_catalog_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN { item.file }
                )
                |> List/latest()
            external_fallback_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN { item.file }
                )
                |> List/latest()
        }

    external_file_tree_file_selected_scope:
        LATEST {
            external_catalog_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN { TEXT { none } }
                )
                |> List/latest()
            external_fallback_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN { TEXT { none } }
                )
                |> List/latest()
        }

    external_file_tree_scope_selected_scope:
        external_catalog_file_tree_rows
        |> List/filter(item, if: item.kind == FileTreeScope)
        |> List/map(item, new:
            item.scope_row_elements.select_scope |> THEN { item.scope_key }
        )
        |> List/latest()

    external_file_tree_file_selected_signal:
        LATEST {
            external_catalog_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN { TEXT { none } }
                )
                |> List/latest()
            external_fallback_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN { TEXT { none } }
                )
                |> List/latest()
        }

    external_file_tree_scope_selected_signal:
        external_catalog_file_tree_rows
        |> List/filter(item, if: item.kind == FileTreeScope)
        |> List/map(item, new:
            item.scope_row_elements.select_scope |> THEN {
                startup_file_record(file: item.file) |> WHEN {
                    Found[value] => value.primary_signal
                    NotFound => store.startup_primary_signal
                }
            }
        )
        |> List/latest()

    external_file_tree_selected_family:
        LATEST {
            external_catalog_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN {
                        startup_file_record(file: item.file) |> WHEN {
                            Found[value] => value.family
                            NotFound => store.startup_selected_family
                        }
                    }
                )
                |> List/latest()
            external_fallback_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeFile)
                |> List/map(item, new:
                    item.file_row_elements.select_file |> THEN {
                        startup_file_record(file: item.file) |> WHEN {
                            Found[value] => value.family
                            NotFound => store.startup_selected_family
                        }
                    }
                )
                |> List/latest()
            external_catalog_file_tree_rows
                |> List/filter(item, if: item.kind == FileTreeScope)
                |> List/map(item, new:
                    item.scope_row_elements.select_scope |> THEN {
                        startup_file_record(file: item.file) |> WHEN {
                            Found[value] => value.family
                            NotFound => store.startup_selected_family
                        }
                    }
                )
                |> List/latest()
        }

    file_tree_selected_file:
        LATEST {
            default_file_tree_selected_file
            external_file_tree_selected_file
            load_requested_fixture_file |> WHEN {
                TEXT { simple.vcd } => TEXT { simple.vcd }
                TEXT { wave_27.fst } => TEXT { wave_27.fst }
                TEXT { simple_test.ghw } => TEXT { simple_test.ghw }
                __ => SKIP
            }
        }

    startup_selected_variable_config:
        LIST {
            [file: TEXT { simple.vcd }, unique_id: TEXT { ~/repos/NovyWave/test_files/simple.vcd|simple_tb.s|A[3:0] }, signal_id: TEXT { clk }, formatter: Hexadecimal, row_height: 28, group: TEXT { simple_tb.s group }]
            [file: TEXT { simple.vcd }, unique_id: TEXT { ~/repos/NovyWave/test_files/simple.vcd|simple_tb.s|B[3:0] }, signal_id: TEXT { reset_n }, formatter: Hexadecimal, row_height: 28, group: TEXT { simple_tb.s group }]
        }

    startup_signal_group_config:
        LIST {
            [name: TEXT { simple_tb.s group }, member_ids: TEXT { clk, reset_n }, collapsed: False]
        }

    startup_timeline_config:
        [
            file: startup_selected_file
            cursor: TEXT { 50 s }
            visible_range: TEXT { 0 s - 250 s }
            zoom_center: TEXT { 50 s }
            tooltip_enabled: True
        ]

    startup_marker_config:
        LIST {
            [time: TEXT { 50 s }, name: TEXT { 50 s }]
        }

    startup_restore_summary:
        TEXT { config restore: simple.vcd opened, simple_tb.s expanded, A[3:0]/B[3:0] selected, cursor 50 s }

    load_files_path:
        startup_selected_file_path |> HOLD load_files_path {
            LATEST {
                elements.load_file_path_input.text |> THEN { elements.load_file_path_input.text }
                elements.select_counter_file |> THEN { TEXT { ~/repos/NovyWave/test_files/simple.vcd } }
                elements.select_uart_compare_file |> THEN { TEXT { ~/repos/NovyWave/test_files/wave_27.fst } }
                elements.select_ghw_file |> THEN { TEXT { ~/repos/NovyWave/test_files/simple_test.ghw } }
            }
        }

    external_file_error:
        Text/empty() |> HOLD external_file_error {
            LATEST {
                elements.external_file_load_error.text
                elements.open_load_files_dialog |> THEN { Text/empty() }
                elements.load_file_path_input.text |> THEN { Text/empty() }
                load_requested_fixture_file |> WHEN {
                    TEXT { none } => load_requested_fixture_error
                    __ => Text/empty()
                }
                elements.external_file_loaded_name.text |> THEN { Text/empty() }
                elements.close_load_files_dialog |> THEN { Text/empty() }
            }
        }

    external_file_active:
        No |> HOLD external_file_active {
            LATEST {
                elements.external_file_loaded_name.text |> THEN { Yes }
                load_requested_fixture_file |> WHEN { __ => No }
                elements.select_counter_file |> THEN { No }
                elements.select_uart_compare_file |> THEN { No }
                elements.select_ghw_file |> THEN { No }
                elements.load_default_file |> THEN { No }
                elements.show_empty |> THEN { No }
            }
        }

    external_file_tree_label:
        TEXT { - local file } |> HOLD external_file_tree_label {
            LATEST {
                TEXT { - } |> Text/concat(with: elements.external_file_loaded_name.text, separator: " ")
                elements.show_empty |> THEN { TEXT { - local file } }
            }
        }

    load_files_dialog_title:
        TEXT { No file dialog } |> HOLD load_files_dialog_title {
            LATEST {
                elements.open_load_files_dialog |> THEN { TEXT { Load files } }
                elements.close_load_files_dialog |> THEN { TEXT { No file dialog } }
                elements.external_file_loaded_name.text |> THEN { TEXT { No file dialog } }
                load_requested_fixture_file |> WHEN {
                    TEXT { none } => TEXT { Load files }
                    __ => TEXT { No file dialog }
                }
                elements.begin_default_file_load |> THEN { TEXT { No file dialog } }
                elements.load_default_file |> THEN { TEXT { No file dialog } }
                elements.show_empty |> THEN { TEXT { No file dialog } }
                elements.open_workspace_dialog |> THEN { TEXT { No file dialog } }
            }
        }

    load_files_dialog_hint:
        TEXT { File dialog closed } |> HOLD load_files_dialog_hint {
            LATEST {
                elements.open_load_files_dialog |> THEN { TEXT { Enter a built-in VCD, FST, or GHW fixture path. Fixture metadata and bounded pages remain pure Boon data. } }
                elements.close_load_files_dialog |> THEN { TEXT { File dialog closed } }
                elements.external_file_loaded_name.text |> THEN { TEXT { File dialog closed } }
                load_requested_fixture_file |> WHEN {
                    TEXT { none } => TEXT { Enter a built-in VCD, FST, or GHW fixture path. Fixture metadata and bounded pages remain pure Boon data. }
                    __ => TEXT { File dialog closed }
                }
                elements.begin_default_file_load |> THEN { TEXT { File dialog closed } }
                elements.load_default_file |> THEN { TEXT { File dialog closed } }
                elements.show_empty |> THEN { TEXT { File dialog closed } }
                elements.open_workspace_dialog |> THEN { TEXT { File dialog closed } }
            }
        }

    load_files_dialog_selection:
        TEXT { none } |> HOLD load_files_dialog_selection {
            LATEST {
                elements.open_load_files_dialog |> THEN { TEXT { Path: } |> Text/concat(with: load_files_path, separator: " ") }
                elements.load_file_path_input.text |> THEN { TEXT { Path: } |> Text/concat(with: elements.load_file_path_input.text, separator: " ") }
                elements.external_file_load_error.text |> THEN { elements.external_file_load_error.text }
                load_requested_fixture_file |> WHEN {
                    TEXT { none } => load_requested_fixture_error
                    __ => TEXT { none }
                }
                elements.close_load_files_dialog |> THEN { TEXT { none } }
                elements.external_file_loaded_name.text |> THEN { TEXT { none } }
                elements.begin_default_file_load |> THEN { TEXT { none } }
                elements.load_default_file |> THEN { TEXT { none } }
                elements.show_empty |> THEN { TEXT { none } }
                elements.open_workspace_dialog |> THEN { TEXT { none } }
            }
        }

    waveform_status:
        LATEST {
            Empty
            elements.show_empty |> THEN { Empty }
            elements.begin_default_file_load |> THEN { Loading }
            elements.load_default_file |> THEN { Loaded }
            load_requested_fixture_file |> WHEN {
                TEXT { none } => SKIP
                __ => Loaded
            }
            elements.external_file_loaded_name.text |> THEN { Loaded }
        }

    empty_state_title: TEXT { No waveform loaded }
    empty_state_hint: TEXT { Drop or load a VCD, FST, or GHW waveform to inspect signals. }
    empty_state_bridge_label: TEXT { Bridge state: no request scheduled; pure descriptor is wave:none }
    empty_state_formats_label: TEXT { Supported waveform formats: VCD, FST, GHW }
    loading_state_title: TEXT { Loading waveform }
    loading_state_hint: TEXT { Opening the built-in simple.vcd fixture through the wellen.v1-compatible descriptor contract. }
    reference_visual_basis: NovyReference/visual_basis_label()
    reference_loaded_basis: NovyReference/loaded_reference_label()
    reference_empty_basis: NovyReference/empty_reference_label()
    reference_workflow_basis: NovyReference/workflow_basis_label()
    reference_waveform_basis: NovyReference/waveform_basis_label()
    reference_comparison_status: NovyReference/comparison_compact_label()
    reference_descriptor: NovyReference/reference_descriptor()

    active_file:
        startup_selected_file |> HOLD active_file {
            LATEST {
                elements.select_counter_file |> THEN { TEXT { simple.vcd } }
                elements.select_uart_compare_file |> THEN { TEXT { wave_27.fst } }
                elements.select_ghw_file |> THEN { TEXT { simple_test.ghw } }
                elements.scope_cpu_expand |> THEN { TEXT { simple.vcd } }
                elements.scope_cpu_collapse |> THEN { TEXT { simple.vcd } }
                elements.scope_uart |> THEN { TEXT { wave_27.fst } }
                elements.scope_analog |> THEN { TEXT { wave_27.fst } }
                file_tree_rows
                    |> List/filter(item, if: item.kind == FileTreeFile)
                    |> List/map(item, new:
                        item.file_row_elements.select_file |> THEN { item.file }
                    )
                    |> List/latest()
                external_file_tree_selected_file
                file_tree_rows
                    |> List/filter(item, if: item.kind == FileTreeScope)
                    |> List/map(item, new:
                        item.scope_row_elements.select_scope |> THEN { item.file }
                    )
                    |> List/latest()
                elements.begin_default_file_load |> THEN { store.startup_selected_file }
                elements.load_default_file |> THEN { store.startup_selected_file }
                load_requested_fixture_file |> WHEN {
                    TEXT { simple.vcd } => TEXT { simple.vcd }
                    TEXT { wave_27.fst } => TEXT { wave_27.fst }
                    TEXT { simple_test.ghw } => TEXT { simple_test.ghw }
                    __ => SKIP
                }
                elements.external_file_loaded_name.text
                elements.show_empty |> THEN { TEXT { none } }
            }
        }

    waveform_file_metadata:
        LIST {
            [file: "simple.vcd", format: "VCD", digest: "sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de", waveform_ref: "wave:vcd:simple:0-250s", full_range: "0 s - 250 s", initial_window: "0 s - 250 s", range_start: 0, range_end: 250, initial_start: 0, initial_end: 250, canvas_width: 360, cursor_left: 0, cursor_default: 50, cursor_right: 150, zoom_center_default: 50, stats: "VCD 2 signals, 0-250s, bounded pages", large_file_contract: "simple.vcd 311B -> bounded page requests only", hierarchy_page: "HIER:simple_tb/s", hierarchy_cursor: "hierarchy cursor simple_tb.s:0..64 next=none", materialization_bound: "visible rows 2/2, waveform segments 6/256 max", time_unit: "s", timescale: "1 s/native tick", range_source: FileHeader, metadata_source: WellenHeader]
            [file: "wave_27.fst", format: "FST", digest: "sha256:aa4a6993101ff31601e12d613b746d8753f20448d78e8b720f708403047dc172", waveform_ref: "wave:fst:wave-27:0-240ns", full_range: "0 ns - 240 ns", initial_window: "0 ns - 120 ns", range_start: 0, range_end: 240, initial_start: 0, initial_end: 120, canvas_width: 360, cursor_left: 36, cursor_default: 42, cursor_right: 48, zoom_center_default: 42, stats: "FST 5 signals, 0-240ns, bounded pages", large_file_contract: "wave_27.fst 28860652B -> bounded compare page only", hierarchy_page: "HIER:top.uart compare page", hierarchy_cursor: "hierarchy cursor top.uart:0..64 next=none", materialization_bound: "visible rows 4/5, waveform segments 28/256 max", time_unit: "ns", timescale: "inferred FST native tick", range_source: FileHeader, metadata_source: WellenHeader]
            [file: "simple_test.ghw", format: "GHW", digest: "sha256:3485b4b9a423ce61e54a9bd4a2c525cf7576f0e36d39ad73b208c2e38e980491", waveform_ref: "wave:ghw:simple-test:0-100ns", full_range: "0 ns - 100 ns", initial_window: "0 ns - 100 ns", range_start: 0, range_end: 100, initial_start: 0, initial_end: 100, canvas_width: 360, cursor_left: 36, cursor_default: 42, cursor_right: 48, zoom_center_default: 42, stats: "GHW 4 signals, 0-100ns, bounded pages", large_file_contract: "simple_test.ghw 833B -> bounded page requests only", hierarchy_page: "HIER:ghw.simple/counter", hierarchy_cursor: "hierarchy cursor ghw.simple:0..64 next=none", materialization_bound: "visible rows 3/4, waveform segments 20/256 max", time_unit: "ns", timescale: "GHW native tick", range_source: FileHeader, metadata_source: WellenHeader]
            [file: "none", format: "none", digest: "sha256:none", waveform_ref: "wave:none", full_range: "no waveform range", initial_window: "no request window", range_start: 0, range_end: 0, initial_start: 0, initial_end: 0, canvas_width: 360, cursor_left: 0, cursor_default: 0, cursor_right: 0, zoom_center_default: 0, stats: "no waveform stats", large_file_contract: "no large file materialized", hierarchy_page: "HIER:none", hierarchy_cursor: "hierarchy cursor none", materialization_bound: "visible rows 0/0, waveform segments 0/256 max", time_unit: "none", timescale: "no timescale", range_source: NoFile, metadata_source: NoFile]
        }

    active_metadata_file:
        active_file

    active_metadata_record:
        waveform_metadata_record(file: active_metadata_file)

    active_metadata_format:
        active_metadata_record |> WHEN {
            Found[value] => value.format
            NotFound => TEXT { none }
        }

    active_metadata_digest:
        active_metadata_record |> WHEN {
            Found[value] => value.digest
            NotFound => TEXT { sha256:none }
        }

    active_metadata_waveform_ref:
        active_metadata_record |> WHEN {
            Found[value] => value.waveform_ref
            NotFound => TEXT { wave:none }
        }

    active_metadata_full_range:
        active_metadata_record |> WHEN {
            Found[value] => value.full_range
            NotFound => TEXT { no waveform range }
        }

    active_metadata_initial_window:
        active_metadata_record |> WHEN {
            Found[value] => value.initial_window
            NotFound => TEXT { no request window }
        }

    active_metadata_range_start:
        active_metadata_record |> WHEN {
            Found[value] => value.range_start
            NotFound => 0
        }

    active_metadata_range_end:
        active_metadata_record |> WHEN {
            Found[value] => value.range_end
            NotFound => 0
        }

    active_metadata_initial_start:
        active_metadata_record |> WHEN {
            Found[value] => value.initial_start
            NotFound => 0
        }

    active_metadata_initial_end:
        active_metadata_record |> WHEN {
            Found[value] => value.initial_end
            NotFound => 0
        }

    active_metadata_canvas_width:
        active_metadata_record |> WHEN {
            Found[value] => value.canvas_width
            NotFound => 360
        }

    active_metadata_stats:
        active_metadata_record |> WHEN {
            Found[value] => value.stats
            NotFound => TEXT { no waveform stats }
        }

    active_metadata_large_file_contract:
        active_metadata_record |> WHEN {
            Found[value] => value.large_file_contract
            NotFound => TEXT { no large file materialized }
        }

    active_metadata_hierarchy_page:
        active_metadata_record |> WHEN {
            Found[value] => value.hierarchy_page
            NotFound => TEXT { HIER:none }
        }

    active_metadata_hierarchy_cursor:
        active_metadata_record |> WHEN {
            Found[value] => value.hierarchy_cursor
            NotFound => TEXT { hierarchy cursor none }
        }

    active_metadata_materialization_bound:
        active_metadata_record |> WHEN {
            Found[value] => value.materialization_bound
            NotFound => TEXT { visible rows 0/0, waveform segments 0/256 max }
        }

    active_metadata_time_unit:
        active_metadata_record |> WHEN {
            Found[value] => value.time_unit
            NotFound => TEXT { none }
        }

    active_metadata_timescale:
        active_metadata_record |> WHEN {
            Found[value] => value.timescale
            NotFound => TEXT { no timescale }
        }

    active_metadata_range_source:
        active_metadata_record |> WHEN {
            Found[value] => value.range_source
            NotFound => NoFile
        }

    active_metadata_source:
        active_metadata_record |> WHEN {
            Found[value] => value.metadata_source
            NotFound => NoFile
        }

    external_loaded_metadata_format:
        elements.external_file_loaded_format.text

    external_loaded_metadata_digest:
        elements.external_file_loaded_digest.text

    external_loaded_metadata_waveform_ref:
        elements.external_file_loaded_waveform_ref.text

    external_loaded_metadata_stats:
        elements.external_file_loaded_stats.text

    external_loaded_metadata_large_file_contract:
        elements.external_file_loaded_contract.text

    effective_metadata_format:
        active_file |> WHEN {
            TEXT { none } => active_metadata_format
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_format
                False => active_metadata_format
            }
        }

    effective_metadata_digest:
        active_file |> WHEN {
            TEXT { none } => active_metadata_digest
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_digest
                False => active_metadata_digest
            }
        }

    effective_metadata_waveform_ref:
        active_file |> WHEN {
            TEXT { none } => active_metadata_waveform_ref
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_waveform_ref
                False => active_metadata_waveform_ref
            }
        }

    effective_metadata_stats:
        active_file |> WHEN {
            TEXT { none } => active_metadata_stats
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_stats
                False => active_metadata_stats
            }
        }

    effective_metadata_large_file_contract:
        active_file |> WHEN {
            TEXT { none } => active_metadata_large_file_contract
            __ => external_file_active == Yes |> WHEN {
                True => external_loaded_metadata_large_file_contract
                False => active_metadata_large_file_contract
            }
        }

    compare_file:
        comparison_waveform_mode |> WHEN {
            Active => comparison_waveform_open_result |> WHEN {
                WaveformOpened => TEXT { simple.vcd }
                __ => TEXT { none }
            }
            Inactive => TEXT { none }
        }

    file_compare_status:
        compare_file |> WHEN {
            TEXT { none } => active_file |> WHEN {
                TEXT { none } => TEXT { no waveform loaded }
                file => TEXT { single file: } |> Text/concat(with: file, separator: " ")
            }
            compare =>
                TEXT { comparing }
                |> Text/concat(with: compare, separator: " ")
                |> Text/concat(with: TEXT { to }, separator: " ")
                |> Text/concat(with: active_file, separator: " ")
        }

    file_compare_descriptor:
        [
            primary: active_file
            compare: compare_file
            status: file_compare_status
            page: compare_request_page
            source: TEXT { Wellen/signal_page }
            primary_fingerprint: real_signal_page_request_fingerprint
            comparison_fingerprint: comparison_signal_page_request_fingerprint
            comparison_transition_count: comparison_transition_count
        ]

    bridge_file_format:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { VCD }
            False => effective_metadata_format
        }

    bridge_file_digest:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { sha256:78e6f482fe39dd5ae04a7162d27f513d6a57be6e9d1a948b916167459bead01e }
            False => effective_metadata_digest
        }

    bridge_waveform_ref:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { diagnostic:unsupported-corrupted-vcd }
            False => waveform_status == Loading |> WHEN {
                True => TEXT { wave:opening:simple }
                False => effective_metadata_waveform_ref
            }
        }

    bridge_descriptor_file:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { corrupted.vcd }
            False => active_file
        }

    bridge_open_status:
        LATEST {
            TEXT { FILE_READY }
            elements.select_counter_file |> THEN { TEXT { FILE_READY } }
            elements.select_uart_compare_file |> THEN { TEXT { FILE_READY } }
            elements.select_ghw_file |> THEN { TEXT { FILE_READY } }
            elements.begin_default_file_load |> THEN { TEXT { OPENING } }
            elements.load_default_file |> THEN { TEXT { FILE_READY } }
            load_requested_fixture_file |> WHEN {
                TEXT { none } => TEXT { FILE_ERROR }
                __ => TEXT { FILE_READY }
            }
            elements.external_file_loaded_name.text |> THEN { TEXT { FILE_READY } }
            elements.show_empty |> THEN { TEXT { NOT_REQUESTED } }
        }

    bridge_open_summary:
        real_waveform_open_result |> WHEN {
            WaveformOpened =>
                TEXT { opened }
                |> Text/concat(with: real_bridge_stats, separator: " ")
            __ => diagnostic_state == Unsupported |> WHEN {
                True => TEXT { unsupported waveform file: corrupted.vcd }
                False => waveform_status |> WHEN {
                    Empty => TEXT { no file loaded }
                    Loading => TEXT { opening VCD simple.vcd }
                    __ => external_file_active == Yes |> WHEN {
                        True => TEXT { local file } |> Text/concat(with: active_file, separator: " ")
                        False => TEXT { opened } |> Text/concat(with: bridge_file_format, separator: " ") |> Text/concat(with: bridge_waveform_ref, separator: " ")
                    }
                }
            }
        }

    bridge_hierarchy_page_label:
        real_hierarchy_page_result |> WHEN {
            HierarchyPage => real_runtime_status
            __ => diagnostic_state == Unsupported |> WHEN {
                True => TEXT { HIER:none }
                False => waveform_status |> WHEN {
                    Empty => TEXT { HIER:none }
                    Loading => TEXT { HIER:opening }
                    __ => external_file_active == Yes |> WHEN {
                        True => TEXT { HIER:local file metadata }
                        False => active_metadata_hierarchy_page
                    }
                }
            }
        }

    bridge_waveform_stats_label:
        real_waveform_open_result |> WHEN {
            WaveformOpened => real_bridge_stats
            __ => diagnostic_state == Unsupported |> WHEN {
                True => TEXT { no waveform stats }
                False => waveform_status |> WHEN {
                    Empty => TEXT { no waveform stats }
                    Loading => TEXT { loading waveform stats }
                    __ => effective_metadata_stats
                }
            }
        }

    bridge_large_file_contract:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { corrupted.vcd 25B -> diagnostic only }
            False => waveform_status |> WHEN {
                Empty => TEXT { no large file materialized }
                Loading => TEXT { simple.vcd pending -> no page materialized }
                __ => effective_metadata_large_file_contract
            }
        }

    bridge_payload_limit_bytes: 65536
    bridge_transition_limit: 256
    bridge_visible_row_limit: 32
    bridge_segment_limit: 256

    bridge_page_window_label:
        bridge_request_window_label == TEXT { no request window } |> WHEN {
            True => TEXT { no page window scheduled }
            False =>
                TEXT { window }
                |> Text/concat(with: bridge_request_window_label, separator: " ")
                |> Text/concat(with: bridge_transition_limit, separator: ", max ")
                |> Text/concat(with: TEXT { transitions, payload <= 64KiB }, separator: " ")
        }

    bridge_hierarchy_page_cursor_label:
        diagnostic_state == Unsupported |> WHEN {
            True => TEXT { hierarchy cursor none }
            False => waveform_status |> WHEN {
                Empty => TEXT { hierarchy cursor none }
                Loading => TEXT { hierarchy cursor opening }
                __ => external_file_active == Yes |> WHEN {
                    True => TEXT { hierarchy cursor root:0..64 next=local }
                    False => active_metadata_hierarchy_cursor
                }
            }
        }

    bridge_materialization_bound_label:
        selected_rows_removed_signal_id == TEXT { reset_n } |> WHEN {
            True => TEXT { visible rows 1/2, waveform segments 3/256 max }
            False => waveform_status == Loading |> WHEN {
                True => TEXT { visible rows 0/2, waveform segments 0/256 max }
                False => active_metadata_materialization_bound
            }
        }

    bridge_payload_bound_label:
        TEXT { payload <= 64KiB; full waveform never enters Boon }

    bridge_page_schema_version: 1
    bridge_page_schema_hash: TEXT { sha256:novywave-wellen-page-ref-v1 }
    bridge_module_name: TEXT { wellen.v1 }

    compare_request_page:
        comparison_waveform_mode |> WHEN {
            Active => comparison_signal_page_result |> WHEN {
                SignalPage => comparison_signal_page_result.request_fingerprint
                WaveformFailed => TEXT { comparison failed }
                __ => TEXT { comparison opening }
            }
            Inactive => active_file |> WHEN {
                TEXT { none } => TEXT { compare:none }
                __ => TEXT { primary: } |> Text/concat(with: real_signal_page_request_fingerprint, separator: "")
            }
        }

    compare_result_label:
        comparison_waveform_mode |> WHEN {
            Active => comparison_signal_page_result |> WHEN {
                SignalPage =>
                    TEXT { real comparison }
                    |> Text/concat(with: active_file, separator: ": ")
                    |> Text/concat(with: TEXT { vs simple.vcd }, separator: " ")
                    |> Text/concat(with: comparison_transition_count, separator: ", transitions: ")
                WaveformFailed => comparison_signal_page_result.diagnostic
                __ => TEXT { opening comparison }
            }
            Inactive => active_file |> WHEN {
                TEXT { none } => TEXT { no compare page }
                file => TEXT { primary page: } |> Text/concat(with: file, separator: " ")
            }
        }

    file_status_detail:
        diagnostic_state == Unsupported |> WHEN {
            True => diagnostic_label
            False => compare_result_label
        }

    diagnostic_state:
        LATEST {
            OK
            elements.select_counter_file |> THEN { OK }
            elements.select_uart_compare_file |> THEN { OK }
            elements.select_ghw_file |> THEN { OK }
            elements.begin_default_file_load |> THEN { Loading }
            elements.load_default_file |> THEN { OK }
            load_requested_fixture_file |> WHEN {
                TEXT { none } => Unsupported
                __ => OK
            }
            elements.external_file_loaded_name.text |> THEN { OK }
            elements.external_file_load_error.text |> THEN { Unsupported }
            elements.show_empty |> THEN { Idle }
        }

    diagnostic_label:
        LATEST {
            TEXT { bridge diagnostics OK }
            elements.select_counter_file |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_uart_compare_file |> THEN { TEXT { bridge diagnostics OK } }
            elements.select_ghw_file |> THEN { TEXT { bridge diagnostics OK } }
            elements.begin_default_file_load |> THEN { TEXT { loading waveform } }
            elements.load_default_file |> THEN { TEXT { bridge diagnostics OK } }
            load_requested_fixture_file |> WHEN {
                TEXT { none } => load_requested_fixture_error
                __ => TEXT { fixture metadata OK }
            }
            elements.external_file_loaded_name.text |> THEN { TEXT { local file metadata OK } }
            elements.external_file_load_error.text
            elements.show_empty |> THEN { TEXT { no file loaded } }
        }

    diagnostic_file:
        LATEST {
            TEXT { none }
            elements.select_counter_file |> THEN { TEXT { none } }
            elements.select_uart_compare_file |> THEN { TEXT { none } }
            elements.select_ghw_file |> THEN { TEXT { none } }
            elements.begin_default_file_load |> THEN { TEXT { none } }
            elements.load_default_file |> THEN { TEXT { none } }
            load_requested_fixture_file |> WHEN {
                TEXT { none } => TEXT { unsupported fixture path }
                __ => TEXT { none }
            }
            elements.external_file_loaded_path.text
            elements.external_file_load_error.text |> THEN { load_files_path }
            elements.show_empty |> THEN { TEXT { none } }
        }

    bridge_diagnostic:
        NovyBridge/diagnostic(
            diagnostic_kind: diagnostic_state
            file: diagnostic_file
            message: diagnostic_label
        )

    mode:
        LATEST {
            Dark
            elements.mode_to_light |> THEN { Light }
            elements.mode_to_dark |> THEN { Dark }
        }

    row_selected_scope_key:
        file_tree_rows
        |> List/filter(item, if: item.kind == FileTreeScope)
        |> List/map(item, new:
            item.scope_row_elements.select_scope |> THEN { item.scope_key }
        )
        |> List/latest()

    active_scope:
        startup_selected_scope_key |> HOLD active_scope {
            LATEST {
                real_first_signal_parent_id |> WHEN {
                    TEXT { none } => SKIP
                    __ => real_first_signal_parent_id
                }
                elements.scope_cpu |> THEN { TEXT { simple_tb_s } }
                elements.scope_cpu_expand |> THEN { TEXT { simple_tb_s } }
                elements.scope_cpu_collapse |> THEN { TEXT { simple_tb_s } }
                elements.scope_uart |> THEN { TEXT { top_uart } }
                elements.scope_analog |> THEN { TEXT { top_analog } }
                elements.select_counter_file |> THEN { store.startup_selected_scope_key }
                elements.select_uart_compare_file |> THEN { TEXT { top_uart } }
                elements.select_ghw_file |> THEN { TEXT { ghw_simple } }
                file_tree_rows
                    |> List/filter(item, if: item.kind == FileTreeFile)
                    |> List/map(item, new:
                        item.file_row_elements.select_file |> THEN {
                            startup_file_record(file: item.file) |> WHEN {
                                Found[value] => value.selected_scope_key
                                NotFound => store.startup_selected_scope_key
                            }
                        }
                    )
                    |> List/latest()
                row_selected_scope_key
                external_file_tree_file_selected_scope
                external_file_tree_scope_selected_scope
                load_requested_fixture_file |> WHEN {
                    TEXT { simple.vcd } => TEXT { simple_tb_s }
                    TEXT { wave_27.fst } => TEXT { top_uart }
                    TEXT { simple_test.ghw } => TEXT { ghw_simple }
                    __ => SKIP
                }
                elements.load_default_file |> THEN { store.startup_selected_scope_key }
                elements.external_file_loaded_name.text |> THEN { TEXT { none } }
                elements.show_empty |> THEN { TEXT { none } }
            }
        }

    active_signal:
        startup_primary_signal |> HOLD active_signal {
            LATEST {
                real_first_signal_id |> WHEN {
                    TEXT { none } => SKIP
                    __ => real_first_signal_id
                }
                row_selected_signal_key
                elements.select_clk |> THEN { TEXT { clk } }
                elements.select_reset |> THEN { TEXT { reset_n } }
                elements.select_data |> THEN {
                    active_signal |> WHEN {
                        data_bus => TEXT { none }
                        __ => TEXT { data_bus }
                    }
                }
                elements.select_temperature |> THEN { TEXT { temperature } }
                elements.select_counter_file |> THEN { TEXT { clk } }
                elements.select_uart_compare_file |> THEN { TEXT { tx_data } }
                elements.select_ghw_file |> THEN { TEXT { ghw_counter } }
                file_tree_rows
                    |> List/filter(item, if: item.kind == FileTreeFile)
                    |> List/map(item, new:
                        item.file_row_elements.select_file |> THEN {
                            startup_file_record(file: item.file) |> WHEN {
                                Found[value] => value.primary_signal
                                NotFound => store.startup_primary_signal
                            }
                        }
                    )
                    |> List/latest()
                file_tree_rows
                    |> List/filter(item, if: item.kind == FileTreeScope)
                    |> List/map(item, new:
                        item.scope_row_elements.select_scope |> THEN {
                            startup_file_record(file: item.file) |> WHEN {
                                Found[value] => value.primary_signal
                                NotFound => store.startup_primary_signal
                            }
                        }
                    )
                    |> List/latest()
                external_file_tree_file_selected_signal
                external_file_tree_scope_selected_signal
                load_requested_fixture_file |> WHEN {
                    TEXT { simple.vcd } => TEXT { clk }
                    TEXT { wave_27.fst } => TEXT { tx_data }
                    TEXT { simple_test.ghw } => TEXT { ghw_counter }
                    __ => SKIP
                }
                elements.load_default_file |> THEN { store.startup_primary_signal }
                elements.external_file_loaded_name.text |> THEN { TEXT { none } }
                elements.show_empty |> THEN { TEXT { none } }
            }
        }

    real_hierarchy_signal_rows:
        real_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                real_hierarchy_page_result.rows
                |> List/filter(item, if: item.kind == TEXT { Signal })
            __ => LIST {}
        }

    real_first_signal_parent_id:
        real_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                real_hierarchy_page_result.rows
                |> List/find(item, if: item.kind == TEXT { Signal })
                |> WHEN {
                    Found[value] => value.parent_id
                    NotFound => TEXT { none }
                }
            __ => TEXT { none }
        }

    signal_catalog:
        real_hierarchy_signal_rows
        |> List/map(item, new:
            new_signal(signal: real_signal_catalog_row(signal_row: item))
        )

    selected_signal_count:
        selected_rows_count

    row_selected_signal_key:
        signal_catalog
        |> List/map(item, new:
            item.signal_elements.select_signal
                |> THEN { item.key }
        )
        |> List/latest()

    row_selected_signal_record:
        signal_catalog_record(key: row_selected_signal_key)

    row_selected_signal_bridge_key:
        row_selected_signal_record |> WHEN {
            Found[value] => value.bridge_key
            NotFound => TEXT { NONE }
        }

    row_selected_signal_fit_page:
        row_selected_signal_record |> WHEN {
            Found[value] => value.fit_page
            NotFound => TEXT { NONE }
        }

    selected_signal_family:
        active_file

    selected_signal_defaults:
        real_hierarchy_signal_rows
        |> List/map(item, new:
            new_selected_visible_item(
                row: real_selected_signal_row(signal_row: item)
            )
        )

    real_waveform_transition_count:
        real_signal_page_result |> WHEN {
            SignalPage => real_signal_page_result.next_offset
            __ => 0
        }

    startup_waveform_transition_summary:
        TEXT { real bounded waveform transitions }
        |> Text/concat(with: real_waveform_transition_count, separator: ": ")

    startup_waveform_projection_summary:
        TEXT { projection from bounded Wellen pages: segment widths derive from real transition and timeline data }

    selected_rows_enabled_value:
        TEXT { loaded } |> HOLD selected_rows_enabled_value {
            LATEST {
                elements.show_empty |> THEN { TEXT { none } }
                elements.begin_default_file_load |> THEN { TEXT { none } }
                elements.load_default_file |> THEN { TEXT { loaded } }
                elements.external_file_loaded_name.text |> THEN { TEXT { loaded } }
                elements.select_counter_file |> THEN { TEXT { loaded } }
                elements.select_uart_compare_file |> THEN { TEXT { loaded } }
                elements.select_ghw_file |> THEN { TEXT { loaded } }
                file_tree_selected_file |> THEN { TEXT { loaded } }
            }
        }

    group_header_collapsed:
        selected_group == Collapsed

    group_header_chevron:
        group_header_collapsed |> WHEN {
            True => TEXT { > }
            False => TEXT { v }
        }

    selected_rows_profile:
        LATEST {
            DefaultOrder
            selected_signal_defaults
                |> List/map(item, new:
                    item.row_elements.remove_signal
                        |> THEN { WithoutSelection }
                )
                |> List/latest()
            elements.selected_remove_data |> THEN { WithoutData }
            elements.selected_remove_clk |> THEN { WithoutSelection }
            elements.selected_remove_reset |> THEN { WithoutSelection }
            elements.selected_remove_data_valid |> THEN { WithoutSelection }
            elements.selected_remove_data_ready |> THEN { WithoutSelection }
            elements.selected_remove_state |> THEN { WithoutSelection }
            elements.selected_remove_error_count |> THEN { WithoutSelection }
            elements.selected_remove_temperature |> THEN { WithoutSelection }
            elements.selected_remove_tx_data |> THEN { WithoutSelection }
            elements.selected_remove_rx_data |> THEN { WithoutSelection }
            elements.selected_remove_baud_tick |> THEN { WithoutSelection }
            elements.selected_remove_uart_busy |> THEN { WithoutSelection }
            elements.selected_remove_ghw_counter |> THEN { WithoutSelection }
            elements.selected_remove_ghw_enable |> THEN { WithoutSelection }
            elements.selected_remove_ghw_state |> THEN { WithoutSelection }
            elements.selected_clear_all |> THEN { Empty }
            elements.selected_restore_data |> THEN { DefaultOrder }
            elements.selected_data_up |> THEN { DataFirst }
            elements.selected_data_down |> THEN { DataLast }
            elements.select_counter_file |> THEN { DefaultOrder }
            elements.select_uart_compare_file |> THEN { DefaultOrder }
            elements.select_ghw_file |> THEN { DefaultOrder }
            file_tree_selected_file |> THEN { DefaultOrder }
            elements.load_default_file |> THEN { DefaultOrder }
            elements.show_empty |> THEN { Empty }
        }

    selected_rows_removed_signal_id:
        LATEST {
            TEXT { none }
            selected_signal_defaults
                |> List/map(item, new:
                    item.row_elements.remove_signal
                        |> THEN { item.id }
                )
                |> List/latest()
            elements.selected_remove_data |> THEN { TEXT { data_bus } }
            elements.selected_remove_clk |> THEN { TEXT { clk } }
            elements.selected_remove_reset |> THEN { TEXT { reset_n } }
            elements.selected_remove_data_valid |> THEN { TEXT { data_valid } }
            elements.selected_remove_data_ready |> THEN { TEXT { data_ready } }
            elements.selected_remove_state |> THEN { TEXT { state } }
            elements.selected_remove_error_count |> THEN { TEXT { error_count } }
            elements.selected_remove_temperature |> THEN { TEXT { temperature } }
            elements.selected_remove_tx_data |> THEN { TEXT { tx_data } }
            elements.selected_remove_rx_data |> THEN { TEXT { rx_data } }
            elements.selected_remove_baud_tick |> THEN { TEXT { baud_tick } }
            elements.selected_remove_uart_busy |> THEN { TEXT { uart_busy } }
            elements.selected_remove_ghw_counter |> THEN { TEXT { ghw_counter } }
            elements.selected_remove_ghw_enable |> THEN { TEXT { ghw_enable } }
            elements.selected_remove_ghw_state |> THEN { TEXT { ghw_state } }
            elements.selected_clear_all |> THEN { TEXT { none } }
            elements.selected_restore_data |> THEN { TEXT { none } }
            elements.selected_data_up |> THEN { TEXT { none } }
            elements.selected_data_down |> THEN { TEXT { none } }
            elements.select_counter_file |> THEN { TEXT { none } }
            elements.select_uart_compare_file |> THEN { TEXT { none } }
            elements.select_ghw_file |> THEN { TEXT { none } }
            elements.load_default_file |> THEN { TEXT { none } }
            elements.show_empty |> THEN { TEXT { none } }
        }

    selected_rows_first_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_data_up |> THEN { TEXT { data_bus } }
            elements.selected_remove_data |> THEN { TEXT { none } }
            elements.selected_restore_data |> THEN { TEXT { none } }
            elements.selected_data_down |> THEN { TEXT { none } }
            elements.select_counter_file |> THEN { TEXT { none } }
            elements.select_uart_compare_file |> THEN { TEXT { none } }
            elements.select_ghw_file |> THEN { TEXT { none } }
            elements.load_default_file |> THEN { TEXT { none } }
            elements.show_empty |> THEN { TEXT { none } }
        }

    selected_rows_last_signal_id:
        LATEST {
            TEXT { none }
            elements.selected_data_down |> THEN { TEXT { data_bus } }
            elements.selected_remove_data |> THEN { TEXT { none } }
            elements.selected_restore_data |> THEN { TEXT { none } }
            elements.selected_data_up |> THEN { TEXT { none } }
            elements.select_counter_file |> THEN { TEXT { none } }
            elements.select_uart_compare_file |> THEN { TEXT { none } }
            elements.select_ghw_file |> THEN { TEXT { none } }
            elements.load_default_file |> THEN { TEXT { none } }
            elements.show_empty |> THEN { TEXT { none } }
        }

    selected_visible_items:
        selected_signal_defaults
        |> List/filter(item, if: item.family == selected_signal_family)
        |> List/filter(item, if: item.enabled == selected_rows_enabled_value)
        |> List/filter(item, if: item.selected == True)
        |> List/filter(item, if: item.hidden_when_group != selected_group)
        |> List/filter(item, if: item.id != selected_rows_removed_signal_id)

    selected_lane_visible_row_count:
        selected_visible_items |> List/length()

    selected_lane_overscan_row_count:
        0

    selected_signal_lane_rows:
        selected_visible_items
        |> List/map(item, new: new_signal_lane_row(row: item))

    selected_lane_materialized_row_count:
        selected_signal_lane_rows |> List/length()

    selected_lane_materialization:
        [
            collection: TEXT { selected_signal_lanes }
            axis: TEXT { y }
            visible_start: 0
            visible_row_count: selected_lane_visible_row_count
            overscan_before_row_count: 0
            overscan_after_row_count: 0
            overscan_row_count: selected_lane_overscan_row_count
            materialized_row_count: selected_lane_materialized_row_count
            materialized_rows_equal_visible_plus_overscan: selected_lane_materialized_row_count == selected_lane_visible_row_count + selected_lane_overscan_row_count
            stable_lane_prefix: TEXT { selected_signal_lanes }
            request_window: bridge_request_window_label
            response_window: bridge_response_window_label
            page_digest: bridge_waveform_page_digest
        ]

    selected_signal_rows:
        selected_visible_items
        |> List/filter(item, if: item.item_kind == VariableRow)

    selected_signals:
        selected_signal_rows

    selected_signal_format_rows:
        selected_signal_rows
        |> List/map(item, new: [id: item.id, formatter: item.formatter, bit_width: item.bit_width])

    selected_cursor_pair_source_rows:
        active_file == TEXT { simple_test.ghw } |> WHEN {
            True => selected_signal_rows |> List/filter(item, if: item.id == active_signal)
            False => selected_signal_rows
        }

    selected_cursor_pair_rows:
        selected_cursor_pair_source_rows
        |> List/map(item, new: selected_cursor_pair_row(signal: item))

    selected_variable_file:
        active_file

    selected_timeline_metadata_file:
        external_file_active == Yes |> WHEN {
            True => active_file
            False => selected_variable_file
        }

    selected_timeline_full_range:
        selected_timeline_range_start
        |> Text/time_range_label(end: selected_timeline_range_end, unit: selected_timeline_time_unit)

    selected_timeline_initial_window:
        selected_timeline_window_start
        |> Text/time_range_label(end: selected_timeline_window_end, unit: selected_timeline_time_unit)

    selected_timeline_range_start:
        real_waveform_open_result |> WHEN {
            WaveformOpened => real_waveform_open_result.start_time
            __ => 0
        }

    selected_timeline_range_end:
        real_waveform_open_result |> WHEN {
            WaveformOpened => real_waveform_open_result.end_time
            __ => 0
        }

    selected_timeline_window_start:
        selected_timeline_range_start

    selected_timeline_window_end:
        selected_timeline_range_end

    selected_timeline_metadata_record:
        waveform_metadata_record(file: selected_timeline_metadata_file)

    selected_waveform_metadata_canvas_width:
        selected_timeline_metadata_record |> WHEN {
            Found[value] => value.canvas_width
            NotFound => active_metadata_canvas_width
        }

    selected_waveform_canvas_width:
        selected_waveform_metadata_canvas_width |> HOLD selected_waveform_canvas_width {
            LATEST {
                elements.waveform_click.pointer_width |> THEN { elements.waveform_click.pointer_width |> Text/to_number() }
                elements.waveform_hover.pointer_width |> THEN { elements.waveform_hover.pointer_width |> Text/to_number() }
                elements.select_counter_file |> THEN { selected_waveform_metadata_canvas_width }
                elements.select_uart_compare_file |> THEN { selected_waveform_metadata_canvas_width }
                elements.select_ghw_file |> THEN { selected_waveform_metadata_canvas_width }
                file_tree_selected_file |> THEN { selected_waveform_metadata_canvas_width }
                elements.load_default_file |> THEN { selected_waveform_metadata_canvas_width }
                elements.show_empty |> THEN { selected_waveform_metadata_canvas_width }
            }
        }

    selected_timeline_time_unit:
        real_waveform_open_result |> WHEN {
            WaveformOpened => real_waveform_open_result.timescale_unit
            __ => TEXT { tick }
        }

    selected_timeline_timescale:
        real_waveform_open_result |> WHEN {
            WaveformOpened =>
                real_waveform_open_result.timescale_factor
                |> Number/to_text(radix: 10)
                |> Text/concat(with: real_waveform_open_result.timescale_unit, separator: " ")
            __ => TEXT { no timescale }
        }

    selected_timeline_range_source:
        real_waveform_open_result |> WHEN {
            WaveformOpened => FileHeader
            __ => NoFile
        }

    selected_timeline_metadata_source:
        real_waveform_open_result |> WHEN {
            WaveformOpened => WellenHeader
            __ => NoFile
        }

    selected_timeline_cursor_left:
        selected_timeline_range_start

    selected_timeline_cursor_default:
        Number/interpolate(
            start: selected_timeline_range_start
            end: selected_timeline_range_end
            numerator: 1
            denominator: 5
            fallback: selected_timeline_range_start
        )

    selected_timeline_cursor_right:
        Number/interpolate(
            start: selected_timeline_range_start
            end: selected_timeline_range_end
            numerator: 3
            denominator: 5
            fallback: selected_timeline_range_end
        )

    selected_timeline_zoom_center_default:
        selected_timeline_cursor_default

    waveform_click_pointer_x_text:
        TEXT { 0 } |> HOLD waveform_click_pointer_x_text {
            LATEST {
                elements.waveform_click.pointer_x
                elements.load_default_file |> THEN { TEXT { 0 } }
                elements.show_empty |> THEN { TEXT { 0 } }
            }
        }

    waveform_hover_pointer_x_text:
        TEXT { 0 } |> HOLD waveform_hover_pointer_x_text {
            LATEST {
                elements.waveform_hover.pointer_x
                elements.load_default_file |> THEN { TEXT { 0 } }
                elements.show_empty |> THEN { TEXT { 0 } }
            }
        }

    zoom_center_keyboard_value:
        selected_timeline_zoom_center_default |> HOLD zoom_center_keyboard_value {
            LATEST {
                elements.keyboard_capture.key |> WHEN {
                    Z => selected_timeline_range_start
                    R => selected_timeline_zoom_center_default
                    __ => SKIP
                }
                elements.select_counter_file |> THEN { selected_timeline_zoom_center_default }
                elements.select_uart_compare_file |> THEN { selected_timeline_zoom_center_default }
                elements.select_ghw_file |> THEN { selected_timeline_zoom_center_default }
                file_tree_selected_file |> THEN { selected_timeline_zoom_center_default }
                elements.load_default_file |> THEN { 50 }
                elements.show_empty |> THEN { selected_timeline_zoom_center_default }
            }
        }

    selected_timeline_zoom_center_value:
        selected_timeline_zoom_center_default |> HOLD selected_timeline_zoom_center_value {
            LATEST {
                elements.keyboard_capture.key |> WHEN {
                    Z => zoom_center_keyboard_value
                    R => zoom_center_keyboard_value
                    __ => SKIP
                }
                elements.zoom_reset |> THEN { selected_timeline_zoom_center_default }
                elements.select_counter_file |> THEN { selected_timeline_zoom_center_default }
                elements.select_uart_compare_file |> THEN { selected_timeline_zoom_center_default }
                elements.select_ghw_file |> THEN { selected_timeline_zoom_center_default }
                file_tree_selected_file |> THEN { selected_timeline_zoom_center_default }
                elements.load_default_file |> THEN { 50 }
                elements.show_empty |> THEN { selected_timeline_zoom_center_default }
            }
        }

    selected_timeline_zoom_center_number:
        selected_timeline_zoom_center_value

    waveform_hover_zoom_center_value:
        selected_timeline_zoom_center_default |> HOLD waveform_hover_zoom_center_value {
            LATEST {
                elements.waveform_hover.pointer_x |> THEN { Number/project_time(pointer_x: elements.waveform_hover.pointer_x, pointer_width: elements.waveform_hover.pointer_width, viewport_start: viewport_label_start, viewport_end: viewport_label_end, fallback: selected_timeline_zoom_center_value) }
                elements.keyboard_capture.key |> WHEN {
                    Z => zoom_center_keyboard_value
                    R => zoom_center_keyboard_value
                    __ => SKIP
                }
                elements.zoom_reset |> THEN { selected_timeline_zoom_center_default }
                elements.select_counter_file |> THEN { selected_timeline_zoom_center_default }
                elements.select_uart_compare_file |> THEN { selected_timeline_zoom_center_default }
                elements.select_ghw_file |> THEN { selected_timeline_zoom_center_default }
                file_tree_selected_file |> THEN { selected_timeline_zoom_center_default }
                elements.load_default_file |> THEN { 50 }
                elements.show_empty |> THEN { selected_timeline_zoom_center_default }
            }
        }

    selected_timeline_tick_0:
        viewport_label_start

    selected_timeline_tick_1:
        Number/interpolate(start: viewport_label_start, end: viewport_label_end, numerator: 1, denominator: 4, fallback: viewport_label_start)

    selected_timeline_tick_2:
        Number/interpolate(start: viewport_label_start, end: viewport_label_end, numerator: 2, denominator: 4, fallback: viewport_label_start)

    selected_timeline_tick_3:
        Number/interpolate(start: viewport_label_start, end: viewport_label_end, numerator: 3, denominator: 4, fallback: viewport_label_end)

    selected_timeline_tick_4:
        viewport_label_end

    selected_timeline_cursor_update:
        LATEST {
            elements.waveform_click.pointer_x |> THEN { Number/project_time(pointer_x: elements.waveform_click.pointer_x, pointer_width: elements.waveform_click.pointer_width, viewport_start: viewport_label_start, viewport_end: viewport_label_end, fallback: selected_timeline_cursor_value) }
            elements.cursor_left |> THEN { selected_timeline_cursor_left }
            elements.cursor_right |> THEN { selected_timeline_cursor_right }
            elements.marker_jump |> THEN { selected_timeline_cursor_default }
            elements.zoom_reset |> THEN { selected_timeline_cursor_default }
            elements.keyboard_capture.key |> WHEN {
                D => selected_timeline_cursor_default
                Q => selected_timeline_cursor_left
                R => selected_timeline_cursor_default
                E => selected_timeline_cursor_right
                __ => SKIP
            }
            elements.select_counter_file |> THEN { selected_timeline_cursor_default }
            elements.select_uart_compare_file |> THEN { selected_timeline_cursor_default }
            elements.select_ghw_file |> THEN { selected_timeline_cursor_default }
            elements.select_clk |> THEN { selected_timeline_cursor_default }
            elements.select_reset |> THEN { selected_timeline_cursor_default }
            elements.select_data |> THEN { selected_timeline_cursor_default }
            elements.select_temperature |> THEN { selected_timeline_cursor_default }
            row_selected_signal_key |> THEN { selected_timeline_cursor_default }
            file_tree_selected_file |> THEN { selected_timeline_cursor_default }
            elements.load_default_file |> THEN { 50 }
            elements.show_empty |> THEN { selected_timeline_cursor_default }
        }

    selected_timeline_cursor_value:
        selected_timeline_cursor_default |> HOLD selected_timeline_cursor_value {
            selected_timeline_cursor_update
        }

    selected_waveform_segments:
        selected_signal_rows
        |> List/find(item, if: item.id == active_signal)
        |> WHEN {
            Found[value] => value.segments
            NotFound => LIST {}
        }

    active_waveform_segment_labels:
        selected_waveform_segments
        |> List/map(item, new: item.label)
        |> Text/join(separator: ",", empty: "none")

    active_waveform_segment_count:
        selected_waveform_segments |> List/length()

    timeline_axis_tick_0:
        selected_timeline_tick_0 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_1:
        selected_timeline_tick_1 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_2:
        selected_timeline_tick_2 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_3:
        selected_timeline_tick_3 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    timeline_axis_tick_4:
        selected_timeline_tick_4 |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    data_bus_alias:
        signal_catalog_record(key: TEXT { data_bus }) |> WHEN {
            Found[value] => value.alias
            NotFound => Text/empty()
        }

    signal_search_text:
        Text/empty() |> HOLD signal_search_text {
            elements.signal_search_input.text |> Text/trim()
        }

    signal_search_needle:
        signal_search_text |> Text/to_lowercase()

    search_results:
        signal_catalog
        |> List/filter(item, if:
            signal_search_text |> Text/is_empty() |> WHEN {
                True => item.scope == active_scope
                False =>
                    item.name
                    |> Text/to_lowercase()
                    |> Text/contains(needle: signal_search_needle)
                    |> WHEN {
                        True => True
                        False =>
                            item.family
                            |> Text/to_lowercase()
                            |> Text/contains(needle: signal_search_needle)
                    }
            }
        )

    variable_rows:
        List/chunk(list: search_results, size: 1)

    search_results_count:
        search_results |> List/length()

    search_results_key_summary:
        search_results
        |> List/map(item, new: item.key)
        |> Text/join(separator: ",", empty: "none")

    search_results_name_summary:
        search_results
        |> List/map(item, new: item.name)
        |> Text/join(separator: ", ", empty: "none")

    focused_control_label:
        TEXT { none } |> HOLD focused_control_label {
            LATEST {
                elements.signal_search_focus_probe.event.click |> THEN { TEXT { signal search } }
                elements.scope_cpu |> THEN { TEXT { none } }
                elements.scope_cpu_expand |> THEN { TEXT { none } }
                elements.scope_cpu_collapse |> THEN { TEXT { none } }
                elements.scope_uart |> THEN { TEXT { none } }
                elements.scope_analog |> THEN { TEXT { none } }
                row_selected_scope_key |> THEN { TEXT { none } }
                row_selected_signal_key |> THEN { TEXT { none } }
                elements.select_counter_file |> THEN { TEXT { none } }
                elements.select_uart_compare_file |> THEN { TEXT { none } }
                elements.select_ghw_file |> THEN { TEXT { none } }
                elements.load_default_file |> THEN { TEXT { none } }
                elements.show_empty |> THEN { TEXT { none } }
            }
        }

    focused_control_material_label:
        focused_control_label == TEXT { signal search } |> WHEN {
            True => TEXT { FocusedControl }
            False => TEXT { RestingControl }
        }

    pressed_control_label:
        TEXT { none } |> HOLD pressed_control_label {
            LATEST {
                elements.format_cycle |> THEN { TEXT { Fmt } }
                elements.format_dropdown_toggle |> THEN { TEXT { none } }
                elements.format_binary |> THEN { TEXT { none } }
                elements.format_hex |> THEN { TEXT { none } }
                elements.format_grouped |> THEN { TEXT { none } }
                elements.format_octal |> THEN { TEXT { none } }
                elements.format_signed |> THEN { TEXT { none } }
                elements.format_unsigned |> THEN { TEXT { none } }
                elements.format_ascii |> THEN { TEXT { none } }
                elements.mode_to_light |> THEN { TEXT { none } }
                elements.mode_to_dark |> THEN { TEXT { none } }
                elements.load_default_file |> THEN { TEXT { none } }
                elements.show_empty |> THEN { TEXT { none } }
                elements.signal_search_focus_probe.event.click |> THEN { TEXT { none } }
                elements.scope_cpu |> THEN { TEXT { none } }
                elements.scope_cpu_expand |> THEN { TEXT { none } }
                elements.scope_cpu_collapse |> THEN { TEXT { none } }
                elements.scope_uart |> THEN { TEXT { none } }
                elements.scope_analog |> THEN { TEXT { none } }
                row_selected_scope_key |> THEN { TEXT { none } }
                row_selected_signal_key |> THEN { TEXT { none } }
                elements.select_counter_file |> THEN { TEXT { none } }
                elements.select_uart_compare_file |> THEN { TEXT { none } }
                elements.select_ghw_file |> THEN { TEXT { none } }
                elements.select_clk |> THEN { TEXT { none } }
                elements.select_reset |> THEN { TEXT { none } }
                elements.select_data |> THEN { TEXT { none } }
                elements.select_temperature |> THEN { TEXT { none } }
                elements.zoom_in |> THEN { TEXT { none } }
                elements.zoom_out |> THEN { TEXT { none } }
                elements.pan_left |> THEN { TEXT { none } }
                elements.pan_right |> THEN { TEXT { none } }
                elements.cursor_left |> THEN { TEXT { none } }
                elements.cursor_right |> THEN { TEXT { none } }
                elements.marker_toggle |> THEN { TEXT { none } }
                elements.marker_remove |> THEN { TEXT { none } }
                elements.group_create |> THEN { TEXT { none } }
                elements.group_toggle |> THEN { TEXT { none } }
                elements.group_expand |> THEN { TEXT { none } }
                elements.row_taller |> THEN { TEXT { none } }
                elements.row_shorter |> THEN { TEXT { none } }
            }
        }

    pressed_control_material_label:
        pressed_control_label == TEXT { none } |> WHEN {
            True => TEXT { RestingControl }
            False => TEXT { PressedControl }
        }

    format_dropdown_state:
        Closed |> HOLD format_dropdown_state {
            LATEST {
                elements.format_dropdown_toggle |> THEN {
                    format_dropdown_state |> WHEN {
                        Open => Closed
                        __ => Open
                    }
                }
                elements.format_cycle |> THEN { Closed }
                elements.format_binary |> THEN { Closed }
                elements.format_hex |> THEN { Closed }
                elements.format_grouped |> THEN { Closed }
                elements.format_octal |> THEN { Closed }
                elements.format_signed |> THEN { Closed }
                elements.format_unsigned |> THEN { Closed }
                elements.format_ascii |> THEN { Closed }
                elements.load_default_file |> THEN { Closed }
                elements.show_empty |> THEN { Closed }
                elements.select_counter_file |> THEN { Closed }
                elements.select_uart_compare_file |> THEN { Closed }
                elements.select_ghw_file |> THEN { Closed }
            }
        }

    search_result_label:
        signal_search_text |> Text/is_empty() |> WHEN {
            True =>
                search_results_count
                |> Text/concat(with: TEXT { results in }, separator: " ")
                |> Text/concat(with: active_scope_label, separator: " ")
            False => search_results_count == 1 |> WHEN {
                True =>
                    TEXT { 1 result: }
                    |> Text/concat(with: search_results_name_summary, separator: " ")
                False => search_results_count == 0 |> WHEN {
                    True =>
                        TEXT { 0 results: }
                        |> Text/concat(with: signal_search_text, separator: " ")
                    False => search_results_count > 12 |> WHEN {
                        True =>
                            search_results_count
                            |> Text/concat(with: TEXT { results: scroll variables list }, separator: " ")
                        False =>
                            search_results_count
                            |> Text/concat(with: TEXT { results: }, separator: " ")
                            |> Text/concat(with: search_results_name_summary, separator: " ")
                    }
                }
            }
        }

    search_scope_mode: TEXT { Global }

    keyboard_last_key:
        Text/empty() |> HOLD keyboard_last_key {
            LATEST {
                elements.keyboard_capture.key
                elements.waveform_hover.pointer_x |> THEN { Text/empty() }
                elements.waveform_click.pointer_x |> THEN { Text/empty() }
                elements.load_default_file |> THEN { Text/empty() }
                elements.show_empty |> THEN { Text/empty() }
                elements.select_counter_file |> THEN { Text/empty() }
                elements.select_uart_compare_file |> THEN { Text/empty() }
                elements.select_ghw_file |> THEN { Text/empty() }
                elements.select_clk |> THEN { Text/empty() }
                elements.select_reset |> THEN { Text/empty() }
                elements.select_data |> THEN { Text/empty() }
                elements.select_temperature |> THEN { Text/empty() }
                row_selected_scope_key |> THEN { Text/empty() }
                row_selected_signal_key |> THEN { Text/empty() }
                elements.format_dropdown_toggle |> THEN { Text/empty() }
                elements.format_cycle |> THEN { Text/empty() }
                elements.format_binary |> THEN { Text/empty() }
                elements.format_hex |> THEN { Text/empty() }
                elements.format_grouped |> THEN { Text/empty() }
                elements.format_octal |> THEN { Text/empty() }
                elements.format_signed |> THEN { Text/empty() }
                elements.format_unsigned |> THEN { Text/empty() }
                elements.format_ascii |> THEN { Text/empty() }
            }
        }

    selected_group:
        LATEST {
            Expanded
            elements.group_create |> THEN { Expanded }
            elements.group_toggle |> THEN { Collapsed }
            elements.group_expand |> THEN { Expanded }
            elements.group_remove |> THEN { None }
            elements.load_default_file |> THEN { Expanded }
            elements.show_empty |> THEN { None }
        }

    group_creation_state:
        LATEST {
            Created
            elements.group_create |> THEN { Created }
            elements.group_remove |> THEN { None }
            elements.load_default_file |> THEN { Created }
            elements.show_empty |> THEN { None }
        }

    group_name:
        LATEST {
            TEXT { simple_tb.s group }
            elements.group_create |> THEN { TEXT { simple_tb.s group } }
            elements.group_rename |> THEN { TEXT { core buses } }
            elements.group_remove |> THEN { TEXT { No group } }
            elements.load_default_file |> THEN { TEXT { simple_tb.s group } }
            elements.show_empty |> THEN { TEXT { No group } }
        }

    group_count_label:
        LATEST {
            TEXT { 1 group }
            elements.group_create |> THEN { TEXT { 1 group } }
            elements.group_remove |> THEN { TEXT { 0 groups } }
            elements.load_default_file |> THEN { TEXT { 1 group } }
            elements.show_empty |> THEN { TEXT { 0 groups } }
        }

    group_members_label:
        LATEST {
            TEXT { A[3:0], B[3:0] }
            elements.group_create |> THEN { TEXT { A[3:0], B[3:0] } }
            elements.group_remove |> THEN { TEXT { none } }
            elements.load_default_file |> THEN { TEXT { A[3:0], B[3:0] } }
            elements.show_empty |> THEN { TEXT { none } }
        }

    group_status_label:
        LATEST {
            TEXT { 1 group }
            elements.group_create |> THEN { TEXT { 1 group } }
            elements.group_remove |> THEN { TEXT { no group } }
            elements.load_default_file |> THEN { TEXT { 1 group } }
            elements.show_empty |> THEN { TEXT { no group } }
        }

    group_to_create:
        elements.group_create |> THEN { TEXT { simple_tb.s group } }

    groups:
        LIST {}
        |> List/append(item: group_to_create |> THEN {
            [
                name: group_to_create
                members_label: TEXT { A[3:0], B[3:0] }
            ]
        })
        |> List/map(item, new: new_signal_group(group: item, store: store))
        |> List/remove(item, when:
            LATEST {
                elements.group_remove |> THEN { True }
                elements.load_default_file |> THEN { True }
                elements.show_empty |> THEN { True }
            }
        )

    selected_rows_count:
        selected_signal_rows |> List/length()

    selected_rows_order_label:
        selected_signal_rows
        |> List/map(item, new: item.name)
        |> Text/join(separator: ", ", empty: "none")

    selected_signal_count_label:
        selected_rows_count |> Text/concat(with: TEXT { selected }, separator: " ")

    analog_limit_kind:
        Auto |> HOLD analog_limit_kind {
            LATEST {
                elements.analog_limits_auto |> THEN { Auto }
                elements.analog_limits_manual |> THEN { Manual }
                elements.load_default_file |> THEN { Auto }
            }
        }

    analog_limit_validity:
        Valid |> HOLD analog_limit_validity {
            LATEST {
                elements.analog_limits_auto |> THEN { Valid }
                elements.analog_limits_manual |> THEN { Valid }
                elements.analog_limits_invalid |> THEN { Rejected }
                elements.load_default_file |> THEN { Valid }
            }
        }

    analog_limit_min:
        TEXT { 39 C } |> HOLD analog_limit_min {
            LATEST {
                elements.analog_limits_manual |> THEN { TEXT { -10 C } }
                elements.analog_limits_auto |> THEN { TEXT { 39 C } }
                elements.zoom_in |> THEN { TEXT { 40 C } }
                elements.zoom_out |> THEN { TEXT { 38 C } }
                elements.pan_left |> THEN { TEXT { 39 C } }
                elements.pan_right |> THEN { TEXT { 40 C } }
                elements.load_default_file |> THEN { TEXT { 39 C } }
            }
        }

    analog_limit_max:
        TEXT { 44 C } |> HOLD analog_limit_max {
            LATEST {
                elements.analog_limits_manual |> THEN { TEXT { 80 C } }
                elements.analog_limits_auto |> THEN { TEXT { 44 C } }
                elements.zoom_in |> THEN { TEXT { 43 C } }
                elements.zoom_out |> THEN { TEXT { 45 C } }
                elements.pan_left |> THEN { TEXT { 43 C } }
                elements.pan_right |> THEN { TEXT { 44 C } }
                elements.load_default_file |> THEN { TEXT { 44 C } }
            }
        }

    analog_range_label:
        TEXT { Auto 39 C .. 44 C } |> HOLD analog_range_label {
            LATEST {
                elements.analog_limits_manual |> THEN { TEXT { Manual -10 C .. 80 C } }
                elements.analog_limits_auto |> THEN { TEXT { Auto 39 C .. 44 C } }
                elements.zoom_in |> THEN { TEXT { Auto 40 C .. 43 C } }
                elements.zoom_out |> THEN { TEXT { Auto 38 C .. 45 C } }
                elements.pan_left |> THEN { TEXT { Auto 39 C .. 43 C } }
                elements.pan_right |> THEN { TEXT { Auto 40 C .. 44 C } }
                elements.load_default_file |> THEN { TEXT { Auto 39 C .. 44 C } }
            }
        }

    analog_limit_error:
        TEXT { none } |> HOLD analog_limit_error {
            LATEST {
                elements.analog_limits_invalid |> THEN { TEXT { rejected min >= max } }
                elements.analog_limits_auto |> THEN { TEXT { none } }
                elements.analog_limits_manual |> THEN { TEXT { none } }
                elements.load_default_file |> THEN { TEXT { none } }
            }
        }

    analog_limit_descriptor:
        [
            limit_kind: analog_limit_kind
            validity: analog_limit_validity
            min: analog_limit_min
            max: analog_limit_max
            visible_window: keyboard_viewport_label
            source: TEXT { Boon-visible analog limits }
        ]

    marker_visibility:
        Visible |> HOLD marker_visibility {
            LATEST {
                elements.marker_remove |> THEN { Hidden }
                elements.marker_toggle |> THEN { Visible }
                elements.load_default_file |> THEN { Visible }
                elements.show_empty |> THEN { Hidden }
            }
        }

    marker_current_label:
        TEXT { 50 s } |> HOLD marker_current_label {
            LATEST {
                elements.marker_rename |> THEN { TEXT { data stable } }
                elements.marker_remove |> THEN { TEXT { No markers } }
                elements.marker_toggle |> THEN { TEXT { 0 s } }
                elements.load_default_file |> THEN { TEXT { 50 s } }
                elements.show_empty |> THEN { TEXT { No markers } }
            }
        }

    marker_state:
        Default |> HOLD marker_state {
            LATEST {
                elements.marker_rename |> THEN { Renamed }
                elements.marker_remove |> THEN { Empty }
                elements.marker_toggle |> THEN { Added }
                elements.load_default_file |> THEN { Default }
                elements.show_empty |> THEN { Empty }
            }
        }

    marker_label:
        TEXT { M 50 s } |> HOLD marker_label {
            LATEST {
                elements.marker_rename |> THEN { TEXT { M simple transition } }
                elements.marker_remove |> THEN { TEXT { No markers } }
                elements.marker_jump |> THEN { marker_label }
                elements.marker_toggle |> THEN { TEXT { M 0 s } }
                elements.load_default_file |> THEN { TEXT { M 50 s } }
                elements.show_empty |> THEN { TEXT { No markers } }
            }
        }

    marker_focus_label:
        TEXT { marker at 50 s } |> HOLD marker_focus_label {
            LATEST {
                elements.marker_rename |> THEN { TEXT { simple transition at 50 s } }
                elements.marker_jump |> THEN {
                    marker_state |> WHEN {
                        Renamed => TEXT { jumped to simple transition at 50 s }
                        Default => TEXT { jumped to 50 s }
                        Added => TEXT { jumped to 0 s }
                        __ => TEXT { jumped to 50 s }
                    }
                }
                elements.marker_remove |> THEN { TEXT { no marker selected } }
                elements.marker_toggle |> THEN { TEXT { added marker at 0 s } }
                elements.load_default_file |> THEN { TEXT { marker at 50 s } }
                elements.show_empty |> THEN { TEXT { no marker selected } }
            }
        }

    marker_default_label:
        TEXT { 50 s }

    marker_to_add:
        LATEST {
            elements.marker_toggle |> THEN { TEXT { 0 s } }
            elements.load_default_file |> THEN { TEXT { 50 s } }
        }

    marker_add_from_toggle:
        elements.marker_toggle |> THEN { TEXT { 0 s } }

    marker_add_from_load:
        elements.load_default_file |> THEN { TEXT { 50 s } }

    markers:
        LIST {
            [label: TEXT { 50 s }]
        }
        |> List/append(item: marker_add_from_toggle |> THEN {
            [label: TEXT { 0 s }]
        })
        |> List/append(item: marker_add_from_load |> THEN {
            [label: TEXT { 50 s }]
        })
        |> List/map(item, new: new_marker(marker: item, store: store))
        |> List/remove(item, when:
            LATEST {
                item.marker_elements.remove_marker |> THEN { True }
                elements.marker_remove |> THEN { True }
                elements.show_empty |> THEN { True }
            }
        )

    active_marker_count:
        markers
        |> List/retain(item, if: item.has_label)
        |> List/count()

    marker_count_label:
        active_marker_count |> WHEN {
            0 => TEXT { 0 markers }
            1 => TEXT { 1 marker }
            __ => active_marker_count |> Text/concat(with: TEXT { markers }, separator: " ")
        }

    row_size:
        Normal |> HOLD row_size {
            LATEST {
                elements.row_taller |> THEN { Tall }
                elements.row_shorter |> THEN { Compact }
                elements.signal_row_resize_drag.text |> THEN {
                    elements.signal_row_resize_drag.text |> WHEN {
                        TEXT { Grow } => row_size |> WHEN {
                            Compact => Normal
                            __ => Tall
                        }
                        TEXT { Shrink } => row_size |> WHEN {
                            Tall => Normal
                            __ => Compact
                        }
                        __ => row_size
                    }
                }
            }
        }

    value_format:
        LATEST {
            Hexadecimal
            elements.format_cycle |> THEN { NovyModel/next_format(format: value_format) }
            elements.format_binary |> THEN { Binary }
            elements.format_hex |> THEN { Hexadecimal }
            elements.format_grouped |> THEN { GroupedBinary }
            elements.format_octal |> THEN { Octal }
            elements.format_signed |> THEN { Signed }
            elements.format_unsigned |> THEN { Unsigned }
            elements.format_ascii |> THEN { ASCII }
            elements.load_default_file |> THEN { Hexadecimal }
        }

    active_signal_default_record:
        selected_signal_default_record(id: active_signal)

    active_signal_format:
        active_signal_default_record |> WHEN {
            Found[value] => value.formatter
            NotFound => value_format
        }

    active_signal_bit_width:
        active_signal_default_record |> WHEN {
            Found[value] => value.bit_width
            NotFound => TEXT { 1-bit }
        }

    data_bus_row_format:
        active_signal_format

    zoom_step:
        0 |> HOLD zoom_step {
            LATEST {
                elements.zoom_in |> THEN {
                    zoom_step >= 3 |> WHEN {
                        True => 3
                        False => zoom_step + 1
                    }
                }
                elements.zoom_out |> THEN {
                    zoom_step <= -2 |> WHEN {
                        True => -2
                        False => zoom_step - 1
                    }
                }
                elements.zoom_reset |> THEN { 0 }
                elements.keyboard_capture.key |> WHEN {
                    W => zoom_step >= 3 |> WHEN {
                        True => 3
                        False => zoom_step + 1
                    }
                    S => zoom_step <= -2 |> WHEN {
                        True => -2
                        False => zoom_step - 1
                    }
                    R => 0
                    __ => SKIP
                }
                elements.select_counter_file |> THEN { 0 }
                elements.select_uart_compare_file |> THEN { 0 }
                elements.select_ghw_file |> THEN { 0 }
                file_tree_selected_file |> THEN { 0 }
                elements.load_default_file |> THEN { 0 }
                elements.show_empty |> THEN { 0 }
            }
        }

    zoom_level:
        NovyModel/zoom_level_from_step(step: zoom_step)

    waveform_projection_zoom_level:
        zoom_level |> WHEN {
            Wide => Wide
            Widest => Widest
            __ => Fit
        }

    pan_window:
        Center |> HOLD pan_window {
            LATEST {
                elements.pan_left |> THEN { LeftWindow }
                elements.pan_right |> THEN { RightWindow }
                elements.zoom_reset |> THEN { Center }
                elements.keyboard_capture.key |> WHEN {
                    A => LeftWindow
                    D => RightWindow
                    R => Center
                    Q => RightWindow
                    E => RightWindow
                    __ => SKIP
                }
                elements.select_counter_file |> THEN { Center }
                elements.select_uart_compare_file |> THEN { Center }
                elements.select_ghw_file |> THEN { Center }
                file_tree_selected_file |> THEN { Center }
                elements.load_default_file |> THEN { Center }
                elements.show_empty |> THEN { Center }
            }
        }

    cursor_position:
        selected_timeline_cursor_value <= selected_timeline_cursor_left |> WHEN {
            True => Cursor36
            False => selected_timeline_cursor_value >= selected_timeline_cursor_right |> WHEN {
                True => Cursor48
                False => Cursor42
            }
        }

    viewport_window_key:
        selected_timeline_metadata_file
        |> Text/concat(with: zoom_level, separator: "|")
        |> Text/concat(with: pan_window, separator: "|")

    viewport_initial_span_value:
        Number/max(left: selected_timeline_window_end - selected_timeline_window_start, right: 0)

    viewport_range_span_value:
        Number/max(left: selected_timeline_range_end - selected_timeline_range_start, right: 0)

    viewport_close_unit_value:
        viewport_initial_span_value / 5

    viewport_closer_unit_value:
        viewport_initial_span_value / 25

    viewport_duration_value:
        zoom_level |> WHEN {
            Widest => viewport_range_span_value
            Wide => viewport_range_span_value
            Fit => viewport_initial_span_value
            Close => Number/max(left: viewport_close_unit_value * 3, right: 1)
            Closer => Number/max(left: viewport_closer_unit_value * 4, right: 1)
            Closest => Number/max(left: viewport_closer_unit_value, right: 1)
            __ => viewport_initial_span_value
        }

    viewport_anchor_center_value:
        pan_window |> WHEN {
            LeftWindow => selected_timeline_zoom_center_number - viewport_duration_value / 2
            RightWindow => selected_timeline_zoom_center_number + viewport_duration_value / 2
            __ => selected_timeline_zoom_center_number
        }

    viewport_desired_start_value:
        viewport_anchor_center_value - viewport_duration_value / 2

    viewport_label_start:
        Number/max(left: selected_timeline_range_start, right: Number/min(left: viewport_desired_start_value, right: selected_timeline_range_end - viewport_duration_value))

    viewport_label_end:
        Number/min(left: selected_timeline_range_end, right: viewport_label_start + viewport_duration_value)

    viewport_label:
        viewport_label_start
        |> Text/time_range_label(end: viewport_label_end, unit: selected_timeline_time_unit)

    keyboard_viewport_label:
        viewport_label

    cursor_label:
        selected_timeline_cursor_value |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    keyboard_cursor_label:
        selected_timeline_cursor_value |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    zoom_center_label:
        waveform_hover_zoom_center_value |> Text/concat(with: selected_timeline_time_unit, separator: " ")

    waveform_cursor_offset:
        Number/project_offset(time: selected_timeline_cursor_value, viewport_start: viewport_label_start, viewport_end: viewport_label_end, canvas_width: selected_waveform_canvas_width, fallback: 0, zoom: waveform_projection_zoom_level)

    waveform_zoom_center_offset:
        Number/project_offset(time: waveform_hover_zoom_center_value, viewport_start: viewport_label_start, viewport_end: viewport_label_end, canvas_width: selected_waveform_canvas_width, fallback: 0, zoom: waveform_projection_zoom_level)

    active_signal_catalog_record:
        signal_catalog_record(key: active_signal)

    active_signal_label:
        active_signal_catalog_record |> WHEN {
            Found[value] => value.label
            NotFound => TEXT { none }
        }

    active_scope_key:
        active_scope

    active_scope_label:
        real_hierarchy_page_result |> WHEN {
            HierarchyPage =>
                real_hierarchy_page_result.rows
                |> List/find(item, if: item.id == active_scope)
                |> WHEN {
                    Found[value] => value.full_name
                    NotFound => TEXT { none }
                }
            __ => TEXT { none }
        }

    active_scope_signal_count:
        real_hierarchy_signal_rows
        |> List/filter(item, if: item.parent_id == active_scope)
        |> List/length()
        |> Number/to_text(radix: 10)
        |> Text/concat(with: TEXT { signals }, separator: " ")

    scope_cpu_expansion_state:
        LATEST {
            Expanded
            elements.scope_cpu |> THEN { Expanded }
            elements.scope_cpu_expand |> THEN { Expanded }
            elements.scope_cpu_collapse |> THEN { Collapsed }
            elements.select_counter_file |> THEN { Expanded }
            elements.load_default_file |> THEN { Expanded }
            elements.show_empty |> THEN { Collapsed }
        }

    active_scope_expansion_label:
        active_scope == TEXT { simple_tb_s } |> WHEN {
            True => scope_cpu_expansion_state
            False => active_scope == TEXT { none } |> WHEN {
                True => None
                False => Expanded
            }
        }

    active_scope_visible_signal_count:
        active_scope == TEXT { simple_tb_s } |> WHEN {
            True => scope_cpu_expansion_state == Expanded |> WHEN {
                True => TEXT { 2 visible }
                False => TEXT { 0 visible }
            }
            False => active_scope == TEXT { top_uart } |> WHEN {
                True => TEXT { 5 visible }
                False => active_scope == TEXT { top_analog } |> WHEN {
                    True => TEXT { 2 visible }
                    False => active_scope == TEXT { ghw_simple } |> WHEN {
                        True => TEXT { 4 visible }
                        False => TEXT { 0 visible }
                    }
                }
            }
        }

    data_signal_toggle_state:
        TEXT { Off } |> HOLD data_signal_toggle_state {
            LATEST {
                elements.select_data |> THEN {
                    data_signal_toggle_state |> WHEN {
                        On => TEXT { Off }
                        Off => TEXT { On }
                        __ => TEXT { On }
                    }
                }
                elements.select_clk |> THEN { TEXT { Off } }
                elements.select_reset |> THEN { TEXT { Off } }
                elements.select_temperature |> THEN { TEXT { Off } }
                elements.load_default_file |> THEN { TEXT { Off } }
                elements.show_empty |> THEN { TEXT { Off } }
            }
        }

    active_signal_key:
        active_signal_catalog_record |> WHEN {
            Found[value] => value.bridge_key
            NotFound => TEXT { NONE }
        }

    format_label:
        NovyModel/format_label(format: active_signal_format)

    waveform_format_label:
        real_bridge_format

    data_bus_rendered_value:
        NovyModel/selected_data_value_at_cursor(format: data_bus_row_format, cursor: cursor_position)

    temperature_rendered_value:
        NovyModel/selected_temperature_value_at_cursor(format: active_signal_format, cursor: cursor_position)

    row_height:
        NovyModel/row_height(size: row_size)

    bridge_request_fingerprint:
        bridge_request_descriptor_label

    bridge_page_request_fingerprint:
        active_signal_key == TEXT { NONE } |> WHEN {
            True => TEXT { no-request }
            False =>
                TEXT { request }
                |> Text/concat(with: active_scope_key, separator: "|")
                |> Text/concat(with: active_signal_key, separator: "|")
                |> Text/concat(with: zoom_level, separator: "|")
                |> Text/concat(with: pan_window, separator: "|")
                |> Text/concat(with: active_signal_format, separator: "|")
        }

    bridge_page_request_descriptor_label:
        active_signal_key == TEXT { NONE } |> WHEN {
            True => TEXT { No request scheduled }
            False =>
                active_scope_key
                |> Text/concat(with: active_signal_key, separator: "/")
                |> Text/concat(with: zoom_level, separator: "/")
                |> Text/concat(with: pan_window, separator: "/")
                |> Text/concat(with: active_signal_format, separator: "/")
        }

    bridge_request_page:
        bridge_request_compact_label

    bridge_response_scope:
        TEXT { SIMPLE_TB_S } |> HOLD bridge_response_scope {
            LATEST {
                elements.select_counter_file |> THEN { TEXT { SIMPLE_TB_S } }
                elements.select_uart_compare_file |> THEN { TEXT { TOP_UART } }
                elements.select_ghw_file |> THEN { TEXT { GHW_SIMPLE } }
                file_tree_selected_file |> THEN {
                    file_tree_selected_file |> WHEN {
                        TEXT { wave_27.fst } => TEXT { TOP_UART }
                        TEXT { simple_test.ghw } => TEXT { GHW_SIMPLE }
                        TEXT { simple.vcd } => TEXT { SIMPLE_TB_S }
                        __ => TEXT { NONE }
                    }
                }
                elements.scope_cpu |> THEN { TEXT { SIMPLE_TB_S } }
                elements.scope_uart |> THEN { TEXT { TOP_UART } }
                elements.scope_analog |> THEN { TEXT { TOP_ANALOG } }
                row_selected_scope_key |> THEN {
                    row_selected_scope_key |> WHEN {
                        simple_tb_s => TEXT { SIMPLE_TB_S }
                        top_uart => TEXT { TOP_UART }
                        top_analog => TEXT { TOP_ANALOG }
                        ghw_simple => TEXT { GHW_SIMPLE }
                        __ => TEXT { NONE }
                    }
                }
                elements.stale_response_probe |> THEN { TEXT { SIMPLE_TB_S } }
                elements.load_default_file |> THEN { TEXT { SIMPLE_TB_S } }
                elements.show_empty |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_signal:
        TEXT { A_SIGNAL } |> HOLD bridge_response_signal {
            LATEST {
                elements.select_counter_file |> THEN { TEXT { A_SIGNAL } }
                elements.select_uart_compare_file |> THEN { TEXT { TX_DATA } }
                elements.select_ghw_file |> THEN { TEXT { GHW_COUNTER } }
                file_tree_selected_file |> THEN {
                    file_tree_selected_file |> WHEN {
                        TEXT { wave_27.fst } => TEXT { TX_DATA }
                        TEXT { simple_test.ghw } => TEXT { GHW_COUNTER }
                        TEXT { simple.vcd } => TEXT { A_SIGNAL }
                        __ => TEXT { NONE }
                    }
                }
                elements.select_clk |> THEN { TEXT { A_SIGNAL } }
                elements.select_reset |> THEN { TEXT { B_SIGNAL } }
                elements.select_data |> THEN { TEXT { DATA_BUS } }
                elements.select_temperature |> THEN { TEXT { TEMPERATURE } }
                row_selected_signal_key |> THEN { row_selected_signal_bridge_key }
                elements.stale_response_probe |> THEN { TEXT { A_SIGNAL } }
                elements.load_default_file |> THEN { TEXT { A_SIGNAL } }
                elements.show_empty |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_zoom:
        Fit |> HOLD bridge_response_zoom {
            LATEST {
                elements.select_counter_file |> THEN { Fit }
                elements.select_uart_compare_file |> THEN { Fit }
                elements.select_ghw_file |> THEN { Fit }
                elements.zoom_in |> THEN { Close }
                elements.zoom_out |> THEN { Wide }
                elements.zoom_reset |> THEN { Fit }
                elements.cursor_left |> THEN { Close }
                elements.stale_response_probe |> THEN { Fit }
                elements.load_default_file |> THEN { Fit }
                elements.show_empty |> THEN { None }
            }
        }

    bridge_response_pan:
        Center |> HOLD bridge_response_pan {
            LATEST {
                elements.select_counter_file |> THEN { Center }
                elements.select_uart_compare_file |> THEN { Center }
                elements.select_ghw_file |> THEN { Center }
                elements.pan_left |> THEN { LeftWindow }
                elements.pan_right |> THEN { RightWindow }
                elements.zoom_reset |> THEN { Center }
                elements.cursor_left |> THEN { RightWindow }
                elements.stale_response_probe |> THEN { Center }
                elements.load_default_file |> THEN { Center }
                elements.show_empty |> THEN { None }
            }
        }

    bridge_response_window_key:
        selected_timeline_metadata_file
        |> Text/concat(with: bridge_response_zoom, separator: "|")
        |> Text/concat(with: bridge_response_pan, separator: "|")

    bridge_response_viewport_duration:
        bridge_response_zoom |> WHEN {
            Widest => viewport_range_span_value
            Wide => viewport_range_span_value
            Fit => viewport_initial_span_value
            Close => Number/max(left: viewport_close_unit_value * 3, right: 1)
            Closer => Number/max(left: viewport_closer_unit_value * 4, right: 1)
            Closest => Number/max(left: viewport_closer_unit_value, right: 1)
            __ => viewport_initial_span_value
        }

    bridge_response_viewport_anchor_center:
        bridge_response_pan |> WHEN {
            LeftWindow => selected_timeline_zoom_center_number - bridge_response_viewport_duration / 2
            RightWindow => selected_timeline_zoom_center_number + bridge_response_viewport_duration / 2
            __ => selected_timeline_zoom_center_number
        }

    bridge_response_viewport_desired_start:
        bridge_response_viewport_anchor_center - bridge_response_viewport_duration / 2

    bridge_response_window_start:
        Number/max(left: selected_timeline_range_start, right: Number/min(left: bridge_response_viewport_desired_start, right: selected_timeline_range_end - bridge_response_viewport_duration))

    bridge_response_window_end:
        Number/min(left: selected_timeline_range_end, right: bridge_response_window_start + bridge_response_viewport_duration)

    bridge_response_cursor:
        Cursor42 |> HOLD bridge_response_cursor {
            LATEST {
                elements.select_counter_file |> THEN { Cursor42 }
                elements.select_uart_compare_file |> THEN { Cursor42 }
                elements.select_ghw_file |> THEN { Cursor42 }
                elements.cursor_left |> THEN { Cursor36 }
                elements.cursor_right |> THEN { Cursor48 }
                elements.stale_response_probe |> THEN { Cursor42 }
                elements.load_default_file |> THEN { Cursor42 }
                elements.show_empty |> THEN { None }
            }
        }

    bridge_response_format:
        Hexadecimal |> HOLD bridge_response_format {
            LATEST {
                elements.select_counter_file |> THEN { Hexadecimal }
                elements.select_uart_compare_file |> THEN { Hexadecimal }
                elements.select_ghw_file |> THEN { Hexadecimal }
                elements.format_cycle |> THEN { NovyModel/next_format(format: bridge_response_format) }
                elements.stale_response_probe |> THEN { Hexadecimal }
                elements.load_default_file |> THEN { Hexadecimal }
                elements.show_empty |> THEN { None }
            }
        }

    bridge_response_window_label:
        active_signal_key == TEXT { NONE } |> WHEN {
            True => TEXT { no response window }
            False => bridge_response_window_start |> Text/time_range_label(end: bridge_response_window_end, unit: selected_timeline_time_unit)
        }

    bridge_request_window_label:
        active_signal_key == TEXT { NONE } |> WHEN {
            True => TEXT { no request window }
            False => keyboard_viewport_label
        }

    bridge_request_generation:
        bridge_file_format == TEXT { none } |> WHEN {
            True => 0
            False => bridge_file_format == TEXT { FST } |> WHEN {
                True => 2
                False => bridge_file_format == TEXT { GHW } |> WHEN {
                    True => 3
                    False => 1
                }
            }
        }

    bridge_request_input_digest:
        bridge_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { input:none }
            False =>
                bridge_file_digest
                |> Text/concat(with: bridge_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_request_fingerprint, separator: "|")
                |> Text/concat(with: bridge_request_window_label, separator: "|")
        }

    bridge_page_request_input_digest:
        bridge_page_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { input:none }
            False =>
                bridge_file_digest
                |> Text/concat(with: bridge_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_page_request_fingerprint, separator: "|")
                |> Text/concat(with: bridge_request_window_label, separator: "|")
        }

    bridge_request_structural_key:
        bridge_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { no-request }
            False =>
                TEXT { gen }
                |> Text/concat(with: bridge_request_generation, separator: ":")
                |> Text/concat(with: bridge_request_fingerprint, separator: "|")
                |> Text/concat(with: bridge_request_input_digest, separator: "|")
        }

    bridge_page_request_structural_key:
        bridge_page_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { no-request }
            False =>
                TEXT { gen }
                |> Text/concat(with: bridge_request_generation, separator: ":")
                |> Text/concat(with: bridge_page_request_fingerprint, separator: "|")
                |> Text/concat(with: bridge_page_request_input_digest, separator: "|")
        }

    bridge_response_file_digest:
        TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } |> HOLD bridge_response_file_digest {
            LATEST {
                elements.select_counter_file |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.select_uart_compare_file |> THEN { TEXT { sha256:aa4a6993101ff31601e12d613b746d8753f20448d78e8b720f708403047dc172 } }
                elements.select_ghw_file |> THEN { TEXT { sha256:3485b4b9a423ce61e54a9bd4a2c525cf7576f0e36d39ad73b208c2e38e980491 } }
                file_tree_selected_file |> THEN {
                    waveform_metadata_record(file: file_tree_selected_file) |> WHEN {
                        Found[value] => value.digest
                        NotFound => TEXT { sha256:none }
                    }
                }
                elements.cursor_left |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.stale_response_probe |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.load_default_file |> THEN { TEXT { sha256:726d6fa4d5baa8881462f131997d16ff21494bb88708eb6b23420215e3f5a5de } }
                elements.external_file_loaded_digest.text
                elements.show_empty |> THEN { TEXT { sha256:none } }
            }
        }

    bridge_response_waveform_ref:
        TEXT { wave:vcd:simple:0-250s } |> HOLD bridge_response_waveform_ref {
            LATEST {
                elements.select_counter_file |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.select_uart_compare_file |> THEN { TEXT { wave:fst:wave-27:0-240ns } }
                elements.select_ghw_file |> THEN { TEXT { wave:ghw:simple-test:0-100ns } }
                file_tree_selected_file |> THEN {
                    waveform_metadata_record(file: file_tree_selected_file) |> WHEN {
                        Found[value] => value.waveform_ref
                        NotFound => TEXT { wave:none }
                    }
                }
                elements.cursor_left |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.stale_response_probe |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.load_default_file |> THEN { TEXT { wave:vcd:simple:0-250s } }
                elements.external_file_loaded_waveform_ref.text
                elements.show_empty |> THEN { TEXT { wave:none } }
            }
        }

    bridge_response_generation:
        1 |> HOLD bridge_response_generation {
            LATEST {
                elements.select_counter_file |> THEN { 1 }
                elements.select_uart_compare_file |> THEN { 2 }
                elements.select_ghw_file |> THEN { 3 }
                file_tree_selected_file |> THEN {
                    file_tree_selected_file |> WHEN {
                        TEXT { wave_27.fst } => 2
                        TEXT { simple_test.ghw } => 3
                        TEXT { simple.vcd } => 1
                        __ => 0
                    }
                }
                elements.cursor_left |> THEN { 1 }
                elements.stale_response_probe |> THEN { 0 }
                elements.load_default_file |> THEN { 1 }
                elements.external_file_loaded_name.text |> THEN { 1 }
                elements.show_empty |> THEN { 0 }
            }
        }

    bridge_response_input_digest:
        bridge_response_descriptor_label == TEXT { No response available } |> WHEN {
            True => TEXT { input:none }
            False =>
                bridge_response_file_digest
                |> Text/concat(with: bridge_response_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_response_fingerprint, separator: "|")
                |> Text/concat(with: bridge_response_window_label, separator: "|")
        }

    bridge_page_response_input_digest:
        bridge_page_response_descriptor_label == TEXT { No response available } |> WHEN {
            True => TEXT { input:none }
            False =>
                bridge_response_file_digest
                |> Text/concat(with: bridge_response_waveform_ref, separator: "|")
                |> Text/concat(with: bridge_page_response_fingerprint, separator: "|")
                |> Text/concat(with: bridge_response_window_label, separator: "|")
        }

    bridge_response_structural_key:
        bridge_response_descriptor_label == TEXT { No response available } |> WHEN {
            True => TEXT { no-request }
            False =>
                TEXT { gen }
                |> Text/concat(with: bridge_response_generation, separator: ":")
                |> Text/concat(with: bridge_response_fingerprint, separator: "|")
                |> Text/concat(with: bridge_response_input_digest, separator: "|")
        }

    bridge_page_response_structural_key:
        bridge_page_response_descriptor_label == TEXT { No response available } |> WHEN {
            True => TEXT { no-request }
            False =>
                TEXT { gen }
                |> Text/concat(with: bridge_response_generation, separator: ":")
                |> Text/concat(with: bridge_page_response_fingerprint, separator: "|")
                |> Text/concat(with: bridge_page_response_input_digest, separator: "|")
        }

    bridge_response_fingerprint:
        bridge_response_descriptor_label

    bridge_page_response_fingerprint:
        bridge_response_signal == TEXT { NONE } |> WHEN {
            True => TEXT { no-request }
            False =>
                TEXT { request }
                |> Text/concat(with: bridge_response_scope, separator: "|")
                |> Text/concat(with: bridge_response_signal, separator: "|")
                |> Text/concat(with: bridge_response_zoom, separator: "|")
                |> Text/concat(with: bridge_response_pan, separator: "|")
                |> Text/concat(with: bridge_response_format, separator: "|")
        }

    bridge_page_response_descriptor_label:
        bridge_response_signal == TEXT { NONE } |> WHEN {
            True => TEXT { No response available }
            False =>
                bridge_response_scope
                |> Text/concat(with: bridge_response_signal, separator: "/")
                |> Text/concat(with: bridge_response_zoom, separator: "/")
                |> Text/concat(with: bridge_response_pan, separator: "/")
                |> Text/concat(with: bridge_response_format, separator: "/")
        }

    bridge_response_page:
        bridge_response_compact_label

    bridge_request_descriptor_label:
        real_signal_page_request_fingerprint

    bridge_response_descriptor_label:
        real_signal_page_result |> WHEN {
            SignalPage => real_signal_page_result.request_fingerprint
            __ => TEXT { No response available }
        }

    bridge_request_descriptor:
        [
            page: bridge_page_request_descriptor_label
            descriptor: bridge_page_request_descriptor_label
            fingerprint: bridge_page_request_fingerprint
            identity: [
                module: TEXT { wellen.v1 }
                file_digest: bridge_file_digest
                waveform_ref: bridge_waveform_ref
                selected_file: selected_variable_file
                timeline_metadata_file: selected_timeline_metadata_file
                metadata_source: selected_timeline_metadata_source
                range_source: selected_timeline_range_source
                time_unit: selected_timeline_time_unit
                timescale: selected_timeline_timescale
                file_range: selected_timeline_full_range
                scope: active_scope_key
                signal: active_signal_key
                zoom: zoom_level
                pan: pan_window
                format: active_signal_format
                window: bridge_request_window_label
            ]
            window: bridge_page_window_label
            hierarchy_cursor: bridge_hierarchy_page_cursor_label
            payload_limit_bytes: bridge_payload_limit_bytes
            transition_limit: bridge_transition_limit
            visible_row_limit: bridge_visible_row_limit
            segment_limit: bridge_segment_limit
            materialization: bridge_materialization_bound_label
        ]

    bridge_response_descriptor:
        [
            page: bridge_response_page
            descriptor: bridge_response_descriptor_label
            fingerprint: bridge_response_fingerprint
            identity: [
                module: TEXT { wellen.v1 }
                file_digest: bridge_response_file_digest
                waveform_ref: bridge_response_waveform_ref
                timeline_metadata_file: selected_timeline_metadata_file
                metadata_source: selected_timeline_metadata_source
                range_source: selected_timeline_range_source
                time_unit: selected_timeline_time_unit
                timescale: selected_timeline_timescale
                file_range: selected_timeline_full_range
                scope: bridge_descriptor_scope_label(descriptor: bridge_response_descriptor_label)
                signal: bridge_descriptor_signal_label(descriptor: bridge_response_descriptor_label)
                zoom: bridge_descriptor_zoom_label(descriptor: bridge_response_descriptor_label)
                pan: bridge_descriptor_pan_label(descriptor: bridge_response_descriptor_label)
                cursor: bridge_descriptor_cursor_label(descriptor: bridge_response_descriptor_label)
                format: bridge_descriptor_format_label(descriptor: bridge_response_descriptor_label)
                window: bridge_descriptor_window_label(descriptor: bridge_response_descriptor_label)
            ]
            payload_limit_bytes: bridge_payload_limit_bytes
            transition_limit: bridge_transition_limit
            visible_row_limit: bridge_visible_row_limit
            segment_limit: bridge_segment_limit
        ]

    bridge_signal_page_label:
        bridge_page_request_descriptor_label == TEXT { No request scheduled } |> WHEN {
            True => TEXT { no-request }
            False => bridge_page_request_descriptor_label
        }

    bridge_cursor_values_label:
        selected_cursor_pair_rows
        |> List/map(item, new: item.label)
        |> Text/join(separator: " ", empty: "unavailable")
        |> Text/concat(with: keyboard_cursor_label, separator: " at ")

    bridge_open_descriptor:
        [
            module: TEXT { wellen.v1 }
            provider: NovyBridge/provider_version()
            schema: NovyBridge/schema_version()
            export: TEXT { open }
            file: bridge_descriptor_file
            format: bridge_file_format
            digest: bridge_file_digest
            waveform_ref: bridge_waveform_ref
            metadata_file: active_metadata_file
            metadata_source: active_metadata_source
            range_source: active_metadata_range_source
            time_unit: active_metadata_time_unit
            timescale: active_metadata_timescale
            file_range: active_metadata_full_range
            status: bridge_open_status
            policy: NovyBridge/data_policy_label()
        ]

    bridge_request_label:
        bridge_request_fingerprint

    bridge_request_compact_label_raw:
        TEXT { A_FIT } |> HOLD bridge_request_compact_label_raw {
            LATEST {
                elements.select_counter_file |> THEN { TEXT { A_FIT } }
                elements.select_uart_compare_file |> THEN { TEXT { CMP_UART } }
                elements.select_ghw_file |> THEN { TEXT { GHW_MAIN } }
                file_tree_selected_file |> THEN {
                    file_tree_selected_file |> WHEN {
                        TEXT { wave_27.fst } => TEXT { CMP_UART }
                        TEXT { simple_test.ghw } => TEXT { GHW_MAIN }
                        TEXT { simple.vcd } => TEXT { A_FIT }
                        __ => TEXT { NONE }
                    }
                }
                elements.select_clk |> THEN { TEXT { A_FIT } }
                elements.select_reset |> THEN { TEXT { B_FIT } }
                elements.select_data |> THEN {
                    data_signal_toggle_state |> WHEN {
                        On => TEXT { DATA_FIT }
                        Off => TEXT { NONE }
                    }
                }
                elements.select_temperature |> THEN { TEXT { TEMP_FIT } }
                row_selected_signal_key |> THEN { row_selected_signal_fit_page }
                elements.format_cycle |> THEN { TEXT { DATA_BIN } }
                elements.format_binary |> THEN { TEXT { DATA_BIN } }
                elements.format_hex |> THEN { TEXT { DATA_HEX } }
                elements.format_grouped |> THEN { TEXT { DATA_GROUP } }
                elements.format_octal |> THEN { TEXT { DATA_OCT } }
                elements.format_signed |> THEN { TEXT { DATA_SGN } }
                elements.format_unsigned |> THEN { TEXT { DATA_UNS } }
                elements.format_ascii |> THEN { TEXT { DATA_ASC } }
                elements.zoom_in |> THEN { TEXT { DATA_CLOSE } }
                elements.zoom_out |> THEN { TEXT { DATA_WIDE } }
                elements.zoom_reset |> THEN { TEXT { DATA_FIT } }
                elements.pan_right |> THEN { TEXT { DATA_RIGHT } }
                elements.cursor_left |> THEN { TEXT { DATA_36NS } }
                elements.cursor_right |> THEN { TEXT { DATA_48NS } }
                elements.keyboard_capture.key |> WHEN {
                    W => TEXT { DATA_CLOSE }
                    S => TEXT { DATA_WIDE }
                    R => TEXT { DATA_FIT }
                    Q => TEXT { DATA_36NS }
                    E => TEXT { DATA_48NS }
                    D => TEXT { DATA_RIGHT }
                    A => TEXT { DATA_LEFT }
                    __ => SKIP
                }
                elements.load_default_file |> THEN { TEXT { A_FIT } }
                elements.show_empty |> THEN { TEXT { NONE } }
            }
        }

    bridge_request_compact_label:
        NovyModel/request_page(compact: bridge_request_compact_label_raw, format: active_signal_format, zoom: zoom_level)

    bridge_response_compact_label:
        TEXT { A_FIT } |> HOLD bridge_response_compact_label {
            LATEST {
                elements.select_counter_file |> THEN { TEXT { A_FIT } }
                elements.select_uart_compare_file |> THEN { TEXT { CMP_UART } }
                elements.select_ghw_file |> THEN { TEXT { GHW_MAIN } }
                file_tree_selected_file |> THEN {
                    file_tree_selected_file |> WHEN {
                        TEXT { wave_27.fst } => TEXT { CMP_UART }
                        TEXT { simple_test.ghw } => TEXT { GHW_MAIN }
                        TEXT { simple.vcd } => TEXT { A_FIT }
                        __ => TEXT { NONE }
                    }
                }
                elements.cursor_left |> THEN { TEXT { A_0S } }
                elements.keyboard_capture.key |> WHEN {
                    D => TEXT { A_FIT }
                    Q => TEXT { A_0S }
                    S => TEXT { A_0S }
                    W => TEXT { A_0S }
                    R => TEXT { A_FIT }
                    E => TEXT { A_150S }
                    A => TEXT { A_0S }
                    __ => SKIP
                }
                elements.stale_response_probe |> THEN { TEXT { A_FIT } }
                elements.load_default_file |> THEN { TEXT { A_FIT } }
                elements.show_empty |> THEN { TEXT { NONE } }
            }
        }

    bridge_response_status:
        bridge_page_match_status(request: bridge_request_structural_key, response: bridge_response_structural_key)

    bridge_response_status_compact_label:
        bridge_page_match_compact_label(request: bridge_request_structural_key, response: bridge_response_structural_key)

    bridge_page_response_status:
        bridge_page_match_status(request: bridge_page_request_structural_key, response: bridge_page_response_structural_key)

    bridge_page_response_status_compact_label:
        bridge_page_match_compact_label(request: bridge_page_request_structural_key, response: bridge_page_response_structural_key)

    bridge_artifact_byte_length:
        bridge_descriptor_file |> WHEN {
            TEXT { wave_27.fst } => 28860652
            TEXT { simple_test.ghw } => 833
            TEXT { corrupted.vcd } => 25
            TEXT { none } => 0
            __ => 311
        }

    bridge_artifact_ref:
        NovyBridge/artifact_ref(
            file: bridge_descriptor_file
            format: bridge_file_format
            digest: bridge_file_digest
            generation: bridge_request_generation
            byte_length: bridge_artifact_byte_length
            status: bridge_open_status
        )

    bridge_blob_ref:
        NovyBridge/blob_ref(
            digest: bridge_file_digest
            byte_length: bridge_artifact_byte_length
            media_type: TEXT { application/vnd.wellen.waveform }
            storage: TEXT { fixture-bounded-pages }
            encoding: bridge_file_format
            generation: bridge_request_generation
            status: bridge_open_status
        )

    bridge_open_result:
        NovyBridge/open_result(
            artifact_ref: bridge_artifact_ref
            blob_ref: bridge_blob_ref
            status: bridge_open_status
            diagnostic: bridge_diagnostic
        )

    bridge_hierarchy_page_digest:
        TEXT { page:hierarchy }
        |> Text/concat(with: bridge_file_digest, separator: "|")
        |> Text/concat(with: bridge_page_request_fingerprint, separator: "|")

    bridge_signal_page_digest:
        TEXT { page:signal }
        |> Text/concat(with: bridge_file_digest, separator: "|")
        |> Text/concat(with: bridge_page_request_fingerprint, separator: "|")

    bridge_waveform_page_digest:
        TEXT { page:waveform }
        |> Text/concat(with: bridge_file_digest, separator: "|")
        |> Text/concat(with: bridge_page_request_fingerprint, separator: "|")
        |> Text/concat(with: bridge_request_window_label, separator: "|")

    bridge_cursor_values_page_digest:
        TEXT { page:cursor_values }
        |> Text/concat(with: bridge_file_digest, separator: "|")
        |> Text/concat(with: cursor_label, separator: "|")

    bridge_waveform_stats_page_digest:
        TEXT { page:waveform_stats }
        |> Text/concat(with: bridge_file_digest, separator: "|")
        |> Text/concat(with: bridge_waveform_stats_label, separator: "|")

    bridge_waveform_sample_count:
        selected_waveform_segments |> List/length()

    bridge_hierarchy_page_ref:
        [
            ref_type: TEXT { PageRef }
            page_kind: TEXT { hierarchy_page }
            artifact_digest: bridge_file_digest
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_hierarchy_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: 0
            transition_count: 0
            byte_length: 2048
            status: bridge_open_status
        ]

    bridge_signal_page_ref:
        [
            ref_type: TEXT { PageRef }
            page_kind: TEXT { signal_page }
            artifact_digest: bridge_file_digest
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_signal_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: 0
            transition_count: 0
            byte_length: 4096
            status: bridge_open_status
        ]

    bridge_waveform_page_ref:
        [
            ref_type: TEXT { PageRef }
            page_kind: TEXT { waveform_page }
            artifact_digest: bridge_file_digest
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_waveform_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: bridge_waveform_sample_count
            transition_count: bridge_waveform_sample_count
            byte_length: bridge_payload_limit_bytes
            status: bridge_page_response_status
        ]

    bridge_cursor_values_page_ref:
        [
            ref_type: TEXT { PageRef }
            page_kind: TEXT { cursor_values }
            artifact_digest: bridge_file_digest
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_request_fingerprint
            response_fingerprint: bridge_response_fingerprint
            input_digest: bridge_request_input_digest
            page_digest: bridge_cursor_values_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: selected_rows_count
            transition_count: 0
            byte_length: 1024
            status: bridge_response_status
        ]

    bridge_waveform_stats_page_ref:
        [
            ref_type: TEXT { PageRef }
            page_kind: TEXT { waveform_stats }
            artifact_digest: bridge_file_digest
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_waveform_stats_page_digest
            generation: bridge_request_generation
            row_count: 1
            sample_count: 0
            transition_count: bridge_waveform_sample_count
            byte_length: 1024
            status: bridge_open_status
        ]

    bridge_hierarchy_page:
        [
            page_type: TEXT { hierarchy_page }
            descriptor: bridge_hierarchy_page_label
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_hierarchy_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: 0
            transition_count: 0
            byte_length: 2048
            status: bridge_open_status
        ]

    bridge_signal_page:
        [
            page_type: TEXT { signal_page }
            descriptor: bridge_signal_page_label
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_signal_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: 0
            transition_count: 0
            byte_length: 4096
            status: bridge_open_status
        ]

    bridge_waveform_page:
        [
            page_type: TEXT { waveform_page }
            descriptor: bridge_page_request_descriptor_label
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_waveform_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: bridge_waveform_sample_count
            transition_count: bridge_waveform_sample_count
            byte_length: bridge_payload_limit_bytes
            status: bridge_page_response_status
        ]

    bridge_cursor_values:
        [
            page_type: TEXT { cursor_values }
            cursor: keyboard_cursor_label
            rows: selected_cursor_pair_rows
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_request_fingerprint
            response_fingerprint: bridge_response_fingerprint
            input_digest: bridge_request_input_digest
            page_digest: bridge_cursor_values_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: selected_rows_count
            transition_count: 0
            byte_length: 1024
            status: bridge_response_status
        ]

    bridge_waveform_stats:
        [
            page_type: TEXT { waveform_stats }
            file: bridge_descriptor_file
            format: bridge_file_format
            schema_version: bridge_page_schema_version
            schema_hash: bridge_page_schema_hash
            request_fingerprint: bridge_page_request_fingerprint
            response_fingerprint: bridge_page_response_fingerprint
            input_digest: bridge_page_request_input_digest
            page_digest: bridge_waveform_stats_page_digest
            generation: bridge_request_generation
            row_count: selected_rows_count
            sample_count: 0
            transition_count: bridge_waveform_sample_count
            byte_length: 1024
            file_byte_length: bridge_artifact_byte_length
            status: bridge_open_status
        ]

    bridge_diagnostics:
        [
            diagnostics_type: TEXT { BridgeDiagnostics }
            diagnostic_count: 1
            primary_diagnostic_type: TEXT { BridgeDiagnostic }
            primary_kind: diagnostic_state
            primary_file: diagnostic_file
            primary_message: diagnostic_label
        ]

    bridge_status:
        [
            open: bridge_open_status
            response: bridge_response_status
            response_compact: bridge_response_status_compact_label
            stale_policy: TEXT { generation and request fingerprint equality required }
        ]

    stale_response_policy: TEXT { generation and request fingerprint equality required }
    bridge_contract: TEXT { wellen.v1-compatible fixture contract: open, hierarchy_page, signal_page, cursor_values }
    bridge_provider_version: TEXT { deterministic fixture provider v1 }
    bridge_schema_version: TEXT { wellen.v1 fixture schema; stable fixture hashes in descriptors }
    bridge_effect_exports: TEXT { open/hierarchy/signal/cursor }
    bridge_data_policy: TEXT { comparable descriptors only; no Rust handles }
]

FUNCTION startup_file_record(file) {
    store.startup_workspace_opened_files
    |> List/find(item, if: item.file == file)
}

FUNCTION waveform_metadata_record(file) {
    store.waveform_file_metadata
    |> List/find(item, if: item.file == file)
}

FUNCTION signal_catalog_record(key) {
    store.signal_catalog
    |> List/find(item, if: item.key == key)
}

FUNCTION selected_signal_default_record(id) {
    store.selected_signal_defaults
    |> List/find(item, if: item.id == id)
}

FUNCTION bridge_page_match_status(request, response) {
    request == TEXT { no-request } |> WHEN {
        True => TEXT { NOT_REQUESTED }
        False => request == response |> WHEN {
            True => TEXT { ACCEPTED_CURRENT_PAGE }
            False => TEXT { REJECTED_STALE_PAGE }
        }
    }
}

FUNCTION bridge_page_match_compact_label(request, response) {
    request == TEXT { no-request } |> WHEN {
        True => TEXT { NONE }
        False => request == response |> WHEN {
            True => TEXT { CURRENT }
            False => TEXT { STALE }
        }
    }
}

FUNCTION bridge_descriptor_scope_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } => TEXT { TOP_UART }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { GHW_SIMPLE }
        TEXT { No response available } => TEXT { NONE }
        __ => TEXT { SIMPLE_TB_S }
    }
}

FUNCTION bridge_descriptor_signal_label(descriptor) {
    descriptor |> WHEN {
        TEXT { TOP_UART/TX_DATA/Fit/Center/Cursor42/Hexadecimal } => TEXT { TX_DATA }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { GHW_COUNTER }
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => TEXT { A_SIGNAL }
        TEXT { No response available } => TEXT { NONE }
        __ => TEXT { A_SIGNAL }
    }
}

FUNCTION bridge_descriptor_zoom_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => Close
        TEXT { No response available } => None
        __ => Fit
    }
}

FUNCTION bridge_descriptor_pan_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => RightWindow
        TEXT { No response available } => None
        __ => Center
    }
}

FUNCTION bridge_descriptor_cursor_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => Cursor36
        TEXT { No response available } => None
        __ => Cursor42
    }
}

FUNCTION bridge_descriptor_format_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => Binary
        TEXT { No response available } => None
        __ => Hexadecimal
    }
}

FUNCTION bridge_descriptor_window_label(descriptor) {
    descriptor |> WHEN {
        TEXT { SIMPLE_TB_S/A_SIGNAL/Close/RightWindow/Cursor36/Binary } => TEXT { 50 s - 150 s }
        TEXT { GHW_SIMPLE/GHW_COUNTER/Fit/Center/Cursor42/Hexadecimal } => TEXT { 0 ns - 100 ns }
        TEXT { No response available } => TEXT { no response window }
        __ => TEXT { 0 s - 250 s }
    }
}

FUNCTION new_file_tree_row(file_tree_row) {
    [
        file_row_elements: [
            select_file: SOURCE
        ]
        scope_row_elements: [
            select_scope: SOURCE
        ]
        kind: file_tree_row.kind
        file: file_tree_row.file
        scope_key: file_tree_row.scope_key
        label: file_tree_row.label
        expanded_label: file_tree_row.expanded_label
        collapsed_label: file_tree_row.collapsed_label
        indent_width: file_tree_row.indent_width
        selected_file: file_tree_row.selected_file
        source_key: file_tree_row.source_key
    ]
}

FUNCTION real_signal_catalog_row(signal_row) {
    [
        key: signal_row.signal_id
        bridge_key: signal_row.signal_id
        fit_page: TEXT { REAL_SIGNAL_PAGE }
        label: signal_row.signal_id
        scope: signal_row.parent_id
        name: signal_row.name
        kind: signal_row.encoding
        bit_width: real_signal_bit_width(signal_row: signal_row)
        direction: TEXT { Signal }
        family: store.active_file
        selected_initial: True
    ]
}

FUNCTION real_selected_signal_row(signal_row) {
    [
        family: store.active_file
        file: store.active_file
        id: signal_row.signal_id
        remove_kind: RemoveRow
        name: signal_row.name
        current_value: real_cursor_value_text(signal_id: signal_row.signal_id)
        bit_width: real_signal_bit_width(signal_row: signal_row)
        formatter: Hexadecimal
        initial_formatter: Hexadecimal
        kind: signal_row.encoding |> WHEN {
            TEXT { Real } => Analog
            __ => Digital
        }
        enabled: TEXT { loaded }
        item_kind: VariableRow
        grouped: False
        hidden_when_group: Never
        member_count_label: Text/empty()
        row_count_label: Text/empty()
        divider_height_after: 3
        segments: real_signal_segments(signal_id: signal_row.signal_id)
    ]
}

FUNCTION real_signal_bit_width(signal_row) {
    signal_row.width == 0 |> WHEN {
        True => signal_row.encoding
        False =>
            signal_row.width
            |> Number/to_text(radix: 10)
            |> Text/concat(with: TEXT { bit }, separator: "-")
    }
}

FUNCTION real_signal_segments(signal_id) {
    store.real_signal_page_result |> WHEN {
        SignalPage =>
            store.real_signal_page_result.signals
            |> List/find(item, if: item.signal_id == signal_id)
            |> WHEN {
                Found[value] => value.transitions
                NotFound => LIST {}
            }
            |> List/map(item, new:
                real_waveform_segment(
                    transition: item
                    signal_id: signal_id
                )
            )
        __ => LIST {}
    }
}

FUNCTION comparison_signal_segments() {
    store.comparison_signal_page_result |> WHEN {
        SignalPage =>
            store.comparison_signal_page_result.signals
            |> List/find(item, if: item.signal_id == store.comparison_first_signal_id)
            |> WHEN {
                Found[value] => value.transitions
                NotFound => LIST {}
            }
            |> List/map(item, new:
                comparison_waveform_segment(transition: item)
            )
        __ => LIST {}
    }
}

FUNCTION comparison_waveform_segment(transition) {
    [
        file: TEXT { simple.vcd }
        signal_id: store.comparison_first_signal_id
        start_time_value: transition.time
        end_time_value: transition.end_time
        state: real_waveform_value_state(value: transition.value)
        label: real_waveform_value_text(value: transition.value)
        click_time:
            transition.time
            |> Number/to_text(radix: 10)
            |> Text/concat(with: comparison_waveform_time_unit(), separator: " ")
    ]
}

FUNCTION comparison_waveform_time_unit() {
    store.comparison_waveform_open_result |> WHEN {
        WaveformOpened => store.comparison_waveform_open_result.timescale_unit
        __ => TEXT { tick }
    }
}

FUNCTION real_cursor_value_text(signal_id) {
    store.real_cursor_values_result |> WHEN {
        CursorValues => real_waveform_value_text(
            value:
                store.real_cursor_values_result.rows
                |> List/find(item, if: item.signal_id == signal_id)
                |> WHEN {
                    Found[value] => value.value
                    NotFound => StringValue[text: Text/empty()]
                }
        )
        __ => Text/empty()
    }
}

FUNCTION real_waveform_segment(transition, signal_id) {
    [
        file: store.active_file
        signal_id: signal_id
        start_time_value: transition.time
        end_time_value: transition.end_time
        state: real_waveform_value_state(value: transition.value)
        label: real_waveform_value_text(value: transition.value)
        click_time:
            transition.time
            |> Number/to_text(radix: 10)
            |> Text/concat(with: real_waveform_time_unit(), separator: " ")
    ]
}

FUNCTION real_waveform_time_unit() {
    store.real_waveform_open_result |> WHEN {
        WaveformOpened => store.real_waveform_open_result.timescale_unit
        __ => TEXT { tick }
    }
}

FUNCTION real_waveform_value_text(value) {
    value |> WHEN {
        BinaryValue => value.bits
        FourStateValue => value.bits
        NineStateValue => value.bits
        StringValue => value.text
        RealValue => value.value |> Number/to_text(radix: 10)
        NonFiniteReal => value.classification
        __ => TEXT { ? }
    }
}

FUNCTION real_waveform_value_state(value) {
    value |> WHEN {
        BinaryValue => real_bits_state(bits: value.bits)
        FourStateValue => real_bits_state(bits: value.bits)
        NineStateValue => real_bits_state(bits: value.bits)
        RealValue => AnalogMid
        __ => Unknown
    }
}

FUNCTION real_bits_state(bits) {
    bits |> Text/all_chars_in(chars: TEXT { 0L }) |> WHEN {
        True => Low
        False => bits |> Text/all_chars_in(chars: TEXT { 01HL }) |> WHEN {
            True => High
            False => Unknown
        }
    }
}

FUNCTION new_signal(signal) {
    [
        signal_elements: [
            select_signal: SOURCE
            alias_input: SOURCE
        ]
        row_elements: [
            remove_signal: SOURCE
        ]
        key: signal.key
        bridge_key: signal.bridge_key
        fit_page: signal.fit_page
        label: signal.label
        scope: signal.scope
        name: signal.name
        kind: signal.kind
        bit_width: signal.bit_width
        direction: signal.direction
        family: signal.family
        selected_initial: signal.selected_initial
        selected_once:
            signal.selected_initial |> HOLD selected_once {
                LATEST {
                    signal_elements.select_signal |> THEN { True }
                    row_elements.remove_signal |> THEN { False }
                    elements.select_clk |> THEN { signal.key == TEXT { clk } |> WHEN { True => True False => selected_once } }
                    elements.select_reset |> THEN { signal.key == TEXT { reset_n } |> WHEN { True => True False => selected_once } }
                    elements.select_data |> THEN { signal.key == TEXT { data_bus } |> WHEN { True => True False => selected_once } }
                    elements.select_temperature |> THEN { signal.key == TEXT { temperature } |> WHEN { True => True False => selected_once } }
                    elements.selected_remove_clk |> THEN { signal.key == TEXT { clk } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_reset |> THEN { signal.key == TEXT { reset_n } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_data |> THEN { signal.key == TEXT { data_bus } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_data_valid |> THEN { signal.key == TEXT { data_valid } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_data_ready |> THEN { signal.key == TEXT { data_ready } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_state |> THEN { signal.key == TEXT { state } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_error_count |> THEN { signal.key == TEXT { error_count } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_temperature |> THEN { signal.key == TEXT { temperature } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_tx_data |> THEN { signal.key == TEXT { tx_data } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_rx_data |> THEN { signal.key == TEXT { rx_data } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_baud_tick |> THEN { signal.key == TEXT { baud_tick } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_uart_busy |> THEN { signal.key == TEXT { uart_busy } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_ghw_counter |> THEN { signal.key == TEXT { ghw_counter } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_ghw_enable |> THEN { signal.key == TEXT { ghw_enable } |> WHEN { True => False False => selected_once } }
                    elements.selected_remove_ghw_state |> THEN { signal.key == TEXT { ghw_state } |> WHEN { True => False False => selected_once } }
                    selected_signal_defaults
                        |> List/filter(item, if: item.item_kind == VariableRow)
                        |> List/map(item, new:
                            item.row_elements.remove_signal
                                |> THEN {
                                    item.id == signal.key |> WHEN {
                                        True => item.family == signal.family |> WHEN {
                                            True => False
                                            False => selected_once
                                        }
                                        False => selected_once
                                    }
                                }
                        )
                        |> List/latest()
                    elements.selected_clear_all |> THEN { False }
                    elements.selected_restore_data |> THEN { signal.selected_initial }
                    elements.select_counter_file |> THEN { signal.selected_initial }
                    elements.select_uart_compare_file |> THEN { signal.selected_initial }
                    elements.select_ghw_file |> THEN { signal.selected_initial }
                    file_tree_selected_file |> THEN { signal.selected_initial }
                    elements.load_default_file |> THEN { signal.selected_initial }
                    elements.show_empty |> THEN { False }
                }
            }
        alias:
            Text/empty() |> HOLD alias {
                signal_elements.alias_input.text
            }
    ]
}

FUNCTION new_selected_visible_item(row) {
    row.item_kind |> WHEN {
        VariableRow => new_selected_signal(selected_signal: row)
        __ => row
    }
}

FUNCTION new_signal_lane_row(row) {
    row.item_kind |> WHEN {
        VariableRow => new_signal_lane_variable_row(row: row)
        __ => new_signal_lane_group_row(row: row)
    }
}

FUNCTION signal_lane_identity(row) {
    row.file
        |> Text/concat(with: row.family, separator: "|")
        |> Text/concat(with: row.id, separator: "|")
}

FUNCTION signal_lane_focus_state(row) {
    row.id == store.active_signal |> WHEN {
        True => ActiveLane
        False => IdleLane
    }
}

FUNCTION signal_lane_segment_rows(row) {
    row.segments
        |> List/retain(item, if: waveform_segment_is_visible(segment: item))
        |> List/map(item, new:
            new_signal_lane_segment(
                segment: new_waveform_segment(segment: item)
                row: row
            )
        )
}

FUNCTION new_signal_lane_segment(segment, row) {
    [
        file: segment.file
        signal_id: segment.signal_id
        lane_key: signal_lane_identity(row: row)
        start_time_value: segment.start_time_value
        end_time_value: segment.end_time_value
        visible_start_time_value: segment.visible_start_time_value
        visible_end_time_value: segment.visible_end_time_value
        projection_source: segment.projection_source
        width: segment.width
        state: segment.state
        raw_label: segment.raw_label
        label: segment.label
        click_time: segment.click_time
        page_kind: TEXT { waveform_page }
        request_window: store.bridge_request_window_label
        response_window: store.bridge_response_window_label
    ]
}

FUNCTION new_signal_lane_variable_row(row) {
    [
        lane_key: signal_lane_identity(row: row)
        lane_identity: signal_lane_identity(row: row)
        row_elements: row.row_elements
        format_elements: row.format_elements
        family: row.family
        file: row.file
        id: row.id
        signal_id: row.id
        remove_kind: row.remove_kind
        name: row.name
        signal_label: row.name
        current_value: selected_cursor_value_for_signal(signal: row, format: row.formatter)
        bit_width: row.bit_width
        kind: row.kind
        enabled: row.enabled
        item_kind: row.item_kind
        grouped: row.grouped
        hidden_when_group: row.hidden_when_group
        member_count_label: row.member_count_label
        row_count_label: row.row_count_label
        divider_height_after: row.divider_height_after
        formatter: row.formatter
        format: row.formatter
        format_label: row.format_label
        format_dropdown_state: row.format_dropdown_state
        lane_state: [
            item_kind: row.item_kind
            kind: row.kind
            grouped: row.grouped
            enabled: row.enabled
        ]
        focus_state: signal_lane_focus_state(row: row)
        hit_regions: [
            label_target: row.name
            address: row.id
            remove_kind: row.remove_kind
            waveform_target: TEXT { waveform canvas }
            focus_target: row.name
        ]
        window_ref: [
            request_window: store.bridge_request_window_label
            response_window: store.bridge_response_window_label
            viewport_start: store.viewport_label_start
            viewport_end: store.viewport_label_end
            canvas_width: store.selected_waveform_canvas_width
            zoom: store.waveform_projection_zoom_level
        ]
        page_refs: [
            signal_page_ref: store.bridge_signal_page_ref
            waveform_page_ref: store.bridge_waveform_page_ref
            cursor_values_page_ref: store.bridge_cursor_values_page_ref
        ]
        materialization_ref: [
            collection: TEXT { selected_signal_lanes }
            axis: TEXT { y }
            visible_start: 0
            visible_row_count: store.selected_lane_visible_row_count
            overscan_before_row_count: 0
            overscan_after_row_count: 0
            overscan_row_count: store.selected_lane_overscan_row_count
        ]
        segments: signal_lane_segment_rows(row: row)
    ]
}

FUNCTION new_signal_lane_group_row(row) {
    [
        lane_key: signal_lane_identity(row: row)
        lane_identity: signal_lane_identity(row: row)
        family: row.family
        file: row.file
        id: row.id
        signal_id: row.id
        name: row.name
        signal_label: row.name
        current_value: row.current_value
        kind: row.kind
        enabled: row.enabled
        item_kind: row.item_kind
        grouped: row.grouped
        hidden_when_group: row.hidden_when_group
        member_count_label: row.member_count_label
        row_count_label: row.row_count_label
        divider_height_after: row.divider_height_after
        lane_state: [
            item_kind: row.item_kind
            kind: row.kind
            grouped: row.grouped
            enabled: row.enabled
        ]
        focus_state: GroupLane
        hit_regions: [
            label_target: row.name
            address: row.id
            waveform_target: TEXT { waveform canvas }
            focus_target: row.name
        ]
        window_ref: [
            request_window: store.bridge_request_window_label
            response_window: store.bridge_response_window_label
            viewport_start: store.viewport_label_start
            viewport_end: store.viewport_label_end
            canvas_width: store.selected_waveform_canvas_width
            zoom: store.waveform_projection_zoom_level
        ]
        page_refs: [
            signal_page_ref: store.bridge_signal_page_ref
            waveform_page_ref: store.bridge_waveform_page_ref
            cursor_values_page_ref: store.bridge_cursor_values_page_ref
        ]
        materialization_ref: [
            collection: TEXT { selected_signal_lanes }
            axis: TEXT { y }
            visible_start: 0
            visible_row_count: store.selected_lane_visible_row_count
            overscan_before_row_count: 0
            overscan_after_row_count: 0
            overscan_row_count: store.selected_lane_overscan_row_count
        ]
        segments: signal_lane_segment_rows(row: row)
    ]
}

FUNCTION selected_row_is_visible(row) {
    row.item_kind |> WHEN {
        GroupHeader =>
            store.signal_catalog
            |> List/filter(item, if: item.family == row.family)
            |> List/any(item, if: item.selected_once)
        VariableRow =>
            store.signal_catalog
            |> List/filter(item, if: item.key == row.id)
            |> List/any(item, if: item.selected_once)
        __ => True
    }
}

FUNCTION new_selected_signal(selected_signal) {
    [
        row_elements: [
            remove_signal: SOURCE
        ]
        format_elements: [
            format_dropdown_toggle: SOURCE
            format_binary: SOURCE
            format_hex: SOURCE
            format_grouped: SOURCE
            format_octal: SOURCE
            format_signed: SOURCE
            format_unsigned: SOURCE
            format_ascii: SOURCE
        ]
        family: selected_signal.family
        file: selected_signal.file
        id: selected_signal.id
        remove_kind: selected_signal.remove_kind
        name: selected_signal.name
        bit_width: selected_signal.bit_width
        initial_formatter: selected_signal.initial_formatter
        kind: selected_signal.kind
        enabled: selected_signal.enabled
        item_kind: selected_signal.item_kind
        grouped: selected_signal.grouped
        hidden_when_group: selected_signal.hidden_when_group
        member_count_label: selected_signal.member_count_label
        row_count_label: selected_signal.row_count_label
        divider_height_after: selected_signal.divider_height_after
        segments: selected_signal.segments
        selected: selected_row_is_visible(row: selected_signal)
        formatter:
            selected_signal.formatter |> HOLD formatter {
                LATEST {
                    format_elements.format_binary |> THEN { Binary }
                    format_elements.format_hex |> THEN { Hexadecimal }
                    format_elements.format_grouped |> THEN { GroupedBinary }
                    format_elements.format_octal |> THEN { Octal }
                    format_elements.format_signed |> THEN { Signed }
                    format_elements.format_unsigned |> THEN { Unsigned }
                    format_elements.format_ascii |> THEN { ASCII }
                    elements.format_cycle |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => NovyModel/next_format(format: formatter)
                            False => formatter
                        }
                    }
                    elements.format_binary |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => Binary
                            False => formatter
                        }
                    }
                    elements.format_hex |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => Hexadecimal
                            False => formatter
                        }
                    }
                    elements.format_grouped |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => GroupedBinary
                            False => formatter
                        }
                    }
                    elements.format_octal |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => Octal
                            False => formatter
                        }
                    }
                    elements.format_signed |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => Signed
                            False => formatter
                        }
                    }
                    elements.format_unsigned |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => Unsigned
                            False => formatter
                        }
                    }
                    elements.format_ascii |> THEN {
                        selected_signal.id == store.active_signal |> WHEN {
                            True => ASCII
                            False => formatter
                        }
                    }
                    elements.select_counter_file |> THEN { selected_signal.initial_formatter }
                    elements.select_uart_compare_file |> THEN { selected_signal.initial_formatter }
                    elements.select_ghw_file |> THEN { selected_signal.initial_formatter }
                    file_tree_selected_file |> THEN { selected_signal.initial_formatter }
                    elements.load_default_file |> THEN { selected_signal.initial_formatter }
                    elements.show_empty |> THEN { selected_signal.initial_formatter }
                }
            }
        format_label:
            NovyModel/format_short_label(format: formatter)
        format_dropdown_state:
            Closed |> HOLD format_dropdown_state {
                LATEST {
                    format_elements.format_dropdown_toggle |> THEN {
                        format_dropdown_state |> WHEN {
                            Open => Closed
                            __ => Open
                        }
                    }
                    format_elements.format_binary |> THEN { Closed }
                    format_elements.format_hex |> THEN { Closed }
                    format_elements.format_grouped |> THEN { Closed }
                    format_elements.format_octal |> THEN { Closed }
                    format_elements.format_signed |> THEN { Closed }
                    format_elements.format_unsigned |> THEN { Closed }
                    format_elements.format_ascii |> THEN { Closed }
                    elements.load_default_file |> THEN { Closed }
                    elements.show_empty |> THEN { Closed }
                }
            }
        current_value: selected_cursor_value_for_signal(signal: selected_signal, format: selected_signal.formatter)
    ]
}

FUNCTION selected_cursor_value_for_signal(signal, format) {
    signal.current_value
}

FUNCTION selected_cursor_pair_row(signal) {
    [
        label: selected_cursor_pair_name(signal: signal) |> Text/concat(with: selected_cursor_value_for_signal(signal: signal, format: signal.formatter), separator: "=")
    ]
}

FUNCTION selected_cursor_pair_name(signal) {
    signal.id |> WHEN {
        TEXT { clk } => TEXT { A }
        TEXT { reset_n } => TEXT { B }
        TEXT { ghw_counter } => TEXT { ghw_counter }
        __ => signal.name
    }
}

FUNCTION new_waveform_segment(segment) {
    [
        file: segment.file
        signal_id: segment.signal_id
        start_time_value: segment.start_time_value
        end_time_value: segment.end_time_value
        visible_start_time_value: Number/max(left: segment.start_time_value, right: store.viewport_label_start)
        visible_end_time_value: Number/min(left: segment.end_time_value, right: store.viewport_label_end)
        projection_source: RuntimeTimelineMetadata
        width: segment.state |> WHEN {
            CursorLine => 0
            MarkerLine => 0
            __ => Number/project_width(start_time: Number/max(left: segment.start_time_value, right: store.viewport_label_start), end_time: Number/min(left: segment.end_time_value, right: store.viewport_label_end), viewport_start: store.viewport_label_start, viewport_end: store.viewport_label_end, canvas_width: store.selected_waveform_canvas_width, fallback: 0, zoom: store.waveform_projection_zoom_level)
        }
        state: segment.state
        raw_label: segment.label
        label: segment.label
        click_time: segment.click_time
    ]
}

FUNCTION waveform_segment_is_visible(segment) {
    segment.state |> WHEN {
        CursorLine => False
        MarkerLine => False
        __ => segment.end_time_value > store.viewport_label_start |> WHEN {
            True => segment.start_time_value < store.viewport_label_end
            False => False
        }
    }
}

FUNCTION new_marker(marker, store) {
    [
        marker_elements: [
            remove_marker: SOURCE
        ]
        label:
            marker.label
        has_label: True
    ]
}

FUNCTION new_signal_group(group, store) {
    [
        group_elements: [
            collapse_group: SOURCE
            expand_group: SOURCE
        ]
        name:
            group.name |> HOLD name {
                store.elements.group_rename |> THEN { TEXT { core buses } }
            }
        members_label: group.members_label
        collapsed:
            False |> HOLD collapsed {
                LATEST {
                    store.elements.group_toggle |> THEN { True }
                    store.elements.group_expand |> THEN { False }
                }
            }
        state_label:
            collapsed |> WHEN {
                True => Collapsed
                False => Expanded
            }
        row_count_label: TEXT { 4 grouped signals }
    ]
}

scene: NovyView/main_scene(PASS: [store: store])
