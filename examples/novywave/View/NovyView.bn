FUNCTION variable_vcore_row() {
    variable_static_row(
        name_text: TEXT { vcore }
        chip_a: TEXT { Analog }
        chip_b: TEXT { 16-bit }
        chip_c: TEXT { Sense }
    )
}

FUNCTION variable_static_row(name_text, chip_a, chip_b, chip_c) {
    Scene/Element/stripe(
        element: []
        direction: Row
        gap: 8
        style: [width: Fill, height: 20, paint: False]
        items: LIST {
            variable_name_text(label_text: name_text)
            variable_chip_literal(label_text: chip_a)
            variable_chip_literal(label_text: chip_b)
            variable_chip_literal(label_text: chip_c)
        }
    )
}

