FUNCTION station_json() {
    "{\"ok\":true,\"data\":{\"station\":{\"id\":\"NSR:StopPlace:548\",\"name\":\"Førde rutebilstasjon\",\"kind\":\"bus_station\",\"latitude\":61.452,\"longitude\":5.857,\"locality\":\"Førde\",\"municipality\":\"Sunnfjord\",\"transportModes\":[\"bus\",\"coach\"],\"importedAt\":\"2026-07-10T08:00:00Z\"},\"snapshot\":{\"stationId\":\"NSR:StopPlace:548\",\"state\":\"fresh\",\"version\":\"2026-07-10T10:00:00Z\",\"updatedAt\":\"2026-07-10T10:00:00Z\",\"lastSuccessfulAt\":\"2026-07-10T10:00:00Z\",\"warning\":null,\"departures\":[{\"id\":\"dep_100_1\",\"serviceJourneyId\":\"SKY:ServiceJourney:100-1\",\"lineId\":\"SKY:Line:100\",\"lineCode\":\"100\",\"destination\":\"Nordfjordeid\",\"aimedDepartureAt\":\"2026-07-10T10:15:00Z\",\"expectedDepartureAt\":\"2026-07-10T10:17:00Z\",\"status\":\"delayed\",\"delaySeconds\":120,\"platform\":\"1\",\"realtime\":true}],\"departureBoard\":{\"windowStart\":\"2026-07-10T10:00:00Z\",\"windowEnd\":\"2026-07-10T22:00:00Z\",\"limit\":20,\"hasMore\":false},\"nearbyVehicles\":[{\"id\":\"SKY:Vehicle:12345\",\"transportMode\":\"bus\",\"passengerServiceState\":\"non_passenger\",\"lineCode\":\"100\",\"destination\":\"Nordfjordeid\",\"state\":\"live\",\"latitude\":61.453,\"longitude\":5.858,\"bearing\":42,\"delaySeconds\":120,\"distanceMeters\":null,\"lastSeenAt\":\"2026-07-10T09:59:58Z\",\"version\":\"2026-07-10T09:59:58Z\"}],\"servingVehicles\":[{\"id\":\"SKY:Vehicle:67890\",\"transportMode\":\"bus\",\"passengerServiceState\":\"unknown\",\"lineCode\":\"100\",\"destination\":\"Nordfjordeid\",\"state\":\"live\",\"latitude\":61.636,\"longitude\":6.216,\"bearing\":32,\"delaySeconds\":120,\"distanceMeters\":null,\"lastSeenAt\":\"2026-07-10T09:59:57Z\",\"version\":\"2026-07-10T09:59:57Z\",\"callRole\":\"calls_here\",\"progress\":\"before_station\",\"stationCallAt\":\"2026-07-10T10:17:00Z\"}],\"servingVehicleCoverage\":{\"windowStart\":\"2026-07-10T04:00:00Z\",\"windowEnd\":\"2026-07-10T16:00:00Z\",\"candidateJourneyCount\":12,\"queriedJourneyCount\":12,\"truncated\":false}}},\"meta\":{\"requestId\":\"req_station\",\"updatedAt\":\"2026-07-10T10:00:00Z\"}}"
}

