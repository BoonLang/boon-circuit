        element: []
        direction: Column
        gap: 2
        style: [
            width: 150
            height: Fill
            padding: 8
            rounded_corners: 10
            material: NovyTheme/material(mode: PASSED.store.mode, of: PanelInset)
        ]
        items: LIST {
            text_line(label_text: stat_label, font: Muted, width: Fill, height: 18)
            text_line(label_text: stat_value, font: Mono, width: Fill, height: 24)
        }
    )
}

FUNCTION loaded_app() {
    PASSED.store.panel_arrangement == Docked |> WHEN {
        True => loaded_app_docked()
        False => loaded_app_stacked()
    }
}

