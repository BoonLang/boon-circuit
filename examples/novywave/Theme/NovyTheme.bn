-- Physical NovyWave material and text theme.

FUNCTION material(mode, of) {
    of |> WHEN {
        AppBackground => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #111827 }
                Light => TEXT { #f4f7fb }
            }
            gloss: 0.02
        ]

        PanelSurface => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #172033 }
                Light => TEXT { #f8fafc }
            }
            gloss: 0.07
            metal: 0.0
            transparency: PASSED.mode |> WHEN {
                Dark => 0.08
                Light => 0.10
            }
            frosted_blur: 10
            frosted_saturate: 1.14
            glass_highlight: 0.32
            glass_highlight_color: PASSED.mode |> WHEN {
                Dark => TEXT { #dce8ff38 }
                Light => TEXT { #ffffffa3 }
            }
            border: PASSED.mode |> WHEN {
                Dark => TEXT { #2f80ed }
                Light => TEXT { #2563eb }
            }
            border_width: 1
            shadows: LIST {
                [y: 1, blur: 2, color: TEXT { #ffffff40 }]
                [y: 14, blur: 30, color: TEXT { #1d4ed829 }]
            }
        ]

        PanelInset => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #0b1220 }
                Light => TEXT { #ffffff }
            }
            gloss: 0.05
            transparency: PASSED.mode |> WHEN {
                Dark => 0.04
                Light => 0.06
            }
            frosted_blur: 6
            glass_highlight: 0.18
            glass_highlight_color: PASSED.mode |> WHEN {
                Dark => TEXT { #dce8ff22 }
                Light => TEXT { #ffffff9c }
            }
            border: PASSED.mode |> WHEN {
                Dark => TEXT { #25344f }
                Light => TEXT { #d7dde8 }
            }
            border_width: 1
        ]

        TimelineGlass => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #020817d8 }
                Light => TEXT { #f8fbffb8 }
            }
            refraction: 1.5
            gloss: 0.08
            transparency: PASSED.mode |> WHEN {
                Dark => 0.16
                Light => 0.18
            }
            frosted_blur: 14
            frosted_saturate: 1.22
            glass_highlight: 0.58
            glass_highlight_color: PASSED.mode |> WHEN {
                Dark => TEXT { #dce8ff4d }
                Light => TEXT { #ffffffb8 }
            }
        ]

        TraceHigh => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #3b82f6 }
                Light => TEXT { #2563eb }
            }
            glow: [color: TEXT { #3b82f6aa }, intensity: 0.28]
        ]

        TraceLow => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #020817 }
                Light => TEXT { #d7e2ef }
            }
        ]

        TraceUnknown => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #60a5fa }
                Light => TEXT { #3b82f6 }
            }
            glow: [color: TEXT { #60a5fa88 }, intensity: 0.20]
        ]

        AnalogTrace => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #6bbdff }
                Light => TEXT { #1267aa }
            }
            glow: [color: TEXT { #6bbdff88 }, intensity: 0.22]
        ]

        CursorGlow => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #ffef8a }
                Light => TEXT { #9a7600 }
            }
            gloss: 0.18
            glow: [color: TEXT { #ffe768aa }, intensity: 0.38]
        ]

        MarkerChip => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #6147d9 }
                Light => TEXT { #e7ddff }
            }
            gloss: 0.20
            glass_highlight: 0.30
            glow: [color: TEXT { #8f75ff88 }, intensity: 0.22]
        ]

        SelectedRow => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #203b62 }
                Light => TEXT { #d7e9ff }
            }
            border: PASSED.mode |> WHEN {
                Dark => TEXT { #73b7ff }
                Light => TEXT { #2474bb }
            }
            border_width: 1
            glow: [color: TEXT { #60a5fa55 }, intensity: 0.12]
        ]

        HoverControl => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #1a2b44 }
                Light => TEXT { #e9f3ff }
            }
            gloss: 0.08
            border: PASSED.mode |> WHEN {
                Dark => TEXT { #49617f }
                Light => TEXT { #bad0e8 }
            }
            border_width: 1
        ]

        PressedControl => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #28466d }
                Light => TEXT { #cce4ff }
            }
            gloss: 0.12
            glow: [color: TEXT { #65b8ff44 }, intensity: 0.10]
            border: PASSED.mode |> WHEN {
                Dark => TEXT { #65b8ff }
                Light => TEXT { #2474bb }
            }
            border_width: 1
        ]

        FocusedControl => [
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #11243b }
                Light => TEXT { #e9f3ff }
            }
            gloss: 0.11
            glow: [color: TEXT { #65b8ff66 }, intensity: 0.16]
            border: PASSED.mode |> WHEN {
                Dark => TEXT { #65b8ff }
                Light => TEXT { #2474bb }
            }
            border_width: 1
        ]

        Warning => [color: TEXT { #f6d365 }]
        Error => [color: TEXT { #ff6b7a }]
        __ => [color: TEXT { #00000000 }]
    }
}

FUNCTION font(mode, of) {
    of |> WHEN {
        Title => [
            family: TEXT { Inter, Arial, SansSerif }
            size: 32
            weight: Bold
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #eef7ff }
                Light => TEXT { #102033 }
            }
        ]
        Heading => [
            family: TEXT { Inter, Arial, SansSerif }
            size: 15
            weight: Bold
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #dceaff }
                Light => TEXT { #182a3d }
            }
        ]
        Body => [
            family: TEXT { Inter, Arial, SansSerif }
            size: 12
            weight: Regular
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #d2def0 }
                Light => TEXT { #25384c }
            }
        ]
        Muted => [
            family: TEXT { Inter, Arial, SansSerif }
            size: 11
            weight: Regular
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #90a4bf }
                Light => TEXT { #60748b }
            }
        ]
        Mono => [
            family: TEXT { JetBrains Mono, Menlo, Monospace }
            size: 11
            weight: Regular
            color: PASSED.mode |> WHEN {
                Dark => TEXT { #dbeafe }
                Light => TEXT { #172033 }
            }
        ]
        __ => [
            size: 12
            color: TEXT { #ffffff }
        ]
    }
}

FUNCTION trace_material(mode, state) {
    state |> WHEN {
        High => material(mode: mode, of: TraceHigh)
        Low => material(mode: mode, of: TraceLow)
        Unknown => material(mode: mode, of: TraceUnknown)
        AnalogLow => material(mode: mode, of: AnalogTrace)
        AnalogMid => material(mode: mode, of: AnalogTrace)
        AnalogHigh => material(mode: mode, of: AnalogTrace)
        __ => material(mode: mode, of: TraceUnknown)
    }
}

FUNCTION trace_height(state) {
    state |> WHEN {
        High => 18
        Low => 6
        Unknown => 14
        AnalogLow => 8
        AnalogMid => 15
        AnalogHigh => 24
        __ => 10
    }
}
