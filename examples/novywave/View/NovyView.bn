    waveform_trace_cell_blue_base(segment: segment)
}

FUNCTION waveform_trace_cell_blue_base(segment) {
    Scene/Element/label(
        element: [event: [key_down: PASSED.store.elements.keyboard_capture], hovered: PASSED.store.elements.waveform_hover]
        style: [
            width: Fill
            height: NovyTheme/trace_height_for_row(state: segment.state, row_size: PASSED.store.row_size)
            align: [column: Center]
            rounded_corners: 0
            background: [color: TEXT { #2563EB }]
            border: [color: TEXT { #60A5FA }]
            glow: [color: TEXT { #3b82f62a }, intensity: 0.03]
            material: NovyTheme/material(mode: PASSED.store.mode, of: TraceHigh)
        ]
        label: Scene/Element/text(
            element: []
            style: [
                ...NovyTheme/trace_label_font(mode: PASSED.store.mode, tone: Blue)
                width: Fill
                height: Fill
                center: True
                vertical_align: Center
            ]
            text: segment.label
        )
    )
}

